#!/bin/bash
# c-thru State Archiver & Cleaner (v73 Optimized)
# 
# Usage: ./tools/c-thru-cleanup <scenario_id>

SCENARIO_ID=$1
ARCHIVE_ROOT="test/supervisor-benchmark/results/archives"

if [[ -z "$SCENARIO_ID" ]]; then
    echo "Usage: c-thru-cleanup <scenario_id>"
    exit 1
fi

mkdir -p "$ARCHIVE_ROOT/$SCENARIO_ID"

# 1. Archive Volatile State
if [[ -f "supervisor_state.md" ]]; then
    mv "supervisor_state.md" "$ARCHIVE_ROOT/$SCENARIO_ID/state.md"
    echo "[CLEANUP] Archived supervisor_state.md"
fi

# 2. Snapshot the Bayesian Ledger (Do NOT delete - it is institutional memory)
if [[ -f "supervisor_wiki.jsonl" ]]; then
    cp "supervisor_wiki.jsonl" "$ARCHIVE_ROOT/$SCENARIO_ID/wiki_snapshot.jsonl"
    echo "[CLEANUP] Snapshot of Bayesian Ledger saved."
fi

# 3. Snapshot Environment Context
if [[ -f ".wiki-context.json" ]]; then
    cp ".wiki-context.json" "$ARCHIVE_ROOT/$SCENARIO_ID/context_snapshot.json"
fi

echo "[CLEANUP] Workspace is now PURE for the next prompt."

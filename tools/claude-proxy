function postJsonLocal(port, pathName, payload) {
  return new Promise((resolve, reject) => {
    const body = JSON.stringify(payload);
    const req = http.request(
      { hostname: '127.0.0.1', port, path: pathName, method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(body) } },
      res => {
        const chunks = [];
        res.on('data', c => chunks.push(c));
        res.on('end', () => {
          try { resolve(JSON.parse(Buffer.concat(chunks).toString('utf8'))); }
          catch (e) { reject(new Error('postJsonLocal: invalid JSON: ' + e.message)); }
        });
      }
    );
    req.on('error', reject);
    req.setTimeout(10000, () => req.destroy(new Error('postJsonLocal: timeout')));
    req.write(body);
    req.end();
  });
}

const EXPLICIT_PORT = process.env.CLAUDE_PROXY_PORT;
const INITIAL_PORT = EXPLICIT_PORT ? Number(EXPLICIT_PORT) : 0;

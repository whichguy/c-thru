// ── Config loading & reload ────────────────────────────────────────────
function loadConfig() {
  const resolved = resolveSelectedConfigPath({ baseDir: __dirname, syncProfile: false });
  if (!resolved) { console.error('c-thru: no model-map.json found'); process.exit(1); }
  CONFIG_PATH = resolved.path;
  CONFIG_SOURCE = resolved.source;
  try {
    GLOBAL_CONFIG = JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));
    CONFIG_MTIME_MS = Math.floor(fs.statSync(CONFIG_PATH).mtimeMs);
  } catch (e) {
    console.error(`c-thru: failed to load ${CONFIG_PATH}: ${e.message}`);
    process.exit(1);
  }
}

function resolveConfigSelectionForReload() {
  return resolveSelectedConfigPath({ baseDir: __dirname, syncProfile: false });
}

function validateRouteGraph(cfg) {
  const routes = cfg.routes || {};
  for (const start of Object.keys(routes)) {
    const seen = new Set();
    let cur = start;
    while (cur && routes[cur]) {
      if (seen.has(cur)) throw new Error(`route cycle detected involving '${cur}'`);
      seen.add(cur);
      cur = routes[cur];
    }
  }
}

function validateWithNode(pathToValidate) {
  const validator = path.join(__dirname, 'model-map-validate.js');
  if (!fs.existsSync(validator)) return true;
  const result = spawnSync(process.execPath, [validator, pathToValidate], { encoding: 'utf8', env: { ...process.env, C_THRU_MODEL_MAP_TRUSTED_JS: CONFIG_SOURCE === 'profile' ? '1' : '0' } });
  return result.status === 0;
}

function reloadConfigFromDisk() {
  try {
    const previousPath = CONFIG_PATH;
    const resolved = resolveConfigSelectionForReload();
    if (!resolved) throw new Error('no model-map.json found');
    const nextPath = resolved.path;
    const nextSource = resolved.source;
    const nextConfig = JSON.parse(fs.readFileSync(nextPath, 'utf8'));
    const nextMtime = Math.floor(fs.statSync(nextPath).mtimeMs);
    validateRouteGraph(nextConfig);
    const tmpPath = path.join(os.tmpdir(), `c-thru-validate-${process.pid}.json`);
    try {
      fs.writeFileSync(tmpPath, JSON.stringify(nextConfig));
      if (!validateWithNode(tmpPath)) throw new Error('schema validation failed');
    } finally { try { fs.unlinkSync(tmpPath); } catch {} }
    GLOBAL_CONFIG = nextConfig;
    CONFIG_PATH = nextPath;
    CONFIG_SOURCE = nextSource;
    CONFIG_MTIME_MS = nextMtime;
    if (activeRequests > 0) console.error(`c-thru: hot-reloaded config (draining ${activeRequests} in-flight requests)`);
    if (CONFIG_PATH !== previousPath) startConfigWatcher();
    return true;
  } catch (e) {
    console.error(`c-thru: config reload failed: ${e.message}`);
    return false;
  }
}

function refreshConfigIfChanged() {
  try {
    const nextMtime = Math.floor(fs.statSync(CONFIG_PATH).mtimeMs);
    if (nextMtime !== CONFIG_MTIME_MS) reloadConfigFromDisk();
  } catch {}
}

let configWatcher = null;
function startConfigWatcher() {
  if (configWatcher) try { configWatcher.close(); } catch {}
  try {
    configWatcher = fs.watch(path.dirname(CONFIG_PATH), (ev, file) => {
      if (file === path.basename(CONFIG_PATH)) refreshConfigIfChanged();
    });
  } catch {}
}

// ── Main Server ──────────────────────────────────────────────────────
loadConfig();
startConfigWatcher();

let activeRequests = 0;
const server = http.createServer((req, res) => {
  activeRequests++;
  const snapshot = GLOBAL_CONFIG;
  configStorage.run(snapshot, async () => {
    try {
      refreshConfigIfChanged();
      proxyLog('request', { method: req.method, url: req.url });
      traceLog('in.client', req.method, req.url, req.headers);
      
      const finalize = () => { activeRequests--; };
      res.on('finish', finalize);
      res.on('close', () => { if (!res.writableFinished) finalize(); });

      // ── Routes ────────────────────────────────────────────────────────
      if (req.url === '/ping') {
        return send(res, 200, { ok: true, pid: process.pid, config_path: CONFIG_PATH, active_tier: resolveActiveTier(CONFIG), active_mode: resolveLlmMode(CONFIG) });
      }

      if (req.method === 'GET' && (req.url === '/c-thru/status' || req.url === '/c-thru/status/')) {
        const tier = resolveActiveTier(CONFIG);
        const mode = resolveLlmMode(CONFIG);
        const profiles = ((CONFIG || {}).llm_profiles || {})[tier] || {};
        const active_capabilities = {};
        for (const [alias, entry] of Object.entries(profiles)) {
          const model = resolveProfileModel(entry, mode);
          if (model) active_capabilities[alias] = model.replace(BACKEND_SIGIL_RE, '$1');
        }
        return send(res, 200, { ok: true, mode, hardware_tier: tier, config_source: CONFIG_SOURCE, active_capabilities, ollama_health: stats.byBackendId['ollama_local'] || 'healthy' });
      }

      if (req.method === 'POST' && (req.url === '/c-thru/mode' || req.url === '/c-thru/mode/')) {
        const buf = await readBody(req);
        let payload; try { payload = JSON.parse(buf.toString()); } catch {}
        const mode = payload?.mode;
        if (!mode || !LLM_MODE_ENUM.has(mode)) return send(res, 400, { error: 'invalid mode' });
        process.env.CLAUDE_LLM_MODE = mode;
        return send(res, 200, { ok: true, new_mode: mode, message: `Mode switched to ${mode}` });
      }

      if (req.method === 'POST' && (req.url === '/c-thru/reload' || req.url === '/c-thru/reload/')) {
        reloadConfigFromDisk();
        return send(res, 200, { ok: true, message: 'Reloaded' });
      }

      if (req.url === '/debug/stats') return send(res, 200, { ...stats, activeRequests });

      if (req.method === 'GET' && req.url === '/v1/active-models') {
        const tier = resolveActiveTier(CONFIG);
        const mode = resolveLlmMode(CONFIG);
        const profiles = (CONFIG.llm_profiles || {})[tier] || {};
        const capabilities = [];
        for (const [alias, entry] of Object.entries(profiles)) {
          const m = resolveProfileModel(entry, mode);
          if (m) capabilities.push({ capability: alias, model: m.replace(BACKEND_SIGIL_RE, '$1') });
        }
        return send(res, 200, { tier, mode, capabilities });
      }

      // Main Message Dispatch
      if (req.method === 'POST' && req.url.startsWith('/v1/messages')) {
        const buf = await readBody(req);
        const body = JSON.parse(buf.toString());
        const hwTier = resolveActiveTier(CONFIG);
        const activeMode = resolveLlmMode(CONFIG);
        
        const resolved = resolveBackend(body.model, CONFIG, hwTier, activeMode);
        if (resolved.error) return send(res, 400, { error: resolved.error });
        
        // ── Phase 3 ranking ──
        const RANK_MODES = { 
          'fastest-possible': 'fastest', 
          'smallest-possible': 'smallest', 
          'best-opensource': 'best-opensource',
          'best-opensource-cloud': 'best-opensource-cloud',
          'best-opensource-local': 'best-opensource-local'
        };
        const criterion = RANK_MODES[activeMode];
        let finalModel = resolved.effectiveModel;
        let finalBackend = resolved.backend;
        
        if (criterion && BENCHMARK) {
          const capKey = resolved.logicalRole || resolveCapabilityAlias(body.model, CONFIG, hwTier);
          const role = capKey ? BENCHMARK.capability_to_role?.[capKey] : null;
          if (role) {
            const candidates = Object.keys(CONFIG.model_routes || {}).filter(k => !k.startsWith('re:'));
            const best = pickBenchmarkBest(criterion, candidates, BENCHMARK, role, CONFIG.model_routes || {}, CONFIG.backends || {});
            if (best && best !== finalModel) {
              const replaced = resolveBackend(best, CONFIG, hwTier, activeMode);
              if (!replaced.error) { finalModel = replaced.effectiveModel; finalBackend = replaced.backend; }
            }
          }
        }

        if (finalBackend.kind === 'ollama') {
          if (!(await ensureOllamaReadyOrSend(finalModel, finalBackend.url, resolved.logicalRole, res))) return;
          return forwardOllama(req, res, { ...body, model: finalModel }, finalBackend, finalModel, {});
        }
        return forwardAnthropic(req, res, { ...body, model: finalModel }, finalBackend, finalModel, {});
      }

      send(res, 404, { error: `unknown path: ${req.url}` });
    } catch (err) {
      proxyLog('fatal_error', { error: err.message, stack: err.stack });
      send(res, 500, { error: 'internal error' });
    }
  });
});

server.listen(INITIAL_PORT, '127.0.0.1', () => {
  process.stdout.write(`READY ${server.address().port}\n`);
  console.error(`c-thru listening on :${server.address().port}`);
});

process.on('SIGHUP', () => reloadConfigFromDisk());
process.on('SIGTERM', () => process.exit(0));
process.on('SIGINT', () => process.exit(0));

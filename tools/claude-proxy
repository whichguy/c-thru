function numberFromEnv(name, fallback) {
  if (process.env[name] == null || process.env[name] === '') return fallback;
  const value = Number(process.env[name]);
  return Number.isFinite(value) ? value : fallback;
}

const DEBUG = numberFromEnv('CLAUDE_PROXY_DEBUG', numberFromEnv('CLAUDE_ROUTER_DEBUG', 0));
const DEFAULT_OLLAMA_URL = process.env.OLLAMA_BASE_URL || 'http://localhost:11434';

let CONFIG;
let CONFIG_PATH;
let CONFIG_SOURCE;
let CONFIG_MTIME_MS = 0;

function debugLog(event, fields = {}) {
  if (!DEBUG) return;
  console.error(`claude-proxy debug ${JSON.stringify({
    event,
    pid: process.pid,
    ts: nowIso(),
    ...fields,
  })}`);
}

function proxyLog(event, fields = {}) {
  console.error(`claude-proxy [${event}] ${JSON.stringify({ pid: process.pid, ts: nowIso(), ...fields })}`);
}

function loadConfig() {
  const resolved = resolveConfigPath();
  if (!resolved) {
    console.error('claude-proxy: no model-map.json found');
    process.exit(1);
  }
  CONFIG_PATH = resolved.path;
  CONFIG_SOURCE = resolved.source;
  try {
    CONFIG = JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));
    CONFIG_MTIME_MS = fs.statSync(CONFIG_PATH).mtimeMs;
  } catch (e) {
    console.error(`claude-proxy: failed to load ${CONFIG_PATH}: ${e.message}`);
    process.exit(1);
  }
  // Validate no cycles in routes — throws on error; exit on startup failure.
  try { validateRouteGraph(); } catch (e) {
    console.error(`claude-proxy: ${e.message}`);
    process.exit(1);
  }
  // Validate with external validator if available — exits on startup failure.
  if (!validateWithNode()) process.exit(1);
}

// validateRouteGraph accepts an explicit config object so callers can validate
// before swapping the global CONFIG. Throws on error (never calls process.exit)
// so it is safe to call from hot-reload paths.
function validateRouteGraph(cfg) {
  const routes = (cfg || CONFIG).routes || {};
  const seen = new Set();
  for (const start of Object.keys(routes)) {
    seen.clear();
    let cur = start;
    let steps = 0;
    while (routes[cur] !== undefined) {
      if (seen.has(cur)) {
        throw new Error(`route cycle detected involving '${cur}' in ${CONFIG_PATH}`);
      }
      seen.add(cur);
      cur = routes[cur];
      steps++;
      if (steps > 256) {
        throw new Error(`route resolution limit hit starting at '${start}'`);
      }
    }
  }
}

// validateWithNode shells out to model-map-validate.js and returns false on
// failure (never calls process.exit) so it is safe to call from hot-reload paths.
// pathToValidate defaults to CONFIG_PATH; pass a temp file to avoid TOCTOU.
function validateWithNode(pathToValidate) {
  pathToValidate = pathToValidate || CONFIG_PATH;
  const validator = path.join(path.dirname(process.argv[1] || ''), 'model-map-validate.js');
  if (!fs.existsSync(validator)) return true;
  try {
    const result = spawnSync(process.execPath, [validator, pathToValidate], { encoding: 'utf8', timeout: 5000 });
    if (result.status !== 0) {
      console.error(`claude-proxy: invalid model-map config: ${pathToValidate}`);
      return false;
    }
  } catch (e) {
    console.error(`claude-proxy: validator spawn failed: ${e.message}`);
  }
  return true;
}

loadConfig();

function reloadConfigFromDisk() {
  try {
    const nextConfig = JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8'));
    // Capture mtime before validation so that if statSync throws, CONFIG is never swapped.
    const nextMtime = fs.statSync(CONFIG_PATH).mtimeMs;
    // Validate before swapping so a bad config never replaces a good one.
    validateRouteGraph(nextConfig);
    const tmpPath = path.join(os.tmpdir(), `claude-proxy-validate-${process.pid}.json`);
    try {
      fs.writeFileSync(tmpPath, JSON.stringify(nextConfig));
      if (!validateWithNode(tmpPath)) throw new Error('schema validation failed');
    } finally {
      try { fs.unlinkSync(tmpPath); } catch {}
    }
    CONFIG = nextConfig;
    CONFIG_MTIME_MS = nextMtime;
    return true;
  } catch (e) {
    console.error(`claude-proxy: config reload failed, keeping old config: ${e.message}`);
    return false;
  }
}

function refreshConfigIfChanged() {
  try {
    const nextMtime = fs.statSync(CONFIG_PATH).mtimeMs;
    if (nextMtime !== CONFIG_MTIME_MS) reloadConfigFromDisk();
  } catch { /* ignore transient stat failures */ }
}

// Watch for config changes
let configWatcher = null;
let reloadTimer = null;
try {
  const watchDir = path.dirname(CONFIG_PATH);
  configWatcher = fs.watch(watchDir, (eventType, filename) => {
    if (filename === path.basename(CONFIG_PATH)) {
      if (reloadTimer) clearTimeout(reloadTimer);
      reloadTimer = setTimeout(() => {
        if (reloadConfigFromDisk()) {
          console.error(`claude-proxy: reloaded config from ${CONFIG_PATH}`);
        }
      }, 50);
    }
  });
  configWatcher.on('error', () => {});
} catch { /* fs.watch not available on all platforms */ }

// ── Route resolution ───────────────────────────────────────────────────

function resolveRouteModel(model) {
  // model_overrides: unconditional name substitution applied before routes graph traversal.
  // No separate cycle guard needed — the downstream routes traversal already has one;
  // the override's output becomes input to that traversal.
  const overrideTarget = CONFIG.model_overrides?.[model];
  if (typeof overrideTarget === 'string' && overrideTarget && overrideTarget !== model) {
    debugLog('proxy.model_overrides.remap', { from: model, to: overrideTarget });
    model = overrideTarget;
  }
  const routes = CONFIG.routes || {};
  const maxDepth = Math.min(CONFIG.routes_max_depth || 32, 256);
  const seen = new Set();
  let cur = model;
  let steps = 0;
  while (routes[cur] !== undefined) {
    if (seen.has(cur)) return cur; // cycle — return last resolved
    seen.add(cur);
    cur = routes[cur];
    steps++;
    if (steps >= maxDepth) return cur;
  }
  return cur;
}

function looksLikePatternKey(key) {
  return key.startsWith('re:') || /[*?\[]/.test(key);
}

function matchPattern(key, model) {
  if (key.startsWith('re:')) {
    try { return new RegExp(key.slice(3)).test(model); } catch { return false; }
  }
  // Glob-style matching
  const regex = key.replace(/[.+^${}()|]/g, '\\$&').replace(/\*/g, '.*').replace(/\?/g, '.');
  try { return new RegExp(`^${regex}$`).test(model); } catch { return false; }
}

function lookupPatternValue(section, model) {
  const obj = CONFIG[section] || {};
  for (const [key, value] of Object.entries(obj)) {
    if (!looksLikePatternKey(key)) continue;
    if (matchPattern(key, model)) return value;
  }
  return null;
}

function profileAliasKey(alias) {
  return alias === 'general-default' ? 'default' : alias;
}

function resolveConnectivityMode() {
  const m = resolveLlmMode(CONFIG);
  return m === 'offline' ? 'disconnect' : 'connected';
}

function resolveLogicalAlias(model) {
  const tier     = resolveActiveTier(CONFIG);
  const capAlias = resolveCapabilityAlias(model, CONFIG, tier);
  if (!capAlias) return model;
  const profile  = (CONFIG.llm_profiles || {})[tier];
  if (!profile) return model;
  const entry    = profile[profileAliasKey(capAlias)];
  if (!entry || typeof entry !== 'object') return model;
  const resolved = resolveProfileModel(entry, resolveLlmMode(CONFIG));
  return typeof resolved === 'string' && resolved ? resolved : model;
}


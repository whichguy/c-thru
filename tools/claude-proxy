};

function defaultPersistentUsageStats() {
  return {
    version: 1,
    updated_at: null,
    last_request_at: null,
    totals: {
      requests_completed: 0,
      input_tokens_total: 0,
      output_tokens_total: 0,
    },
    byClientModel: {},
    byEffectiveModel: {},
    byBackendId: {},
    byMapping: {},
  };
}

function loadPersistentUsageStats() {
  try {
    if (!fs.existsSync(USAGE_STATS_FILE)) return defaultPersistentUsageStats();
    const parsed = JSON.parse(fs.readFileSync(USAGE_STATS_FILE, 'utf8'));
    if (!parsed || typeof parsed !== 'object') return defaultPersistentUsageStats();
    return {
      ...defaultPersistentUsageStats(),
      ...parsed,
      totals: {
        ...defaultPersistentUsageStats().totals,
        ...(parsed.totals || {}),
      },
      byClientModel: parsed.byClientModel || {},
      byEffectiveModel: parsed.byEffectiveModel || {},
      byBackendId: parsed.byBackendId || {},
      byMapping: parsed.byMapping || {},
    };
  } catch {
    return defaultPersistentUsageStats();
  }
}

function ensureUsageBucket(parent, key, seed = {}) {
  if (!key) return null;
  if (!parent[key]) {
    parent[key] = {
      requests: 0,
      input_tokens_total: 0,
      output_tokens_total: 0,
      first_used_at: null,
      last_used_at: null,
      last_status: null,
      ...seed,
    };
  }
  return parent[key];
}

function schedulePersistentUsageFlush() {
  usagePersistPending = true;
  if (usagePersistTimer) return;
  usagePersistTimer = setTimeout(() => {
    usagePersistTimer = null;
    if (!usagePersistPending) return;
    usagePersistPending = false;
    const tmpPath = `${USAGE_STATS_FILE}.tmp.${crypto.randomUUID()}`;
    fs.promises.mkdir(path.dirname(USAGE_STATS_FILE), { recursive: true })
      .then(() => fs.promises.writeFile(tmpPath, `${JSON.stringify(persistentUsage, null, 2)}\n`))
      .then(() => fs.promises.rename(tmpPath, USAGE_STATS_FILE))
      .catch(error => {
        debugLog('proxy.usage.persist.failed', { error: error.message, file: USAGE_STATS_FILE });
      });
  }, USAGE_FLUSH_DEBOUNCE_MS);
  if (typeof usagePersistTimer.unref === 'function') usagePersistTimer.unref();
}

function flushPersistentUsageNowSync() {
  if (!usagePersistPending && !fs.existsSync(USAGE_STATS_FILE)) return;
  try {
    fs.mkdirSync(path.dirname(USAGE_STATS_FILE), { recursive: true });
    const tmpPath = `${USAGE_STATS_FILE}.tmp.${crypto.randomUUID()}`;
    fs.writeFileSync(tmpPath, `${JSON.stringify(persistentUsage, null, 2)}\n`);
    fs.renameSync(tmpPath, USAGE_STATS_FILE);
    usagePersistPending = false;
  } catch (error) {
    debugLog('proxy.usage.persist_sync.failed', { error: error.message, file: USAGE_STATS_FILE });
  }
}

function appendUsageLog(entry) {
  if (!USAGE_LOG_FILE) return;
  if (!USAGE_LOG_INCLUDE_ZERO_TOKEN_CALLS && !entry.input_tokens && !entry.output_tokens) return;
  const line = `${JSON.stringify(entry)}\n`;
  usageLogChain = usageLogChain
    .then(() => fs.promises.mkdir(path.dirname(USAGE_LOG_FILE), { recursive: true }))
    .then(() => fs.promises.appendFile(USAGE_LOG_FILE, line))
    .catch(error => {
      debugLog('proxy.usage.log.failed', { error: error.message, file: USAGE_LOG_FILE });
    });
}

function notePersistentUsage(entry) {
  const ts = nowIso();
  const inputTokens = Number.isFinite(entry.input_tokens) ? entry.input_tokens : 0;
  const outputTokens = Number.isFinite(entry.output_tokens) ? entry.output_tokens : 0;
  const status = entry.status_code == null ? null : Number(entry.status_code);
  persistentUsage.updated_at = ts;
  persistentUsage.last_request_at = ts;
  persistentUsage.totals.requests_completed += 1;
  persistentUsage.totals.input_tokens_total += inputTokens;
  persistentUsage.totals.output_tokens_total += outputTokens;

  const clientBucket = ensureUsageBucket(persistentUsage.byClientModel, entry.client_model, { model: entry.client_model });
  const effectiveBucket = ensureUsageBucket(persistentUsage.byEffectiveModel, entry.effective_model, { model: entry.effective_model });
  const backendBucket = ensureUsageBucket(persistentUsage.byBackendId, entry.backend_id, {
    backend_id: entry.backend_id,
    backend_kind: entry.backend_kind || null,
  });
  const mappingKey = `${entry.client_model || '<none>'}=>${entry.effective_model || '<none>'}`;
  const mappingBucket = ensureUsageBucket(persistentUsage.byMapping, mappingKey, {
    client_model: entry.client_model || null,
    effective_model: entry.effective_model || null,
  });

  for (const bucket of [clientBucket, effectiveBucket, backendBucket, mappingBucket]) {
    if (!bucket) continue;
    bucket.requests += 1;
    bucket.input_tokens_total += inputTokens;
    bucket.output_tokens_total += outputTokens;
    bucket.first_used_at = bucket.first_used_at || ts;
    bucket.last_used_at = ts;
    bucket.last_status = status;
  }

  schedulePersistentUsageFlush();
  appendUsageLog({
    ts,
    endpoint: entry.endpoint,
    client_model: entry.client_model || null,
    effective_model: entry.effective_model || null,
    backend_id: entry.backend_id || null,
    backend_kind: entry.backend_kind || null,
    status_code: status,
    input_tokens: inputTokens,
    output_tokens: outputTokens,
    duration_ms: entry.duration_ms == null ? null : entry.duration_ms,
    stream: Boolean(entry.stream),
    stop_reason: entry.stop_reason || null,
  });
}

function usageFromJsonPayload(payload) {
  if (!payload || typeof payload !== 'object') return { input_tokens: 0, output_tokens: 0, stop_reason: null };
  const usage = payload.usage || {};
  return {
    input_tokens: Number.isFinite(usage.input_tokens) ? usage.input_tokens : (Number.isFinite(payload.input_tokens) ? payload.input_tokens : 0),
    output_tokens: Number.isFinite(usage.output_tokens) ? usage.output_tokens : 0,
    stop_reason: typeof payload.stop_reason === 'string' ? payload.stop_reason : null,
  };
}

function createStreamUsageTracker() {
  return {
    buffer: '',
    input_tokens: 0,
    output_tokens: 0,
    stop_reason: null,
  };
}

function noteStreamUsageChunk(tracker, chunk) {
  tracker.buffer += chunk.toString();
  const blocks = tracker.buffer.split('\n\n');
  tracker.buffer = blocks.pop();
  for (const block of blocks) {
    const dataLines = block.split('\n').filter(line => line.startsWith('data:')).map(line => line.slice(5).trim());
    if (!dataLines.length) continue;
    let parsed;
    try {
      parsed = JSON.parse(dataLines.join('\n'));
    } catch {
      continue;
    }
    if (parsed.type === 'message_start' && parsed.message?.usage?.input_tokens != null) {
      tracker.input_tokens = Math.max(tracker.input_tokens, Number(parsed.message.usage.input_tokens) || 0);
    }
    if (parsed.type === 'message_delta' && parsed.usage?.output_tokens != null) {
      tracker.output_tokens = Math.max(tracker.output_tokens, Number(parsed.usage.output_tokens) || 0);
    }
    if (typeof parsed.stop_reason === 'string') {
      tracker.stop_reason = parsed.stop_reason;
    } else if (parsed.delta?.stop_reason) {
      tracker.stop_reason = parsed.delta.stop_reason;
    }
  }
}

function finalizeTrackedUsage(meta, extra = {}) {
  if (!meta || meta._usageFinalized) return;
  meta._usageFinalized = true;
  notePersistentUsage({
    endpoint: meta.endpoint,
    client_model: meta.clientModel,
    effective_model: meta.effectiveModel,
    backend_id: meta.backend?.id || null,
    backend_kind: meta.backend?.kind || null,
    duration_ms: nowMs() - meta.startedAtMs,
    stream: meta.stream,
    ...extra,
  });
}

function recordStats(endpoint, backend, clientModel, effectiveModel, statusCode) {
  stats.requestsTotal++;
  stats.byEndpoint[endpoint] = (stats.byEndpoint[endpoint] || 0) + 1;
  if (backend) stats.byBackendKind[backend.kind || 'unknown'] = (stats.byBackendKind[backend.kind || 'unknown'] || 0) + 1;
  if (clientModel) stats.byClientModel[clientModel] = (stats.byClientModel[clientModel] || 0) + 1;
  if (effectiveModel) stats.byEffectiveModel[effectiveModel] = (stats.byEffectiveModel[effectiveModel] || 0) + 1;
  if (statusCode) stats.byStatus[String(statusCode)] = (stats.byStatus[String(statusCode)] || 0) + 1;
}

// ── Fallback strategies ───────────────────────────────────────────────

const VALID_FAILURE_CLASSES = new Set(['network_failure', 'rate_limit', 'account_quota', 'context_limit']);
const cooldowns = new Map(); // model -> { untilMs, failureClass }

// In-memory ring buffer of recent fallback events. Consumed by the
// /hooks/context endpoint so Claude can explain "why was that slow?" on
// the next user turn. Out-of-process readers (Stop hook, statusline) use
// ~/.claude/proxy.log as the source of truth — no file snapshot is written.
const fallbackEvents = [];
const FALLBACK_EVENTS_MAX = 10;

function recordFallbackEvent(primary, served_by, reason) {
  fallbackEvents.unshift({ at: Date.now(), primary, served_by, reason });
  if (fallbackEvents.length > FALLBACK_EVENTS_MAX) fallbackEvents.length = FALLBACK_EVENTS_MAX;
  fireDesktopNotification(primary, served_by);
}

function fireDesktopNotification(primary, served_by) {
  if (process.platform !== 'darwin') return;
  if (process.env.CLAUDE_PROXY_NOTIFY !== '1') return;
  const msg = `Primary ${primary} is unreachable. Serving from ${served_by}.`;
  // Pass msg as a positional arg to an AppleScript handler rather than interpolating —
  // avoids any quoting/escape pitfalls if a model name contains "/`/\/newlines.
  try {
    const child = spawn('osascript', [
      '-e', 'on run argv',
      '-e', 'display notification (item 1 of argv) with title "c-thru proxy" sound name "Tink"',
      '-e', 'end run',
      '--', msg,
    ], { detached: true, stdio: 'ignore' });
    child.on('error', () => {});
    child.unref();
  } catch {}
}

// Debounce Ollama warm-ups to avoid a flood on repeated fallbacks.
// Uses Ollama's HTTP /api/generate with an empty prompt — this triggers
// model load and respects `keep_alive` (how long the model stays resident
// after this call). Fire-and-forget; errors are swallowed.
//
// Why HTTP instead of `ollama run`:
//   - no CLI process dependency (Ollama may be installed as a service only)
//   - `keep_alive` controls residency cleanly; CLI doesn't
//   - no stdin-wait quirk (`ollama run <m> ''` waits for stdin EOF)
//   - honors the backend URL (CLI uses $OLLAMA_HOST which may be wrong)
const ollamaWarmLastMs = new Map(); // model -> last warm timestamp
const OLLAMA_WARM_DEBOUNCE_MS = numberFromEnv('CLAUDE_PROXY_OLLAMA_WARM_DEBOUNCE_MS', 30000);
const OLLAMA_WARM_KEEP_ALIVE = process.env.CLAUDE_PROXY_OLLAMA_KEEP_ALIVE || '30m';
const OLLAMA_WARM_HTTP_TIMEOUT_MS = numberFromEnv('CLAUDE_PROXY_OLLAMA_WARM_TIMEOUT_MS', 5000);
function warmOllamaModel(model, backendId, backendUrl) {
  if (!model) return;
  const last = ollamaWarmLastMs.get(model) || 0;
  if (Date.now() - last < OLLAMA_WARM_DEBOUNCE_MS) return;
  ollamaWarmLastMs.set(model, Date.now());

  const urlStr = (backendUrl || DEFAULT_OLLAMA_URL).replace(/\/$/, '') + '/api/generate';
  proxyLog('fallback.warm_http', { candidate: model, backend_id: backendId, keep_alive: OLLAMA_WARM_KEEP_ALIVE });
  try {
    const body = JSON.stringify({ model, prompt: '', keep_alive: OLLAMA_WARM_KEEP_ALIVE });
    // Pick http/https by protocol — backendUrl comes from model-map config
    // and may be HTTPS for a remote Ollama reverse-proxy setup.
    // URL schemes are case-insensitive per RFC 3986 §3.1 — normalize before checking.
    const transport = urlStr.toLowerCase().startsWith('https:') ? https : http;
    const req = transport.request(urlStr, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(body) },
    }, res => {
      // Drain so the socket can be reused; body content is irrelevant.
      res.resume();
      // Belt-and-suspenders: if Ollama streams a slow chunked body, don't
      // leave the socket half-open past our timeout.
      res.setTimeout(OLLAMA_WARM_HTTP_TIMEOUT_MS, () => res.destroy());
    });
    req.on('error', () => {}); // Ollama unreachable — actual request will surface it
    req.setTimeout(OLLAMA_WARM_HTTP_TIMEOUT_MS, () => req.destroy());
    req.write(body);
    req.end();
  } catch { /* malformed URL, etc. — ignore */ }
}

// ── Ollama GC helpers ─────────────────────────────────────────────────
// recordOllamaPull: non-fatal shell-out to c-thru-ollama-gc record.
// execFile (not exec) for safety with tag chars that might contain special characters.
function recordOllamaPull(model, backendUrl) {
  return new Promise((resolve) => {
    execFile(GC_TOOL_PATH, ['record', model, 'proxy', backendUrl], { timeout: 5000 }, () => resolve());
  });
}

// ── Ollama HTTP helpers (async, stdlib only) ───────────────────────────
// Replace spawnSync('ollama', …) with native HTTP so the request path
// never blocks the event loop. All helpers pick http/https by lowercased
// scheme per RFC 3986 §3.1.

const OLLAMA_PULL_TIMEOUT_MS = numberFromEnv('CLAUDE_PROXY_OLLAMA_PULL_TIMEOUT_MS', 30 * 60 * 1000);
const pullInFlight = new Map(); // key: backendUrl+'|'+model → Promise

function _ollamaUrl(backendUrl, suffix) {
  return (backendUrl || DEFAULT_OLLAMA_URL).replace(/\/$/, '') + suffix;
}
function _ollamaTransport(urlStr) {
  return urlStr.toLowerCase().startsWith('https:') ? https : http;
}

function ollamaListTags(backendUrl) {
  const urlStr = _ollamaUrl(backendUrl, '/api/tags');
  return new Promise((resolve, reject) => {
    const transport = _ollamaTransport(urlStr);
    const req = transport.request(urlStr, { method: 'GET' }, res => {
      const chunks = [];
      res.on('data', c => chunks.push(c));
      res.on('end', () => {
        if (res.statusCode < 200 || res.statusCode >= 300) {
          return reject(new Error(`ollama /api/tags status ${res.statusCode}`));
        }
        try {
          const body = JSON.parse(Buffer.concat(chunks).toString('utf8'));
          const names = (body && Array.isArray(body.models)) ? body.models.map(m => m.name).filter(Boolean) : [];
          resolve(names);
        } catch (e) { reject(new Error('ollama /api/tags invalid JSON: ' + e.message)); }
      });
    });
    req.on('error', reject);
    req.setTimeout(OLLAMA_WARM_HTTP_TIMEOUT_MS, () => req.destroy(new Error('ollama /api/tags timeout')));
    req.end();
  });
}

function ollamaPs(backendUrl) {
  const urlStr = _ollamaUrl(backendUrl, '/api/ps');
  return new Promise((resolve, reject) => {
    const transport = _ollamaTransport(urlStr);
    const req = transport.request(urlStr, { method: 'GET' }, res => {
      const chunks = [];
      res.on('data', c => chunks.push(c));
      res.on('end', () => {
        if (res.statusCode < 200 || res.statusCode >= 300) {
          return reject(new Error(`ollama /api/ps status ${res.statusCode}`));
        }
        try {
          const body = JSON.parse(Buffer.concat(chunks).toString('utf8'));
          const models = (body && Array.isArray(body.models)) ? body.models : [];
          resolve(models.map(m => ({ name: m.name, size_vram: m.size_vram, expires_at: m.expires_at })));
        } catch (e) { reject(new Error('ollama /api/ps invalid JSON: ' + e.message)); }
      });
    });
    req.on('error', reject);
    req.setTimeout(OLLAMA_WARM_HTTP_TIMEOUT_MS, () => req.destroy(new Error('ollama /api/ps timeout')));
    req.end();
  });
}

function ollamaPull(backendUrl, model) {
  const urlStr = _ollamaUrl(backendUrl, '/api/pull');
  return new Promise((resolve, reject) => {
    const transport = _ollamaTransport(urlStr);
    const body = JSON.stringify({ model, stream: true });
    const ac = new AbortController();
    const start = Date.now();
    const timer = setTimeout(() => ac.abort(), OLLAMA_PULL_TIMEOUT_MS);
    let settled = false;
    const settle = (fn, arg) => { if (settled) return; settled = true; clearTimeout(timer); fn(arg); };

    const req = transport.request(urlStr, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(body) },
      signal: ac.signal,
    }, res => {
      if (res.statusCode < 200 || res.statusCode >= 300) {
        res.resume();
        return settle(reject, new Error(`ollama /api/pull status ${res.statusCode}`));
      }
      let buf = '';
      let lastLogMs = 0;
      res.setEncoding('utf8');
      res.on('data', chunk => {
        buf += chunk;
        let idx;
        while ((idx = buf.indexOf('\n')) !== -1) {
          const line = buf.slice(0, idx).trim();
          buf = buf.slice(idx + 1);
          if (!line) continue;
          let evt;
          try { evt = JSON.parse(line); } catch { continue; }
          if (evt.error) return settle(reject, new Error(evt.error));
          if (evt.status === 'success') return settle(resolve);
          const now = Date.now();
          if (now - lastLogMs >= 500) {
            lastLogMs = now;
            proxyLog('ollama.pull.progress', {
              model, backend_url: backendUrl, status: evt.status || null,
              completed: evt.completed || null, total: evt.total || null,
            });
          }
        }
      });
      res.on('end', () => settle(resolve));
      res.on('error', e => settle(reject, e));
    });
    req.on('error', e => {
      if (ac.signal.aborted) {
        const err = new Error(`ollama /api/pull timed out after ${Date.now() - start}ms`);
        err.code = 'ETIMEDOUT';
        return settle(reject, err);
      }
      settle(reject, e);
    });
    req.write(body);
    req.end();
  });
}

function ollamaLoad(backendUrl, model, opts) {
  const urlStr = _ollamaUrl(backendUrl, '/api/generate');
  const { numCtx, keepAlive } = opts || {};
  return new Promise((resolve, reject) => {
    let settled = false;
    const settle = (fn, arg) => { if (settled) return; settled = true; fn(arg); };
    const payload = { model, prompt: '', keep_alive: keepAlive || OLLAMA_WARM_KEEP_ALIVE };
    if (numCtx) payload.options = { num_ctx: numCtx };
    const body = JSON.stringify(payload);
    const transport = _ollamaTransport(urlStr);
    const req = transport.request(urlStr, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(body) },
    }, res => {
      res.resume();
      res.setTimeout(OLLAMA_WARM_HTTP_TIMEOUT_MS, () => {
        res.destroy();
        settle(reject, new Error('ollama /api/generate response timeout'));
      });
      res.on('end', () => settle(resolve));
      res.on('error', e => settle(reject, e));
    });
    req.on('error', e => settle(reject, e));
    req.setTimeout(OLLAMA_WARM_HTTP_TIMEOUT_MS, () => {
      req.destroy();
      settle(reject, new Error('ollama /api/generate timeout'));
    });
    req.write(body);
    req.end();
  });
}

// ── Logical-role exclusivity ───────────────────────────────────────────
// Ensures at most one physical model is loaded per logical alias role.
// Swap is lazy (triggered on next request) and serialized per-role.
// Unload happens after M_new is confirmed pullable; no rollback on failure.
const roleBindings = new Map();   // role → { model: string, backendUrl: string }
const roleSwapLocks = new Map();  // role → Promise (serialize concurrent swaps)

function ollamaUnloadModel(backendUrl, model) {
  const urlStr = _ollamaUrl(backendUrl, '/api/generate');
  return new Promise((resolve) => {
    const body = JSON.stringify({ model, keep_alive: 0 });
    const transport = _ollamaTransport(urlStr);
    const req = transport.request(urlStr, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(body) },
    }, res => { res.resume(); resolve(); });
    req.on('error', () => resolve()); // best-effort — if Ollama is gone, nothing to unload
    req.setTimeout(10000, () => { req.destroy(); resolve(); });
    req.write(body);
    req.end();
  });
}

async function enforceRoleExclusivity(logicalRole, newModel, backendUrl) {
  const prev = roleBindings.get(logicalRole);
  roleBindings.set(logicalRole, { model: newModel, backendUrl });
  if (!prev || prev.model === newModel) return;

  // Binding changed — serialize the swap so concurrent reqs for this role queue up
  const lock = roleSwapLocks.get(logicalRole) || Promise.resolve();
  const next = lock.then(async () => {
    const current = roleBindings.get(logicalRole);
    if (!current || current.model === newModel) return; // a concurrent req already swapped
    proxyLog('role_exclusivity.swap', { role: logicalRole, old: prev.model, new: newModel });
    await ollamaUnloadModel(prev.backendUrl || backendUrl, prev.model);
  }).finally(() => {
    if (roleSwapLocks.get(logicalRole) === next) roleSwapLocks.delete(logicalRole);
  });
  roleSwapLocks.set(logicalRole, next);
  await next;
}

function recordFailureClass(failureClass) {
  stats.byFailureClass[failureClass] = (stats.byFailureClass[failureClass] || 0) + 1;
}

function nowIso() {
  return new Date().toISOString();
}

function nowMs() {
  return Date.now();
}

function isLocalHostName(hostname) {
  return ['localhost', '127.0.0.1', '0.0.0.0', '::1'].includes(hostname);
}

function isManagedCloudBackend(backend, effectiveModel) {
  if (!backend || !backend.id || !backend.url) return false;
  if (backend.id === '__ollama_fallback__') return false;
  if (String(effectiveModel || '').endsWith(':cloud')) return true;
  try {
    const url = new URL(backend.url);
    return !isLocalHostName(url.hostname);
  } catch {
    return false;
  }
}

function ensureBackendHealthEntry(backend, effectiveModel) {
  if (!backend || !backend.id) return null;
  if (!stats.byBackendId[backend.id]) {
    const now = nowIso();
    const nowAt = nowMs();
    stats.byBackendId[backend.id] = {
      backend_id: backend.id,
      backend_kind: backend.kind || 'unknown',
      backend_url: backend.url || '',
      managed: isManagedCloudBackend(backend, effectiveModel),
      state: 'healthy',
      state_since: now,
      state_since_ms: nowAt,
      last_failure_class: null,
      last_failure_at: null,
      last_failure_at_ms: null,
      last_success_at: null,
      last_success_at_ms: null,
      last_healed_at: null,
      last_healed_at_ms: null,
      next_probe_at_ms: 0,
      request_count: 0,
      success_count: 0,
      failure_count: 0,
      consecutive_failures: 0,
      consecutive_successes: 0,
      slow_streak: 0,
      last_latency_ms: null,
      ewma_latency_ms: null,
      recent_latencies_ms: [],
    };
  }
  const entry = stats.byBackendId[backend.id];
  entry.backend_kind = backend.kind || entry.backend_kind;
  entry.backend_url = backend.url || entry.backend_url;
  entry.managed = isManagedCloudBackend(backend, effectiveModel);
  return entry;
}

function persistHealthState() {
  try {
    fs.mkdirSync(path.dirname(HEALTH_STATE_FILE), { recursive: true });
    // A8: use a UUID so two proxy instances can't collide on pid reuse.
    const tmpPath = `${HEALTH_STATE_FILE}.tmp.${crypto.randomUUID()}`;
    fs.writeFileSync(tmpPath, JSON.stringify({
      version: healthMeta.version,
      generated_at: nowIso(),
      event_seq: healthMeta.eventSeq,
      last_transition: healthMeta.lastTransition,
      recent_events: healthMeta.recentEvents,
      backends: stats.byBackendId,
    }, null, 2));
    fs.renameSync(tmpPath, HEALTH_STATE_FILE);
  } catch {
    // Best-effort observability only.
  }
}

function transitionBackendState(entry, nextState, reason) {
  if (!entry || entry.state === nextState) return;
  const at = nowIso();
  const atMs = nowMs();
  debugLog('proxy.health.transition.before', {
    backend_id: entry.backend_id,
    from: entry.state,
    to: nextState,
    reason,
    consecutive_failures: entry.consecutive_failures,
    consecutive_successes: entry.consecutive_successes,
    ewma_latency_ms: entry.ewma_latency_ms,
    last_latency_ms: entry.last_latency_ms,
    next_probe_at_ms: entry.next_probe_at_ms,
  });
  const event = {
    event_id: ++healthMeta.eventSeq,
    backend_id: entry.backend_id,
    from: entry.state,
    to: nextState,
    reason,
    at,
    at_ms: atMs,
  };
  entry.state = nextState;
  entry.state_since = at;
  entry.state_since_ms = atMs;
  if (nextState === 'healthy') {
    entry.last_healed_at = at;
    entry.last_healed_at_ms = atMs;
    entry.next_probe_at_ms = 0;
  } else if (nextState === 'recovering') {
    entry.next_probe_at_ms = 0;
  }
  healthMeta.lastTransition = event;
  healthMeta.recentEvents.push(event);
  if (healthMeta.recentEvents.length > HEALTH_EVENT_LOG_LIMIT) {
    healthMeta.recentEvents = healthMeta.recentEvents.slice(-HEALTH_EVENT_LOG_LIMIT);
  }
  debugLog('proxy.health.transition.after', {
    backend_id: entry.backend_id,
    state: entry.state,
    reason,
    event_id: event.event_id,
    state_since_ms: entry.state_since_ms,
    next_probe_at_ms: entry.next_probe_at_ms,
    last_healed_at_ms: entry.last_healed_at_ms,
  });
}

function updateLatency(entry, latencyMs) {
  if (!entry || !Number.isFinite(latencyMs)) return;
  entry.last_latency_ms = latencyMs;
  entry.recent_latencies_ms.push(latencyMs);
  if (entry.recent_latencies_ms.length > HEALTH_LATENCY_WINDOW) {
    entry.recent_latencies_ms = entry.recent_latencies_ms.slice(-HEALTH_LATENCY_WINDOW);
  }
  if (entry.ewma_latency_ms == null) {
    entry.ewma_latency_ms = latencyMs;
  } else {
    entry.ewma_latency_ms = Math.round((HEALTH_EWMA_ALPHA * latencyMs) + ((1 - HEALTH_EWMA_ALPHA) * entry.ewma_latency_ms));
  }
}

function noteBackendSuccess(backend, effectiveModel, latencyMs) {
  const entry = ensureBackendHealthEntry(backend, effectiveModel);
  if (!entry || !entry.managed) return;

  const at = nowIso();
  const atMs = nowMs();
  const previousState = entry.state;
  entry.request_count++;
  entry.success_count++;
  entry.consecutive_successes++;
  entry.consecutive_failures = 0;
  entry.last_success_at = at;
  entry.last_success_at_ms = atMs;
  updateLatency(entry, latencyMs);

  const isSlow = Number.isFinite(latencyMs) && latencyMs >= HEALTH_SLOW_THRESHOLD_MS;
  entry.slow_streak = isSlow ? entry.slow_streak + 1 : 0;

  if ((entry.state === 'degraded' || entry.state === 'disconnected') && !isSlow) {
    transitionBackendState(entry, 'recovering', 'successful_probe');
  } else if ((entry.state === 'degraded' || entry.state === 'disconnected') && isSlow) {
    entry.next_probe_at_ms = atMs + HEALTH_RECOVERY_PROBE_MS;
  } else if (entry.state === 'recovering' && isSlow) {
    transitionBackendState(entry, 'degraded', 'slow_recovery_response');
    entry.next_probe_at_ms = atMs + HEALTH_RECOVERY_PROBE_MS;
  }

  if (entry.state === 'recovering' && entry.consecutive_successes >= HEALTH_HEAL_SUCCESS_COUNT && (entry.ewma_latency_ms == null || entry.ewma_latency_ms < HEALTH_SLOW_THRESHOLD_MS)) {
    transitionBackendState(entry, 'healthy', 'recovered');
  } else if (entry.state === 'healthy' && entry.slow_streak >= HEALTH_DEGRADE_SLOW_STREAK) {
    transitionBackendState(entry, 'degraded', 'slow_responses');
    entry.next_probe_at_ms = atMs + HEALTH_RECOVERY_PROBE_MS;
  }

  if (previousState !== entry.state && (entry.state === 'recovering' || entry.state === 'healthy')) {
    debugLog('proxy.health.cooldown.clear', {
      backend_id: entry.backend_id,
      effective_model: effectiveModel,
      previous_state: previousState,
      next_state: entry.state,
    });
    clearCooldown(effectiveModel);
  }

  persistHealthState();
}

function noteBackendFailure(backend, effectiveModel, failureClass, latencyMs, reason) {
  const entry = ensureBackendHealthEntry(backend, effectiveModel);
  if (!entry || !entry.managed) return;

  const at = nowIso();
  const atMs = nowMs();
  entry.request_count++;
  entry.failure_count++;
  entry.consecutive_failures++;
  entry.consecutive_successes = 0;
  entry.slow_streak = 0;
  entry.last_failure_class = failureClass || null;
  entry.last_failure_at = at;
  entry.last_failure_at_ms = atMs;
  if (Number.isFinite(latencyMs)) updateLatency(entry, latencyMs);

  if (failureClass === 'network_failure') {
    if (entry.state === 'recovering' || entry.consecutive_failures >= HEALTH_DISCONNECT_FAILURES) {
      transitionBackendState(entry, 'disconnected', reason || 'network_failure');
    } else if (entry.consecutive_failures >= HEALTH_DEGRADE_FAILURES) {
      transitionBackendState(entry, 'degraded', reason || 'network_failure');
    }
    entry.next_probe_at_ms = atMs + HEALTH_RECOVERY_PROBE_MS;
  }

  persistHealthState();
}

function shouldPreferFallbackForHealth(backend, effectiveModel) {
  const entry = ensureBackendHealthEntry(backend, effectiveModel);
  if (!entry || !entry.managed) return false;
  if (entry.state !== 'degraded' && entry.state !== 'disconnected') return false;
  return nowMs() < (entry.next_probe_at_ms || 0);
}

function classifyError(statusCode, headers, bodyText = '') {
  const body = String(bodyText || '').toLowerCase();
  if (body.includes('credits exhausted') || body.includes('account quota') || body.includes('insufficient credits')) return 'account_quota';
  if (body.includes('context length exceeded') || body.includes('context limit') || body.includes('too many tokens')) return 'context_limit';
  if (statusCode === 400 && /credit balance|insufficient credit/i.test(bodyText || '')) return 'account_quota';
  if (statusCode === 401) return 'account_quota'; // invalid / revoked key
  if (statusCode === 429) return 'rate_limit';
  if (statusCode === 402 || statusCode === 403) return 'account_quota';
  if (statusCode === 413) return 'context_limit';
  if (statusCode >= 500) return 'network_failure';
  return null;
}

function getCooldownMs(model, failureClass) {
  const strategies = CONFIG.fallback_strategies || {};
  const strategy = strategies[model];
  if (!strategy) return 0;
  const cooldown = (strategy.cooldown || {})[failureClass];
  if (!cooldown) return 0;
  if (cooldown.mode === 'none') return 0;
  if (cooldown.mode === 'fixed' || cooldown.mode === 'header_or_max') {
    return (cooldown.seconds || cooldown.max_seconds || 0) * 1000;
  }
  return 0;
}

function isCooledDown(model) {
  const entry = cooldowns.get(model);
  if (!entry) return false;
  if (Date.now() >= entry.untilMs) {
    cooldowns.delete(model);
    return false;
  }
  return true;
}

function clearCooldown(model) {
  if (!model) return;
  if (cooldowns.has(model)) {
    debugLog('proxy.cooldown.clear', {
      model,
      previous_until_ms: cooldowns.get(model)?.untilMs || null,
      previous_failure_class: cooldowns.get(model)?.failureClass || null,
    });
  }
  cooldowns.delete(model);
}

function setCooldown(model, failureClass, statusCode, headers) {
  // Liveness semantics: first error marks the model dead. It stays dead until
  // the background liveness prober (see startLivenessProbeLoop) successfully
  // probes the backend and calls clearCooldown. No time-based expiry.
  const untilMs = Number.POSITIVE_INFINITY;
  proxyLog('liveness.mark_dead', { model, failure_class: failureClass, status_code: statusCode });
  cooldowns.set(model, { untilMs, failureClass, markedDeadAtMs: Date.now() });
}

function shouldBypassCooldownForRecoveryProbe(backend, effectiveModel) {
  const entry = ensureBackendHealthEntry(backend, effectiveModel);
  if (!entry || !entry.managed) return false;
  if (entry.state !== 'degraded' && entry.state !== 'disconnected') return false;
  return nowMs() >= (entry.next_probe_at_ms || 0);
}

function resolveFallbackModel(model, failureClass, logicalRole = null) {
  // Per-profile hard_fail gate: classifier must error rather than cascade to a non-equivalent model.
  if (logicalRole) {
    const cfg = CONFIG;
    const hw = resolveActiveTier(CONFIG);
    const profiles = cfg.llm_profiles?.[hw] || {};
    const profileEntry = profiles[profileAliasKey(logicalRole)];
    if (profileEntry?.on_failure === 'hard_fail') return null;
  }
  const strategies = CONFIG.fallback_strategies || {};
  const strategy = strategies[model];
  if (!strategy || !strategy.event) return null;
  if (failureClass && !VALID_FAILURE_CLASSES.has(failureClass)) return null;
  const candidates = strategy.event[failureClass];
  if (!Array.isArray(candidates) || candidates.length === 0) return null;
  for (const candidate of candidates) {
    const resolved = resolveLogicalAlias(resolveRouteModel(candidate));
    if (!isCooledDown(resolved)) return resolved;
  }
  return null;
}

// ── Backend resolution ─────────────────────────────────────────────────

function isLocalOllamaBackend(model, backendUrl) {
  if (String(model || '').endsWith(':cloud')) return false;
  try {
    const url = new URL(backendUrl);
    return ['localhost', '127.0.0.1', '0.0.0.0', '::1'].includes(url.hostname);
  } catch {
    return false;
  }
}

async function ensureOllamaModelLoaded(model, backendUrl, logicalRole = null) {
  if (SKIP_WARMUP) return null;
  if (!isLocalOllamaBackend(model, backendUrl)) return null;
  debugLog('proxy.ollama.prepare.start', { model, backend_url: backendUrl, logical_role: logicalRole });

  // 1) Is the model present?
  let tags;
  try { tags = await ollamaListTags(backendUrl); }
  catch (e) {
    debugLog('proxy.ollama.prepare.list.error', { model, backend_url: backendUrl, error: e.message });
    return null; // Ollama unreachable — mirror today's ENOENT branch (skip warm-up, let request surface it)
  }
  debugLog('proxy.ollama.prepare.list.result', {
    model, backend_url: backendUrl, cached: tags.includes(model), cached_count: tags.length,
  });

  // 2) Pull if missing (dedup concurrent pulls on same model+backend)
  if (!tags.includes(model)) {
    const key = backendUrl + '\0' + model;
    let pending = pullInFlight.get(key);
    if (!pending) {
      proxyLog('ollama.pull.start', { model, backend_url: backendUrl });
      console.error(`claude-proxy: '${model}' not cached on ${backendUrl} — pulling now...`);
      pending = ollamaPull(backendUrl, model).finally(() => pullInFlight.delete(key));
      pullInFlight.set(key, pending);
    }
    try { await pending; }
    catch (e) {
      const isTimeout = e && e.code === 'ETIMEDOUT';
      proxyLog('ollama.pull.failure', {
        model, backend_url: backendUrl, error: e.message, timeout: !!isTimeout,
      });
      const msg = isTimeout
        ? `Pull timed out: ${e.message}`
        : `Failed to pull '${model}' from ${backendUrl}: ${e.message}`;
      return { type: 'api_error', message: msg };
    }
    proxyLog('ollama.pull.success', { model, backend_url: backendUrl });
    recordOllamaPull(model, backendUrl).catch(() => {});
  }

  // 3) Enforce role exclusivity — unload previous model for this role if binding changed.
  //    Runs after pull so M_new is confirmed available before M_old is evicted.
  if (logicalRole) await enforceRoleExclusivity(logicalRole, model, backendUrl);

  // 4) Already loaded?
  let loaded = [];
  try { loaded = await ollamaPs(backendUrl); }
  catch (e) {
    debugLog('proxy.ollama.prepare.ps.error', { model, backend_url: backendUrl, error: e.message });
    return null;
  }
  if (loaded.some(m => m.name === model)) {
    debugLog('proxy.ollama.prepare.loaded', { model, backend_url: backendUrl });
    return null;
  }

  // 5) Trigger load (fire-and-forget — the actual request will also load it, this just pre-warms)
  const numCtx = (CONFIG.ollama_defaults && CONFIG.ollama_defaults.num_ctx) || 65536;
  debugLog('proxy.ollama.prepare.warm.start', { model, backend_url: backendUrl, num_ctx: numCtx });
  ollamaLoad(backendUrl, model, { numCtx, keepAlive: OLLAMA_WARM_KEEP_ALIVE }).catch(() => {});
  return null;
}

async function ensureOllamaReadyOrSend(res, model, backendUrl, logicalRole = null) {
  const error = await ensureOllamaModelLoaded(model, backendUrl, logicalRole);
  if (!error) return true;
  if (!res.headersSent) send(res, 502, { error });
  return false;
}

function formatBackendError(kind, targetUrl, error) {
  if (kind === 'ollama') {
    return { type: 'api_error', message: `Cannot reach Ollama at ${targetUrl}: ${error.message}` };
  }
  return { type: 'api_error', message: error.message };
}

function isFatalCallTimeout(error) {
  return error && error.code === 'CLAUDE_PROXY_FATAL_CALL_TIMEOUT';
}

function formatFatalCallTimeout(targetUrl, timeoutMs) {
  return {
    type: 'api_error',
    message: `Fatal call timeout after ${timeoutMs}ms while waiting for upstream ${targetUrl}`,
  };
}

function attachFatalCallTimeout(up, res, targetUrl, timeoutMs, state) {
  if (!Number.isFinite(timeoutMs) || timeoutMs <= 0) return () => {};
  let cleared = false;
  const clear = () => {
    if (cleared) return;
    cleared = true;
    clearTimeout(timer);
    res.off('finish', clear);
    res.off('close', clear);
    up.off('close', clear);
    up.off('error', clear);
  };
  const timer = setTimeout(() => {
    state.fatalTimeoutTriggered = true;
    const error = new Error(`fatal call timeout after ${timeoutMs}ms`);
    error.code = 'CLAUDE_PROXY_FATAL_CALL_TIMEOUT';
    if (state.upstreamResponse && !state.upstreamResponse.destroyed) {
      state.upstreamResponse.destroy(error);
    }
    if (!up.destroyed) up.destroy(error);
    if (res.headersSent && !res.writableEnded) res.end();
  }, timeoutMs);
  if (typeof timer.unref === 'function') timer.unref();
  res.on('finish', clear);
  res.on('close', clear);
  up.on('close', clear);
  up.on('error', clear);
  return clear;
}

const BACKEND_SIGIL_RE = /^(.+)@([A-Za-z0-9_-]+)$/;

function resolveBackend(model) {
  if (model == null || typeof model !== 'string' || !model.trim()) {
    return { error: 'model is required', status: 400 };
  }

  const modelRoutes = CONFIG.model_routes || {};
  const routes = CONFIG.routes || {};
  const backends = CONFIG.backends || {};

  // 1. Follow route graph first
  const afterRoute = resolveRouteModel(model);
  const terminalModel = resolveLogicalAlias(afterRoute);
  const logicalRole = resolveCapabilityAlias(afterRoute, CONFIG, resolveActiveTier(CONFIG));

  // 1a. @<backend> sigil: "model@backend_id" binds directly to named backend
  const sigilMatch = terminalModel.match(BACKEND_SIGIL_RE);
  if (sigilMatch) {
    const [, baseModel, backendId] = sigilMatch;
    if (backends[backendId]) {
      // Strip the @suffix — it is a routing sigil, not part of the model name
      return { backend: { id: backendId, ...backends[backendId] }, effectiveModel: baseModel, logicalRole };
    }
    return { error: `@backend sigil '${backendId}' in '${terminalModel}' is not a declared backend`, status: 500, extra: { terminal_model: terminalModel } };
  }

  // 2. Try exact match in model_routes
  if (modelRoutes[terminalModel] !== undefined) {
    const id = modelRoutes[terminalModel];
    const backend = backends[id];
    if (!backend) return { error: `backend '${id}' not defined for model '${terminalModel}'`, status: 500, extra: { terminal_model: terminalModel } };
    return { backend: { id, ...backend }, effectiveModel: terminalModel, logicalRole };
  }

  // 3. Try pattern match in model_routes
  const patternBackend = lookupPatternValue('model_routes', terminalModel);
  if (patternBackend) {
    const backend = backends[patternBackend];
    if (!backend) return { error: `backend '${patternBackend}' not defined for pattern-matched model '${terminalModel}'`, status: 500, extra: { terminal_model: terminalModel } };
    return { backend: { id: patternBackend, ...backend }, effectiveModel: terminalModel, logicalRole };
  }

  // 4. If model was routed but terminal not in model_routes, try original model
  if (terminalModel !== model && modelRoutes[model] !== undefined) {
    const id = modelRoutes[model];
    const backend = backends[id];
    if (!backend) return { error: `backend '${id}' not defined for model '${model}'`, status: 500 };
    return { backend: { id, ...backend }, effectiveModel: model, logicalRole };
  }

  // 5. Default: unknown claude-* → anthropic, everything else → ollama fallback
  if (/^claude-/i.test(terminalModel)) {
    // Find the anthropic backend
    const anthroEntry = Object.entries(backends).find(([, v]) => (v.kind || 'anthropic') === 'anthropic');
    if (anthroEntry) {
      const [id, backend] = anthroEntry;
      return { backend: { id, ...backend }, effectiveModel: terminalModel, logicalRole };
    }
  }

  // 6. Ollama fallback
  console.error(`claude-proxy: '${terminalModel}' not in model_routes — assuming local Ollama at ${DEFAULT_OLLAMA_URL}`);
  return {
    backend: { id: '__ollama_fallback__', kind: 'ollama', url: DEFAULT_OLLAMA_URL, _ollamaFallback: true },
    effectiveModel: terminalModel,
    logicalRole,
  };
}

// ── Helper functions ───────────────────────────────────────────────────

// Injects x-c-thru-resolved-via for hook observability without log-parsing.
// Only emits on capability requests (logicalRole alias present); skipped on non-capability paths.
function addResolvedViaHeader(respHeaders, resolved) {
  const capability = resolved?.capability || resolved?.logicalRole;
  if (!capability) return;
  respHeaders['x-c-thru-resolved-via'] = JSON.stringify({
    capability,
    profile: resolved.logicalRole || capability,
    served_by: resolved.effectiveModel || resolved.served_by || null,
  });
}

function send(res, code, obj) {
  const body = JSON.stringify(obj);
  res.writeHead(code, {
    'content-type': 'application/json',
    'content-length': Buffer.byteLength(body),
  });
  res.end(body);
}

function sseEvent(res, eventName, data) {
  res.write(`event: ${eventName}\ndata: ${JSON.stringify(data)}\n\n`);
}

function addAnnotationHeaders(res, effectiveModel, backend) {
  if (ANNOTATE_MODEL) {
    res.setHeader('x-claude-proxy-served-by', effectiveModel || '');
  }
}

// ── Anthropic passthrough ──────────────────────────────────────────────
// Forwards the request body verbatim; replaces x-api-key with the real
// backend key from env. Streams SSE through untouched via pipe().
// ── SSE patcher ───────────────────────────────────────────────────────
// Some OpenRouter models (e.g. GLM) omit usage in message_start events.
// Claude Code crashes with "undefined is not an object (evaluating '_.input_tokens')".
// Patch the SSE stream inline to ensure usage fields are always present.
function patchSseBlock(block) {
  const lines = block.split('\n');
  let dataIdx = -1;
  let payload = null;
  for (let i = 0; i < lines.length; i++) {
    if (lines[i].startsWith('data:')) {
      try {
        const p = JSON.parse(lines[i].slice(5).trim());
        if (p && p.type === 'message_start') { payload = p; dataIdx = i; }
      } catch {}
    }
  }
  if (dataIdx < 0 || !payload) return block;
  if (!payload.message) payload.message = {};
  if (!payload.message.usage || typeof payload.message.usage !== 'object') {
    payload.message.usage = { input_tokens: 0, output_tokens: 0, cache_creation_input_tokens: 0, cache_read_input_tokens: 0 };
  } else {
    if (payload.message.usage.input_tokens == null) payload.message.usage.input_tokens = 0;
    if (payload.message.usage.output_tokens == null) payload.message.usage.output_tokens = 0;
  }
  lines[dataIdx] = 'data: ' + JSON.stringify(payload);
  return lines.join('\n');
}

// A3: cap the pending-frame buffer so a backend that never emits `\n\n`
// can't grow it unbounded. Legitimate Anthropic SSE frames are <10KB;
// the cap is deliberately enormous (512 MiB) to catch only pathological
// runaway streams and never truncate real traffic.
const SSE_BUFFER_MAX_BYTES = 512 * 1024 * 1024;

function createSsePatcher() {
  let buf = '';
  return new Transform({
    transform(chunk, _enc, cb) {
      buf += chunk.toString('utf8');
      const blocks = buf.split('\n\n');
      buf = blocks.pop();
      let out = '';
      for (const block of blocks) out += patchSseBlock(block) + '\n\n';
      if (out) this.push(out);
      if (Buffer.byteLength(buf, 'utf8') > SSE_BUFFER_MAX_BYTES) {
        return cb(new Error(`SSE frame exceeded ${SSE_BUFFER_MAX_BYTES} bytes without delimiter`));
      }
      cb();
    },
    flush(cb) {
      if (buf.trim()) this.push(patchSseBlock(buf));
      cb();
    },
  });
}

function forwardAnthropic(req, res, body, backend, effectiveModel, requestMeta = null) {
  const targetUrl = new URL(backend.url);
  const authKey = backend.auth_env ? process.env[backend.auth_env] : '';
  const timeoutState = { upstreamResponse: null, fatalTimeoutTriggered: false };
  const streamUsage = createStreamUsageTracker();
  const responseChunks = [];

  const bodyStr = body ? JSON.stringify(body) : '';
  const headers = {
    ...(body ? { 'content-type': 'application/json', 'content-length': Buffer.byteLength(bodyStr) } : {}),
    'anthropic-version': req.headers['anthropic-version'] || '2023-06-01',
    'accept': req.headers['accept'] || 'application/json',
  };
  if (req.headers['anthropic-beta']) headers['anthropic-beta'] = req.headers['anthropic-beta'];
  if (authKey) headers['x-api-key'] = authKey;
  // Forward custom request headers (x-custom-*)
  for (const [k, v] of Object.entries(req.headers)) {
    if (k.startsWith('x-custom-') || k.startsWith('x-upstream-')) headers[k] = v;
  }

  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;
  const options = {
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: req.url,
    method: req.method,
    headers,
  };

  const up = lib.request(options, upRes => {
    timeoutState.upstreamResponse = upRes;
    const respHeaders = { ...upRes.headers };
    if (ANNOTATE_MODEL && effectiveModel) respHeaders['x-claude-proxy-served-by'] = effectiveModel;
    addResolvedViaHeader(respHeaders, requestMeta);
    res.writeHead(upRes.statusCode, respHeaders);
    upRes.on('data', chunk => {
      const contentType = String(upRes.headers['content-type'] || '');
      if (contentType.includes('text/event-stream')) {
        noteStreamUsageChunk(streamUsage, chunk);
      } else if (contentType.includes('application/json')) {
        responseChunks.push(chunk);
      }
    });
    upRes.on('end', () => {
      const contentType = String(upRes.headers['content-type'] || '');
      if (contentType.includes('text/event-stream')) {
        finalizeTrackedUsage(requestMeta, {
          status_code: upRes.statusCode,
          input_tokens: streamUsage.input_tokens,
          output_tokens: streamUsage.output_tokens,
          stop_reason: streamUsage.stop_reason,
        });
      } else if (contentType.includes('application/json')) {
        let parsed = null;
        try { parsed = JSON.parse(Buffer.concat(responseChunks).toString('utf8')); } catch { parsed = null; }
        const usage = usageFromJsonPayload(parsed);
        finalizeTrackedUsage(requestMeta, {
          status_code: upRes.statusCode,
          input_tokens: usage.input_tokens,
          output_tokens: usage.output_tokens,
          stop_reason: usage.stop_reason,
        });
      } else {
        finalizeTrackedUsage(requestMeta, { status_code: upRes.statusCode, input_tokens: 0, output_tokens: 0 });
      }
    });
    const isSse = String(upRes.headers['content-type'] || '').includes('text/event-stream');
    if (isSse) {
      upRes.pipe(createSsePatcher()).pipe(res);
    } else {
      upRes.pipe(res);
    }
  });
  attachFatalCallTimeout(up, res, targetUrl.origin, FATAL_CALL_TIMEOUT_MS, timeoutState);
  up.on('error', e => {
    if (isFatalCallTimeout(e)) {
      finalizeTrackedUsage(requestMeta, { status_code: 504, input_tokens: 0, output_tokens: 0, stop_reason: 'fatal_timeout' });
      if (!res.headersSent) send(res, 504, { error: formatFatalCallTimeout(targetUrl.origin, FATAL_CALL_TIMEOUT_MS) });
      else res.end();
      return;
    }
    finalizeTrackedUsage(requestMeta, { status_code: 502, input_tokens: 0, output_tokens: 0, stop_reason: 'proxy_error' });
    if (!res.headersSent) send(res, 502, { error: formatBackendError('anthropic', targetUrl.origin, e) });
    else res.end();
  });
  if (bodyStr) up.write(bodyStr);
  up.end();
}

// ── Ollama Anthropic-compatible passthrough ────────────────────────────
// When Ollama exposes /v1/messages (Anthropic-compatible), forward the
// request verbatim. This preserves all fields: temperature, top_p, tools,
// tool_result, structured content, etc.
function forwardOllamaPassthrough(req, res, body, backend, effectiveModel, requestMeta = null) {
  const targetUrl = new URL(backend.url);
  const authKey = backend.auth_env ? process.env[backend.auth_env] : null;
  const timeoutState = { upstreamResponse: null, fatalTimeoutTriggered: false };
  const streamUsage = createStreamUsageTracker();
  const responseChunks = [];

  // Replace model with the resolved terminal model
  const outBody = { ...body, model: effectiveModel || body.model };

  const bodyStr = JSON.stringify(outBody);
  const headers = {
    'content-type': 'application/json',
    'content-length': Buffer.byteLength(bodyStr),
  };
  if (authKey) headers['authorization'] = `Bearer ${authKey}`;
  // Forward client API key if no auth_env
  if (!authKey && req.headers['x-api-key']) {
    headers['authorization'] = `Bearer ${req.headers['x-api-key']}`;
  }
  // Forward custom request headers (x-custom-*)
  for (const [k, v] of Object.entries(req.headers)) {
    if (k.startsWith('x-custom-') || k.startsWith('x-upstream-')) headers[k] = v;
  }

  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;
  const options = {
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: req.url,
    method: req.method,
    headers,
  };

  const up = lib.request(options, upRes => {
    timeoutState.upstreamResponse = upRes;
    const respHeaders = { ...upRes.headers };
    if (ANNOTATE_MODEL && effectiveModel) respHeaders['x-claude-proxy-served-by'] = effectiveModel;
    addResolvedViaHeader(respHeaders, requestMeta);
    if (upRes.statusCode !== 200) {
      const errChunks = [];
      upRes.on('data', c => errChunks.push(c));
      upRes.on('end', () => {
        finalizeTrackedUsage(requestMeta, { status_code: upRes.statusCode, input_tokens: 0, output_tokens: 0, stop_reason: 'error_response' });
        if (!res.headersSent) {
          res.writeHead(upRes.statusCode, respHeaders);
          res.end(Buffer.concat(errChunks));
        }
      });
      return;
    }
    // Stream SSE through
    res.writeHead(200, respHeaders);
    upRes.on('data', chunk => {
      const contentType = String(upRes.headers['content-type'] || '');
      if (contentType.includes('text/event-stream')) {
        noteStreamUsageChunk(streamUsage, chunk);
      } else if (contentType.includes('application/json')) {
        responseChunks.push(chunk);
      }
    });
    upRes.on('end', () => {
      const contentType = String(upRes.headers['content-type'] || '');
      if (contentType.includes('text/event-stream')) {
        finalizeTrackedUsage(requestMeta, {
          status_code: upRes.statusCode,
          input_tokens: streamUsage.input_tokens,
          output_tokens: streamUsage.output_tokens,
          stop_reason: streamUsage.stop_reason,
        });
      } else if (contentType.includes('application/json')) {
        let parsed = null;
        try { parsed = JSON.parse(Buffer.concat(responseChunks).toString('utf8')); } catch { parsed = null; }
        const usage = usageFromJsonPayload(parsed);
        finalizeTrackedUsage(requestMeta, {
          status_code: upRes.statusCode,
          input_tokens: usage.input_tokens,
          output_tokens: usage.output_tokens,
          stop_reason: usage.stop_reason,
        });
      } else {
        finalizeTrackedUsage(requestMeta, { status_code: upRes.statusCode, input_tokens: 0, output_tokens: 0 });
      }
    });
    upRes.pipe(res);
  });
  attachFatalCallTimeout(up, res, targetUrl.origin, FATAL_CALL_TIMEOUT_MS, timeoutState);
  up.on('error', e => {
    if (isFatalCallTimeout(e)) {
      finalizeTrackedUsage(requestMeta, { status_code: 504, input_tokens: 0, output_tokens: 0, stop_reason: 'fatal_timeout' });
      if (!res.headersSent) send(res, 504, { error: formatFatalCallTimeout(targetUrl.origin, FATAL_CALL_TIMEOUT_MS) });
      else res.end();
      return;
    }
    finalizeTrackedUsage(requestMeta, { status_code: 502, input_tokens: 0, output_tokens: 0, stop_reason: 'proxy_error' });
    if (!res.headersSent) send(res, 502, { error: formatBackendError('ollama', targetUrl.origin, e) });
    else res.end();
  });
  up.write(bodyStr);
  up.end();
}

function forwardOllama(req, res, body, backend, effectiveModel, requestMeta = null) {
  return forwardOllamaPassthrough(req, res, body, backend, effectiveModel, requestMeta);
}

// ── Request handler ───────────────────────────────────────────────────

async function readBody(req) {
  const chunks = [];
  for await (const c of req) chunks.push(c);
  return Buffer.concat(chunks);
}

function handleRequestWithFallback(req, res, body, resolved) {
  const { backend, effectiveModel, logicalRole } = resolved;
  const clientModel = body.model;
  const endpoint = req.url;

  const doForward = (b, em, fwdBody) => {
    res._statsBackend = b;
    res._statsEffectiveModel = em || fwdBody.model || clientModel;
    const requestMeta = {
      endpoint,
      clientModel,
      effectiveModel: em || fwdBody.model || clientModel,
      backend: b,
      stream: Boolean(fwdBody && fwdBody.stream),
      startedAtMs: nowMs(),
      capability: logicalRole,
      logicalRole,
    };
    if (b.kind === 'ollama') {
      (async () => {
        if (!(await ensureOllamaReadyOrSend(res, em || clientModel, b.url, logicalRole))) return;
        return forwardOllama(req, res, fwdBody, b, em, requestMeta);
      })().catch(err => {
        if (!res.headersSent) send(res, 500, { error: err.message });
      });
      return;
    }
    if (b.kind === 'anthropic') return forwardAnthropic(req, res, fwdBody, b, em, requestMeta);
    return send(res, 500, { error: `unknown backend kind: ${b.kind}` });
  };

  if (!backend) return send(res, 500, { error: 'no backend resolved' });

  // Check if this model has fallback strategies
  const terminalModel = effectiveModel || clientModel;
  const strategies = CONFIG.fallback_strategies || {};
  const strategy = strategies[terminalModel];

  if (!strategy) {
    return doForward(backend, effectiveModel, body);
  }

  // Chain fallback: iterate all candidates in strategy.event[failureClass],
  // skipping dead ones, marking each failure as dead and continuing.
  const tryFallbackChain = (candidates, failureClass, startIdx = 0) => {
    for (let i = startIdx; i < candidates.length; i++) {
      const rawCandidate = candidates[i];
      const candidateModel = resolveLogicalAlias(resolveRouteModel(rawCandidate));
      if (isCooledDown(candidateModel)) {
        proxyLog('fallback.skip_dead', { candidate: candidateModel, index: i });
        continue;
      }
      const cResolved = resolveBackend(candidateModel);
      if (cResolved.error) {
        proxyLog('fallback.skip_unresolvable', { candidate: candidateModel, error: cResolved.error });
        continue;
      }
      return attemptCandidate(candidateModel, cResolved, candidates, failureClass, i);
    }
    proxyLog('fallback.chain_exhausted', { terminal_model: terminalModel, count: candidates.length });
    if (!res.headersSent) send(res, 502, { error: `all ${candidates.length} fallback candidates exhausted or dead` });
    else res.end();
  };

  const attemptCandidate = (candidateModel, cResolved, candidates, failureClass, currentIdx) => {
    const cBackend = cResolved.backend;
    const cBody = { ...body, model: candidateModel };
    const cBodyStr = JSON.stringify(cBody);
    const cUrl = new URL(cBackend.url);
    const cHeaders = {
      'content-type': 'application/json',
      'content-length': Buffer.byteLength(cBodyStr),
      'accept': req.headers['accept'] || 'application/json',
    };
    if (cBackend.kind === 'ollama') {
      const k = cBackend.auth_env ? process.env[cBackend.auth_env] : (req.headers['x-api-key'] || '');
      if (k) cHeaders.authorization = `Bearer ${k}`;
    } else {
      const k = cBackend.auth_env ? process.env[cBackend.auth_env] : '';
      cHeaders['anthropic-version'] = req.headers['anthropic-version'] || '2023-06-01';
      if (req.headers['anthropic-beta']) cHeaders['anthropic-beta'] = req.headers['anthropic-beta'];
      if (k) cHeaders['x-api-key'] = k;
    }
    const cLib = cUrl.protocol === 'https:' ? https : http;
    const cStart = nowMs();
    proxyLog('fallback.attempt', { candidate: candidateModel, backend_id: cBackend.id, index: currentIdx });

    const cUp = cLib.request({
      hostname: cUrl.hostname,
      port: cUrl.port || (cUrl.protocol === 'https:' ? 443 : 80),
      path: req.url,
      method: req.method,
      headers: cHeaders,
    }, (upRes) => {
      const isOllamaCloud = cBackend.kind === 'ollama' && isManagedCloudBackend(cBackend, candidateModel);
      if (!isOllamaCloud) {
        cUp.setTimeout(0);
        if (isManagedCloudBackend(cBackend, candidateModel)) {
          cUp.setTimeout(CLOUD_STREAM_INACTIVITY_TIMEOUT_MS, () => cUp.destroy(new Error('stream inactivity')));
        }
      }
      const cChunks = [];
      let firstChunk = true;
      upRes.on('data', c => {
        if (isOllamaCloud && firstChunk) {
          firstChunk = false;
          cUp.setTimeout(0);
          cUp.setTimeout(CLOUD_STREAM_INACTIVITY_TIMEOUT_MS, () => cUp.destroy(new Error('stream inactivity')));
        }
        cChunks.push(c);
      });
      upRes.on('end', () => {
        cUp.setTimeout(0);
        const cRaw = Buffer.concat(cChunks).toString();
        const cFailureClass = classifyError(upRes.statusCode, upRes.headers, cRaw);
        if (cFailureClass) {
          proxyLog('fallback.candidate_failed', { candidate: candidateModel, status_code: upRes.statusCode, failure_class: cFailureClass });
          setCooldown(candidateModel, cFailureClass, upRes.statusCode, upRes.headers);
          return tryFallbackChain(candidates, failureClass, currentIdx + 1);
        }
        proxyLog('fallback.candidate_success', { candidate: candidateModel, terminal_model: terminalModel, status_code: upRes.statusCode, elapsed_ms: nowMs() - cStart, capability: logicalRole, profile: logicalRole });
        recordFallbackEvent(terminalModel, candidateModel, 'chain_success');
        const respHeaders = { ...upRes.headers };
        if (ANNOTATE_MODEL) respHeaders['x-claude-proxy-served-by'] = candidateModel;
        respHeaders['x-claude-proxy-fallback-from'] = terminalModel;
        addResolvedViaHeader(respHeaders, { capability: logicalRole, logicalRole, effectiveModel: candidateModel });
        res.writeHead(upRes.statusCode, respHeaders);
        res.end(cRaw);
      });
    });
    if (isManagedCloudBackend(cBackend, candidateModel)) {
      cUp.setTimeout(CLOUD_CONNECT_TIMEOUT_MS, () => {
        proxyLog('fallback.candidate_ttfb_timeout', { candidate: candidateModel });
        cUp.destroy(new Error(`connect timeout after ${CLOUD_CONNECT_TIMEOUT_MS}ms`));
      });
    }
    cUp.on('error', e => {
      proxyLog('fallback.candidate_error', { candidate: candidateModel, error: e.message });
      setCooldown(candidateModel, 'network_failure', 502, {});
      return tryFallbackChain(candidates, failureClass, currentIdx + 1);
    });
    // For Ollama candidates, fire-and-forget a warm-up so a cold local model
    // loads into memory in parallel with the first request. Debounced per-model.
    if (cBackend.kind === 'ollama') warmOllamaModel(candidateModel, cBackend.id, cBackend.url);
    cUp.write(cBodyStr);
    cUp.end();
  };

  const healthEntry = ensureBackendHealthEntry(backend, terminalModel);
  const recoveryProbeDue = shouldBypassCooldownForRecoveryProbe(backend, terminalModel);
  const cooldownActive = isCooledDown(terminalModel);
  debugLog('proxy.remap.evaluate', {
    terminal_model: terminalModel,
    backend_id: backend.id,
    backend_kind: backend.kind,
    health_state: healthEntry?.state || null,
    last_failure_class: healthEntry?.last_failure_class || null,
    next_probe_at_ms: healthEntry?.next_probe_at_ms || 0,
    cooldown_active: cooldownActive,
    cooldown_failure_class: cooldowns.get(terminalModel)?.failureClass || null,
    recovery_probe_due: recoveryProbeDue,
  });

  if (shouldPreferFallbackForHealth(backend, terminalModel)) {
    const fallbackModel = resolveFallbackModel(terminalModel, healthEntry?.last_failure_class || 'network_failure', logicalRole);
    if (fallbackModel) {
      const fallbackResolved = resolveBackend(fallbackModel);
      if (!fallbackResolved.error) {
        debugLog('proxy.remap.selected', {
          terminal_model: terminalModel,
          reason: `health-${healthEntry.state}`,
          fallback_model: fallbackModel,
          fallback_backend_id: fallbackResolved.backend.id,
          fallback_effective_model: fallbackResolved.effectiveModel,
        });
        res.setHeader('x-claude-proxy-fallback-reason', `health-${healthEntry.state}`);
        return doForward(fallbackResolved.backend, fallbackResolved.effectiveModel, { ...body, model: fallbackModel });
      }
    }
  }

  if (cooldownActive && !recoveryProbeDue) {
    const fallbackModel = resolveFallbackModel(terminalModel, cooldowns.get(terminalModel)?.failureClass || 'rate_limit', logicalRole);
    if (fallbackModel) {
      const fallbackResolved = resolveBackend(fallbackModel);
      if (!fallbackResolved.error) {
        debugLog('proxy.remap.selected', {
          terminal_model: terminalModel,
          reason: 'cooldown',
          fallback_model: fallbackModel,
          fallback_backend_id: fallbackResolved.backend.id,
          fallback_effective_model: fallbackResolved.effectiveModel,
        });
        return doForward(fallbackResolved.backend, fallbackResolved.effectiveModel, { ...body, model: fallbackModel });
      }
    }
  }

  debugLog('proxy.remap.primary', {
    terminal_model: terminalModel,
    backend_id: backend.id,
    effective_model: effectiveModel,
    cooldown_active: cooldownActive,
    recovery_probe_due: recoveryProbeDue,
    health_state: healthEntry?.state || null,
  });

  // Try primary — intercept the response to check for classified errors
  const targetUrl = new URL(backend.url);
  const bodyStr = JSON.stringify(body);
  const fwdHeaders = {
    'content-type': 'application/json',
    'content-length': Buffer.byteLength(bodyStr),
    'accept': req.headers['accept'] || 'application/json',
  };
  if (backend.kind === 'ollama') {
    const authKey = backend.auth_env ? process.env[backend.auth_env] : (req.headers['x-api-key'] || '');
    if (authKey) fwdHeaders.authorization = `Bearer ${authKey}`;
  } else {
    const authKey = backend.auth_env ? process.env[backend.auth_env] : '';
    fwdHeaders['anthropic-version'] = req.headers['anthropic-version'] || '2023-06-01';
    if (req.headers['anthropic-beta']) fwdHeaders['anthropic-beta'] = req.headers['anthropic-beta'];
    if (authKey) fwdHeaders['x-api-key'] = authKey;
  }
  for (const [k, v] of Object.entries(req.headers)) {
    if (k.startsWith('x-custom-') || k.startsWith('x-upstream-')) fwdHeaders[k] = v;
  }

  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;
  const startedAt = nowMs();
  const timeoutState = { upstreamResponse: null, fatalTimeoutTriggered: false };

  const up = lib.request({
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: req.url,
    method: req.method,
    headers: fwdHeaders,
  }, (upRes) => {
    // For Ollama backends, headers arrive before data (Ollama accepts requests before cloud responds).
    // Keep the TTFB timer alive until the first data chunk. For anthropic-kind, headers = connected.
    const isOllamaCloud = backend.kind === 'ollama' && isManagedCloudBackend(backend, effectiveModel || clientModel);
    proxyLog('fallback.upstream_headers', {
      terminal_model: terminalModel,
      backend_id: backend.id,
      status_code: upRes.statusCode,
      is_ollama_cloud: isOllamaCloud,
      elapsed_ms: nowMs() - startedAt,
    });
    if (!isOllamaCloud) {
      up.setTimeout(0); // cancel TTFB — response headers are sufficient signal for anthropic-kind
      if (isManagedCloudBackend(backend, effectiveModel || clientModel)) {
        up.setTimeout(CLOUD_STREAM_INACTIVITY_TIMEOUT_MS, () => {
          proxyLog('fallback.inactivity_timeout', { terminal_model: terminalModel, backend_id: backend.id, elapsed_ms: nowMs() - startedAt });
          up.destroy(new Error(`stream inactivity timeout after ${CLOUD_STREAM_INACTIVITY_TIMEOUT_MS}ms`));
        });
      }
    }
    timeoutState.upstreamResponse = upRes;
    const errChunks = [];
    let ollamaCloudFirstChunk = true;
    upRes.on('data', c => {
      if (isOllamaCloud && ollamaCloudFirstChunk) {
        ollamaCloudFirstChunk = false;
        proxyLog('fallback.first_chunk', { terminal_model: terminalModel, backend_id: backend.id, elapsed_ms: nowMs() - startedAt });
        up.setTimeout(0); // first real data arrived — cancel TTFB timer
        up.setTimeout(CLOUD_STREAM_INACTIVITY_TIMEOUT_MS, () => {
          proxyLog('fallback.inactivity_timeout', { terminal_model: terminalModel, backend_id: backend.id, elapsed_ms: nowMs() - startedAt });
          up.destroy(new Error(`stream inactivity timeout after ${CLOUD_STREAM_INACTIVITY_TIMEOUT_MS}ms`));
        });
      }
      errChunks.push(c);
    });
    upRes.on('end', () => {
      up.setTimeout(0); // cancel inactivity timer — response complete
      const raw = Buffer.concat(errChunks).toString();
      const failureClass = classifyError(upRes.statusCode, upRes.headers, raw);
      if (failureClass) {
        noteBackendFailure(backend, terminalModel, failureClass, nowMs() - startedAt, `status_${upRes.statusCode}`);
        recordFailureClass(failureClass);
        setCooldown(terminalModel, failureClass, upRes.statusCode, upRes.headers);
        const candidates = (CONFIG.fallback_strategies?.[terminalModel]?.event?.[failureClass]) || [];
        if (candidates.length > 0) {
          proxyLog('fallback.chain_start', { terminal_model: terminalModel, failure_class: failureClass, trigger: 'classified_error', candidate_count: candidates.length });
          return tryFallbackChain(candidates, failureClass, 0);
        }
      } else if (upRes.statusCode < 400) {
        noteBackendSuccess(backend, terminalModel, nowMs() - startedAt);
      }
      let usage = { input_tokens: 0, output_tokens: 0, stop_reason: null };
      try { usage = usageFromJsonPayload(JSON.parse(raw)); } catch { /* ignore */ }
      finalizeTrackedUsage({
        endpoint,
        clientModel,
        effectiveModel,
        backend,
        stream: false,
        startedAtMs: startedAt,
      }, {
        status_code: upRes.statusCode,
        input_tokens: usage.input_tokens,
        output_tokens: usage.output_tokens,
        stop_reason: usage.stop_reason,
      });
      const respHeaders = { ...upRes.headers };
      if (ANNOTATE_MODEL && effectiveModel) respHeaders['x-claude-proxy-served-by'] = effectiveModel;
      addResolvedViaHeader(respHeaders, { capability: logicalRole, logicalRole, effectiveModel: effectiveModel || clientModel });
      res.writeHead(upRes.statusCode, respHeaders);
      res.end(raw);
    });
  });
  attachFatalCallTimeout(up, res, targetUrl.origin, FATAL_CALL_TIMEOUT_MS, timeoutState);

  // TTFB timeout for cloud backends: fires if no response headers arrive within
  // CLOUD_CONNECT_TIMEOUT_MS. Cancelled on first response byte so slow-streaming
  // responses (extended thinking, long tool calls) are not affected.
  const isCloudManaged = isManagedCloudBackend(backend, effectiveModel || clientModel);
  proxyLog('fallback.request', {
    terminal_model: terminalModel,
    backend_id: backend.id,
    backend_kind: backend.kind,
    is_cloud_managed: isCloudManaged,
    ttfb_timeout_ms: isCloudManaged ? CLOUD_CONNECT_TIMEOUT_MS : null,
  });
  if (isCloudManaged) {
    up.setTimeout(CLOUD_CONNECT_TIMEOUT_MS, () => {
      proxyLog('fallback.ttfb_timeout', {
        terminal_model: terminalModel,
        backend_id: backend.id,
        elapsed_ms: nowMs() - startedAt,
        timeout_ms: CLOUD_CONNECT_TIMEOUT_MS,
      });
      up.destroy(new Error(`connect timeout after ${CLOUD_CONNECT_TIMEOUT_MS}ms`));
    });
  }

  up.on('error', e => {
    proxyLog('fallback.upstream_error', {
      terminal_model: terminalModel,
      backend_id: backend.id,
      error_code: e.code,
      error_msg: e.message,
      elapsed_ms: nowMs() - startedAt,
      is_fatal_timeout: isFatalCallTimeout(e),
    });
    if (isFatalCallTimeout(e)) {
      noteBackendFailure(backend, terminalModel, 'network_failure', nowMs() - startedAt, 'fatal_call_timeout');
      recordFailureClass('network_failure');
      finalizeTrackedUsage({
        endpoint,
        clientModel,
        effectiveModel,
        backend,
        stream: false,
        startedAtMs: startedAt,
      }, { status_code: 504, input_tokens: 0, output_tokens: 0, stop_reason: 'fatal_timeout' });
      if (!res.headersSent) send(res, 504, { error: formatFatalCallTimeout(targetUrl.origin, FATAL_CALL_TIMEOUT_MS) });
      else res.end();
      return;
    }
    const failureClass = 'network_failure';
    noteBackendFailure(backend, terminalModel, failureClass, nowMs() - startedAt, e.message || 'network_error');
    recordFailureClass(failureClass);
    setCooldown(terminalModel, failureClass, 502, {});
    const candidates = (CONFIG.fallback_strategies?.[terminalModel]?.event?.[failureClass]) || [];
    proxyLog('fallback.chain_start', {
      terminal_model: terminalModel,
      failure_class: failureClass,
      trigger: 'network_error',
      candidate_count: candidates.length,
      has_strategy: !!(CONFIG.fallback_strategies?.[terminalModel]),
    });
    if (candidates.length > 0) {
      return tryFallbackChain(candidates, failureClass, 0);
    }
    finalizeTrackedUsage({
      endpoint,
      clientModel,
      effectiveModel,
      backend,
      stream: false,
      startedAtMs: startedAt,
    }, { status_code: 502, input_tokens: 0, output_tokens: 0, stop_reason: 'network_error' });
    if (!res.headersSent) send(res, 502, { error: formatBackendError(backend.kind, targetUrl.origin, e) });
    else res.end();
  });

  up.write(bodyStr);
  up.end();
}

const server = http.createServer(async (req, res) => {
  refreshConfigIfChanged();
  proxyLog('request', { method: req.method, url: req.url });
  // ── /ping ──────────────────────────────────────────────────────────
  if (req.url === '/ping') {
    return send(res, 200, {
      ok: true,
      pid: process.pid,
      config_path: CONFIG_PATH,
      config_source: CONFIG_SOURCE,
    });
  }

  // ── /debug/stats ────────────────────────────────────────────────────
  if (req.url === '/debug/stats') {
    return send(res, 200, {
      ...stats,
      currentInFlight: stats.currentInFlight,
      backendHealth: stats.byBackendId,
      usagePersistence: {
        stats_file: USAGE_STATS_FILE,
        log_file: USAGE_LOG_FILE || null,
        aggregate: persistentUsage,
      },
      healthMeta: {
        version: healthMeta.version,
        event_seq: healthMeta.eventSeq,
        last_transition: healthMeta.lastTransition,
        recent_events: healthMeta.recentEvents,
      },
    });
  }

  // ── /v1/models ──────────────────────────────────────────────────────
  if (req.method === 'GET' && req.url.startsWith('/v1/models')) {
    // Merge upstream Anthropic models with model_routes and routes keys
    const modelRoutes = CONFIG.model_routes || {};
    const routes = CONFIG.routes || {};
    const backends = CONFIG.backends || {};

    // Find the anthropic backend to proxy the upstream models list
    const anthroEntry = Object.entries(backends).find(([, v]) => (v.kind || 'anthropic') === 'anthropic');

    const localModels = [
      ...Object.keys(modelRoutes).map(id => ({
        id: id,
        type: 'model',
        display_name: id,
        capabilities: { thinking: { supported: true, types: {} } },
      })),
      ...Object.keys(routes).map(id => ({
        id: id,
        type: 'model',
        display_name: id,
        capabilities: { thinking: { supported: true, types: {} } },
      })),
      ...Array.from(LLM_PROFILE_ALIASES).map(id => ({
        id,
        type: 'model',
        display_name: id,
        capabilities: { thinking: { supported: true, types: {} } },
      })),
    ];

    if (anthroEntry) {
      const [, anthroBackend] = anthroEntry;
      const authKey = anthroBackend.auth_env ? process.env[anthroBackend.auth_env] : '';
      const targetUrl = new URL(anthroBackend.url);
      const isHttps = targetUrl.protocol === 'https:';
      const lib = isHttps ? https : http;
      const upReq = lib.request({
        hostname: targetUrl.hostname,
        port: targetUrl.port || (isHttps ? 443 : 80),
        path: req.url,
        method: 'GET',
        headers: {
          ...(authKey ? { 'x-api-key': authKey } : {}),
          'anthropic-version': req.headers['anthropic-version'] || '2023-06-01',
        },
      }, (upRes) => {
        const chunks = [];
        upRes.on('data', c => chunks.push(c));
        upRes.on('end', () => {
          try {
            const upstream = JSON.parse(Buffer.concat(chunks).toString());
            const merged = [...(upstream.data || []), ...localModels];
            // Deduplicate by id
            const seen = new Set();
            const deduped = merged.filter(m => {
              if (seen.has(m.id)) return false;
              seen.add(m.id);
              return true;
            });
            return send(res, 200, { data: deduped, has_more: false, first_id: deduped[0]?.id, last_id: deduped[deduped.length - 1]?.id });
          } catch {
            return send(res, 200, { data: localModels, has_more: false });
          }
        });
      });
      upReq.on('error', () => {
        return send(res, 200, { data: localModels, has_more: false });
      });
      upReq.end();
      return;
    }

    return send(res, 200, { data: localModels, has_more: false });
  }

  // ── /v1/* passthrough ───────────────────────────────────────────────
  if (!req.url.startsWith('/v1/')) {
    return send(res, 404, { error: `unknown path: ${req.url}` });
  }

  // Non-POST /v1/* (e.g., GET /v1/me, GET /v1/models) — forward to Anthropic backend
  // GET /v1/models is handled above, so this is only other GET requests
  if (req.method !== 'POST') {
    const anthroEntry = Object.entries(CONFIG.backends || {}).find(([, v]) => (v.kind || 'anthropic') === 'anthropic');
    if (anthroEntry) {
      const [, anthroBackend] = anthroEntry;
      return forwardAnthropic(req, res, null, anthroBackend, null);
    }
    return send(res, 404, { error: 'no anthropic backend configured for non-POST requests' });
  }

  // Read request body for POST requests
  let body;
  try {
    const buf = await readBody(req);
    try {
      body = JSON.parse(buf.toString());
    } catch {
      return send(res, 400, { error: 'invalid json' });
    }
  } catch {
    return send(res, 400, { error: 'failed to read request body' });
  }

  // POST /v1/messages/count_tokens and other model-scoped endpoints.
  // Strip query string so /v1/messages?beta=true still takes the main path below.
  const pathOnly = req.url.split('?')[0];
  if (pathOnly !== '/v1/messages') {
    // Model-scoped JSON endpoints: route by model field
    const model = body.model;
    if (model) {
      const resolved = resolveBackend(model);
      if (resolved.error) {
        const code = resolved.status || 400;
        const payload = { error: resolved.error };
        if (resolved.extra) Object.assign(payload, resolved.extra);
        return send(res, code, payload);
      }
      const { backend, effectiveModel, logicalRole: countTokRole } = resolved;
      const fwdBody = { ...body, model: effectiveModel || model };
      const requestMeta = {
        endpoint: req.url,
        clientModel: model,
        effectiveModel: effectiveModel || model,
        backend,
        stream: Boolean(fwdBody.stream),
        startedAtMs: nowMs(),
        capability: countTokRole,
        logicalRole: countTokRole,
      };
      if (backend.kind === 'ollama') {
        if (!(await ensureOllamaReadyOrSend(res, effectiveModel || model, backend.url, countTokRole))) return;
        // For Ollama: forward to Ollama's /v1/messages/count_tokens equivalent
        return forwardOllamaPassthrough(req, res, fwdBody, backend, effectiveModel, requestMeta);
      }
      return forwardAnthropic(req, res, fwdBody, backend, effectiveModel, requestMeta);
    }
  }

  // POST /v1/messages — main path
  const model = body.model;
  if (!model) {
    return send(res, 400, { error: 'model is required' });
  }

  const resolved = resolveBackend(model);
  if (resolved.error) {
    const code = resolved.status || 400;
    const payload = { error: resolved.error };
    if (resolved.extra) Object.assign(payload, resolved.extra);
    return send(res, code, payload);
  }

  stats.currentInFlight++;
  const { backend, effectiveModel, logicalRole } = resolved;
  const clientModel = model;
  const fwdBody = { ...body, model: effectiveModel || model };
  const requestMeta = {
    endpoint: req.url,
    clientModel,
    effectiveModel: effectiveModel || model,
    backend,
    stream: Boolean(fwdBody.stream),
    startedAtMs: nowMs(),
    capability: logicalRole,
    logicalRole,
  };

  // Track status via response wrapper; use mutable refs so fallback paths update attribution.
  res._statsBackend = backend;
  res._statsEffectiveModel = effectiveModel || model;
  const originalWriteHead = res.writeHead.bind(res);
  res.writeHead = function(statusCode, ...args) {
    recordStats(req.url, res._statsBackend, clientModel, res._statsEffectiveModel, statusCode);
    stats.currentInFlight = Math.max(0, stats.currentInFlight - 1);
    return originalWriteHead(statusCode, ...args);
  };

  // Use fallback-aware forwarding for models with strategies
  const terminalModel = effectiveModel || model;
  const strategies = CONFIG.fallback_strategies || {};
  proxyLog('dispatch', { terminal_model: terminalModel, has_strategy: !!strategies[terminalModel], backend_kind: backend.kind });
  if (strategies[terminalModel]) {
    handleRequestWithFallback(req, res, fwdBody, resolved);
  } else {
    if (backend.kind === 'ollama' && !(await ensureOllamaReadyOrSend(res, effectiveModel || model, backend.url, logicalRole))) return;
    if (backend.kind === 'anthropic') return forwardAnthropic(req, res, fwdBody, backend, effectiveModel, requestMeta);
    if (backend.kind === 'ollama') return forwardOllama(req, res, fwdBody, backend, effectiveModel, requestMeta);
    return send(res, 500, { error: `unknown backend kind: ${backend.kind}` });
  }

});

server.on('error', (err) => {
  if (err.code === 'EADDRINUSE') {
    console.error(`claude-proxy: port ${err.port || INITIAL_PORT} in use — singleton already running`);
    process.exit(0);
  }
  throw err;
});

// ── Startup probes ────────────────────────────────────────────────────
// Pre-populate cooldowns before the first real request arrives.
// Probes every primary model in fallback_strategies, then conditionally
// probes fallback candidates when their primary is unreachable.

function probeUrlForBackend(backend) {
  if (!backend || !backend.url) return null;
  if (backend.kind === 'ollama') return `${backend.url.replace(/\/$/, '')}/api/tags`;
  if ((backend.kind || 'anthropic') === 'anthropic') {
    const base = backend.url.replace(/\/$/, '');
    // If URL already contains a versioned path (e.g. /api/v1), append /models directly.
    // Otherwise prepend the standard /v1 segment (e.g. https://api.anthropic.com → /v1/models).
    const suffix = /\/v\d+(\/|$)/.test(base) ? '/models' : '/v1/models';
    return `${base}${suffix}`;
  }
  return null;
}

function httpProbe(url, headers, timeoutMs) {
  return new Promise(resolve => {
    const isHttps = url.startsWith('https:');
    const lib = isHttps ? https : http;
    let settled = false;
    const settle = v => { if (!settled) { settled = true; resolve(v); } };
    try {
      const u = new URL(url);
      const req = lib.request({
        hostname: u.hostname,
        port: u.port || (isHttps ? 443 : 80),
        path: u.pathname + u.search,
        method: 'GET',
        headers,
      }, res => {
        const chunks = [];
        res.on('data', c => chunks.push(c));
        res.on('end', () => { clearTimeout(timer); settle({ ok: res.statusCode < 400, statusCode: res.statusCode, headers: res.headers, body: Buffer.concat(chunks).toString() }); });
        res.on('error', () => { clearTimeout(timer); settle({ ok: false, statusCode: 0, headers: {}, body: '' }); });
      });
      const timer = setTimeout(() => { clearTimeout(timer); req.destroy(); settle({ ok: false, statusCode: 0, headers: {}, body: '' }); }, timeoutMs);
      if (typeof timer.unref === 'function') timer.unref();
      req.on('error', () => { clearTimeout(timer); settle({ ok: false, statusCode: 0, headers: {}, body: '' }); });
      req.end();
    } catch {
      settle({ ok: false, statusCode: 0, headers: {}, body: '' });
    }
  });
}

async function probeModel(model, failureClassHint) {
  const resolved = resolveBackend(model);
  if (resolved.error) return;
  const { backend } = resolved;
  const probeUrl = probeUrlForBackend(backend);
  if (!probeUrl) return;

  const probeHeaders = {};
  if ((backend.kind || 'anthropic') === 'anthropic') {
    const apiKey = backend.auth_env ? process.env[backend.auth_env] : '';
    if (apiKey) probeHeaders['x-api-key'] = apiKey;
  } else if (backend.kind === 'ollama' && backend.auth_env) {
    const apiKey = process.env[backend.auth_env] || '';
    if (apiKey) probeHeaders['authorization'] = `Bearer ${apiKey}`;
  }

  const result = await httpProbe(probeUrl, probeHeaders, STARTUP_PROBE_TIMEOUT_MS);
  if (result.ok) {
    // Probe succeeded — if model was marked dead, bring it back alive.
    if (cooldowns.has(model)) {
      proxyLog('liveness.mark_alive', { model });
      clearCooldown(model);
    }
    return;
  }
  if (result.statusCode === 401) return; // key not configured — not a network problem

  const failureClass = classifyError(result.statusCode, result.headers, result.body) || failureClassHint || 'network_failure';
  debugLog('proxy.startup.probe.failure', { model, probe_url: probeUrl, status_code: result.statusCode, failure_class: failureClass });
  console.error(`claude-proxy: startup probe: '${model}' → ${failureClass} (status=${result.statusCode || 'no-response'})`);
  setCooldown(model, failureClass, result.statusCode, result.headers);
  return failureClass;
}

// Shared probe dispatcher — used by both the periodic liveness loop and the
// network-interface watcher. Debounced to 500ms to collapse rapid triggers
// (e.g., DHCP lease races during WiFi reconnect).
let lastDeadProbeMs = 0;
async function triggerDeadModelProbes(reason) {
  const deadModels = [...cooldowns.keys()];
  if (deadModels.length === 0) return;
  const now = Date.now();
  if (now - lastDeadProbeMs < 500) {
    proxyLog('liveness.probe_debounced', { reason, dead_count: deadModels.length });
    return;
  }
  lastDeadProbeMs = now;
  proxyLog('liveness.probe_triggered', { reason, dead_count: deadModels.length });
  for (const model of deadModels) {
    try { await probeModel(model, cooldowns.get(model)?.failureClass || 'network_failure'); } catch {}
  }
}

// Periodic liveness prober. Backstop for cases the interface watcher misses
// (e.g., backend-side failures with local network intact).
const LIVENESS_PROBE_INTERVAL_MS = numberFromEnv('CLAUDE_PROXY_LIVENESS_PROBE_INTERVAL_MS', 30000);
function startLivenessProbeLoop() {
  setInterval(() => {
    if (cooldowns.size === 0) return;
    proxyLog('liveness.probe_cycle', { dead_count: cooldowns.size });
    triggerDeadModelProbes('periodic').catch(() => {});
  }, LIVENESS_PROBE_INTERVAL_MS).unref();
}

// Network interface watcher. Polls os.networkInterfaces() every
// NETWORK_WATCH_INTERVAL_MS. On link-UP transition (interface count grew or
// digest changed with non-zero current count), triggers an immediate probe
// of all dead models — so WiFi reconnect recovers in a few seconds rather
// than waiting up to 30s for the periodic loop.
const NETWORK_WATCH_INTERVAL_MS = numberFromEnv('CLAUDE_PROXY_NETWORK_WATCH_INTERVAL_MS', 3000);
function computeNetworkDigest() {
  const ifaces = os.networkInterfaces();
  const lines = [];
  for (const [name, entries] of Object.entries(ifaces)) {
    if (!Array.isArray(entries)) continue;
    for (const e of entries) {
      if (!e || e.internal) continue;
      // Skip IPv6 link-local (fe80::*) — flaps during reconnect, not useful.
      if (e.family === 'IPv6' && typeof e.address === 'string' && e.address.toLowerCase().startsWith('fe80:')) continue;
      lines.push(`${name}|${e.family}|${e.address}`);
    }
  }
  return lines.sort().join('\n');
}
function startNetworkInterfaceWatcher() {
  let lastDigest = computeNetworkDigest();
  let lastCount = lastDigest ? lastDigest.split('\n').filter(Boolean).length : 0;
  proxyLog('network.watcher_init', { interface_count: lastCount, interval_ms: NETWORK_WATCH_INTERVAL_MS });
  setInterval(() => {
    const cur = computeNetworkDigest();
    if (cur === lastDigest) return;
    const curCount = cur ? cur.split('\n').filter(Boolean).length : 0;
    proxyLog('network.interface_change', { prev_count: lastCount, cur_count: curCount });
    const wasLinkUp = curCount > 0 && curCount >= lastCount;
    lastDigest = cur;
    lastCount = curCount;
    // Only probe on link-UP transitions. Link-DOWN is caught by next request failure.
    if (wasLinkUp) triggerDeadModelProbes('interface_change').catch(() => {});
  }, NETWORK_WATCH_INTERVAL_MS).unref();
}

async function runStartupProbes() {
  const strategies = CONFIG.fallback_strategies || {};
  const primaryModels = Object.keys(strategies);
  if (primaryModels.length === 0) return;

  debugLog('proxy.startup.probe.start', { models: primaryModels });

  await Promise.all(primaryModels.map(async model => {
    const failureClass = await probeModel(model, 'network_failure');
    if (!failureClass) return;

    const candidates = (strategies[model]?.event?.[failureClass] || []);
    await Promise.all(candidates.map(async fallback => {
      if (isCooledDown(fallback)) return;
      await probeModel(fallback, 'network_failure');
    }));
  }));

  debugLog('proxy.startup.probe.done', {});
}

server.listen(INITIAL_PORT, '127.0.0.1', () => {
  proxyApiPort = server.address().port;
  if (!EXPLICIT_PORT) process.stdout.write(`READY ${proxyApiPort}\n`);
  console.error(`claude-proxy listening on 127.0.0.1:${proxyApiPort} (pid=${process.pid})`);
  try { fs.writeFileSync(PID_FILE, String(process.pid)); } catch {}
  if (STARTUP_PROBE_ENABLED) setImmediate(() => runStartupProbes().catch(() => {}));
  startLivenessProbeLoop();
  startNetworkInterfaceWatcher();
  // Background GC sweep — detached so proxy shutdown is never blocked on completion.
  try {
    if (fs.existsSync(GC_TOOL_PATH)) {
      let logFd = null;
      try { logFd = fs.openSync(PROXY_LOG_FILE, 'a'); } catch {}
      const gcStdio = logFd !== null ? ['ignore', logFd, logFd] : ['ignore', 'ignore', 'ignore'];
      let gcChild;
      try {
        gcChild = spawn(GC_TOOL_PATH, ['sweep'], { detached: true, stdio: gcStdio });
      } finally {
        if (logFd !== null) try { fs.closeSync(logFd); } catch {}
      }
      gcChild.unref();
      setTimeout(() => { try { gcChild.kill('SIGTERM'); } catch {} }, 30_000).unref();
    }
  } catch {}
});

// ── Hooks listener (fixed port for HTTP hooks) ─────────────────────────
// ARCH: dual-listener — API port dynamic, hooks port fixed (CLAUDE_PROXY_HOOKS_PORT);
// hooks listener is singleton-guarded via EADDRINUSE exit-0

const hooksServer = require('http').createServer((req, res) => {
  if (req.method === 'GET' && req.url === '/ping') {
    res.writeHead(200, { 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ ok: true, role: 'hooks' }));
    return;
  }
  if (req.method === 'POST' && req.url === '/hooks/context') {
    const chunks = [];
    req.on('data', c => chunks.push(c));
    req.on('end', () => {
      (async () => {
        try {
          const issues = [];
          let body = {};
          try { body = JSON.parse(Buffer.concat(chunks).toString('utf8')); } catch {}
          const prompt = typeof body.prompt === 'string' ? body.prompt : null;
          const eventName = typeof body.hook_event_name === 'string' ? body.hook_event_name : null;

          // Check 1: backend health from live in-memory state
          for (const [id, s] of Object.entries(stats.byBackendId || {})) {
            if (s.state === 'degraded' || s.state === 'disconnected') {
              const alternatives = Object.keys(CONFIG.routes || {}).filter(r => r !== id);
              const alt = alternatives[0] ? ` Alternative: --route ${alternatives[0]}` : '';
              issues.push(`⚠️ Backend ${id} ${s.state} (${s.ewma_latency_ms || 0}ms ewma, ${s.failure_count || 0} failures).${alt}`);
            }
          }

          // Check 1b: recent fallback event — give Claude context to explain if asked
          const recentFallback = fallbackEvents.find(e => Date.now() - e.at < 120_000);
          if (recentFallback) {
            issues.push(`(c-thru) Last turn was served by ${recentFallback.served_by} (primary ${recentFallback.primary} is currently unreachable).`);
          }

          // Check 2: classify_intent for low-confidence routing (UserPromptSubmit only — prompt required)
          if (prompt && proxyApiPort && CONFIG && CONFIG.llm_capabilities?.classify_intent) {
            try {
              const postToMessages = payload => postJsonLocal(proxyApiPort, '/v1/messages', payload);
              const result = await classifyIntent(prompt, CONFIG, postToMessages);
              if (result.confidence < 60 && result.recommended_tool) {
                // Log for offline pattern analysis (non-blocking, fire-and-forget).
                // A6: create with mode 0600 (owner r/w only) and let users opt out entirely
                // via CLAUDE_PROXY_LOG_PROMPTS=0. `appendFile` alone would leave perms at
                // the umask default (usually 0644), so we fs.open with an explicit mode.
                if (process.env.CLAUDE_PROXY_LOG_PROMPTS !== '0') {
                  const logLine = JSON.stringify({ ts: new Date().toISOString(), prompt: prompt.slice(0, 120), result }) + '\n';
                  const logPath = require('path').join(process.env.HOME || require('os').homedir(), '.claude', 'classify-intent-signals.log');
                  require('fs').open(logPath, 'a', 0o600, (openErr, fd) => {
                    if (openErr) return;
                    require('fs').appendFile(fd, logLine, () => {
                      // Pre-existing logs may have been created with umask perms
                      // before A6 landed; chmod is idempotent and cheap.
                      require('fs').chmod(logPath, 0o600, () => {});
                      require('fs').close(fd, () => {});
                    });
                  });
                }
                issues.push(`Note: lightweight model active — this task may benefit from --route default (confidence: ${result.confidence}%)`);
              }
            } catch (classifyErr) {
              console.error('claude-proxy: classify_intent error (skipped):', classifyErr.message);
            }
          }

          if (issues.length > 0) {
            res.writeHead(200, { 'Content-Type': 'application/json' });
            const hookOut = eventName
              ? { hookEventName: eventName, additionalContext: issues.join('\n') }
              : { additionalContext: issues.join('\n') };
            res.end(JSON.stringify({ hookSpecificOutput: hookOut }));
          } else {
            res.writeHead(200, { 'Content-Type': 'application/json' });
            res.end('{}');
          }
        } catch (err) {
          console.error('claude-proxy: /hooks/context error:', err.message);
          res.writeHead(200, { 'Content-Type': 'application/json' });
          res.end('{}');
        }
      })();
    });
    return;
  }
  res.writeHead(404);
  res.end();
});

let hooksListening = false;

hooksServer.on('error', (err) => {
  if (err.code === 'EADDRINUSE') {
    // Port busy — degrade gracefully. Core proxy continues; hooks features unavailable.
    console.error(`claude-proxy: hooks port ${HOOKS_PORT} in use — hooks listener disabled (core proxy unaffected)`);
    return;
  }
  console.error(`claude-proxy: hooks listener error: ${err.message}`);
});

hooksServer.listen(HOOKS_PORT, '127.0.0.1', () => {
  hooksListening = true;
  console.error(`claude-proxy: hooks listener bound on :${HOOKS_PORT}`);
});

function shutdown() {
  try { fs.unlinkSync(PID_FILE); } catch {}
  if (usagePersistTimer) {
    clearTimeout(usagePersistTimer);
    usagePersistTimer = null;
  }
  flushPersistentUsageNowSync();
  const closers = [new Promise(r => server.close(r))];
  if (hooksListening) closers.push(new Promise(r => hooksServer.close(r)));
  Promise.all(closers).then(() => process.exit(0)).catch(() => process.exit(0));
}

process.on('SIGTERM', shutdown);
process.on('SIGINT', shutdown);
process.on('SIGHUP', () => {
  // Re-sync layered config (overrides → effective) before reloading from disk so that
  // edits to model-map.overrides.json take effect without a proxy restart.
  maybeSyncLayeredProfileModelMap();
  if (reloadConfigFromDisk()) {
    console.error('claude-proxy: config reloaded via SIGHUP');
  }
});

// ── Model Resolution ─────────────────────────────────────────────────
const BACKEND_SIGIL_RE = /^(.*)@([a-zA-Z0-9_-]+)$/;

function profileAliasKey(alias) {
  return alias.toLowerCase().replace(/[^a-z0-9_-]/g, '_');
}

function resolveBackend(model, cfg, tier, mode) {
  const backends = cfg.backends || {};
  const modelRoutes = cfg.model_routes || {};
  
  let id = modelRoutes[model];
  if (id) {
    if (backends[id]) return { backend: { id, ...backends[id] }, effectiveModel: model, terminalLabel: model, routingKey: model };
    return { error: `backend '${id}' defined for model '${model}' not found in 'backends' config`, status: 400 };
  }

  for (const [pattern, backendId] of Object.entries(modelRoutes)) {
    if (!pattern.startsWith('re:')) continue;
    try {
      if (new RegExp(pattern.slice(3)).test(model)) {
        id = backendId;
        if (backends[id]) return { backend: { id, ...backends[id] }, effectiveModel: model, terminalLabel: model, routingKey: pattern };
        return { error: `backend '${id}' defined for pattern '${pattern}' not found in 'backends' config`, status: 400 };
      }
    } catch {}
  }

  const sigilMatch = model.match(BACKEND_SIGIL_RE);
  if (sigilMatch) {
    const [, baseModel, backendId] = sigilMatch;
    if (backends[backendId]) return { backend: { id: backendId, ...backends[backendId] }, effectiveModel: baseModel, terminalLabel: baseModel, routingKey: backendId };
  }

  const capAlias = resolveCapabilityAlias(model, cfg, tier);
  if (capAlias) {
    const profile = (cfg.llm_profiles || {})[tier];
    const entry = profile ? profile[capAlias] : null;
    if (entry) {
      const resolved = resolveProfileModel(entry, mode);
      if (resolved) {
        const nested = resolveBackend(resolved, cfg, tier, mode);
        if (nested.error) return nested; // Propagate the error
        return { ...nested, logicalRole: capAlias, capability: capAlias };
      }
    }
  }

  if (process.env.C_THRU_STRICT_MODELS === '1') {
    return { error: `'${model}' not in model_routes and C_THRU_STRICT_MODELS=1 is set`, status: 400 };
  }
  console.error(`c-thru: '${model}' not in model_routes — assuming local Ollama at ${DEFAULT_OLLAMA_URL}`);
  return {
    backend: { id: '__ollama_fallback__', kind: 'ollama', url: DEFAULT_OLLAMA_URL, _ollamaFallback: true },
    effectiveModel: model,
    terminalLabel: model,
    routingKey: 'ollama-fallback'
  };
}


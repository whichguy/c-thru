// CLI flag parsing — flags are aliases for env vars, set before any consumers
// read them. Documented in CLAUDE.md ("Proxy CLI Flags"). Supported forms:
//   --flag value      (space-separated)
//   --flag=value      (= form)
// Unknown flags are recorded for diagnostic logging once the logger is
// available; we don't fail-hard so a typo doesn't take the proxy down, but
// silent-ignore would let typos like `--prfile` no-op invisibly.
const FLAG_ENV_MAP = {
  '--config':      'CLAUDE_MODEL_MAP_PATH',
  '--profile':     'CLAUDE_LLM_PROFILE',
  '--mode':        'CLAUDE_LLM_MODE',
  '--port':        'CLAUDE_PROXY_PORT',
};
const UNRECOGNIZED_CLI_FLAGS = [];
// Permissive: unknown flags are buffered (logged once proxyLog is up at
// L1387) rather than rejected — hard-fail bricks the proxy on a future-flag
// from c-thru we don't know; silent-ignore hides typos. Buffer-and-log splits
// the difference.
function parseCliFlags(argv) {
  for (let i = 0; i < argv.length; i++) {
    const arg = argv[i];
    let flag = arg, value;
    // --flag=value form
    const eq = arg.indexOf('=');
    if (arg.startsWith('--') && eq !== -1) {
      flag = arg.slice(0, eq);
      value = arg.slice(eq + 1);
    }
    if (!Object.prototype.hasOwnProperty.call(FLAG_ENV_MAP, flag)) {
      if (arg.startsWith('--')) UNRECOGNIZED_CLI_FLAGS.push(arg);
      continue;
    }
    // --flag value form (consume next argv slot if it's not itself a flag)
    if (value === undefined) {
      const next = argv[i + 1];
      if (next === undefined || next.startsWith('--')) {
        UNRECOGNIZED_CLI_FLAGS.push(`${flag} (missing value)`);
        continue;
      }
      value = next;
      i++;
    }
    process.env[FLAG_ENV_MAP[flag]] = value;
  }
}
parseCliFlags(process.argv.slice(2));

// 0 = OS assigns a free port; the actual port is reported via "READY <port>" on stdout.
// Set CLAUDE_PROXY_PORT to a specific number only when you need a fixed port
// (e.g. c-thru reload, c-thru restart, or an explicit ANTHROPIC_BASE_URL).
const INITIAL_PORT = numberFromEnv('CLAUDE_PROXY_PORT', 0);
const DEBUG = numberFromEnv('CLAUDE_PROXY_DEBUG', numberFromEnv('CLAUDE_ROUTER_DEBUG', 0));
const DEFAULT_OLLAMA_URL = process.env.OLLAMA_BASE_URL || 'http://localhost:11434';

// Tunable timing constants — env-overridable for tests + power users.
// THREE-TIER UPSTREAM WATCHDOG (each catches a distinct failure mode;
// none subsumes the other — see L914 (TTFT), L1062 (stream stall), L1254 (upstream)):
//   1. TTFT (OLLAMA_TTFT_TIMEOUT_MS, ~11s)        — pre-headers: upstream wedged on connect/load
//   2. Stream stall (STREAM_STALL_HARDFAIL_MS, 5m) — mid-stream: socket alive but no bytes
//   3. Upstream (OLLAMA_UPSTREAM_TIMEOUT_MS, 5m)  — req.setTimeout: rearms on any socket activity
//   4. Wall clock (STREAM_WALL_MS, 35m)            — total stream duration cap regardless of activity
// OLLAMA_UPSTREAM_TIMEOUT_MS: hard cap from request issue to first byte.
//   Note: this is `req.setTimeout` semantics — rearms on socket activity.
//   For mid-stream stalls, see STREAM_STALL_HARDFAIL_MS.
// STREAM_STALL_HARDFAIL_MS: idle gap that destroys a streaming response.
//   Necessary because the upstream timeout can't catch slow trickles.
// STREAM_WALL_MS: absolute wall-clock cap on total stream duration.
//   Fires even if the model is still producing tokens. Prevents indefinite
//   hangs from models that generate very slowly but never stall long enough
//   to trigger STREAM_STALL_HARDFAIL_MS. Set to 0 to disable.
// SSE_PING_INTERVAL_MS: cadence for `event: ping` frames during streaming.
//   Keeps connections alive through nginx/CF/corp-middlebox idle killers.
// OLLAMA_KEEP_ALIVE: how long Ollama should keep the model resident in
//   VRAM after each request (forwarded as the `keep_alive` field).
const OLLAMA_UPSTREAM_TIMEOUT_MS = numberFromEnv('CLAUDE_PROXY_OLLAMA_TIMEOUT_MS', 300000);
const STREAM_STALL_HARDFAIL_MS = numberFromEnv('CLAUDE_PROXY_STREAM_STALL_MS', 300000);
const STREAM_WALL_MS = numberFromEnv('CLAUDE_PROXY_STREAM_WALL_MS', 2100000);
const SSE_PING_INTERVAL_MS = numberFromEnv('CLAUDE_PROXY_PING_INTERVAL_MS', 15000);
const OLLAMA_KEEP_ALIVE = process.env.CLAUDE_PROXY_OLLAMA_KEEP_ALIVE || '60m';
// Time-to-first-response timeout for Ollama. Distinct from
// OLLAMA_UPSTREAM_TIMEOUT_MS (which is `req.setTimeout` semantics —
// rearms on socket activity, including connect). This timer measures
// strictly from request issue until upstream returns HTTP response
// headers. If Ollama is hung/down/uninstalled, we fail fast and route
// to fallback within seconds instead of waiting the full upstream
// timeout. Once headers arrive, this timer is cleared and the existing
// stall watchdog (STREAM_STALL_HARDFAIL_MS) takes over for mid-stream
// idleness.
const OLLAMA_TTFT_TIMEOUT_MS = numberFromEnv('CLAUDE_PROXY_OLLAMA_TTFT_MS', 11000);
// Maximum fallback chain depth. Default 20 — long chains are legitimate
// when users compose redundancy across many providers (anthropic ->
// openrouter -> bedrock -> glm-cloud -> local-large -> local-small -> ...).
// Acts in concert with the per-backend cycle detection (visited Set) —
// the depth cap is a belt-and-suspenders safety net, the cycle Set is
// the primary loop-prevention mechanism.
const MAX_FALLBACK_HOPS = numberFromEnv('CLAUDE_PROXY_MAX_FALLBACK_HOPS', 20);

// :cloud-suffixed Ollama models (e.g. glm-5.1:cloud, deepseek-v4-flash:cloud)
// route through localhost:11434, which proxies to Ollama's hosted infra. Users
// without a subscription get 401/403/404 back. When this env var is set, the
// proxy transparently retries the same request against this local model name
// instead of surfacing the auth error. Set to empty/unset to disable. This is a
// runtime substitution — no model_routes entry is required. Tracked by
// requestMeta._cloudFallbackTried to prevent double-fire on a chained retry.
const OLLAMA_CLOUD_LOCAL_FALLBACK_MODEL = process.env.OLLAMA_CLOUD_LOCAL_FALLBACK_MODEL || 'qwen3.6:35b-a3b-coding-nvfp4';

// Backend-failure cooldown cache. When a backend fails AND has a
// `fallback_to`, we record it here with a TTL so subsequent requests
// transparently skip past it instead of paying the TTFT × 20 cost again.
// CRITICAL invariants:
//  1. Terminal nodes (no `fallback_to`) NEVER enter cooldown. Otherwise
//     a chain whose terminal cooldowns has nowhere left to route, which
//     is worse than no fallback at all.
//  2. The global default (`routes.default`) is a system-wide last-resort
//     and also never enters cooldown.
//  3. On a successful request through a backend, its cooldown entry is
//     cleared (it's healthy again).
//  4. Map size is bounded — capped at 100 entries with FIFO eviction
//     so a misbehaving config can't grow it unbounded.
const FAILED_BACKEND_TTL_MS = numberFromEnv('CLAUDE_PROXY_FAILED_BACKEND_TTL_MS', 60000);
const FAILED_BACKEND_CACHE_MAX = 100;
const failedBackendUntil = new Map();  // backend.id -> timestamp_ms_to_skip_until
function isInCooldown(backendId) {
  if (!failedBackendUntil.has(backendId)) return false;
  const until = failedBackendUntil.get(backendId);
  if (Date.now() >= until) {
    failedBackendUntil.delete(backendId);
    return false;
  }
  return true;
}
// Classify an upstream failure as 'transient' (worth retrying after a
// cooldown) or 'permanent' (the same retry will deterministically reproduce
// the failure until the user's config changes — cooldown is meaningless).
//
// 'permanent':
//   401, 403  — auth-class. The Authorization header isn't going to change
//               between requests of the same session; cooldowning the backend
//               just delays the same error on the next request.
//   404       — the model is genuinely unavailable on this backend (e.g. a
//               cloud :variant the user lacks a subscription for, or a model
//               not pulled locally). Like auth, retrying without operator
//               action will keep failing the same way. Debatable: a 404
//               could in principle mean "model briefly unloaded by Ollama"
//               (then a retry might work later), but in practice the
//               cloud->local rewrite path runs first for Ollama, and 404 from
//               a configured backend almost always means the route graph is
//               wrong, not transient. Classify permanent and let the operator
//               re-pull / fix routes; the cooldown adds nothing.
//
// 'transient' (default — conservative for unknown codes):
//   429, 500-599, ECONNREFUSED, ENOTFOUND, ETIMEDOUT, TTFT timeout —
//   genuinely worth waiting on. Backend may recover.
function classifyFailure(statusCode, errorMessage) {
  if (statusCode === 401 || statusCode === 403 || statusCode === 404) return 'permanent';
  if (statusCode === 429) return 'transient';
  if (typeof statusCode === 'number' && statusCode >= 500 && statusCode <= 599) return 'transient';
  if (typeof errorMessage === 'string') {
    if (/ECONNREFUSED|ENOTFOUND|ETIMEDOUT|EAI_AGAIN|ECONNRESET|EPIPE/.test(errorMessage)) return 'transient';
    if (/TTFT|upstream timeout/i.test(errorMessage)) return 'transient';
  }
  return 'transient';
}

function markBackendFailed(backendId, hasFallback, failureClass = 'transient') {
  // Don't cooldown terminals — they're the last resort within a chain.
  if (!hasFallback) return;
  // Permanent failures (401/403/404) reproduce on every retry until the
  // user fixes config; a cooldown just delays the inevitable while still
  // skipping the backend on the next request. Skip the marking entirely
  // so the backend remains in-chain and the same error surfaces directly,
  // giving the user a faster, clearer signal that something is wrong.
  if (failureClass === 'permanent') return;
  // FIFO cap: when full, evict the oldest entry so new failures still
  // get tracked. Realistic configs have <10 backends so 100 is way headroom.
  if (failedBackendUntil.size >= FAILED_BACKEND_CACHE_MAX) {
    const oldest = failedBackendUntil.keys().next().value;
    if (oldest !== undefined) failedBackendUntil.delete(oldest);
  }
  failedBackendUntil.set(backendId, Date.now() + FAILED_BACKEND_TTL_MS);
}
function clearBackendCooldown(backendId) {
  failedBackendUntil.delete(backendId);
}

let GLOBAL_CONFIG;
let CONFIG_PATH;
let CONFIG_SOURCE;
let CONFIG_MTIME_MS = 0;

Object.defineProperty(global, 'CONFIG', {
  get: () => configStorage.getStore() || GLOBAL_CONFIG,
  configurable: true,
});

function debugLog(event, fields = {}) {
  if (!DEBUG) return;
  console.error(`c-thru debug ${JSON.stringify({
    event,
    pid: process.pid,
    ts: nowIso(),
    ...fields,
  })}`);
}

function proxyLog(event, fields = {}) {
  const line = `${nowIso()} c-thru [${event}] ${JSON.stringify({
    pid: process.pid,
    ...fields,
  })}\n`;
  if (PROXY_LOG_FILE) {
    try {
      fs.appendFileSync(PROXY_LOG_FILE, line);
      checkRotateProxyLog();
    } catch {}
  } else {
    process.stderr.write(line);
  }
}

// Request-correlated logging — gives every event in one request's lifecycle a
// shared req_id and elapsed_ms, so concurrent traffic stays grep-friendly.
function newRequestContext() {
  return {
    id: crypto.randomBytes(2).toString('hex'),  // 4-hex-char id, e.g. "a3f9"
    started: Date.now(),
  };
}

function ctxLog(ctx, event, fields = {}) {
  proxyLog(event, {
    req_id: ctx.id,
    elapsed_ms: Date.now() - ctx.started,
    ...fields,
  });
}

function ctxDebug(ctx, event, fields = {}) {
  debugLog(event, {
    req_id: ctx.id,
    elapsed_ms: Date.now() - ctx.started,
    ...fields,
  });
}

function traceLog(ctx, direction, method, url, headers, body) {
  if (DEBUG < 2) return;
  const scrubbed = scrubHeaders(headers);
  ctxDebug(ctx, `trace.${direction}`, {
    method,
    url,
    headers: scrubbed,
    body_snippet: body ? (typeof body === 'string' ? body.slice(0, 1000) : body.toString('utf8').slice(0, 1000)) : null
  });
}

function nowIso() { return new Date().toISOString(); }
function nowMs() { return Date.now(); }

function numberFromEnv(key, def) {
  const v = process.env[key];
  if (!v) return def;
  const n = parseInt(v, 10);
  return isNaN(n) ? def : n;
}

// ── Persistence & Usage ──────────────────────────────────────────────
const PROXY_LOG_FILE = process.env.CLAUDE_PROXY_LOG_FILE || path.join(os.homedir(), '.claude', 'proxy.log');
const PROXY_LOG_MAX_SIZE = 10 * 1024 * 1024;
const USAGE_STATS_FILE = process.env.CLAUDE_PROXY_USAGE_STATS_FILE || path.join(os.homedir(), '.claude', 'usage-stats.json');
const PID_FILE = path.join(os.homedir(), '.claude', 'proxy.pid');

// Persistent token-usage stats. Loaded at boot, mutated in-process by
// recordUsage() (called from the dispatch-completion paths in forwardOllamaLegacy
// + forwardAnthropic), debounce-flushed to disk so the hot path doesn't pay
// fs.writeFileSync latency per request. Sync-flushed on shutdown signals so
// we don't lose the last debounce window.
function emptyUsage() {
  return { total_input: 0, total_output: 0, total_duration_ms: 0, by_model: {}, by_agent: {}, by_backend: {}, first_recorded: null, last_recorded: null };
}
let persistentUsage = emptyUsage();
function loadPersistentUsage() {
  try {
    if (fs.existsSync(USAGE_STATS_FILE)) {
      const loaded = JSON.parse(fs.readFileSync(USAGE_STATS_FILE, 'utf8'));
      // Merge defensively — a stats file from an older proxy version may be
      // missing newer fields. Preserve loaded counts, fill in missing keys.
      persistentUsage = Object.assign(persistentUsage, loaded);
      if (!persistentUsage.by_backend) persistentUsage.by_backend = {};
      if (!persistentUsage.by_agent) persistentUsage.by_agent = {};
    }
  } catch {}
}
loadPersistentUsage();

function recordUsage(model, backendId, input, output, durationMs, agentName) {
  if (!input && !output) return;  // skip noise from empty/error responses
  const dur = durationMs || 0;
  const now = nowIso();  // single call — reused for all maps so timestamps are identical
  persistentUsage.total_input += input;
  persistentUsage.total_output += output;
  persistentUsage.total_duration_ms += dur;
  if (!persistentUsage.first_recorded) persistentUsage.first_recorded = now;
  persistentUsage.last_recorded = now;
  // Per-model
  if (!persistentUsage.by_model[model])
    persistentUsage.by_model[model] = { input: 0, output: 0, calls: 0, total_duration_ms: 0, first_call: null, last_call: null };
  const bm = persistentUsage.by_model[model];
  bm.input += input;
  bm.output += output;
  bm.calls += 1;
  bm.total_duration_ms += dur;
  if (!bm.first_call) bm.first_call = now;
  bm.last_call = now;
  // Per-agent: only when the original request name differs from the concrete model
  // (guards against double-counting when a literal model name is sent directly)
  if (agentName && agentName !== model) {
    if (!persistentUsage.by_agent[agentName])
      persistentUsage.by_agent[agentName] = { input: 0, output: 0, calls: 0, total_duration_ms: 0, first_call: null, last_call: null, served_by: {} };
    const ba = persistentUsage.by_agent[agentName];
    ba.input += input;
    ba.output += output;
    ba.calls += 1;
    ba.total_duration_ms += dur;
    if (!ba.first_call) ba.first_call = now;
    ba.last_call = now;
    if (!ba.served_by) ba.served_by = {};
    ba.served_by[model] = (ba.served_by[model] || 0) + 1;
  }
  // Per-backend
  if (backendId) {
    if (!persistentUsage.by_backend[backendId]) persistentUsage.by_backend[backendId] = { input: 0, output: 0, calls: 0 };
    persistentUsage.by_backend[backendId].input += input;
    persistentUsage.by_backend[backendId].output += output;
    persistentUsage.by_backend[backendId].calls += 1;
  }
  scheduleUsageFlush();
}

// Debounced async flush. Coalesces multiple recordUsage() calls within a 5s
// window into a single fs.writeFile. The hot path returns immediately; the
// next flush picks up the latest in-memory state.
// CAUTION: in-memory deltas accumulated within the debounce window are lost
// on hard kill (SIGKILL / OOM). SIGTERM/SIGINT/beforeExit handlers (L1561+)
// call flushPersistentUsageNowSync to drain the window — see pairing there.
let usageFlushTimer = null;
const USAGE_FLUSH_DEBOUNCE_MS = 5000;
function scheduleUsageFlush() {
  if (usageFlushTimer) return;
  usageFlushTimer = setTimeout(() => {
    usageFlushTimer = null;
    fs.promises.mkdir(path.dirname(USAGE_STATS_FILE), { recursive: true })
      .then(() => fs.promises.writeFile(USAGE_STATS_FILE, JSON.stringify(persistentUsage, null, 2)))
      .catch(() => {});  // swallow — disk-full / readonly-fs shouldn't break the hot path
  }, USAGE_FLUSH_DEBOUNCE_MS);
}

// Sync flush for shutdown handlers. Called from SIGTERM/SIGINT to make sure
// the last debounce window's writes don't get lost when the process exits.
function flushPersistentUsageNowSync() {
  if (usageFlushTimer) { clearTimeout(usageFlushTimer); usageFlushTimer = null; }
  try {
    fs.mkdirSync(path.dirname(USAGE_STATS_FILE), { recursive: true });
    fs.writeFileSync(USAGE_STATS_FILE, JSON.stringify(persistentUsage, null, 2));
  } catch (e) { console.error('c-thru: failed to write usage stats:', e.message); }
}

function checkRotateProxyLog() {
  if (!PROXY_LOG_FILE) return;
  try {
    const stat = fs.statSync(PROXY_LOG_FILE);
    if (stat.size > PROXY_LOG_MAX_SIZE) {
      const old = PROXY_LOG_FILE + '.old';
      if (fs.existsSync(old)) fs.unlinkSync(old);
      fs.renameSync(PROXY_LOG_FILE, old);
    }
  } catch {}
}

// ── Journal ──────────────────────────────────────────────────────────
const JOURNAL_ENABLED = process.env.CLAUDE_PROXY_JOURNAL === '1';
const JOURNAL_DIR = process.env.CLAUDE_PROXY_JOURNAL_DIR || path.join(os.homedir(), '.claude', 'journal');
const JOURNAL_STREAM_EVENT_CAP = 1000;
const JOURNAL_INCLUDE = (process.env.CLAUDE_PROXY_JOURNAL_INCLUDE || '').split(',').filter(Boolean);
const JOURNAL_EXCLUDE = (process.env.CLAUDE_PROXY_JOURNAL_EXCLUDE || '').split(',').filter(Boolean);
const JOURNAL_MAX_BYTES = numberFromEnv('CLAUDE_PROXY_JOURNAL_MAX_BYTES', 100 * 1024 * 1024);
const SCRUB_HEADERS = new Set(['authorization', 'x-api-key', 'cookie', 'set-cookie']);

function scrubHeaders(headers) {
  if (!headers) return {};
  const out = {};
  for (const [k, v] of Object.entries(headers)) {
    const lk = k.toLowerCase();
    if (SCRUB_HEADERS.has(lk) || lk.startsWith('x-api-')) continue;
    out[k] = v;
  }
  return out;
}

function shouldJournal(capability) {
  if (!JOURNAL_ENABLED) return false;
  if (capability) {
    if (JOURNAL_INCLUDE.length > 0 && !JOURNAL_INCLUDE.includes(capability)) return false;
    if (JOURNAL_EXCLUDE.length > 0 && JOURNAL_EXCLUDE.includes(capability)) return false;
  }
  return true;
}

// Parse SSE event/data pairs from a buffered response body.
// Returns [{event, data}] — data is parsed JSON; unparseable lines are skipped.
function parseSseEvents(buf) {
  const events = [];
  const lines = buf.toString().split('\n');
  let curEvent = null;
  for (const line of lines) {
    const t = line.trim();
    if (t.startsWith('event:')) { curEvent = t.slice(6).trim(); }
    else if (t.startsWith('data:') && curEvent) {
      try { events.push({ event: curEvent, data: JSON.parse(t.slice(5).trim()) }); } catch {}
      curEvent = null;
    } else if (t === '') { curEvent = null; }
  }
  return events;
}

function writeJournalEntry(entry) {
  try {
    const date = entry.ts_iso.slice(0, 10);
    const dir = path.join(JOURNAL_DIR, date);
    fs.mkdirSync(dir, { recursive: true });
    const safeCap = String(entry.capability || 'unknown').replace(/[^A-Za-z0-9_.-]/g, '_');
    const file = path.join(dir, `${safeCap}.jsonl`);
    try {
      const stat = fs.statSync(file);
      if (stat.size >= JOURNAL_MAX_BYTES) {
        const backupPath = path.join(dir, `${safeCap}.1.jsonl`);
        try { fs.unlinkSync(backupPath); } catch (e2) { if (e2.code !== 'ENOENT') throw e2; }
        try {
          fs.renameSync(file, backupPath);
        } catch (renameErr) {
          // Rotation failed — preserve entry in oversized file rather than dropping it
          fs.appendFileSync(file, JSON.stringify(entry) + '\n');
          throw renameErr;
        }
      }
    } catch (e) {
      if (e.code !== 'ENOENT') throw e;
    }
    fs.appendFileSync(file, JSON.stringify(entry) + '\n');
  } catch (e) {
    proxyLog('journal.write_error', { error: e.message });
  }
}



// ── Model Resolution ─────────────────────────────────────────────────
const BACKEND_SIGIL_RE = /^(.*)@([a-zA-Z0-9_-]+)$/;

// Normalize a raw backend/endpoint entry to schema v2 shape.
// Converts legacy kind:"ollama"->format:"anthropic"+auth:"none",
// kind:"openai"->format:"openai". No-op when format is already set.
function normalizeBackend(id, raw) {
  const hasFormat = raw.format != null;
  const format = hasFormat ? raw.format :
    (raw.kind === 'openai' ? 'openai' : 'anthropic');
  const result = { ...raw, id, format };
  if (result.auth == null && raw.kind === 'ollama' && !hasFormat) {
    result.auth = 'none';
  }
  return result;
}

// Returns true if this backend uses the legacy /api/chat translation path
// (Ollama <0.4 or LM Studio shim).
function isOllamaLegacy(backend) {
  return backend.format === 'ollama-legacy' || backend.legacy_ollama_chat === true;
}

// Returns true if this backend is a local Ollama endpoint (either protocol).
function isLocalBackend(backend) {
  return backend.kind === 'ollama' ||
    isOllamaLegacy(backend) ||
    (backend.format === 'anthropic' && /localhost|127\.0\.0\.1/.test(backend.url || ''));
}

// Return the first model_extra_params entry whose pattern is a substring of model.
function getModelExtraParams(model) {
  const extras = CONFIG.model_extra_params;
  if (!extras) return null;
  for (const [pattern, params] of Object.entries(extras)) {
    if (model.includes(pattern)) return params;
  }
  return null;
}

// Shallow-clone body and inject capability sampling defaults + model extra params.
// Caller-supplied values always win (we only fill gaps). top_k and model extras
// are only injected for local backends — cloud Anthropic rejects unknown fields.
function injectSamplingDefaults(body, effectiveModel, capability, backend) {
  if (!body) return body;
  const capDefaults = (CONFIG.capability_sampling_defaults || {})[capability];
  const modelExtras = isLocalBackend(backend) ? getModelExtraParams(effectiveModel) : null;
  if (!capDefaults && !modelExtras) return body;

  const out = Object.assign({}, body);
  if (capDefaults) {
    if (out.temperature == null && capDefaults.temperature != null) out.temperature = capDefaults.temperature;
    if (out.top_p == null && capDefaults.top_p != null) out.top_p = capDefaults.top_p;
    if (isLocalBackend(backend) && out.top_k == null && capDefaults.top_k != null) out.top_k = capDefaults.top_k;
  }
  if (modelExtras) {
    for (const [k, v] of Object.entries(modelExtras)) {
      if (out[k] == null) out[k] = v;
    }
  }
  return out;
}

// Apply auth for an outbound request based on endpoint auth config.
//   auth:"none"       -> strip auth headers, inject nothing
//   auth_env present  -> inject Authorization: Bearer <env value>
//   auth object       -> use header/scheme/env fields
//   (no auth config)  -> passthrough: forward incoming auth verbatim
function applyOutboundAuth(backend, incomingHeaders, outgoingHeaders) {
  const auth = backend.auth;
  const incomingAuth = incomingHeaders['authorization'];
  const incomingKey = incomingHeaders['x-api-key'];

  // Priority 1: Incoming Bearer token from the client.
  // "only in the case we don't have incoming bearer, then use the key."
  // SECURITY: only forward incoming Bearer to Anthropic-shaped backends.
  // Forwarding an ambient ANTHROPIC_API_KEY to Gemini/Ollama would leak
  // the Anthropic key to a third-party provider.
  if (incomingAuth && incomingAuth.startsWith('Bearer ')) {
    const isGemini = backend.format === 'gemini' || backend.kind === 'gemini';
    const isOllama = backend.kind === 'ollama';
    if (!isGemini && !isOllama) {
      outgoingHeaders['authorization'] = incomingAuth;
      return;
    }
    // Gemini/Ollama: drop incoming Bearer (so the Anthropic key never leaks
    // to a third-party provider), then fall through to auth_env / auth object.
    delete outgoingHeaders['authorization'];
    delete outgoingHeaders['Authorization'];
  }

  // Priority 2: Configured auth via auth_env or auth object.
  if (backend.auth_env) {
    const value = process.env[backend.auth_env] || '';
    if (value) {
      if ((backend.format === 'gemini' || backend.kind === 'gemini') && !backend.vertex) {
        outgoingHeaders['x-goog-api-key'] = value;
      } else if (backend.kind === 'anthropic') {
        outgoingHeaders['x-api-key'] = value;
      } else {
        outgoingHeaders['authorization'] = `Bearer ${value}`;
      }
    }
  } else if (auth && typeof auth === 'object') {
    const header = (auth.header || ((backend.format === 'gemini' || backend.kind === 'gemini') && !backend.vertex ? 'x-goog-api-key' : 'Authorization')).toLowerCase();
    const schemeDefault = (header === 'authorization') ? 'Bearer' : '';
    const scheme = auth.scheme != null ? auth.scheme : schemeDefault;
    const value = auth.literal != null ? auth.literal : (auth.env ? process.env[auth.env] || '' : '');
    if (value) outgoingHeaders[header] = scheme ? `${scheme} ${value}` : value;
  } else {
    // Priority 3: Passthrough original headers if no explicit override exists.
    if (incomingAuth && !outgoingHeaders['authorization']) {
      outgoingHeaders['authorization'] = incomingAuth;
    }
    if (incomingKey && !outgoingHeaders['x-api-key']) {
      if ((backend.format === 'gemini' || backend.kind === 'gemini') && !backend.vertex) {
        outgoingHeaders['x-goog-api-key'] = incomingKey;
      } else if (backend.vertex) {
        outgoingHeaders['authorization'] = `Bearer ${incomingKey}`;
      } else {
        outgoingHeaders['x-api-key'] = incomingKey;
      }
    }
  }

  // Default: Ollama backends (kind:"ollama") often use 'Bearer ollama' as a dummy
  // token for their /v1/messages adapter. If no other Authorization header is set, inject it.
  if (backend.kind === 'ollama' && !outgoingHeaders['authorization']) {
    outgoingHeaders['authorization'] = 'Bearer ollama';
  }
}

function resolveBackend(model, cfg, tier, mode, _seen, _chain) {
  const endpointsOrBackends = cfg.endpoints || cfg.backends || {};
  const modelRoutes = cfg.model_routes || {};
  // Cycle/depth guard: model_routes can chain (target = another model name that
  // recurses through resolveRouteTarget -> resolveBackend). A misconfigured map
  // like {"a":"b","b":"a"} would otherwise stack-overflow. Track visited model
  // names and bail with a clean 400 if we revisit one or exceed depth 8.
  const seen = _seen || new Set();
  // Resolution-chain trace for x-c-thru-resolution-chain header. Mutated as a
  // shared reference across recursive calls so all hops accumulate in order.
  // First call seeds with the original requested model.
  const chain = _chain || [`req:${model}`];
  if (seen.has(model)) return { error: `model_routes resolution cycle detected at '${model}'`, status: 400 };
  if (seen.size >= 8) return { error: `model_routes resolution depth exceeded at '${model}' (chain too long)`, status: 400 };
  seen.add(model);

  // Resolve a route target. Targets can be:
  //   string  — either a backend id (terminal) or another model name (recurse).
  //   object  — mode-conditional: { connected: <target>, offline: <target>, ... }.
  //             Picks active mode, falls back to `connected`, then any value.
  //             Allows mixing backend ids and model names per mode (e.g. claude-* -> "anthropic"
  //             when connected, -> "qwen3.6@ollama_local" when offline).
  const resolveRouteTarget = (target, routingKey) => {
    if (target && typeof target === 'object' && !Array.isArray(target)) {
      target = target[mode] || target.connected || target.default || Object.values(target)[0];
      if (!target) return { error: `model_routes['${model}'] has no target for mode '${mode}' or 'connected' fallback`, status: 400 };
    }
    if (typeof target !== 'string' || !target) {
      return { error: `model_routes['${model}'] target must be a string or mode-keyed object`, status: 400 };
    }
    const raw = endpointsOrBackends[target];
    if (raw) {
      chain.push(`route(${routingKey}->${target})`);
      return { backend: normalizeBackend(target, raw), effectiveModel: model, terminalLabel: model, routingKey, chain };
    }
    // Not a backend id — treat as a model name and recurse (handles sigil syntax + further model_routes).
    chain.push(`route(${routingKey}->${target})`);
    return resolveBackend(target, cfg, tier, mode, seen, chain);
  };

  // Auto-synthesized picker aliases: claude-via-<X> resolves the same as <X>.
  // Mirror of the synthesis in /v1/models so the picker entries actually work
  // when selected. Only fires when no explicit claude-via-<X> route exists
  // (user-defined route wins via the modelRoutes[model] lookup below).
  if (modelRoutes[model] === undefined && model.startsWith('claude-via-')) {
    const underlying = model.slice('claude-via-'.length);
    if (modelRoutes[underlying] !== undefined) {
      chain.push(`alias(${model}->${underlying})`);
      const nested = resolveBackend(underlying, cfg, tier, mode, seen, chain);
      if (nested.error) return nested;
      return nested;
    }
  }

  let id = modelRoutes[model];
  if (id !== undefined) {
    // v2 alias object form: { endpoint: "...", name: "..." }
    if (id && typeof id === 'object' && typeof id.endpoint === 'string') {
      const raw = endpointsOrBackends[id.endpoint];
      if (!raw) return { error: `model_routes['${model}'].endpoint references unknown endpoint '${id.endpoint}'`, status: 400 };
      chain.push(`alias(${model}->${id.endpoint}/${id.name})`);
      return { backend: normalizeBackend(id.endpoint, raw), effectiveModel: id.name, terminalLabel: id.name, routingKey: model, chain };
    }
    return resolveRouteTarget(id, model);
  }

  for (const [pattern, target] of Object.entries(modelRoutes)) {
    if (!pattern.startsWith('re:')) continue;
    try {
      if (new RegExp(pattern.slice(3)).test(model)) return resolveRouteTarget(target, pattern);
    } catch (e) { console.error(`c-thru: invalid regex in model_routes key '${pattern}': ${e.message}`); }
  }

  const sigilMatch = model.match(BACKEND_SIGIL_RE);
  if (sigilMatch) {
    const [, baseModel, backendId] = sigilMatch;
    const raw = endpointsOrBackends[backendId];
    if (raw) {
      chain.push(`sigil(${baseModel}@${backendId})`);
      return { backend: normalizeBackend(backendId, raw), effectiveModel: baseModel, terminalLabel: baseModel, routingKey: backendId, chain };
    }
  }

  const capAlias = resolveCapabilityAlias(model, cfg, tier);
  if (capAlias) {
    if (capAlias.startsWith(MODEL_PIN_PREFIX)) {
      const pinnedModel = capAlias.slice(MODEL_PIN_PREFIX.length);
      if (!pinnedModel.trim()) {
        return { error: `agent_to_capability resolves to 'model:' with empty model name`, status: 400 };
      }
      chain.push(`pin(${model}->${pinnedModel})`);
      const nested = resolveBackend(pinnedModel, cfg, tier, mode, seen, chain);
      if (nested.error) return nested;
      return { ...nested, logicalRole: nested.logicalRole || model, capability: model, chain };
    }
    // New schema: llm_profiles[capability] (capability-outer, not tier-outer)
    const entry = (cfg.llm_profiles || {})[capAlias] || null;
    if (entry) {
      const resolved = resolveProfileModel(entry, tier, mode);
      if (resolved) {
        chain.push(`cap(${capAlias}->${mode}/${tier}->${resolved})`);
        const nested = resolveBackend(resolved, cfg, tier, mode, seen, chain);
        if (nested.error) return nested;
        return { ...nested, logicalRole: capAlias, capability: capAlias, chain };
      } else {
        return { error: `no model resolved for capability '${capAlias}' in mode '${mode}' at tier '${tier}'`, status: 503 };
      }
    }
  }

  if (process.env.C_THRU_STRICT_MODELS === '1') {
    return { error: `'${model}' not in model_routes and C_THRU_STRICT_MODELS=1 is set`, status: 400 };
  }
  console.error(`c-thru: '${model}' not in model_routes — assuming local Ollama at ${DEFAULT_OLLAMA_URL}`);
  chain.push(`fallback:ollama(${model})`);
  return {
    backend: { id: '__ollama_fallback__', format: 'anthropic', auth: 'none', url: DEFAULT_OLLAMA_URL, _ollamaFallback: true },
    effectiveModel: model,
    terminalLabel: model,
    routingKey: 'ollama-fallback',
    chain
  };
}

// BENCHMARK is reloadable on SIGHUP — see reloadConfigFromDisk.
// `let` (not `const`) so the daily-fetch script can refresh it via signal.
function loadBenchmark() {
  const bpath = path.join(__dirname, '..', 'docs', 'benchmark.json');
  try { return JSON.parse(fs.readFileSync(bpath, 'utf8')); } catch { return null; }
}
let BENCHMARK = loadBenchmark();

// ── Request handling ───────────────────────────────────────────────
function send(res, code, obj) {
  if (res.headersSent) return;
  const body = JSON.stringify(obj);
  if (code >= 400) {
    proxyLog('error_response', { statusCode: code, payload: obj });
  }
  res.writeHead(code, { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(body) });
  res.end(body);
}

// ── Anthropic-fidelity helpers ───────────────────────────────────────────
// Make our Ollama->Anthropic-translated responses indistinguishable from real
// api.anthropic.com responses. These are used by forwardOllamaLegacy only; the
// forwardAnthropic path passes upstream output through verbatim.

function anthropicMessageId() {
  // api.anthropic.com produces ids like "msg_01XXX..." — 24-char alphanumeric
  // after the prefix. We emit a hex-ish id of similar shape; clients dedupe by
  // exact match, so just-be-unique-per-response is the requirement.
  return 'msg_' + crypto.randomBytes(12).toString('hex');
}

// Map Ollama's `done_reason` to Anthropic's `stop_reason` enum.
// Anthropic values: end_turn | max_tokens | stop_sequence | tool_use | refusal
// Ollama values:   stop | length | load | unload (others bubble through)
function mapStopReason(ollamaDoneReason) {
  switch (ollamaDoneReason) {
    case 'length': return 'max_tokens';
    case 'stop':
    case undefined:
    case null:
      return 'end_turn';
    default: return 'end_turn';  // unknown — be safe, claim natural end
  }
}

// Map an HTTP status code to Anthropic's error-type taxonomy.
//
// Optional second arg: raw upstream error body (string). If parseable as JSON
// and shaped like a Google API error ({error: {status, code, ...}}), the gRPC
// status string is preferred over the HTTP code — Gemini frequently returns
// 400 for `RESOURCE_EXHAUSTED` (a true rate-limit), and Claude Code branches
// on the Anthropic error `type` to choose backoff behavior. Falls back to the
// status-code mapping when the body is missing/unparseable.
function anthropicErrorType(statusCode, errBody) {
  if (typeof errBody === 'string' && errBody.length > 0) {
    try {
      const parsed = JSON.parse(errBody);
      const grpcStatus = parsed && parsed.error && parsed.error.status;
      if (typeof grpcStatus === 'string') {
        switch (grpcStatus) {
          case 'RESOURCE_EXHAUSTED': return 'rate_limit_error';
          case 'PERMISSION_DENIED': return 'permission_error';
          case 'UNAUTHENTICATED':   return 'authentication_error';
          case 'INVALID_ARGUMENT':  return 'invalid_request_error';
          case 'NOT_FOUND':         return 'not_found_error';
          case 'UNAVAILABLE':
          case 'DEADLINE_EXCEEDED': return 'overloaded_error';
          case 'INTERNAL':
          case 'UNKNOWN':           return 'api_error';
        }
      }
    } catch {}
  }
  if (statusCode === 400) return 'invalid_request_error';
  if (statusCode === 401) return 'authentication_error';
  if (statusCode === 403) return 'permission_error';
  if (statusCode === 404) return 'not_found_error';
  if (statusCode === 413) return 'request_too_large';
  if (statusCode === 429) return 'rate_limit_error';
  if (statusCode === 504) return 'timeout_error';
  if (statusCode === 529) return 'overloaded_error';
  return 'api_error';
}

// Send an Anthropic-shaped error response on a non-streaming connection.
// Wraps `send()` so we get the same logging + headers-sent guard.
function sendAnthropicError(res, code, message) {
  send(res, code, {
    type: 'error',
    error: { type: anthropicErrorType(code), message },
  });
}

// Write a single SSE frame with event + data lines. Anthropic always emits
// both lines on every event; the original code relied on data-only deltas
// which is technically valid SSE but stricter clients reject it.
function sseWrite(res, event, data) {
  if (!res.writable) return;
  res.write(`event: ${event}\ndata: ${typeof data === 'string' ? data : JSON.stringify(data)}\n\n`);
}

function readBody(req) {
  return new Promise((resolve, reject) => {
    const chunks = [];
    req.on('data', c => chunks.push(c));
    req.on('error', reject);
    req.on('end', () => resolve(Buffer.concat(chunks)));
  });
}

function flattenMessagesForOllama(body) {
  const messages = Array.isArray(body.messages) ? [...body.messages] : [];
  if (body.system) {
    let systemContent = '';
    if (typeof body.system === 'string') systemContent = body.system;
    else if (Array.isArray(body.system)) systemContent = body.system.filter(c => c.type === 'text').map(c => c.text).join('\n');
    if (systemContent) messages.unshift({ role: 'system', content: systemContent });
  }
  return messages.map(msg => {
    let content = '';
    if (typeof msg.content === 'string') content = msg.content;
    else if (Array.isArray(msg.content)) content = msg.content.filter(c => c.type === 'text').map(c => c.text).join('\n');
    return { role: msg.role, content };
  });
}

// Scrub headers on the REQUEST side only (client -> upstream). The response side
// either writes its own headers (streaming SSE, non-streaming JSON) or pipes
// upstream headers verbatim with an unmodified body, so no scrub is needed there.
function scrubCthruHeaders(headers) {
  const out = { ...headers };
  delete out.host;
  // Drop content-length: the proxy rewrites the request body before forwarding —
  // model name swap, message flattening, keep_alive injection — so the original
  // length is wrong by some non-deterministic delta.
  delete out['content-length'];
  // Remove any x-c-thru specific headers if they exist
  for (const k of Object.keys(out)) {
    if (k.toLowerCase().startsWith('x-c-thru-')) delete out[k];
  }
  return out;
}

// Runtime upstream-fallback. When a primary backend (Anthropic/OpenRouter/etc.)
// returns a transient or auth/availability failure BEFORE we've started
// streaming bytes back to the client, swap to the configured fallback target
// and re-dispatch through the resolver.
//
// Triggers: connection error (ECONNREFUSED/ENOTFOUND/timeout), 401 (auth
// missing/expired), 403, 404 (model unavailable on this backend), 429 (rate
// limited), 5xx (upstream broken). NOT 400 (malformed request — we'd just
// loop). NOT mid-stream (headers already sent — can't undo).
//
// Schema: backends.<id>.fallback_to = "<model_name>" or "<model@backend>".
// The fallback target goes through resolveBackend() so all the existing
// routing logic (sigil parse, mode-conditional routes, capability aliases)
// applies. Cycle detection comes from resolveBackend's _seen Set.
// Special-case fallback for Ollama `:cloud`-suffixed models. When the user has
// no Ollama subscription, glm-5.1:cloud, deepseek-v4-flash:cloud, etc. fail
// with 401/403/404 from localhost:11434 (which proxies to Ollama's hosted
// infrastructure). Rather than surface the auth error or require per-model
// fallback_to wiring, we transparently retry the same request against a local
// model named by OLLAMA_CLOUD_LOCAL_FALLBACK_MODEL.
//
// Returns true if the cloud->local rewrite fired and the request was
// re-dispatched. Returns false if the case doesn't apply (not :cloud-suffixed,
// already retried, or env var unset/empty) — the caller should fall through to
// tryFallbackOrFail in that case.
//
// Edge cases handled:
//  - body.model already rewritten by previous fallback hop (suffix gone)
//  - requestMeta._cloudFallbackTried defensive flag against double-fire
//  - OLLAMA_CLOUD_LOCAL_FALLBACK_MODEL unset/empty -> skip entirely
function tryOllamaCloudLocalFallback(ctx, req, res, body, backend, requestMeta) {
  if (res.headersSent) return false;
  if (!OLLAMA_CLOUD_LOCAL_FALLBACK_MODEL) return false;
  if (requestMeta._cloudFallbackTried) return false;
  if (!body || typeof body.model !== 'string') return false;
  if (!body.model.endsWith(':cloud')) return false;

  const fromModel = body.model;
  requestMeta._cloudFallbackTried = true;
  ctxLog(ctx, 'ollama.cloud_to_local_fallback', {
    backend: backend.id,
    from_model: fromModel,
    to_model: OLLAMA_CLOUD_LOCAL_FALLBACK_MODEL,
  });
  body.model = OLLAMA_CLOUD_LOCAL_FALLBACK_MODEL;
  dispatchOllamaBackend(ctx, req, res, body, backend, OLLAMA_CLOUD_LOCAL_FALLBACK_MODEL, requestMeta);
  return true;
}

// Re-order a fallback_chains array so in-band candidates (quality_score within
// tolerancePct% of the untried top) are sorted by speed_score desc, then out-of-band.
// topScore is computed over untried candidates only to avoid threshold inflation from
// an already-tried high-quality entry.
function sortFallbackChainByTolerance(chain, tolerancePct, triedModels) {
  if (!tolerancePct || chain.length <= 1) return chain;
  const untried = chain.filter(c => {
    const m = typeof c === 'string' ? c : c?.model;
    return m && !triedModels.has(m);
  });
  const scored = untried.filter(c => typeof c?.quality_score === 'number');
  if (scored.length === 0) return chain;
  const topScore = Math.max(...scored.map(c => c.quality_score));
  const threshold = topScore * (1 - tolerancePct / 100);
  return [...chain].sort((a, b) => {
    const aQ = typeof a?.quality_score === 'number' ? a.quality_score : -Infinity;
    const bQ = typeof b?.quality_score === 'number' ? b.quality_score : -Infinity;
    const aIn = aQ >= threshold, bIn = bQ >= threshold;
    if (aIn && bIn) return (b?.speed_score || 0) - (a?.speed_score || 0);
    if (aIn) return -1;
    if (bIn) return 1;
    return 0;  // preserve original order for out-of-band
  });
}

// Try the profile's disconnect_model as a last-resort local terminal.
// Only fires if the model routes to an Ollama backend and hasn't been tried yet.
function tryLocalTerminalFallback(ctx, req, res, body, requestMeta) {
  if (res.headersSent) return false;
  const capKey = requestMeta.capability;
  if (!capKey) return false;
  // New schema: llm_profiles[capability], use resolveLocalFallback to find a local model.
  // Pass activeMode so gov sessions skip Chinese-origin local fallbacks.
  const termModel = resolveLocalFallback(CONFIG.llm_profiles?.[capKey], requestMeta.hwTier, requestMeta.activeMode);
  if (!termModel) return false;
  const triedM = requestMeta._triedModels || new Set();
  if (triedM.has(termModel)) return false;
  const termResolved = resolveBackend(termModel, CONFIG, requestMeta.hwTier, requestMeta.activeMode);
  if (termResolved.error || !isLocalBackend(termResolved.backend)) return false;
  requestMeta._localTerminalAppended = true;
  requestMeta._fallbackFrom = requestMeta._fallbackFrom || termResolved.backend.id;
  body.model = termResolved.effectiveModel;
  if (termResolved.chain) requestMeta.resolutionChain = termResolved.chain;
  ctxLog(ctx, 'fallback.local_terminal', { model: termModel, backend: termResolved.backend.id, capability: capKey });
  dispatchOllamaBackend(ctx, req, res, body, termResolved.backend, termResolved.effectiveModel, requestMeta);
  return true;
}

async function tryFallbackOrFail(ctx, req, res, body, backend, requestMeta, failure) {
  if (res.headersSent) return false;

  // hard_fail: profile entry has on_failure:'hard_fail' — skip cascade entirely.
  if (requestMeta.onFailure === 'hard_fail') {
    ctxLog(ctx, 'fallback.hard_fail_gate', { backend: backend.id, capability: requestMeta.capability });
    return false;
  }

  // Cycle / depth tracking across fallback hops. resolveBackend has its own
  // _seen Set for route-chain cycles within a single resolution; this Set
  // tracks across DISPATCH hops (separate invocations of dispatchOllamaBackend /
  // forwardAnthropic).
  const chain = requestMeta._fallbackChain || (requestMeta._fallbackChain = new Set());
  if (chain.has(backend.id)) {
    ctxLog(ctx, 'fallback.cycle_detected', { from_backend: backend.id, chain: [...chain] });
    if (tryLocalTerminalFallback(ctx, req, res, body, requestMeta)) return true;
    return tryGlobalDefaultFallback(ctx, req, res, body, requestMeta);
  }
  if (chain.size >= MAX_FALLBACK_HOPS) {
    ctxLog(ctx, 'fallback.depth_exceeded', { chain: [...chain], cap: MAX_FALLBACK_HOPS });
    if (tryLocalTerminalFallback(ctx, req, res, body, requestMeta)) return true;
    return tryGlobalDefaultFallback(ctx, req, res, body, requestMeta);
  }
  chain.add(backend.id);
  const triedModels = requestMeta._triedModels || (requestMeta._triedModels = new Set());
  triedModels.add(body.model);

  // Walk the per-backend chain, transparently skipping cooldowned
  // intermediate nodes. Terminal nodes (no fallback_to) always get tried,
  // even if recently failed.
  let cursor = backend;
  let hopsWalked = 0;
  while (cursor.fallback_to && hopsWalked < MAX_FALLBACK_HOPS) {
    const resolved = resolveBackend(cursor.fallback_to, CONFIG, requestMeta.hwTier, requestMeta.activeMode);
    if (resolved.error) {
      ctxLog(ctx, 'fallback.resolve_failed', { fallback: cursor.fallback_to, error: resolved.error });
      break;
    }
    // Cycle protection: don't loop back into anything in the chain.
    if (chain.has(resolved.backend.id)) {
      ctxLog(ctx, 'fallback.cycle_detected', { resolved_backend: resolved.backend.id, chain: [...chain] });
      break;
    }
    // Cooldown: if this candidate is in cooldown AND has its own fallback_to,
    // skip it transparently — descend into ITS fallback. Terminal nodes
    // (no fallback_to) get tried even when in cooldown.
    if (resolved.backend.fallback_to && isInCooldown(resolved.backend.id)) {
      ctxLog(ctx, 'fallback.skip_cooldown', {
        backend: resolved.backend.id,
        descend_to: resolved.backend.fallback_to,
      });
      chain.add(resolved.backend.id);
      cursor = resolved.backend;
      hopsWalked++;
      continue;
    }
    // INVARIANT: only cooldown-skipped intermediates get chain.add()'d in
    // this loop (L694 above). The dispatched target adds itself on re-entry
    // (L668, top-of-function). Adding here would falsely flag it as cycled
    // when its own failure handler runs, killing its legitimate fallback chain.
    // Bug history: this used to add unconditionally, which broke 2-deep chains.
    ctxLog(ctx, 'fallback.triggered', {
      from_backend: backend.id,
      to: resolved.backend.id,
      effective_model: resolved.effectiveModel,
      reason: failure.reason,
      upstream_status: failure.statusCode,
      upstream_error: failure.error,
      chain_depth: chain.size + 1,
      hops_skipped_cooldown: hopsWalked,
    });
    requestMeta._fallbackFrom = requestMeta._fallbackFrom || backend.id;
    body.model = resolved.effectiveModel;
    if (resolved.chain) requestMeta.resolutionChain = resolved.chain;
    if (isOllamaLegacy(resolved.backend)) {
      dispatchOllamaBackend(ctx, req, res, body, resolved.backend, resolved.effectiveModel, requestMeta);
    } else {
      forwardAnthropic(ctx, req, res, body, resolved.backend, resolved.effectiveModel, requestMeta);
    }
    return true;
  }

  // Per-backend chain exhausted. Try capability-level fallback_chains next.
  const capKey = requestMeta.capability;
  const capChain = capKey && CONFIG.fallback_chains?.[requestMeta.hwTier]?.[capKey];
  if (capChain) {
    const tolerancePct = CONFIG.quality_tolerance_pct;
    const applyTolerance = tolerancePct != null &&
      (requestMeta.activeMode === 'cloud-best-quality' || requestMeta.activeMode === 'local-best-quality');
    const sortedChain = applyTolerance
      ? sortFallbackChainByTolerance(capChain, tolerancePct, triedModels)
      : capChain;
    for (const candidate of sortedChain) {
      const m = typeof candidate === 'string' ? candidate : candidate.model;
      if (!m) continue;
      const candidateResolved = resolveBackend(m, CONFIG, requestMeta.hwTier, requestMeta.activeMode);
      if (candidateResolved.error) continue;
      if (triedModels.has(m)) continue;
      if (candidateResolved.backend.fallback_to && isInCooldown(candidateResolved.backend.id)) continue;
      // Do NOT add to chain here — the dispatched candidate adds itself on the next
      // tryFallbackOrFail entry (chain.add(backend.id) at top), matching the
      // invariant used by the per-backend fallback_to walk.
      ctxLog(ctx, 'fallback.chain_candidate', {
        model: m, backend: candidateResolved.backend.id,
        capability: capKey, reason: failure.reason,
      });
      requestMeta._fallbackFrom = requestMeta._fallbackFrom || backend.id;
      body.model = candidateResolved.effectiveModel;
      if (candidateResolved.chain) requestMeta.resolutionChain = candidateResolved.chain;
      if (isOllamaLegacy(candidateResolved.backend)) {
        dispatchOllamaBackend(ctx, req, res, body, candidateResolved.backend, candidateResolved.effectiveModel, requestMeta);
      } else {
        forwardAnthropic(ctx, req, res, body, candidateResolved.backend, candidateResolved.effectiveModel, requestMeta);
      }
      return true;
    }
  }

  // Local-terminal guard: if fallback_chains exhausted, try disconnect_model as Ollama terminal.
  if (tryLocalTerminalFallback(ctx, req, res, body, requestMeta)) return true;

  // All chains exhausted. Fall through to the global default.
  return tryGlobalDefaultFallback(ctx, req, res, body, requestMeta);
}

// Tier-3 last-resort: when every per-backend fallback chain has been
// exhausted (depth, cycle, all cooldown'd terminals failed), try
// routes.default. Distinct from the per-backend chain because it applies
// even when the request had no fallback_to declared anywhere — it's the
// system-wide safety net. Never enters cooldown itself.
function tryGlobalDefaultFallback(ctx, req, res, body, requestMeta) {
  if (res.headersSent) return false;
  const defaultModel = CONFIG.routes && CONFIG.routes.default;
  if (!defaultModel) return false;
  const chain = requestMeta._fallbackChain || (requestMeta._fallbackChain = new Set());
  const resolved = resolveBackend(defaultModel, CONFIG, requestMeta.hwTier, requestMeta.activeMode);
  if (resolved.error) {
    ctxLog(ctx, 'fallback.global_default_resolve_failed', { default_model: defaultModel, error: resolved.error });
    return false;
  }
  if (chain.has(resolved.backend.id)) {
    ctxLog(ctx, 'fallback.global_default_already_tried', { default_model: defaultModel, backend: resolved.backend.id });
    return false;
  }
  ctxLog(ctx, 'fallback.global_default', {
    default_model: defaultModel,
    resolved_backend: resolved.backend.id,
    effective_model: resolved.effectiveModel,
  });
  chain.add(resolved.backend.id);
  body.model = resolved.effectiveModel;
  if (resolved.chain) requestMeta.resolutionChain = resolved.chain;
  if (isOllamaLegacy(resolved.backend)) {
    dispatchOllamaBackend(ctx, req, res, body, resolved.backend, resolved.effectiveModel, requestMeta);
  } else {
    forwardAnthropic(ctx, req, res, body, resolved.backend, resolved.effectiveModel, requestMeta);
  }
  return true;
}

// Whether an upstream status code should trigger fallback (vs. forwarding to
// the client). 400 is excluded — that's our bug, not the upstream's, and
// retrying through a different backend would just loop the same malformed
// request.
function shouldFallbackOnStatus(code) {
  if (code === 400) return false;
  return code >= 401 && code < 600;
}

// =============================================================================
// OUTGOING WIRE FORMAT: Anthropic Messages API (/v1/messages)
// =============================================================================
// This forwarder handles ANY backend that speaks Anthropic's Messages API:
//   - kind: "anthropic"  — api.anthropic.com (auth: x-api-key from auth_env)
//   - kind: "openrouter" — openrouter.ai     (auth: x-api-key from auth_env)
//   - kind: "ollama"     — Ollama 0.4+ Anthropic adapter at /v1/messages
//                          (auth: Authorization: Bearer ollama, hardcoded)
//
// Body is forwarded VERBATIM — no flattening, no tool-block stripping, no
// re-serialization. The only mutation made by callers is body.model (rewritten
// to the resolved concrete model upstream of dispatch). Ollama and Anthropic
// both consume the same dialect at /v1/messages: tool_use / tool_result /
// thinking blocks all roundtrip natively.
//
// For older Ollama installs or LM Studio's Ollama-compat shim that lack
// /v1/messages, opt the backend into forwardOllamaLegacy() with
// `legacy_ollama_chat: true` in model-map.json — that path uses Ollama's
// native /api/chat with the (lossy) flattenMessagesForOllama translation.
// =============================================================================
async function forwardAnthropic(ctx, req, res, body, backend, effectiveModel, requestMeta) {
  const targetUrl = new URL(backend.url);
  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;

  const headers = scrubCthruHeaders(req.headers);
  applyOutboundAuth(backend, req.headers, headers);

  // Combine the backend's optional base path with the client's request path.
  // - Anthropic backend url=https://api.anthropic.com -> pathname='/' -> use req.url verbatim ("/v1/messages?beta=true")
  // - OpenRouter backend url=https://openrouter.ai/api/v1 -> pathname='/api/v1' -> prefix req.url ("/api/v1/v1/messages?beta=true")
  // Treating backend.url as origin+optional-prefix (rather than full endpoint) handles both cases.
  const basePrefix = (targetUrl.pathname === '/' ? '' : targetUrl.pathname.replace(/\/$/, ''));
  const forwardedPath = basePrefix + req.url;
  const options = {
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: forwardedPath,
    method: req.method,
    headers
  };
  ctxDebug(ctx, 'anthropic.request.path', { backend: backend.id, target: `${targetUrl.origin}${forwardedPath}` });

  const up = lib.request(options, upRes => {
    ctxLog(ctx, 'backend_response', { backend: backend.id, statusCode: upRes.statusCode });
    if (shouldFallbackOnStatus(upRes.statusCode) && !res.headersSent) {
      // Buffer the upstream error body for the log, then attempt fallback. If
      // fallback isn't configured or fails to resolve, we fall through to
      // piping the original error to the client.
      let errBody = '';
      upRes.on('data', c => errBody += c.toString());
      upRes.on('end', async () => {
        markBackendFailed(backend.id, !!backend.fallback_to, classifyFailure(upRes.statusCode, errBody));
        const handled = await tryFallbackOrFail(ctx, req, res, body, backend, requestMeta, {
          reason: `upstream returned ${upRes.statusCode}`,
          statusCode: upRes.statusCode,
          error: errBody.slice(0, 200),
        });
        if (!handled && !res.headersSent) {
          // Fallback didn't fire — surface the original error in Anthropic shape.
          sendAnthropicError(res, upRes.statusCode, `backend ${backend.id} returned ${upRes.statusCode}: ${errBody.slice(0, 200)}`);
        }
      });
      return;
    }
    const outHeaders = Object.assign({}, upRes.headers);
    if (requestMeta.capability) {
      outHeaders['x-c-thru-resolved-via'] = JSON.stringify({
        capability: requestMeta.capability,
        served_by: effectiveModel,
        tier: requestMeta.hwTier,
        mode: requestMeta.activeMode,
        latency_ms: Date.now() - (requestMeta.startedAt || Date.now()),
        local_terminal_appended: requestMeta._localTerminalAppended || false,
      });
    }
    outHeaders['x-c-thru-served-by'] = effectiveModel || '';
    outHeaders['x-claude-proxy-served-by'] = effectiveModel || '';
    if (Array.isArray(requestMeta.resolutionChain) && requestMeta.resolutionChain.length) {
      outHeaders['x-c-thru-resolution-chain'] = requestMeta.resolutionChain.join(' -> ');
    }
    if (requestMeta._fallbackFrom) outHeaders['x-c-thru-fallback-from'] = requestMeta._fallbackFrom;
    if (requestMeta._fallbackFrom) outHeaders['x-claude-proxy-fallback-from'] = requestMeta._fallbackFrom;
    res.writeHead(upRes.statusCode, outHeaders);
    // Tee the upstream bytes for usage extraction without affecting the
    // pipe to the client. Anthropic emits `usage.input_tokens` in the
    // message_start SSE frame (or the top-level `usage` for non-stream)
    // and `usage.output_tokens` in message_delta. Buffer caps at 256KB to
    // bound memory on long generations — past that we skip stats rather
    // than blow up. The pipe to res still gets every byte regardless.
    const usageBuf = [];
    let usageBytes = 0;
    const USAGE_BUF_CAP = 256 * 1024;
    upRes.on('data', chunk => {
      if (usageBytes < USAGE_BUF_CAP) {
        usageBuf.push(chunk);
        usageBytes += chunk.length;
      }
    });
    upRes.on('end', () => {
      if (upRes.statusCode !== 200) return;
      try {
        const txt = Buffer.concat(usageBuf).toString('utf8');
        const isSse = (upRes.headers['content-type'] || '').includes('text/event-stream');
        let inputTokens = 0, outputTokens = 0;
        if (isSse) {
          // Locate the message_start frame and pull data: line; parse as JSON.
          // Regex anchors `event:<name>\n` directly to `data:{...}` — Anthropic
          // always emits both lines paired (SSE allows data-only frames but
          // Anthropic doesn't use them). `{[^\n]+}` is a single-line capture:
          // Anthropic's per-frame JSON never contains a raw newline, so no
          // tokenizer needed.
          const startFrame = txt.match(/event:\s*message_start\s*\n\s*data:\s*({[^\n]+})/);
          if (startFrame) {
            try { inputTokens = JSON.parse(startFrame[1]).message?.usage?.input_tokens || 0; } catch {}
          }
          const deltaFrame = txt.match(/event:\s*message_delta\s*\n\s*data:\s*({[^\n]+})/);
          if (deltaFrame) {
            try { outputTokens = JSON.parse(deltaFrame[1]).usage?.output_tokens || 0; } catch {}
          }
        } else {
          const obj = JSON.parse(txt);
          inputTokens = obj.usage?.input_tokens || 0;
          outputTokens = obj.usage?.output_tokens || 0;
        }
        recordUsage(effectiveModel, backend.id, inputTokens, outputTokens,
          Date.now() - (requestMeta.startedAt || Date.now()),
          requestMeta.capability || null);
        clearBackendCooldown(backend.id);
        if (shouldJournal(requestMeta.capability)) {
          const rawBuf = Buffer.concat(usageBuf);
          let parsedResponse = null;
          let streamEvents = null, streamEventsTruncated = false;
          if (body.stream) {
            const all = parseSseEvents(rawBuf);
            streamEventsTruncated = all.length > JOURNAL_STREAM_EVENT_CAP;
            streamEvents = all.slice(0, JOURNAL_STREAM_EVENT_CAP);
          } else {
            try { parsedResponse = JSON.parse(rawBuf.toString()); } catch {}
          }
          writeJournalEntry({
            schema_version: 1,
            id: 'j_' + crypto.randomBytes(6).toString('hex'),
            ts_iso: new Date().toISOString(),
            capability: requestMeta.capability || null,
            mode: requestMeta.activeMode,
            served_by: effectiveModel,
            endpoint: req.url,
            latency_ms: Date.now() - (requestMeta.startedAt || Date.now()),
            stream: !!body.stream,
            ...(body.stream && { stream_events: streamEvents, stream_events_truncated: streamEventsTruncated }),
            request: Object.assign({}, body, {
              _headers: scrubHeaders(req.headers),
              model: requestMeta.originalModel,  // pre-rewrite capability alias
            }),
            response: parsedResponse,
          });
        }
      } catch { /* malformed body — skip stats */ }
    });
    upRes.pipe(res);
  });
  up.on('socket', socket => {
    socket.on('connect', () => ctxDebug(ctx, 'upstream.socket.connected', { backend: backend.id }));
    socket.on('close', hadError => ctxDebug(ctx, 'upstream.socket.closed', { backend: backend.id, had_error: hadError }));
  });
  up.on('error', async e => {
    ctxLog(ctx, 'backend_error', { backend: backend.id, kind: 'anthropic', error: e.message });
    // Connection-error path — no HTTP status to read. classifyFailure
    // inspects the error string for ECONNREFUSED/timeout markers; result
    // is 'transient' (we want to cooldown wedged backends so retries skip
    // them quickly).
    markBackendFailed(backend.id, !!backend.fallback_to, classifyFailure(null, e.message));
    const handled = await tryFallbackOrFail(ctx, req, res, body, backend, requestMeta, {
      reason: 'connection error',
      error: e.message,
    });
    if (!handled && !res.headersSent) {
      sendAnthropicError(res, 502, `backend anthropic at ${targetUrl.origin} error: ${e.message}`);
    }
  });
  const outBody = injectSamplingDefaults(body, effectiveModel, requestMeta.capability, backend);
  if (outBody) up.write(JSON.stringify(outBody));
  up.end();
}

// Build the JSON body for an Ollama /api/chat request.
// Pure: no side effects; called just before up.write() so body.rewrite logging
// can record bytes_in vs bytes_out in the same callsite as the send.
function buildOllamaRequestBody(body, effectiveModel) {
  const numCtx = body.num_ctx || (CONFIG.ollama_defaults && CONFIG.ollama_defaults.num_ctx) || 65536;
  // Use ?? not || for temperature: a caller-provided `0` is a valid request
  // (deterministic generation), and `||` would misinterpret it as "unset"
  // and replace with our default.
  const defaultTemp = (CONFIG.ollama_defaults && CONFIG.ollama_defaults.temperature != null)
    ? CONFIG.ollama_defaults.temperature : undefined;
  const ollamaOptions = { num_ctx: numCtx };
  if (body.temperature !== undefined && body.temperature !== null) {
    ollamaOptions.temperature = body.temperature;
  } else if (defaultTemp !== undefined) {
    ollamaOptions.temperature = defaultTemp;
  }
  return JSON.stringify({
    model: effectiveModel,
    messages: flattenMessagesForOllama(body),
    stream: !!body.stream,
    keep_alive: OLLAMA_KEEP_ALIVE,
    options: ollamaOptions,
  });
}

// Handle a non-200 response from Ollama. Re-shapes native Ollama errors into
// Anthropic's error envelope, then tries cloud->local rewrite and fallback chain
// before falling back to surfacing the original status to the client.
// ARCH: 400 is excluded from fallback (shouldFallbackOnStatus guard) so
//       caller-malformed requests don't loop through the fallback chain.
function handleOllamaError(ctx, req, res, body, backend, requestMeta, upRes) {
  let errBody = '';
  upRes.on('data', c => errBody += c.toString());
  upRes.on('end', async () => {
    let message = errBody;
    try {
      const parsed = JSON.parse(errBody);
      if (parsed.error) {
        message = typeof parsed.error === 'string' ? parsed.error : (parsed.error.message || JSON.stringify(parsed.error));
      }
    } catch {}
    if (shouldFallbackOnStatus(upRes.statusCode) && !res.headersSent) {
      // Cloud->local rewrite first: if the failing model is :cloud-suffixed
      // (e.g. user has no Ollama subscription), swap in the configured
      // local fallback model and retry against the same backend before
      // walking the per-backend fallback_to chain.
      if (tryOllamaCloudLocalFallback(ctx, req, res, body, backend, requestMeta)) {
        return;
      }
      markBackendFailed(backend.id, !!backend.fallback_to, classifyFailure(upRes.statusCode, message));
      const handled = await tryFallbackOrFail(ctx, req, res, body, backend, requestMeta, {
        reason: `upstream returned ${upRes.statusCode}`,
        statusCode: upRes.statusCode,
        error: message.slice(0, 200),
      });
      if (handled) return;
    }
    sendAnthropicError(res, upRes.statusCode, message || `upstream returned ${upRes.statusCode}`);
  });
}

// Set up the full Anthropic SSE pipeline for a streaming Ollama response.
// Called synchronously from the upRes callback so it runs before the stream
// starts flowing. Updates timerControls.stop so the outer up.on('error')
// handler can clear the stall/ping intervals on connection failures.
//
// ARCH: four concurrent timers created here:
//   stallCheck (1s)      — log at >=5s idle, hard-fail at STREAM_STALL_HARDFAIL_MS
//   pingTick             — keep intermediate proxies alive (SSE_PING_INTERVAL_MS cadence)
//   wallTimer (one-shot) — absolute cap on total stream duration (STREAM_WALL_MS, 0=off)
//   All are cleared on: res.close, upRes.end, upRes.error, any hard-fail,
//   and via timerControls.stop() for pre-stream errors in up.on('error').
function setupOllamaStream(ctx, req, res, backend, effectiveModel, requestMeta, up, requestStartedAt, timerControls, upRes, body) {
  const streamHeaders = {
    'Content-Type': 'text/event-stream; charset=utf-8',
    'Cache-Control': 'no-cache',
    'Connection': 'keep-alive',
    // Match real Anthropic — anti-buffering hint for nginx & Cloudflare.
    'X-Accel-Buffering': 'no',
  };
  if (requestMeta.capability) {
    streamHeaders['x-c-thru-resolved-via'] = JSON.stringify({
      capability: requestMeta.capability,
      served_by: effectiveModel,
      tier: requestMeta.hwTier,
      mode: requestMeta.activeMode,
      latency_ms: Date.now() - (requestMeta.startedAt || Date.now()),
      local_terminal_appended: requestMeta._localTerminalAppended || false,
    });
  }
  streamHeaders['x-c-thru-served-by'] = effectiveModel || '';
  streamHeaders['x-claude-proxy-served-by'] = effectiveModel || '';
  if (Array.isArray(requestMeta.resolutionChain) && requestMeta.resolutionChain.length) {
    streamHeaders['x-c-thru-resolution-chain'] = requestMeta.resolutionChain.join(' -> ');
  }
  if (requestMeta._fallbackFrom) streamHeaders['x-c-thru-fallback-from'] = requestMeta._fallbackFrom;
  if (requestMeta._fallbackFrom) streamHeaders['x-claude-proxy-fallback-from'] = requestMeta._fallbackFrom;
  res.writeHead(200, streamHeaders);

  const messageId = anthropicMessageId();

  // Emit Anthropic-shape message_start. Real Anthropic includes input_tokens
  // here, but Ollama doesn't tell us prompt_eval_count until the final chunk;
  // we update those numbers in message_delta at the end. cache_*_input_tokens
  // are always 0 (Ollama has no caching layer) but we include the fields so
  // SDKs that probe their existence don't warn.
  sseWrite(res, 'message_start', {
    type: 'message_start',
    message: {
      id: messageId,
      type: 'message',
      role: 'assistant',
      content: [],
      model: effectiveModel,
      stop_reason: null,
      stop_sequence: null,
      usage: {
        input_tokens: 0,
        cache_creation_input_tokens: 0,
        cache_read_input_tokens: 0,
        output_tokens: 0,
      },
    },
  });

  // Block state machine. Real Anthropic emits content_block_start when a
  // block begins, content_block_delta(s) for tokens, content_block_stop on
  // close. Thinking-mode models produce a thinking block first (index 0)
  // then a text block (index 1); pure-text models produce only a text block.
  // We don't open block 0 up-front anymore — we wait for the first
  // content/thinking token to know which type to start.
  let buffer = '';
  let firstChunk = true;
  let bytesOut = 0;
  let lastChunkAt = Date.now();
  let stalled = false;
  let promptTokens = 0;
  let outputTokens = 0;
  let stopReason = 'end_turn';
  let stopSequence = null;
  // INVARIANT: each openBlock is paired with one closeBlock (currentBlockType
  // null gates idempotency); messageClosed gates closeMessage idempotency —
  // `done:true` and upstream `end` race to close, error paths skip entirely
  // (SSE error frame is itself terminal).
  let blockIndex = -1;          // -1 = no block open yet
  let currentBlockType = null;  // 'thinking' | 'text' | null
  let messageClosed = false;    // tracks whether message_delta+message_stop were emitted
  const streamStart = Date.now();

  const openBlock = (type) => {
    blockIndex++;
    currentBlockType = type;
    const empty = type === 'thinking' ? { type: 'thinking', thinking: '' } : { type: 'text', text: '' };
    sseWrite(res, 'content_block_start', { type: 'content_block_start', index: blockIndex, content_block: empty });
  };
  const closeBlock = () => {
    if (currentBlockType === null) return;
    sseWrite(res, 'content_block_stop', { type: 'content_block_stop', index: blockIndex });
    currentBlockType = null;
  };

  // Emit terminal frames (message_delta + message_stop). Idempotent — guarded
  // by `messageClosed` so we never double-emit if both `done:true` arrives AND
  // upstream `end` fires after.
  const closeMessage = () => {
    if (messageClosed) return;
    closeBlock();
    sseWrite(res, 'message_delta', {
      type: 'message_delta',
      delta: { stop_reason: stopReason, stop_sequence: stopSequence },
      usage: {
        input_tokens: promptTokens,
        cache_creation_input_tokens: 0,
        cache_read_input_tokens: 0,
        output_tokens: outputTokens,
      },
    });
    sseWrite(res, 'message_stop', { type: 'message_stop' });
    messageClosed = true;
  };

  // Idle watchdog — log at >=5s, hard-fail at >=120s. The 5-min `up.setTimeout`
  // rearms on socket activity so it can't catch a slow trickle. This watchdog
  // does. Hard-fail destroys the upstream and emits an Anthropic-shape error
  // SSE frame so the client sees a structured failure instead of a silent hang.
  // Ping keepalive (15s): emits `event: ping` while streaming so long generations
  // survive idle-connection killers in intermediate proxies (nginx, CF, corp middleboxes).
  const stallCheck = setInterval(() => {
    if (!res.writable) { stopTimers(); return; }
    const idle = Date.now() - lastChunkAt;
    if (idle >= STREAM_STALL_HARDFAIL_MS) {
      stopTimers();
      ctxLog(ctx, 'ollama.stream.hard_stall', { idle_ms: idle, backend: backend.id });
      // We deliberately skip closeMessage() here. The Anthropic SSE error
      // event is itself a terminal frame — clients treat it as "stream is
      // over, no more events coming" and emitting message_delta+message_stop
      // after an error frame would be inconsistent with the failure semantics.
      sseWrite(res, 'error', {
        type: 'error',
        error: { type: 'timeout_error', message: `upstream stalled for ${idle}ms — aborting` },
      });
      if (!up.destroyed) up.destroy(new Error(`upstream mid-stream stall ${idle}ms`));
      if (res.writable) res.end();
      return;
    }
    if (idle >= 5000 && !stalled) {
      stalled = true;
      ctxLog(ctx, 'ollama.stream.stall', { idle_ms: idle, backend: backend.id });
    } else if (idle < 5000 && stalled) {
      stalled = false;
    }
  }, 1000);
  const pingTick = setInterval(() => {
    if (!res.writable) { stopTimers(); return; }
    sseWrite(res, 'ping', { type: 'ping' });
  }, SSE_PING_INTERVAL_MS);
  let wallTimer = null;
  if (STREAM_WALL_MS > 0) {
    wallTimer = setTimeout(() => {
      if (messageClosed) return;
      stopTimers();
      ctxLog(ctx, 'ollama.stream.wall_timeout', { elapsed_ms: STREAM_WALL_MS, backend: backend.id });
      sseWrite(res, 'error', {
        type: 'error',
        error: { type: 'timeout_error', message: `stream exceeded wall-clock limit of ${STREAM_WALL_MS}ms — aborting` },
      });
      if (!up.destroyed) up.destroy(new Error(`stream wall-clock timeout ${STREAM_WALL_MS}ms`));
      if (res.writable) res.end();
    }, STREAM_WALL_MS);
  }
  const stopTimers = () => {
    clearInterval(stallCheck);
    clearInterval(pingTick);
    if (wallTimer) { clearTimeout(wallTimer); wallTimer = null; }
  };
  timerControls.stop = stopTimers;  // expose to outer-scope error handlers via mutable ref

  // Client disconnected mid-stream: the request-level `res.on('close')` fires.
  // We need to clear our intervals (otherwise they retain `res`/`upRes` refs
  // and burn CPU writing to a dead socket) AND tear down the upstream so Ollama
  // stops generating tokens we'll never deliver.
  res.on('close', () => {
    if (messageClosed) return;  // normal completion path
    stopTimers();
    if (!up.destroyed) up.destroy(new Error('client disconnected mid-stream'));
  });

  // upRes is the IncomingMessage from Ollama — register data/end/error handlers
  // here (synchronously, before the stream starts flowing).
  upRes.on('data', chunk => {
    if (!res.writable) return;
    if (firstChunk) {
      firstChunk = false;
      ctxLog(ctx, 'ollama.stream.first_chunk', { ttft_ms: Date.now() - requestStartedAt, backend: backend.id });
    }
    bytesOut += chunk.length;
    lastChunkAt = Date.now();
    buffer += chunk.toString();
    let lines = buffer.split('\n');
    buffer = lines.pop();

    for (const line of lines) {
      if (!line.trim()) continue;
      try {
        const ollamaJson = JSON.parse(line);
        if (ollamaJson.done) {
          promptTokens = ollamaJson.prompt_eval_count || 0;
          outputTokens = ollamaJson.eval_count || 0;
          stopReason = mapStopReason(ollamaJson.done_reason);
          closeMessage();
          continue;
        }
        const msg = ollamaJson.message || {};
        const thinkingDelta = msg.thinking;
        const textDelta = msg.content;
        // Thinking tokens: open thinking block lazily, stream as thinking_delta.
        if (thinkingDelta) {
          if (currentBlockType !== 'thinking') {
            if (currentBlockType === 'text') closeBlock();  // shouldn't happen — text rarely precedes thinking
            openBlock('thinking');
          }
          sseWrite(res, 'content_block_delta', {
            type: 'content_block_delta',
            index: blockIndex,
            delta: { type: 'thinking_delta', thinking: thinkingDelta },
          });
        }
        // Text tokens: open text block lazily; if a thinking block is open,
        // close it first so we transition cleanly to a new block index.
        if (textDelta) {
          if (currentBlockType !== 'text') {
            if (currentBlockType === 'thinking') closeBlock();
            openBlock('text');
          }
          sseWrite(res, 'content_block_delta', {
            type: 'content_block_delta',
            index: blockIndex,
            delta: { type: 'text_delta', text: textDelta },
          });
        }
        // If both empty (pure heartbeat chunk), drop silently.
      } catch (e) {
        ctxLog(ctx, 'ollama.stream.parse_error', { line, error: e.message });
      }
    }
  });
  upRes.on('end', () => {
    stopTimers();
    // ALWAYS close the message — covers both normal completion (no-op via
    // messageClosed guard since `done:true` already called closeMessage) AND
    // half-open streams where upstream ended without sending `done` or sent
    // zero ndjson lines. Without this, clients see message_start with no
    // matching message_stop and hang.
    closeMessage();
    ctxLog(ctx, 'ollama.stream.done', {
      backend: backend.id,
      model: effectiveModel,
      duration_ms: Date.now() - streamStart,
      bytes_out: bytesOut,
      prompt_tokens: promptTokens,
      output_tokens: outputTokens,
      stop_reason: stopReason,
    });
    recordUsage(effectiveModel, backend.id, promptTokens, outputTokens,
      Date.now() - (requestMeta.startedAt || Date.now()),
      requestMeta.capability || null);
    clearBackendCooldown(backend.id);
    if (shouldJournal(requestMeta.capability)) {
      writeJournalEntry({
        schema_version: 1,
        id: 'j_' + crypto.randomBytes(6).toString('hex'),
        ts_iso: new Date().toISOString(),
        capability: requestMeta.capability || null,
        mode: requestMeta.activeMode,
        served_by: effectiveModel,
        endpoint: req.url,
        latency_ms: Date.now() - (requestMeta.startedAt || requestStartedAt || Date.now()),
        stream: true,
        stream_events: [],
        stream_events_truncated: false,
        request: Object.assign({}, body, {
          _headers: scrubHeaders(req.headers),
          model: requestMeta.originalModel,
        }),
        response: null,
      });
    }
    if (res.writable) res.end();
  });
  upRes.on('error', e => {
    stopTimers();
    ctxLog(ctx, 'ollama.stream.backend_error', { error: e.message, backend: backend.id });
    // Mid-stream upstream error — emit Anthropic-shape error event so
    // clients see a structured failure instead of an abrupt close.
    sseWrite(res, 'error', {
      type: 'error',
      error: { type: 'api_error', message: `upstream Ollama error: ${e.message}` },
    });
    if (res.writable) res.end();
  });
}

const PROBE_QUESTION = 'What is your model name, where were you born, model id and who is your maker?';

async function handleProbeLlm(req, res) {
  const tier = resolveActiveTier(CONFIG);
  const mode = resolveLlmMode(CONFIG);

  let modelParam = null;
  try { modelParam = new URL(req.url, 'http://x').searchParams.get('model') || null; } catch {}

  const modelName = modelParam || (CONFIG.routes && CONFIG.routes.default) || null;
  if (!modelName) {
    return send(res, 400, { ok: false, error: 'no model specified and no default route configured' });
  }

  const resolved = resolveBackend(modelName, CONFIG, tier, mode);
  if (resolved.error) {
    return send(res, 400, { ok: false, error: resolved.error });
  }

  const { backend, effectiveModel } = resolved;
  if (backend._ollamaFallback) {
    return send(res, 400, { ok: false, error: `'${modelName}' not found in model_routes; cannot probe an unknown model` });
  }
  if (!isLocalBackend(backend)) {
    return send(res, 400, { ok: false, error: `probe only supports local Ollama backends; '${backend.id}' is format '${backend.format || 'anthropic'}'` });
  }

  const ollamaBody = JSON.stringify({
    model: effectiveModel,
    messages: [{ role: 'user', content: PROBE_QUESTION }],
    stream: false,
    keep_alive: OLLAMA_KEEP_ALIVE,
    options: { num_ctx: 4096 },
  });

  const startedAt = Date.now();
  const url = backend.url.replace(/\/$/, '') + '/api/chat';

  return new Promise(resolve => {
    let done = false;
    const up = http.request(url, { method: 'POST', headers: { 'content-type': 'application/json' } }, upRes => {
      let body = '';
      upRes.on('data', c => { body += c.toString(); });
      upRes.on('end', () => {
        if (done) return; done = true;
        if (upRes.statusCode !== 200) {
          send(res, 502, { ok: false, error: `ollama returned ${upRes.statusCode}`, backend: backend.id });
          return resolve();
        }
        let parsed;
        try { parsed = JSON.parse(body); } catch {
          send(res, 502, { ok: false, error: 'ollama returned invalid JSON', backend: backend.id });
          return resolve();
        }
        send(res, 200, {
          ok: true,
          model_used: effectiveModel,
          backend: backend.id,
          response: (parsed.message && parsed.message.content) || '',
          elapsed_ms: Date.now() - startedAt,
        });
        resolve();
      });
    });
    up.setTimeout(15000, () => { up.destroy(new Error('probe timeout')); });
    up.on('error', e => {
      if (done) return; done = true;
      send(res, 502, { ok: false, error: `ollama unreachable: ${e.message}`, backend: backend.id });
      resolve();
    });
    up.write(ollamaBody);
    up.end();
  });
}

// Handle a non-streaming Ollama response. Buffers the full body, parses the
// Ollama JSON, and re-shapes it into an Anthropic Messages response object.
// Mirrors the content array structure of the streaming path (thinking first,
// then text) so callers get a consistent shape regardless of stream mode.
function handleOllamaNonStream(ctx, req, res, body, backend, effectiveModel, requestMeta, upRes) {
  let fullBody = '';
  let bytesOut = 0;
  const nonStreamStart = Date.now();
  upRes.on('data', chunk => { bytesOut += chunk.length; fullBody += chunk.toString(); });
  upRes.on('end', () => {
    try {
      const ollamaJson = JSON.parse(fullBody);
      const promptTokens = ollamaJson.prompt_eval_count || 0;
      const outputTokens = ollamaJson.eval_count || 0;
      const stopReason = mapStopReason(ollamaJson.done_reason);
      const msg = ollamaJson.message || {};
      // Build Anthropic-shape content array — thinking block (if present)
      // first, then text block. Mirrors what the streaming path emits.
      const content = [];
      if (msg.thinking) content.push({ type: 'thinking', thinking: msg.thinking });
      content.push({ type: 'text', text: msg.content || '' });
      const anthropicJson = {
        id: anthropicMessageId(),
        type: 'message',
        role: 'assistant',
        model: effectiveModel,
        content,
        stop_reason: stopReason,
        stop_sequence: null,
        usage: {
          input_tokens: promptTokens,
          cache_creation_input_tokens: 0,
          cache_read_input_tokens: 0,
          output_tokens: outputTokens,
        },
      };
      const respBody = JSON.stringify(anthropicJson);
      const nonStreamHeaders = {
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(respBody),
      };
      if (requestMeta.capability) {
        nonStreamHeaders['x-c-thru-resolved-via'] = JSON.stringify({
          capability: requestMeta.capability,
          served_by: effectiveModel,
          tier: requestMeta.hwTier,
          mode: requestMeta.activeMode,
          latency_ms: Date.now() - (requestMeta.startedAt || Date.now()),
          local_terminal_appended: requestMeta._localTerminalAppended || false,
        });
      }
      nonStreamHeaders['x-c-thru-served-by'] = effectiveModel || '';
      nonStreamHeaders['x-claude-proxy-served-by'] = effectiveModel || '';
      if (requestMeta._fallbackFrom) nonStreamHeaders['x-c-thru-fallback-from'] = requestMeta._fallbackFrom;
      if (requestMeta._fallbackFrom) nonStreamHeaders['x-claude-proxy-fallback-from'] = requestMeta._fallbackFrom;
      res.writeHead(200, nonStreamHeaders);
      res.end(respBody);
      ctxLog(ctx, 'ollama.nonstream.done', {
        backend: backend.id,
        model: effectiveModel,
        duration_ms: Date.now() - nonStreamStart,
        bytes_out: bytesOut,
        prompt_tokens: promptTokens,
        output_tokens: outputTokens,
        stop_reason: stopReason,
      });
      recordUsage(effectiveModel, backend.id, promptTokens, outputTokens,
        Date.now() - (requestMeta.startedAt || Date.now()),
        requestMeta.capability || null);
      clearBackendCooldown(backend.id);
      if (shouldJournal(requestMeta.capability)) {
        let parsedResponse = null;
        try { parsedResponse = JSON.parse(respBody); } catch {}
        writeJournalEntry({
          schema_version: 1,
          id: 'j_' + crypto.randomBytes(6).toString('hex'),
          ts_iso: new Date().toISOString(),
          capability: requestMeta.capability || null,
          mode: requestMeta.activeMode,
          served_by: effectiveModel,
          endpoint: req.url,
          latency_ms: Date.now() - (requestMeta.startedAt || nonStreamStart),
          stream: false,
          request: Object.assign({}, body, {
            _headers: scrubHeaders(req.headers),
            model: requestMeta.originalModel,
          }),
          response: parsedResponse,
        });
      }
    } catch (e) {
      sendAnthropicError(res, 502, `failed to parse Ollama response: ${e.message}`);
    }
  });
}

// Dispatch an Ollama-kind backend to the right forwarder based on the
// `legacy_ollama_chat` opt-in. The default is forwardAnthropic (verbatim
// pass-through to <backend.url>/v1/messages) which preserves tool_use /
// tool_result blocks. The legacy path is for Ollama < 0.4 or LM Studio.
// =============================================================================
// G9: FILES API (Anthropic /v1/files <-> Gemini Files API)
// =============================================================================
//
// Anthropic shape:  POST /v1/files (multipart, name="file") -> {id:"file_…", type:"file", mime_type, size_bytes, filename, created_at}
// Gemini shape:     POST /upload/v1beta/files?uploadType=media + raw bytes -> {file:{name:"files/…", mimeType, sizeBytes, uri, createTime}}
//
// id mapping: Anthropic "file_<x>" <-> Gemini "files/<x>" — symmetrical, no
// state required to round-trip. fileData uri is reconstructed at chat time.

// Pick the first Gemini-format endpoint from CONFIG. Files API is an aux path,
// not a chat dispatch — it doesn't go through resolveBackend / model routes.
function pickGeminiBackend(config) {
  const eps = config.endpoints || config.backends || {};
  for (const [id, ep] of Object.entries(eps)) {
    if (ep && ep.format === 'gemini') {
      return Object.assign({ id }, ep);
    }
  }
  return null;
}

// Best-effort multipart parser for Anthropic's /v1/files upload shape.
// Anthropic's SDK sends a single "file" field; we extract its bytes,
// content-type, and filename. Returns null if no file part found.
function parseMultipartFile(buf, boundary) {
  const haystack = buf.toString('binary');
  const sep = `--${boundary}`;
  const segments = haystack.split(sep);
  for (const seg of segments) {
    if (!/Content-Disposition/i.test(seg)) continue;
    if (!/name="file"/i.test(seg)) continue;
    const headerEnd = seg.indexOf('\r\n\r\n');
    if (headerEnd < 0) continue;
    const headers = seg.slice(0, headerEnd);
    let body = seg.slice(headerEnd + 4);
    // Trailing CRLF before next boundary
    if (body.endsWith('\r\n')) body = body.slice(0, -2);
    const ctMatch = headers.match(/Content-Type:\s*([^\r\n;]+)/i);
    const fnMatch = headers.match(/filename="([^"]+)"/);
    return {
      bytes: Buffer.from(body, 'binary'),
      contentType: ctMatch ? ctMatch[1].trim() : 'application/octet-stream',
      filename: fnMatch ? fnMatch[1] : 'upload',
    };
  }
  return null;
}

// Translate a Gemini Files API resource into Anthropic-shape file metadata.
function geminiFileToAnthropic(file) {
  if (!file || !file.name) return null;
  // Gemini name "files/abc-123" -> Anthropic id "file_abc-123"
  const shortName = String(file.name).replace(/^files\//, '');
  return {
    type: 'file',
    id: 'file_' + shortName,
    mime_type: file.mimeType || 'application/octet-stream',
    size_bytes: Number(file.sizeBytes || 0),
    filename: file.displayName || shortName,
    created_at: file.createTime || new Date().toISOString(),
  };
}

// id <-> Gemini name conversion. file_abc -> files/abc
function anthropicFileIdToGeminiName(id) {
  if (!id || !id.startsWith('file_')) return null;
  return 'files/' + id.slice('file_'.length);
}

// Inverse: given an Anthropic file_id (or Gemini name), build the canonical
// Gemini fileData.fileUri the chat path can reference.
function fileIdToGeminiUri(id, baseUrl) {
  const name = anthropicFileIdToGeminiName(id);
  if (!name) return null;
  const base = (baseUrl || 'https://generativelanguage.googleapis.com').replace(/\/$/, '');
  return `${base}/v1beta/${name}`;
}

function geminiBaseUrl(backend) {
  return (backend.url || 'https://generativelanguage.googleapis.com').replace(/\/$/, '');
}

// Forward a request to Gemini. Returns {statusCode, headers, body:Buffer}.
function geminiHttpRequest(backend, method, urlPath, body, extraHeaders) {
  return new Promise((resolve, reject) => {
    const targetUrl = new URL(geminiBaseUrl(backend) + urlPath);
    const isHttps = targetUrl.protocol === 'https:';
    const lib = isHttps ? https : http;
    const headers = Object.assign({}, extraHeaders || {});
    applyOutboundAuth(backend, {}, headers);
    const opts = {
      hostname: targetUrl.hostname,
      port: targetUrl.port || (isHttps ? 443 : 80),
      path: targetUrl.pathname + targetUrl.search,
      method,
      headers,
      timeout: 60000,
    };
    const req = lib.request(opts, (resp) => {
      const chunks = [];
      resp.on('data', d => chunks.push(d));
      resp.on('end', () => resolve({ statusCode: resp.statusCode, headers: resp.headers, body: Buffer.concat(chunks) }));
      resp.on('error', reject);
    });
    req.on('error', reject);
    if (body) req.write(body);
    req.end();
  });
}

async function handleFilesApi(req, res) {
  const backend = pickGeminiBackend(CONFIG);
  if (!backend) return sendAnthropicError(res, 503, 'no Gemini endpoint configured for /v1/files');
  if (backend.vertex) return sendAnthropicError(res, 501, 'Files API not implemented for Vertex endpoints (see roadmap)');

  // POST /v1/files — upload
  if (req.method === 'POST' && (req.url === '/v1/files' || req.url === '/v1/files/')) {
    const ct = req.headers['content-type'] || '';
    const boundaryMatch = ct.match(/boundary="?([^";]+)"?/);
    if (!boundaryMatch) return sendAnthropicError(res, 400, 'multipart/form-data boundary required');
    const buf = await readBody(req);
    const file = parseMultipartFile(buf, boundaryMatch[1]);
    if (!file) return sendAnthropicError(res, 400, 'no "file" field in multipart body');
    // Simple media upload: ?uploadType=media, raw bytes, Content-Type=mime.
    // Gemini fills in the resource name; we don't supply one.
    const upPath = '/upload/v1beta/files?uploadType=media';
    const result = await geminiHttpRequest(backend, 'POST', upPath, file.bytes, {
      'Content-Type': file.contentType,
      'X-Goog-Upload-Protocol': 'raw',
    }).catch(e => ({ statusCode: 502, headers: {}, body: Buffer.from(e.message) }));
    if (result.statusCode >= 400) {
      return sendAnthropicError(res, result.statusCode, `Gemini Files upload error: ${result.body.toString('utf8').slice(0, 500)}`);
    }
    let parsed = null;
    try { parsed = JSON.parse(result.body.toString('utf8')); } catch {}
    const anthropic = geminiFileToAnthropic(parsed?.file || parsed);
    if (!anthropic) return sendAnthropicError(res, 502, 'Gemini Files upload returned unrecognized payload');
    // Override filename from the upload (Gemini drops it on simple media uploads).
    anthropic.filename = file.filename;
    return send(res, 200, anthropic);
  }

  // GET /v1/files — list
  if (req.method === 'GET' && (req.url === '/v1/files' || req.url === '/v1/files/' || req.url.startsWith('/v1/files?'))) {
    const result = await geminiHttpRequest(backend, 'GET', '/v1beta/files', null).catch(e => ({ statusCode: 502, headers: {}, body: Buffer.from(e.message) }));
    if (result.statusCode >= 400) return sendAnthropicError(res, result.statusCode, `Gemini Files list error: ${result.body.toString('utf8').slice(0, 500)}`);
    let parsed = null;
    try { parsed = JSON.parse(result.body.toString('utf8')); } catch {}
    const data = (parsed?.files || []).map(geminiFileToAnthropic).filter(Boolean);
    return send(res, 200, { data, has_more: false, first_id: data[0]?.id || null, last_id: data[data.length - 1]?.id || null });
  }

  // GET /v1/files/{id} or DELETE /v1/files/{id}
  const idMatch = req.url.match(/^\/v1\/files\/(file_[A-Za-z0-9_-]+)\/?$/);
  if (idMatch) {
    const geminiName = anthropicFileIdToGeminiName(idMatch[1]);
    if (!geminiName) return sendAnthropicError(res, 400, `invalid file id: ${idMatch[1]}`);
    if (req.method === 'GET') {
      const result = await geminiHttpRequest(backend, 'GET', '/v1beta/' + geminiName, null).catch(e => ({ statusCode: 502, headers: {}, body: Buffer.from(e.message) }));
      if (result.statusCode >= 400) return sendAnthropicError(res, result.statusCode, `Gemini Files get error: ${result.body.toString('utf8').slice(0, 500)}`);
      let parsed = null;
      try { parsed = JSON.parse(result.body.toString('utf8')); } catch {}
      const anthropic = geminiFileToAnthropic(parsed);
      if (!anthropic) return sendAnthropicError(res, 502, 'Gemini Files get returned unrecognized payload');
      return send(res, 200, anthropic);
    }
    if (req.method === 'DELETE') {
      const result = await geminiHttpRequest(backend, 'DELETE', '/v1beta/' + geminiName, null).catch(e => ({ statusCode: 502, headers: {}, body: Buffer.from(e.message) }));
      if (result.statusCode >= 400) return sendAnthropicError(res, result.statusCode, `Gemini Files delete error: ${result.body.toString('utf8').slice(0, 500)}`);
      return send(res, 200, { id: idMatch[1], deleted: true });
    }
  }

  return sendAnthropicError(res, 404, `not found: ${req.method} ${req.url}`);
}

// Build the observability headers attached to every Gemini-path response.
// Centralises G7 (beta-dropped), G10 (request-id), G13 (schema-scrubbed) so
// streaming / non-streaming / count_tokens response paths all set the same
// telemetry. Caller adds streaming-specific headers afterwards.
// Built-in Gemini deprecation list. Maps deprecated model name → advice.
// Override / extend via top-level `deprecated_models` in config — user entries
// merge over these defaults. Sources: ai.google.dev model card pages and the
// Gemini API release notes (gemini-1.5-* family deprecated 2025-09; -001/-002
// dated tags retired 2024-Q4). Keep keys exact; substring matching would
// false-positive on -latest aliases that route to a newer concrete name.
const GEMINI_DEPRECATED_DEFAULTS = {
  'gemini-1.0-pro': 'use gemini-pro-latest (gemini-1.0-pro retired)',
  'gemini-1.0-pro-001': 'use gemini-pro-latest',
  'gemini-1.0-pro-002': 'use gemini-pro-latest',
  'gemini-1.0-pro-vision': 'use gemini-pro-latest (multimodal merged into Pro family)',
  'gemini-pro-vision': 'use gemini-pro-latest',
  'gemini-1.5-pro': 'use gemini-pro-latest (gemini-1.5-* deprecated 2025-09)',
  'gemini-1.5-pro-001': 'use gemini-pro-latest',
  'gemini-1.5-pro-002': 'use gemini-pro-latest',
  'gemini-1.5-flash': 'use gemini-flash-latest (gemini-1.5-* deprecated 2025-09)',
  'gemini-1.5-flash-001': 'use gemini-flash-latest',
  'gemini-1.5-flash-002': 'use gemini-flash-latest',
  'gemini-1.5-flash-8b': 'use gemini-flash-lite-latest',
  'gemini-2.0-flash-exp': 'use gemini-flash-latest (the -exp suffix is preview-only)',
  'gemini-pro': 'prefer gemini-pro-latest (unversioned alias may route to older variant)',
};
function getDeprecatedModelAdvice(modelName, cfg) {
  if (typeof modelName !== 'string' || !modelName) return null;
  const overrides = (cfg && typeof cfg.deprecated_models === 'object' && cfg.deprecated_models) || {};
  if (Object.prototype.hasOwnProperty.call(overrides, modelName)) {
    const v = overrides[modelName];
    return v === false || v == null ? null : String(v); // false = un-deprecate
  }
  return GEMINI_DEPRECATED_DEFAULTS[modelName] || null;
}
const DEPRECATION_LOGGED = new Set(); // dedupe per-process
function logDeprecationOnce(modelName, advice) {
  const key = `${modelName}|${advice}`;
  if (DEPRECATION_LOGGED.has(key)) return;
  DEPRECATION_LOGGED.add(key);
  console.error(`c-thru: deprecated model '${modelName}' — ${advice}`);
}

// Stamps the Gemini response with the x-c-thru-* observability + routing
// header family. See docs/headers.md for the full reference (which headers
// fire when, streaming vs non-streaming constraints, where to add new ones).
function buildCthruResponseHeaders(req, geminiBody, effectiveModel, requestMeta) {
  const h = {
    'x-c-thru-served-by': effectiveModel || '',
  };
  const advice = getDeprecatedModelAdvice(effectiveModel, GLOBAL_CONFIG);
  if (advice) {
    h['x-c-thru-deprecated-model'] = advice;
    logDeprecationOnce(effectiveModel, advice);
  }
  if (requestMeta && Array.isArray(requestMeta.resolutionChain) && requestMeta.resolutionChain.length) {
    h['x-c-thru-resolution-chain'] = requestMeta.resolutionChain.join(' -> ');
  }
  // G13: schema-scrubbed (set when mapAnthropicToGemini stripped any fields).
  if (geminiBody && geminiBody._schemaRemoved && geminiBody._schemaRemoved.length) {
    h['x-c-thru-schema-scrubbed'] = geminiBody._schemaRemoved.join(',');
  }
  // G4: context-caching status (hit | miss | none). Stamped by forwardGemini
  // after maybeApplyGeminiCache. Absent on Files-API and other non-cached paths.
  if (geminiBody && geminiBody._cacheStatus && geminiBody._cacheStatus !== 'none') {
    h['x-c-thru-cache-status'] = geminiBody._cacheStatus;
  }
  // Wave 4: per-user attribution. Anthropic's metadata.user_id has no Gemini
  // equivalent on :generateContent, so we surface it as a response header for
  // journals + downstream telemetry (purely additive — request to Gemini is
  // unchanged). Stamped by forwardGemini before this call.
  if (geminiBody && typeof geminiBody._userId === 'string' && geminiBody._userId) {
    h['x-c-thru-user-id'] = geminiBody._userId;
  }
  // Wave 4: redacted_thinking blocks are dropped (Gemini cannot decrypt
  // Anthropic-encrypted opaque blobs). Surface the omission so journals +
  // clients can detect that conversation history was lossy.
  if (geminiBody && geminiBody._redactedThinkingDropped) {
    h['x-c-thru-redacted-thinking-dropped'] = '1';
  }
  // Thinking observability: surface auto-enable, budget expansion, and the
  // upstream-reported thoughtsTokenCount so callers can see what was paid.
  if (geminiBody && geminiBody._thinkingAutoEnabled) {
    h['x-c-thru-thinking-auto-enabled'] = '1';
  }
  if (geminiBody && typeof geminiBody._thinkingLevel === 'string') {
    h['x-c-thru-thinking-level'] = geminiBody._thinkingLevel;
  }
  if (geminiBody && typeof geminiBody._thinkingBudgetAdded === 'number') {
    h['x-c-thru-thinking-budget-added'] = String(geminiBody._thinkingBudgetAdded);
  }
  if (geminiBody && typeof geminiBody._thinkingTokens === 'number') {
    h['x-c-thru-thinking-tokens'] = String(geminiBody._thinkingTokens);
  }
  // G7: anthropic-beta tokens are not honored on Gemini upstream — all
  // incoming tokens are effectively dropped. Surface so callers can detect
  // feature loss (prompt-caching, computer-use, etc.) instead of guessing.
  const beta = req.headers['anthropic-beta'];
  if (beta) {
    const tokens = String(beta).split(',').map(s => s.trim()).filter(Boolean);
    if (tokens.length) h['x-c-thru-beta-dropped'] = tokens.join(',');
  }
  // G10: request-id propagation. Anthropic guarantees one on every response
  // for client log correlation. Generate req_<hex16> if upstream didn't.
  const upstreamId = req.headers['request-id'] || req.headers['x-request-id'];
  h['request-id'] = (upstreamId && /^req_[a-f0-9]+$/i.test(upstreamId))
    ? upstreamId
    : 'req_' + crypto.randomBytes(8).toString('hex');
  return h;
}

// =============================================================================
// G4: GEMINI CONTEXT CACHING (lazy, fire-and-forget)
// =============================================================================
//
// Three rules: never add a round-trip on the critical path (turn 1 always
// pays full cost; turn 2+ benefits), fail silent (any cache failure ⇒ no
// caching this turn, never an error to the client), one in-memory state
// structure per proxy process. See `docs/gemini-gap-roadmap.md` G4 for the
// design rationale and the explicit list of skipped behaviors (persistent
// store, multi-breakpoint support, eviction sweep, accurate
// cache_creation_input_tokens, etc.).
//
// Hash key: sha256({model, system, messages-up-to-last-cache_control, tools}).
// Content-addressed; cross-conversation reuse requires byte-identical prefix.
const GEMINI_CACHE_MAP = new Map(); // hash -> { name, expiresAt, model }
// Aggregate counters for /ping observability. Incremented inline at each
// status transition. Single object so /ping returns a coherent snapshot.
const GEMINI_CACHE_STATS = {
  hit: 0, miss: 0, none: 0, empty_prefix: 0, created: 0, stale_retry: 0,
};

function _gcacheParseTtl(ttl) {
  if (!ttl) return '300s';
  if (typeof ttl === 'string') {
    if (/^\d+s$/.test(ttl)) return ttl;
    if (ttl === '5m') return '300s';
    if (ttl === '1h') return '3600s';
    const m = ttl.match(/^(\d+)m$/);
    if (m) return String(Number(m[1]) * 60) + 's';
    const h = ttl.match(/^(\d+)h$/);
    if (h) return String(Number(h[1]) * 3600) + 's';
  }
  return '300s';
}

// Scan body for the last cache_control breakpoint. Returns null if none.
// Otherwise returns { systemIncluded, prefixMessageCount, ttl } where the
// cacheable prefix is body.system (if systemIncluded) plus
// body.messages[0..prefixMessageCount-1].
function _gcacheExtractPrefix(body) {
  let lastTtl = null;
  let systemHasCache = false;
  if (Array.isArray(body.system)) {
    for (const s of body.system) {
      if (s && typeof s === 'object' && s.cache_control) {
        systemHasCache = true;
        if (s.cache_control.ttl) lastTtl = s.cache_control.ttl;
      }
    }
  }
  let lastMsgWithCache = -1;
  if (Array.isArray(body.messages)) {
    for (let i = 0; i < body.messages.length; i++) {
      const msg = body.messages[i];
      if (Array.isArray(msg.content)) {
        for (const block of msg.content) {
          if (block && typeof block === 'object' && block.cache_control) {
            lastMsgWithCache = i;
            if (block.cache_control.ttl) lastTtl = block.cache_control.ttl;
          }
        }
      }
    }
  }
  if (!systemHasCache && lastMsgWithCache < 0) return null;
  return {
    systemIncluded: systemHasCache || lastMsgWithCache >= 0, // system is always part of the prefix
    prefixMessageCount: lastMsgWithCache + 1,
    ttl: _gcacheParseTtl(lastTtl),
  };
}

function _gcacheHash(model, body, info) {
  const obj = {
    m: model,
    s: info.systemIncluded ? (body.system || null) : null,
    msgs: (body.messages || []).slice(0, info.prefixMessageCount),
    t: body.tools || null,
  };
  return crypto.createHash('sha256').update(JSON.stringify(obj)).digest('hex');
}

// Returns { status: 'hit'|'miss'|'none', hash?, pendingCreate? } and mutates
// geminiBody on hit (sets cachedContent, strips cached prefix). `ctx` may be
// undefined for callers that don't have one (status counters are still
// updated; only ctxLog calls are skipped).
function maybeApplyGeminiCache(body, geminiBody, model, ctx) {
  if (body._geminiCacheRetried) { GEMINI_CACHE_STATS.none++; return { status: 'none' }; }
  const info = _gcacheExtractPrefix(body);
  if (!info) { GEMINI_CACHE_STATS.none++; return { status: 'none' }; }
  if (info.prefixMessageCount > (geminiBody.contents || []).length) {
    GEMINI_CACHE_STATS.none++; return { status: 'none' };
  }
  const hash = _gcacheHash(model, body, info);
  const entry = GEMINI_CACHE_MAP.get(hash);
  if (entry && entry.expiresAt > Date.now() && entry.model === model) {
    geminiBody.contents.splice(0, info.prefixMessageCount);
    if (info.systemIncluded) delete geminiBody.systemInstruction;
    geminiBody.cachedContent = entry.name;
    GEMINI_CACHE_STATS.hit++;
    return { status: 'hit', hash, name: entry.name };
  }
  // Miss: snapshot the prefix for async create after the response succeeds.
  const prefixContents = (geminiBody.contents || []).slice(0, info.prefixMessageCount);
  const prefixSystem = info.systemIncluded ? (geminiBody.systemInstruction || null) : null;
  // Skip when there's effectively nothing to cache (e.g. cache_control-only
  // blocks whose text was stripped). Empty cache entries waste a round-trip
  // and Gemini rejects them anyway. Log + count so users debugging
  // "why isn't my cache working" can find an explanation in the journal.
  if (prefixContents.length === 0 && !prefixSystem) {
    // Distinct from `none` (no cache_control marker at all). Counters are
    // non-overlapping so /ping consumers can sum them without double-counting.
    GEMINI_CACHE_STATS.empty_prefix++;
    if (ctx) ctxLog(ctx, 'gemini.cache.empty_prefix', {
      reason: 'cache_control marker present but cacheable prefix is empty after Anthropic->Gemini translation (system blocks may have had cache_control but no text)',
      systemHasCache: info.systemIncluded,
      prefixMessageCount: info.prefixMessageCount,
    });
    return { status: 'none' };
  }
  GEMINI_CACHE_STATS.miss++;
  const pendingCreate = {
    contents: prefixContents,
    systemInstruction: prefixSystem,
    tools: geminiBody.tools || null,
    ttl: info.ttl,
  };
  return { status: 'miss', hash, pendingCreate };
}

function createGeminiCacheAsync(ctx, backend, model, hash, payload) {
  const reqBody = JSON.stringify({
    model: `models/${model}`,
    contents: payload.contents,
    ...(payload.systemInstruction ? { systemInstruction: payload.systemInstruction } : {}),
    ...(payload.tools ? { tools: payload.tools } : {}),
    ttl: payload.ttl,
  });
  // Wave 3: Vertex parity. AI Studio uses /v1beta/cachedContents on the
  // generativelanguage host. Vertex uses
  //   POST /v1/projects/{p}/locations/{l}/cachedContents
  // on the regional aiplatform host. backend.url for Vertex points at
  //   .../v1/projects/{p}/locations/{l}/publishers/google/models
  // (the generate-content prefix), so we strip that suffix to recover the
  // location-scoped root and append /cachedContents.
  let cachePath, cacheBackend = backend;
  if (backend.vertex) {
    const stripped = (backend.url || '').replace(/\/publishers\/google\/models\/?$/, '');
    cacheBackend = Object.assign({}, backend, { url: stripped });
    cachePath = '/cachedContents';
  } else {
    cachePath = '/v1beta/cachedContents';
  }
  geminiHttpRequest(cacheBackend, 'POST', cachePath, reqBody, {
    'Content-Type': 'application/json',
  }).then(result => {
    if (result.statusCode >= 200 && result.statusCode < 300) {
      try {
        const parsed = JSON.parse(result.body.toString('utf8'));
        if (parsed && parsed.name) {
          const ttlSec = Number(String(payload.ttl).replace(/s$/, '')) || 300;
          GEMINI_CACHE_MAP.set(hash, {
            name: parsed.name,
            expiresAt: Date.now() + (ttlSec * 1000),
            model,
          });
          GEMINI_CACHE_STATS.created++;
          ctxLog(ctx, 'gemini.cache.created', { name: parsed.name, ttl: payload.ttl });
        }
      } catch (e) {
        ctxLog(ctx, 'gemini.cache.parse_error', { error: e.message });
      }
    } else {
      // Most common: 400 "content too small to cache". Silent by design.
      ctxLog(ctx, 'gemini.cache.create_failed', { statusCode: result.statusCode });
    }
  }).catch(e => {
    ctxLog(ctx, 'gemini.cache.create_error', { error: e.message });
  });
}

async function forwardGemini(ctx, req, res, body, backend, effectiveModel, requestMeta) {
  // /v1/messages/count_tokens -> Gemini :countTokens (no model invocation, no SSE).
  // Translate {totalTokens:N} -> Anthropic {type:"message_count", input_tokens:N}.
  const isCountTokens = typeof req.url === 'string' && req.url.startsWith('/v1/messages/count_tokens');
  const isStream = !isCountTokens && !!body.stream;
  const geminiBody = mapAnthropicToGemini(body, effectiveModel);
  if (isCountTokens) {
    // countTokens accepts only contents/systemInstruction/tools — strip generationConfig.
    delete geminiBody.generationConfig;
    // Clear thinking telemetry: count_tokens never invokes the model, so
    // auto-enable / budget-expansion didn't actually happen. Leaking these
    // headers would falsely suggest thinking occurred.
    delete geminiBody._thinkingAutoEnabled;
    delete geminiBody._thinkingBudgetAdded;
  }
  // G4: lazy fire-and-forget context caching. Wave 3 enables this for Vertex
  // — createGeminiCacheAsync branches on backend.vertex to choose the correct
  // {region}-aiplatform .../cachedContents URL vs /v1beta/cachedContents.
  let cacheResult = { status: 'none' };
  if (!isCountTokens) {
    try { cacheResult = maybeApplyGeminiCache(body, geminiBody, effectiveModel, ctx); }
    catch (e) { ctxLog(ctx, 'gemini.cache.apply_error', { error: e.message }); cacheResult = { status: 'none' }; }
  }
  // Mark for buildCthruResponseHeaders to surface as x-c-thru-cache-status.
  // Non-enumerable so JSON.stringify doesn't leak it to upstream.
  Object.defineProperty(geminiBody, '_cacheStatus', { value: cacheResult.status, enumerable: false, configurable: true });
  // Wave 4: stash metadata.user_id (Anthropic's per-user attribution) as a
  // non-enumerable property so buildCthruResponseHeaders can stamp it as a
  // response header. Gemini has no inbound equivalent — request body is
  // unchanged. Pure passthrough observability.
  if (body && body.metadata && typeof body.metadata.user_id === 'string') {
    Object.defineProperty(geminiBody, '_userId', { value: body.metadata.user_id, enumerable: false, configurable: true });
  }
  const baseUrl = (backend.url || 'https://generativelanguage.googleapis.com').replace(/\/$/, '');
  const action = isCountTokens ? 'countTokens' : (isStream ? 'streamGenerateContent' : 'generateContent');
  // If streaming, Google's SSE format for streamGenerateContent uses alt=sse query param
  const urlSuffix = isStream ? '?alt=sse' : '';
  const url = backend.vertex
    ? `${baseUrl}/${effectiveModel}:${action}${urlSuffix}`
    : `${baseUrl}/v1beta/models/${effectiveModel}:${action}${urlSuffix}`;
  
  const targetUrl = new URL(url);
  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;

  const headers = scrubCthruHeaders(req.headers);
  headers['content-type'] = 'application/json';
  // x-goog-api-key will be applied by applyOutboundAuth based on Phase 2 changes
  applyOutboundAuth(backend, req.headers, headers);

  ctxLog(ctx, 'gemini.request', { backend: backend.id, url, model: effectiveModel, stream: isStream });

  const payload = JSON.stringify(geminiBody);
  const options = {
    hostname: targetUrl.hostname,
    port: targetUrl.port,
    path: targetUrl.pathname + targetUrl.search,
    method: 'POST',
    headers: headers,
    timeout: 60000,
  };

  const messageId = 'msg_gemini_' + crypto.randomBytes(12).toString('hex');
  const startedAt = Date.now();

  // Wave 1: client-disconnect cancellation. When the Claude Code client closes
  // mid-flight (Ctrl-C, network drop, page reload), we must tear down the
  // upstream HTTPS request to Gemini so it stops streaming + billing tokens
  // no client will read. Mirrors the Ollama path's up.destroy() pattern.
  // stopGeminiPingFn is a late-bound ref because the keepalive interval is
  // declared inside the streaming branch — we install one cancellation hook
  // up here that fires both for pre-upRes disconnects and post-upRes ones.
  let stopGeminiPingFn = () => {};
  let upstreamCancelled = false;

  const up = lib.request(options, (upRes) => {
    const statusCode = upRes.statusCode;
    if (statusCode >= 400) {
      let errBody = '';
      upRes.on('data', d => errBody += d);
      upRes.on('end', () => {
        // G4: stale-cache retry. If we attached a cachedContent ref and the
        // upstream rejected (404 / cache-not-found), drop the entry and retry
        // once with a clean body. Costs an extra round-trip, only at the TTL
        // boundary.
        if (cacheResult.status === 'hit' && (statusCode === 404 || /cached[_ ]?content|not found/i.test(errBody))) {
          GEMINI_CACHE_STATS.stale_retry++;
          ctxLog(ctx, 'gemini.cache.stale', { statusCode, hash: cacheResult.hash });
          GEMINI_CACHE_MAP.delete(cacheResult.hash);
          body._geminiCacheRetried = true;
          return forwardGemini(ctx, req, res, body, backend, effectiveModel, requestMeta);
        }
        ctxLog(ctx, 'gemini.error', { statusCode, body: errBody });
        // Wave 2: parse Gemini gRPC status from body for an accurate Anthropic
        // error type (RESOURCE_EXHAUSTED->rate_limit_error etc.). Propagate
        // Retry-After verbatim, and synthesize anthropic-ratelimit-requests-
        // remaining: 0 on 429 so Claude Code's backoff sees a concrete signal.
        const errType = anthropicErrorType(statusCode, errBody);
        const extraHeaders = {};
        if (upRes.headers && upRes.headers['retry-after']) {
          extraHeaders['Retry-After'] = String(upRes.headers['retry-after']);
        }
        if (statusCode === 429 || errType === 'rate_limit_error') {
          extraHeaders['anthropic-ratelimit-requests-remaining'] = '0';
        }
        if (res.headersSent) return;
        // Backend-level fallback on retryable upstream errors. Mirrors the
        // forwardAnthropic path (~line 1202): mark the backend as failed
        // (puts it in cooldown if appropriate) and ask tryFallbackOrFail to
        // walk the configured chain. Only fires when the endpoint declares
        // fallback_to — otherwise relays the error directly. Without this,
        // gemini_ai's `fallback_to: claude-sonnet-4-6` would only kick in
        // on network errors, not 5xx / auth / quota responses.
        markBackendFailed(backend.id, !!backend.fallback_to, classifyFailure(statusCode, errBody));
        if (backend.fallback_to) {
          tryFallbackOrFail(ctx, req, res, body, backend, requestMeta, {
            reason: `gemini ${statusCode}: ${errBody.slice(0, 200)}`,
            statusCode,
          }).then(handled => {
            if (handled || res.headersSent) return;
            res.writeHead(statusCode, Object.assign(
              { 'Content-Type': 'application/json' },
              extraHeaders,
            ));
            res.end(JSON.stringify({
              type: 'error',
              error: { type: errType, message: `Gemini error: ${errBody}` },
            }));
          }).catch(() => {
            if (res.headersSent) return;
            res.writeHead(statusCode, Object.assign(
              { 'Content-Type': 'application/json' },
              extraHeaders,
            ));
            res.end(JSON.stringify({
              type: 'error',
              error: { type: errType, message: `Gemini error: ${errBody}` },
            }));
          });
          return;
        }
        res.writeHead(statusCode, Object.assign(
          { 'Content-Type': 'application/json' },
          extraHeaders,
        ));
        res.end(JSON.stringify({
          type: 'error',
          error: { type: errType, message: `Gemini error: ${errBody}` },
        }));
      });
      return;
    }
    // G4: schedule fire-and-forget cache creation on miss after we know the
    // upstream call has begun returning success. Runs in parallel with the
    // response stream — no critical-path latency.
    const scheduleCacheCreate = () => {
      if (cacheResult.status === 'miss' && cacheResult.pendingCreate && cacheResult.hash) {
        try { createGeminiCacheAsync(ctx, backend, effectiveModel, cacheResult.hash, cacheResult.pendingCreate); }
        catch (e) { ctxLog(ctx, 'gemini.cache.schedule_error', { error: e.message }); }
      }
    };

    if (isStream) {
      const streamHeaders = Object.assign(
        {
          'Content-Type': 'text/event-stream',
          'Cache-Control': 'no-cache',
          'Connection': 'keep-alive',
        },
        buildCthruResponseHeaders(req, geminiBody, effectiveModel, requestMeta)
      );
      res.writeHead(200, streamHeaders);

      // Anthropic message_start
      res.write(`event: message_start\ndata: ${JSON.stringify({
        type: 'message_start',
        message: {
          id: messageId,
          type: 'message',
          role: 'assistant',
          model: effectiveModel,
          content: [],
          stop_reason: null,
          stop_sequence: null,
          usage: { input_tokens: 0, output_tokens: 0 }
        }
      })}\n\n`);

      // G11: keepalive on long-running quiet streams. Without this an upstream
      // that buffers internally for >30s will let intermediate proxies (k8s
      // ingress, cloudflare, etc.) idle-timeout the SSE connection, hanging
      // the claude CLI client. Mirrors the Anthropic forwarder's pingTick.
      const geminiPingTick = setInterval(() => {
        if (!res.writable) return;
        try { res.write(`event: ping\ndata: ${JSON.stringify({ type: 'ping' })}\n\n`); } catch {}
      }, SSE_PING_INTERVAL_MS);
      const stopGeminiPing = () => { try { clearInterval(geminiPingTick); } catch {} };
      stopGeminiPingFn = stopGeminiPing;

      // Streaming state machine — Anthropic SSE has one open content block at a
      // time. Gemini chunks may interleave text and functionCall parts across
      // candidates, so we track the currently-open block and close it before
      // opening a new one of a different type.
      let currentBlockIndex = 0;
      let openBlockType = null; // null | 'thinking' | 'text' | 'tool_use'
      let lastClosedBlockType = null;
      let toolBlockEmittedInputDelta = false;
      let currentThinkingSignature = '';

      const closeOpenBlock = () => {
        if (openBlockType === null) return;
        // For thinking blocks, emit signature_delta immediately before
        // content_block_stop (Anthropic spec: signature ships inline).
        if (openBlockType === 'thinking') {
          res.write(`event: content_block_delta\ndata: ${JSON.stringify({
            type: 'content_block_delta',
            index: currentBlockIndex,
            delta: { type: 'signature_delta', signature: currentThinkingSignature || '' }
          })}\n\n`);
          currentThinkingSignature = '';
        }
        res.write(`event: content_block_stop\ndata: ${JSON.stringify({
          type: 'content_block_stop',
          index: currentBlockIndex
        })}\n\n`);
        lastClosedBlockType = openBlockType;
        openBlockType = null;
        toolBlockEmittedInputDelta = false;
        currentBlockIndex++;
      };

      // Gemini SSE format is "data: {...}\n\n"
      let buffer = '';
      upRes.on('data', (chunk) => {
        buffer += chunk.toString();
        let lines = buffer.split('\n');
        buffer = lines.pop();

        for (const line of lines) {
          if (line.startsWith('data: ')) {
            try {
              const geminiData = JSON.parse(line.slice(6));
              const candidate = (geminiData.candidates && geminiData.candidates[0]) || {};
              const parts = (candidate.content && candidate.content.parts) || [];

              for (const part of parts) {
                if (part.thought === true) {
                  // Thinking part: open thinking block lazily, stream as
                  // thinking_delta. Track the most recent thoughtSignature so
                  // closeOpenBlock can emit signature_delta on close.
                  if (openBlockType !== 'thinking') {
                    closeOpenBlock();
                    res.write(`event: content_block_start\ndata: ${JSON.stringify({
                      type: 'content_block_start',
                      index: currentBlockIndex,
                      content_block: { type: 'thinking', thinking: '' }
                    })}\n\n`);
                    openBlockType = 'thinking';
                  }
                  if (part.text) {
                    res.write(`event: content_block_delta\ndata: ${JSON.stringify({
                      type: 'content_block_delta',
                      index: currentBlockIndex,
                      delta: { type: 'thinking_delta', thinking: part.text }
                    })}\n\n`);
                  }
                  if (part.thoughtSignature) currentThinkingSignature = part.thoughtSignature;
                } else if (part.text) {
                  if (openBlockType !== 'text') {
                    closeOpenBlock();
                    res.write(`event: content_block_start\ndata: ${JSON.stringify({
                      type: 'content_block_start',
                      index: currentBlockIndex,
                      content_block: { type: 'text', text: '' }
                    })}\n\n`);
                    openBlockType = 'text';
                  }
                  res.write(`event: content_block_delta\ndata: ${JSON.stringify({
                    type: 'content_block_delta',
                    index: currentBlockIndex,
                    delta: { type: 'text_delta', text: part.text }
                  })}\n\n`);
                } else if (part.functionCall) {
                  // Gemini emits the complete functionCall (with full args) in a
                  // single chunk. Translate to Anthropic's two-stage shape:
                  // content_block_start with empty input, then a single
                  // input_json_delta carrying the full args as JSON, then stop.
                  closeOpenBlock();
                  const fc = part.functionCall;
                  const toolId = fc.id || ('call_' + crypto.randomBytes(4).toString('hex'));
                  // Stash thoughtSignature for round-trip on next turn.
                  if (part.thoughtSignature) rememberThoughtSignature(toolId, part.thoughtSignature);
                  res.write(`event: content_block_start\ndata: ${JSON.stringify({
                    type: 'content_block_start',
                    index: currentBlockIndex,
                    content_block: { type: 'tool_use', id: toolId, name: fc.name, input: {} }
                  })}\n\n`);
                  openBlockType = 'tool_use';
                  if (fc.args !== undefined) {
                    res.write(`event: content_block_delta\ndata: ${JSON.stringify({
                      type: 'content_block_delta',
                      index: currentBlockIndex,
                      delta: { type: 'input_json_delta', partial_json: JSON.stringify(fc.args || {}) }
                    })}\n\n`);
                    toolBlockEmittedInputDelta = true;
                  }
                }
              }

              if (candidate.finishReason && candidate.finishReason !== 'NONE') {
                const wasToolUseTrailing = openBlockType === 'tool_use';
                closeOpenBlock();

                const hasToolUse = wasToolUseTrailing || lastClosedBlockType === 'tool_use';
                const { stop_reason, stop_sequence } = mapGeminiFinishReason(candidate.finishReason, { hasToolUse, ctx });

                // Gemini's usageMetadata only appears on the last stream chunk
                // (confirmed in API docs). Read thoughtsTokenCount here for
                // (a) Anthropic-parity output_tokens (visible + thinking) and
                // (b) journaling/observability via the geminiBody stash.
                // The header x-c-thru-thinking-tokens cannot be set on a
                // streaming response (writeHead already flushed). We emit a
                // custom `c-thru-thinking-tokens` SSE event before
                // message_delta so callers that opt in can read it without
                // relying on a non-spec field inside Anthropic's usage object.
                // Per the SSE spec, unknown event types are ignored by strict
                // clients (Anthropic SDK falls into that bucket).
                const candidatesCount = (geminiData.usageMetadata || {}).candidatesTokenCount || 0;
                const thoughtsCount = (geminiData.usageMetadata || {}).thoughtsTokenCount || 0;
                if (thoughtsCount > 0) {
                  Object.defineProperty(geminiBody, '_thinkingTokens', {
                    value: thoughtsCount, enumerable: false, configurable: true,
                  });
                  res.write(`event: c-thru-thinking-tokens\ndata: ${JSON.stringify({
                    type: 'c-thru-thinking-tokens',
                    thinking_tokens: thoughtsCount,
                  })}\n\n`);
                }
                res.write(`event: message_delta\ndata: ${JSON.stringify({
                  type: 'message_delta',
                  delta: { stop_reason, stop_sequence },
                  usage: {
                    output_tokens: candidatesCount + thoughtsCount,
                  },
                })}\n\n`);
              }
            } catch (e) {
              ctxLog(ctx, 'gemini.stream.parse_error', { error: e.message, line });
            }
          }
        }
      });

      upRes.on('end', () => {
        stopGeminiPing();
        res.write(`event: message_stop\ndata: {"type": "message_stop"}\n\n`);
        res.end();
        clearBackendCooldown(backend.id);
        scheduleCacheCreate();
      });
      upRes.on('error', stopGeminiPing);
      // Note: client-disconnect handling is wired at the function level via
      // cancelUpstream (req/res 'close' -> up.destroy() + stopGeminiPing).
      // This branch's old `res.on('close', stopGeminiPing)` was removed in
      // Wave 1 to consolidate cleanup into the single cancelUpstream path.
    } else {
      // Non-streaming
      let respBody = '';
      upRes.on('data', d => respBody += d);
      upRes.on('end', () => {
        try {
          const geminiData = JSON.parse(respBody);
          if (isCountTokens) {
            // Gemini :countTokens -> {totalTokens, ...}. Map to Anthropic
            // /v1/messages/count_tokens shape: {input_tokens}. (Anthropic
            // historically returned {input_tokens:N}; the type:"message_count"
            // wrapper was added later — emit both for forward compatibility.)
            const inputTokens = geminiData.totalTokens ?? geminiData.totalTokensCount ?? 0;
            const anthropicRes = { input_tokens: inputTokens };
            res.writeHead(200, Object.assign(
              { 'Content-Type': 'application/json' },
              buildCthruResponseHeaders(req, geminiBody, effectiveModel, requestMeta)
            ));
            res.end(JSON.stringify(anthropicRes));
            clearBackendCooldown(backend.id);
            return;
          }
          const candidate = (geminiData.candidates && geminiData.candidates[0]) || {};
          const content = candidate.content || {};
          const parts = content.parts || [];
          
          // Gemini may interleave thought parts with text/functionCall parts.
          // Anthropic clients expect thinking blocks before any text/tool_use.
          // Partition + reassemble so order is: thinking[] -> text/tool_use[].
          //
          // G12 emission policy: thought parts only appear here when the client
          // opted in upstream — mapAnthropicToGemini sets
          // generationConfig.thinkingConfig.includeThoughts=true iff
          // body.thinking.type==='enabled' (see L2531). Without that flag Gemini
          // won't emit thought:true parts, so the "double-render on
          // non-thinking models" concern is gated at the request-build site,
          // not here. Pass thought parts through unconditionally so that any
          // future upstream-initiated thinking still surfaces to the client.
          //
          // thoughtSignature placement varies: Gemini 3+ may attach it to a
          // sibling text/functionCall part rather than the thought part itself.
          // First-pass collect any thoughtSignature seen on the candidate so we
          // can backfill thinking blocks whose own part lacked one. Mirrors the
          // streaming path, which streams thinking_delta then emits
          // signature_delta from currentThinkingSignature on close.
          let firstSeenSignature = '';
          for (const p of parts) {
            if (p.thoughtSignature && !firstSeenSignature) firstSeenSignature = p.thoughtSignature;
          }
          const thinkingBlocks = [];
          const otherBlocks = [];
          for (const p of parts) {
            if (p.thought === true) {
              thinkingBlocks.push({
                type: 'thinking',
                thinking: p.text || '',
                signature: p.thoughtSignature || firstSeenSignature || '',
              });
              continue;
            }
            if (p.text) {
              otherBlocks.push({ type: 'text', text: p.text });
              continue;
            }
            if (p.functionCall) {
              // Preserve Gemini-supplied id when present; synthesize otherwise.
              // Anthropic clients reference this id back via tool_result.tool_use_id.
              const id = p.functionCall.id || ('call_' + crypto.randomBytes(4).toString('hex'));
              // Stash Gemini's thoughtSignature so the next turn's request can
              // re-attach it (Gemini 3+ rejects multi-turn tool flows otherwise).
              if (p.thoughtSignature) rememberThoughtSignature(id, p.thoughtSignature);
              otherBlocks.push({ type: 'tool_use', id, name: p.functionCall.name, input: p.functionCall.args || {} });
            }
          }
          const anthropicContent = [...thinkingBlocks, ...otherBlocks];

          const hasToolUse = anthropicContent.some(b => b.type === 'tool_use');
          const { stop_reason, stop_sequence } = mapGeminiFinishReason(candidate.finishReason, { hasToolUse, ctx });

          const anthropicRes = {
            id: messageId,
            type: 'message',
            role: 'assistant',
            model: effectiveModel,
            content: anthropicContent,
            stop_reason,
            stop_sequence,
            usage: {
              input_tokens: (geminiData.usageMetadata || {}).promptTokenCount || 0,
              // Anthropic parity: output_tokens INCLUDES thinking tokens
              // (Anthropic's API rolls thinking into output_tokens for
              // billing/observability). Gemini reports them separately as
              // candidatesTokenCount (visible) + thoughtsTokenCount (thinking).
              // Sum them so SDK clients see token totals matching Anthropic
              // semantics; the breakdown surfaces via x-c-thru-thinking-tokens.
              output_tokens:
                ((geminiData.usageMetadata || {}).candidatesTokenCount || 0)
                + ((geminiData.usageMetadata || {}).thoughtsTokenCount || 0),
              // G4: Gemini surfaces cache-served tokens as cachedContentTokenCount.
              // cache_creation_input_tokens stays 0 — Gemini doesn't report this in
              // usage and the create happens asynchronously.
              cache_read_input_tokens: (geminiData.usageMetadata || {}).cachedContentTokenCount || 0,
              cache_creation_input_tokens: 0,
            }
          };

          // Stash thoughtsTokenCount so buildCthruResponseHeaders can surface
          // it as x-c-thru-thinking-tokens. Anthropic has no native field for
          // "thinking output tokens" (output_tokens covers visible only).
          const thoughtsTokenCount = (geminiData.usageMetadata || {}).thoughtsTokenCount;
          if (typeof thoughtsTokenCount === 'number' && thoughtsTokenCount > 0) {
            Object.defineProperty(geminiBody, '_thinkingTokens', {
              value: thoughtsTokenCount, enumerable: false, configurable: true,
            });
          }
          const respHeaders = Object.assign(
            { 'Content-Type': 'application/json' },
            buildCthruResponseHeaders(req, geminiBody, effectiveModel, requestMeta)
          );
          res.writeHead(200, respHeaders);
          res.end(JSON.stringify(anthropicRes));
          clearBackendCooldown(backend.id);
          scheduleCacheCreate();
        } catch (e) {
          ctxLog(ctx, 'gemini.parse_error', { error: e.message, body: respBody });
          sendAnthropicError(res, 502, `failed to parse Gemini response: ${e.message}`);
        }
      });
    }
  });

  up.on('error', (e) => {
    ctxLog(ctx, 'gemini.request_error', { error: e.message });
    tryFallbackOrFail(ctx, req, res, body, backend, requestMeta, { reason: e.message, statusCode: 502 });
  });

  const cancelUpstream = () => {
    if (upstreamCancelled) return;
    upstreamCancelled = true;
    try { stopGeminiPingFn(); } catch {}
    try { if (!up.destroyed) up.destroy(); } catch {}
  };
  req.on('close', cancelUpstream);
  res.on('close', cancelUpstream);

  up.write(payload);
  up.end();
}

function dispatchGeminiBackend(ctx, req, res, body, backend, effectiveModel, requestMeta) {
  return forwardGemini(ctx, req, res, body, backend, effectiveModel, requestMeta);
}

function dispatchOllamaBackend(ctx, req, res, body, backend, effectiveModel, requestMeta) {
  if (backend.format === 'ollama-legacy' || backend.legacy_ollama_chat === true) {
    return forwardOllamaLegacy(ctx, req, res, body, backend, effectiveModel, requestMeta);
  }
  return forwardAnthropic(ctx, req, res, body, backend, effectiveModel, requestMeta);
}

// =============================================================================
// GEMINI TRANSLATION
// =============================================================================

// Process-wide cache: tool_use_id -> Gemini thoughtSignature. Required because
// Gemini 3+ tool_use rejects subsequent turns whose functionCall parts don't
// echo back the original signature ("Function call is missing a
// thought_signature" 400). Anthropic's tool_use schema has no field for
// vendor-specific blobs, so we stash the signature here on the response path
// and re-attach it on the next request's tool_use -> functionCall translation.
//
// Bounded by GEMINI_THOUGHT_SIG_MAX_ENTRIES (default 10000) with FIFO
// eviction, plus TTL of GEMINI_THOUGHT_SIG_TTL_MS (default 1h). Both override
// via env for testing.
const GEMINI_THOUGHT_SIG_MAX_ENTRIES = Number(process.env.GEMINI_THOUGHT_SIG_MAX_ENTRIES || 10000);
const GEMINI_THOUGHT_SIG_TTL_MS = Number(process.env.GEMINI_THOUGHT_SIG_TTL_MS || 3600000);
const GEMINI_THOUGHT_SIG_CACHE = new Map(); // tool_use_id -> { sig, ts }
function rememberThoughtSignature(toolUseId, sig) {
  if (!toolUseId || !sig) return;
  GEMINI_THOUGHT_SIG_CACHE.set(toolUseId, { sig, ts: Date.now() });
  if (GEMINI_THOUGHT_SIG_CACHE.size > GEMINI_THOUGHT_SIG_MAX_ENTRIES) {
    // Evict oldest 10% (FIFO via insertion order).
    const drop = Math.ceil(GEMINI_THOUGHT_SIG_MAX_ENTRIES * 0.1);
    let i = 0;
    for (const k of GEMINI_THOUGHT_SIG_CACHE.keys()) {
      if (i++ >= drop) break;
      GEMINI_THOUGHT_SIG_CACHE.delete(k);
    }
  }
}
function lookupThoughtSignature(toolUseId) {
  const entry = GEMINI_THOUGHT_SIG_CACHE.get(toolUseId);
  if (!entry) return null;
  if (Date.now() - entry.ts > GEMINI_THOUGHT_SIG_TTL_MS) {
    GEMINI_THOUGHT_SIG_CACHE.delete(toolUseId);
    return null;
  }
  return entry.sig;
}

// Map Gemini finishReason -> Anthropic stop_reason.
// Returns { stop_reason, stop_sequence }. Safety/recitation/blocklist surface
// as stop_sequence='gemini_safety_block' so clients can distinguish a refusal
// from a normal end_turn.
const GEMINI_SAFETY_REASONS = new Set(['SAFETY', 'RECITATION', 'BLOCKLIST', 'PROHIBITED_CONTENT', 'SPII']);
function mapGeminiFinishReason(finishReason, opts) {
  const o = opts || {};
  if (finishReason === 'MAX_TOKENS') return { stop_reason: 'max_tokens', stop_sequence: null };
  if (finishReason === 'STOP' || !finishReason || finishReason === 'NONE') {
    return { stop_reason: o.hasToolUse ? 'tool_use' : 'end_turn', stop_sequence: null };
  }
  if (GEMINI_SAFETY_REASONS.has(finishReason)) {
    return { stop_reason: 'stop_sequence', stop_sequence: 'gemini_safety_block' };
  }
  // OTHER / unknown — log for observability and fall through to end_turn.
  if (o.ctx) ctxLog(o.ctx, 'gemini.unknown_finish_reason', { finishReason });
  return { stop_reason: o.hasToolUse ? 'tool_use' : 'end_turn', stop_sequence: null };
}

// Strip JSON Schema features Gemini doesn't support (oneOf/anyOf/allOf/$ref/$defs).
// - oneOf/anyOf: collapse to the first variant (best-effort; preserves the most-likely shape).
// - allOf: shallow-merge all variants into the parent object.
// - $ref / $defs / $schema / $id: dropped (Gemini can't dereference).
// Returns the scrubbed schema and a list of removed feature names (for observability).
function scrubGeminiSchema(schema, removed) {
  if (!schema || typeof schema !== 'object') return schema;
  if (Array.isArray(schema)) return schema.map(s => scrubGeminiSchema(s, removed));
  const out = {};
  for (const [k, v] of Object.entries(schema)) {
    if (k === '$schema' || k === '$id' || k === '$defs' || k === 'definitions') {
      removed.add(k);
      continue;
    }
    if (k === '$ref') {
      removed.add('$ref');
      continue;
    }
    // Gemini's JSON Schema dialect is much stricter than standard. Each of
    // these fields triggers an INVALID_ARGUMENT 400 even though they're
    // valid JSON Schema. Discovered via live e2e against Claude Code's
    // default tool definitions. Drop silently and surface in
    // x-c-thru-schema-scrubbed for observability.
    //
    // Gemini-rejected (drop): additionalProperties, propertyNames, const,
    //   exclusiveMinimum, exclusiveMaximum, llmGuidance (Claude Code custom),
    //   examples (Claude Code custom; differs from Gemini's `example` singular).
    // Gemini-supported (keep): type, format, description, nullable, enum,
    //   minimum, maximum, minItems, maxItems, minLength, maxLength, pattern,
    //   properties, required, items, default, example, propertyOrdering.
    //
    // TODO: switch to allowlist if more fields surface. Blacklist is
    // whack-a-mole but safer for now (no risk of stripping a supported field).
    if (k === 'additionalProperties' || k === 'propertyNames' ||
        k === 'const' || k === 'exclusiveMinimum' || k === 'exclusiveMaximum' ||
        k === 'llmGuidance' || k === 'examples') {
      removed.add(k);
      continue;
    }
    if (k === 'oneOf' || k === 'anyOf') {
      removed.add(k);
      if (Array.isArray(v) && v.length > 0) {
        const first = scrubGeminiSchema(v[0], removed);
        if (first && typeof first === 'object' && !Array.isArray(first)) {
          for (const [fk, fv] of Object.entries(first)) {
            if (out[fk] == null) out[fk] = fv;
          }
        }
      }
      continue;
    }
    if (k === 'allOf') {
      removed.add(k);
      if (Array.isArray(v)) {
        for (const variant of v) {
          const sv = scrubGeminiSchema(variant, removed);
          if (sv && typeof sv === 'object' && !Array.isArray(sv)) {
            for (const [vk, vv] of Object.entries(sv)) {
              if (vk === 'properties' && typeof vv === 'object') {
                out.properties = Object.assign({}, out.properties || {}, vv);
              } else if (vk === 'required' && Array.isArray(vv)) {
                out.required = Array.from(new Set([...(out.required || []), ...vv]));
              } else if (out[vk] == null) {
                out[vk] = vv;
              }
            }
          }
        }
      }
      continue;
    }
    out[k] = scrubGeminiSchema(v, removed);
  }
  return out;
}

// Map Anthropic tool_choice to Gemini toolConfig.functionCallingConfig.
// Anthropic shapes: {type:'auto'} | {type:'any'} | {type:'tool', name} | {type:'none'}
// Gemini modes: AUTO (model decides), ANY (must call a function), NONE (must not call)
// allowedFunctionNames restricts which functions can be called when mode is ANY.
function mapToolChoice(toolChoice) {
  if (!toolChoice) return null;
  const tc = typeof toolChoice === 'string' ? { type: toolChoice } : toolChoice;
  let mode = 'AUTO';
  let allowedFunctionNames = null;
  if (tc.type === 'auto') mode = 'AUTO';
  else if (tc.type === 'any') mode = 'ANY';
  else if (tc.type === 'tool' && tc.name) { mode = 'ANY'; allowedFunctionNames = [tc.name]; }
  else if (tc.type === 'none') mode = 'NONE';
  const cfg = { mode };
  if (allowedFunctionNames) cfg.allowedFunctionNames = allowedFunctionNames;
  return { functionCallingConfig: cfg };
}

// Gemini 3 family detection. The thinkingLevel parameter is the preferred
// API for Gemini 3+; thinkingBudget is back-compat only and mixing both
// (in the same request) returns 400. Includes the *-latest aliases that
// Google currently resolves to Gemini 3.
function isGemini3FamilyModel(modelName) {
  if (typeof modelName !== 'string') return false;
  if (/^gemini-3(\.\d+)?-/i.test(modelName)) return true;
  return modelName === 'gemini-pro-latest'
    || modelName === 'gemini-flash-latest'
    || modelName === 'gemini-flash-lite-latest'
    || modelName === 'gemini-pro'
    || modelName === 'gemini-flash';
}

// Map Anthropic numeric `budget_tokens` to Gemini's `thinkingLevel` enum.
// Per-model support varies: gemini-3-pro supports only 'low'/'high';
// gemini-3.1-pro adds 'medium'; gemini-3-flash adds 'minimal'. We pick the
// nearest level the target model supports.
function budgetToThinkingLevel(budgetTokens, modelName) {
  // Auto-enable default (no explicit budget) → 'low'.
  if (budgetTokens == null) return 'low';
  const supportsMinimal = /^gemini-3.*flash/i.test(modelName);
  // gemini-3-pro (NOT gemini-3.1-pro) supports only low/high — no medium.
  const supportsMedium = !/^gemini-3-pro($|-)/i.test(modelName);
  if (budgetTokens === 0) return supportsMinimal ? 'minimal' : 'low';
  if (budgetTokens <= 2048) return 'low';
  if (budgetTokens >= 16384) return 'high';
  return supportsMedium ? 'medium' : 'high';
}

// Approximate per-level budget for maxOutputTokens expansion. Gemini 3
// counts thinking against maxOutputTokens, so when caller set max_tokens we
// expand by an estimate of the level's typical consumption. Conservative
// upper-bound estimates so visible answers don't get truncated.
function thinkingLevelToApproxBudget(level) {
  switch (level) {
    case 'minimal': return 256;
    case 'low':     return 2048;
    case 'medium':  return 8192;
    case 'high':    return 16384;
    default:        return 1024;
  }
}

function mapAnthropicToGemini(body, effectiveModel) {
  const geminiReq = {
    contents: [],
    generationConfig: {}
  };

  if (body.temperature != null) geminiReq.generationConfig.temperature = body.temperature;
  if (body.top_p != null) geminiReq.generationConfig.topP = body.top_p;
  if (body.top_k != null) geminiReq.generationConfig.topK = body.top_k;
  if (body.max_tokens != null) geminiReq.generationConfig.maxOutputTokens = body.max_tokens;
  if (body.stop_sequences != null) geminiReq.generationConfig.stopSequences = body.stop_sequences;

  // Anthropic `thinking: {type:'enabled', budget_tokens:N}` -> Gemini
  // `generationConfig.thinkingConfig`. Older Gemini models (2.0, flash-lite)
  // silently ignore — no model-version gate. Caller-wins: omit if absent so
  // we don't override capability_sampling_defaults.
  //
  // Auto-enable on Gemini 3 Pro: the model's flagship reasoning is gated
  // behind opt-in upstream, so absent any thinking field we default it on
  // with a 1024-token budget. Explicit {type:'disabled'} respected as opt-out.
  let thinkingEnabled = body.thinking && body.thinking.type === 'enabled';
  let autoEnabled = false;
  let thinkingBudget = 0;
  // Detection: explicit Gemini 3 Pro tags (gemini-3-pro, gemini-3.1-pro,
  // gemini-3-pro-preview, gemini-3.1-pro-preview), or the
  // `gemini-pro-latest` / `gemini-pro` aliases that Google currently
  // resolves to Gemini 3 Pro. The hyphen-delimited `-pro(-|$)` anchor avoids
  // matching `gemini-3-flash-*`, where /pro/i would substring-match "p..r"
  // false positives in unusual future names.
  const isGemini3Pro = typeof effectiveModel === 'string' && (
    /^gemini-3(\.\d+)?-pro(-|$)/i.test(effectiveModel)
    || effectiveModel === 'gemini-pro-latest'
    || effectiveModel === 'gemini-pro'
  );
  const explicitDisabled = body.thinking && body.thinking.type === 'disabled';
  if (!thinkingEnabled && !explicitDisabled && isGemini3Pro
      && (!body.thinking || !body.thinking.type)) {
    thinkingEnabled = true;
    autoEnabled = true;
    thinkingBudget = 1024;
  } else if (thinkingEnabled) {
    thinkingBudget = Number(body.thinking.budget_tokens) || 1024;
  }
  if (thinkingEnabled) {
    // Gemini 3+ uses `thinkingLevel` (low/medium/high/minimal); older
    // Gemini models keep the legacy numeric `thinkingBudget`. Mixing both
    // returns 400 from upstream.
    const useLevel = isGemini3FamilyModel(effectiveModel);
    let appliedBudget;
    if (useLevel) {
      // Preserve explicit 0 (→ 'minimal' on flash); only treat absent budget
      // as null. `|| null` would coerce 0 to null and lose the signal.
      const explicitBudget = body.thinking?.budget_tokens;
      const budgetArg = autoEnabled || explicitBudget == null
        ? null
        : Number(explicitBudget);
      const level = budgetToThinkingLevel(budgetArg, effectiveModel);
      geminiReq.generationConfig.thinkingConfig = {
        thinkingLevel: level,
        includeThoughts: true,
      };
      appliedBudget = thinkingLevelToApproxBudget(level);
      Object.defineProperty(geminiReq, '_thinkingLevel', {
        value: level, enumerable: false, configurable: true,
      });
    } else {
      geminiReq.generationConfig.thinkingConfig = {
        thinkingBudget,
        includeThoughts: true,
      };
      appliedBudget = thinkingBudget;
    }
    // Budget arithmetic: Gemini 3 counts thinking against maxOutputTokens.
    // Expand the cap by the (approximate, level-derived) budget so
    // max_tokens means "visible answer length" — matching Anthropic
    // semantics — rather than "pooled budget".
    if (body.max_tokens != null) {
      geminiReq.generationConfig.maxOutputTokens = Number(body.max_tokens) + appliedBudget;
      Object.defineProperty(geminiReq, '_thinkingBudgetAdded', {
        value: appliedBudget, enumerable: false, configurable: true,
      });
    }
    if (autoEnabled) {
      Object.defineProperty(geminiReq, '_thinkingAutoEnabled', {
        value: true, enumerable: false, configurable: true,
      });
    }
  }

  if (body.system) {
    // Anthropic system blocks may carry cache_control (a Claude-specific feature).
    // Strip cache_control entirely; keep only the text. If a block has only
    // cache_control and no text, skip it rather than emitting empty parts.
    const systemText = Array.isArray(body.system)
      ? body.system.map(s => (s && typeof s === 'object' ? (s.text || '') : String(s || ''))).filter(Boolean).join('\n')
      : body.system;
    if (systemText) {
      geminiReq.systemInstruction = { parts: [{ text: systemText }] };
    }
  }

  const schemaRemoved = new Set();
  let redactedThinkingDropped = false;
  if (body.tools) {
    geminiReq.tools = [{
      functionDeclarations: body.tools.map(t => ({
        name: t.name,
        description: t.description,
        parameters: scrubGeminiSchema(t.input_schema, schemaRemoved)
      }))
    }];
  }

  const toolConfig = mapToolChoice(body.tool_choice);
  if (toolConfig) geminiReq.toolConfig = toolConfig;

  // Build tool_use_id -> name lookup for tool_result -> functionResponse mapping.
  // Gemini's functionResponse must include the same id used in the original
  // functionCall when one was supplied (parallel calls disambiguation).
  const toolIdToName = {};
  if (body.messages) {
    for (const msg of body.messages) {
      if (msg.role === 'assistant' && Array.isArray(msg.content)) {
        for (const block of msg.content) {
          if (block.type === 'tool_use') {
            toolIdToName[block.id] = block.name;
          }
        }
      }
    }
  }

  for (const msg of body.messages) {
    const role = msg.role === 'assistant' ? 'model' : 'user';
    const parts = [];
    if (Array.isArray(msg.content)) {
      for (const block of msg.content) {
        if (block.type === 'text') {
          parts.push({ text: block.text });
        } else if (block.type === 'tool_use') {
          const fc = { name: block.name, args: block.input };
          if (block.id) fc.id = block.id;
          // Gemini 3+ requires the original thoughtSignature to be echoed back
          // when this tool_use appears in conversation history. Look it up by
          // tool_use_id from our process-wide cache populated on the response
          // path. Missing -> omit (works for non-3 models, fails for 3+).
          const part = { functionCall: fc };
          if (block.id) {
            const sig = lookupThoughtSignature(block.id);
            if (sig) part.thoughtSignature = sig;
          }
          parts.push(part);
        } else if (block.type === 'tool_result') {
          const name = toolIdToName[block.tool_use_id] || 'unknown_tool';
          let responseObj = block.content;
          if (typeof responseObj === 'string') {
            try { responseObj = JSON.parse(responseObj); } catch { responseObj = { content: responseObj }; }
          } else if (Array.isArray(responseObj)) {
            // tool_result.content can be an array of content blocks (e.g., [{type:'text', text:'...'}]).
            // Gemini wants a flat object — extract text and stringify other types.
            const textParts = responseObj.filter(b => b && b.type === 'text').map(b => b.text || '').join('\n');
            responseObj = { content: textParts || JSON.stringify(responseObj) };
          }
          // Anthropic tool_result.is_error=true signals upstream that the tool
          // failed and the model should consider retry/error handling. Gemini's
          // functionResponse uses an `error` field on response. Wrap the original
          // content under .error so the model still sees the failure detail.
          if (block.is_error === true) {
            const baseContent = (responseObj && typeof responseObj === 'object') ? responseObj : { content: String(responseObj || '') };
            responseObj = { error: baseContent };
          }
          const fr = { name, response: responseObj };
          if (block.tool_use_id) fr.id = block.tool_use_id;
          parts.push({ functionResponse: fr });
        } else if (block.type === 'thinking') {
          // Echo prior thinking back to Gemini as a structured part so multi-turn
          // thinking sessions verify against the original signature on Gemini 3+.
          // Older Gemini models (2.5, 2.0) accept `thought:true` parts but do
          // not enforce signature presence — safe to send unconditionally.
          const tp = { text: block.thinking || '', thought: true };
          if (block.signature) tp.thoughtSignature = block.signature;
          parts.push(tp);
        } else if (block.type === 'redacted_thinking') {
          // Anthropic-encrypted opaque blob. Gemini cannot decrypt, would 400
          // if forwarded. Skip the part and surface the omission via header.
          redactedThinkingDropped = true;
          continue;
        } else if (block.type === 'image') {
          // Anthropic image blocks: base64 inline, url, or file_id (post-G9).
          const src = block.source || {};
          if (src.type === 'base64' && src.data) {
            parts.push({ inlineData: { mimeType: src.media_type || 'image/png', data: src.data } });
          } else if (src.type === 'url' && src.url) {
            parts.push({ fileData: { fileUri: src.url, mimeType: src.media_type } });
          } else if (src.type === 'file' && src.file_id) {
            const uri = fileIdToGeminiUri(src.file_id);
            if (uri) parts.push({ fileData: { fileUri: uri, mimeType: src.media_type } });
          }
        } else if (block.type === 'document') {
          // PDF/document blocks. base64 inline, url, or file_id (post-G9).
          const src = block.source || {};
          if (src.type === 'base64' && src.data) {
            parts.push({ inlineData: { mimeType: src.media_type || 'application/pdf', data: src.data } });
          } else if (src.type === 'url' && src.url) {
            parts.push({ fileData: { fileUri: src.url, mimeType: src.media_type || 'application/pdf' } });
          } else if (src.type === 'file' && src.file_id) {
            const uri = fileIdToGeminiUri(src.file_id);
            if (uri) parts.push({ fileData: { fileUri: uri, mimeType: src.media_type || 'application/pdf' } });
          }
        }
      }
    } else if (typeof msg.content === 'string') {
      parts.push({ text: msg.content });
    }
    geminiReq.contents.push({ role, parts });
  }

  // Stash schema-scrubbing telemetry so the caller can emit a header.
  if (schemaRemoved.size > 0) {
    Object.defineProperty(geminiReq, '_schemaRemoved', {
      value: Array.from(schemaRemoved), enumerable: false
    });
  }

  if (redactedThinkingDropped) {
    Object.defineProperty(geminiReq, '_redactedThinkingDropped', {
      value: true, enumerable: false
    });
  }

  return geminiReq;
}

function translateGeminiCandidateToAnthropic(candidate, messageId, modelName, isLast = false) {
  const events = [];
  const content = candidate.content || {};
  const parts = content.parts || [];

  for (let i = 0; i < parts.length; i++) {
    const part = parts[i];
    if (part.text) {
      events.push({
        type: 'content_block_delta',
        index: i,
        delta: { type: 'text_delta', text: part.text }
      });
    } else if (part.functionCall) {
      // Gemini functionCall is a single part. Anthropic tool_use is a block.
      // In SSE, this is trickier because we need message_start first.
      // This helper is for deltas.
    }
  }

  if (isLast && candidate.finishReason) {
    let stopReason = 'end_turn';
    if (candidate.finishReason === 'STOP') stopReason = 'end_turn';
    else if (candidate.finishReason === 'MAX_TOKENS') stopReason = 'max_tokens';
    else if (candidate.finishReason === 'SAFETY') stopReason = 'stop_sequence'; // closest match
    
    events.push({
      type: 'message_delta',
      delta: { stop_reason: stopReason, stop_sequence: null },
      usage: { output_tokens: 0 } // usage usually comes in separate metadata
    });
  }

  return events;
}

// =============================================================================
// LEGACY WIRE FORMAT: Ollama native /api/chat (NOT Anthropic Messages API)
// =============================================================================
// Translates Anthropic-format requests to Ollama's native /api/chat shape via
// flattenMessagesForOllama() + buildOllamaRequestBody(), and translates the
// NDJSON response back to Anthropic SSE via setupOllamaStream().
//
// This path strips non-text content blocks (tool_use, tool_result, thinking)
// during flattening — multi-turn tool conversations don't roundtrip cleanly.
// Use only for backends without /v1/messages support (Ollama < 0.4, LM Studio's
// Ollama-compat shim) by setting `legacy_ollama_chat: true` on the backend.
// New deployments should leave the flag absent and use forwardAnthropic via
// dispatchOllamaBackend.
// =============================================================================
async function forwardOllamaLegacy(ctx, req, res, body, backend, effectiveModel, requestMeta) {
  const url = backend.url.replace(/\/$/, '') + '/api/chat';
  const headers = scrubCthruHeaders(req.headers);
  headers['content-type'] = 'application/json';
  const isStream = !!body.stream;
  const inBytes = (requestMeta && requestMeta.inBytes) || 0;

  ctxLog(ctx, 'ollama.request', { backend: backend.id, url, model: effectiveModel, stream: isStream });
  const upTimeoutMs = OLLAMA_UPSTREAM_TIMEOUT_MS;
  const requestStartedAt = Date.now();

  // timerControls.stop is updated by setupOllamaStream so up.on('error') can
  // clear the stall/ping intervals even on pre-stream connection failures.
  const timerControls = { stop: () => {} };

  // TTFT (time-to-first-response-headers) timer. Fires fast (default 11s)
  // if upstream doesn't return HTTP headers, distinguishing "Ollama is
  // unreachable / dead / wedged" from "Ollama is taking a while to load
  // a big model" (the latter still gets the full upTimeoutMs budget once
  // headers arrive). Cleared in the upRes callback on first response.
  // On fire: destroy the request, which routes through up.on('error')
  // -> tryFallbackOrFail for transparent fallback to the configured
  // backup backend.
  let ttftTimer = setTimeout(() => {
    ttftTimer = null;
    ctxLog(ctx, 'ollama.ttft.timeout', {
      backend: backend.id,
      url,
      model: effectiveModel,
      after_ms: OLLAMA_TTFT_TIMEOUT_MS,
    });
    up.destroy(new Error(`upstream did not return headers within ${OLLAMA_TTFT_TIMEOUT_MS}ms (TTFT)`));
  }, OLLAMA_TTFT_TIMEOUT_MS);

  const up = http.request(url, { method: 'POST', headers }, upRes => {
    if (ttftTimer) { clearTimeout(ttftTimer); ttftTimer = null; }
    const ttftMs = Date.now() - requestStartedAt;
    ctxLog(ctx, 'ollama.response', { backend: backend.id, status: upRes.statusCode, model: effectiveModel, ttft_ms: ttftMs });
    if (upRes.statusCode !== 200) {
      handleOllamaError(ctx, req, res, body, backend, requestMeta, upRes);
      return;
    }
    if (isStream) {
      setupOllamaStream(ctx, req, res, backend, effectiveModel, requestMeta, up, requestStartedAt, timerControls, upRes, body);
    } else {
      handleOllamaNonStream(ctx, req, res, body, backend, effectiveModel, requestMeta, upRes);
    }
  });

  up.on('socket', socket => {
    socket.on('connect', () => ctxDebug(ctx, 'upstream.socket.connected', { backend: backend.id }));
    socket.on('close', hadError => ctxDebug(ctx, 'upstream.socket.closed', { backend: backend.id, had_error: hadError }));
  });

  up.setTimeout(upTimeoutMs, () => {
    if (ttftTimer) { clearTimeout(ttftTimer); ttftTimer = null; }
    ctxLog(ctx, 'backend_error', { backend: backend.id, kind: 'ollama', error: `upstream timeout after ${upTimeoutMs}ms` });
    up.destroy(new Error(`upstream timeout after ${upTimeoutMs}ms`));
  });
  up.on('error', async e => {
    if (ttftTimer) { clearTimeout(ttftTimer); ttftTimer = null; }
    ctxLog(ctx, 'backend_error', { backend: backend.id, kind: 'ollama', error: e.message });
    const statusCode = e.message.startsWith('upstream timeout') || e.message.includes('TTFT') ? 504 : 502;
    // Always stop interval timers first to avoid the leak.
    timerControls.stop();
    if (res.headersSent) {
      // Mid-stream upstream error: too late for fallback (bytes already on
      // the wire to the client). Emit a structured SSE error frame instead
      // of a silent socket close.
      if (res.writable) {
        sseWrite(res, 'error', {
          type: 'error',
          error: { type: anthropicErrorType(statusCode), message: `backend ollama at ${backend.url} error: ${e.message}` },
        });
        res.end();
      }
      return;
    }
    // Pre-stream: try the configured fallback if any. Catches connection
    // errors (ECONNREFUSED, ENOTFOUND), TTFT timeouts (upstream wedged on
    // headers), upstream timeouts (5min hard cap). Same machinery as
    // forwardAnthropic — re-resolves through the route graph and dispatches
    // through dispatchOllamaBackend or forwardAnthropic depending on the fallback
    // target's backend kind.
    //
    // Cloud->local rewrite first: if the failing model is :cloud-suffixed
    // (network down -> localhost can't reach Ollama's hosted infra), swap in
    // the configured local fallback model and retry against the same backend
    // before walking the per-backend fallback_to chain.
    if (tryOllamaCloudLocalFallback(ctx, req, res, body, backend, requestMeta)) {
      return;
    }
    // Connection-error / TTFT timeout path. statusCode here is our synthetic
    // 502/504 (computed above from the error message); pass the message so
    // classifyFailure can pick up the TTFT/timeout markers — both classify
    // as 'transient'.
    markBackendFailed(backend.id, !!backend.fallback_to, classifyFailure(statusCode, e.message));
    const handled = await tryFallbackOrFail(ctx, req, res, body, backend, requestMeta, {
      reason: 'connection error',
      error: e.message,
    });
    if (!handled && !res.headersSent) {
      sendAnthropicError(res, statusCode, `backend ollama at ${backend.url} error: ${e.message}`);
    }
  });

  const ollamaBody = buildOllamaRequestBody(body, effectiveModel);
  ctxLog(ctx, 'body.rewrite', {
    bytes_in: inBytes,
    bytes_out: ollamaBody.length,
    model_swap: body.model !== effectiveModel,
    incoming_model: body.model,
    resolved_model: effectiveModel,
  });
  ctxDebug(ctx, 'trace.body.rewrite_diff', {
    in_preview: JSON.stringify(body).slice(0, 300),
    out_preview: ollamaBody.slice(0, 300),
    headers_dropped: ['host', 'connection', 'content-length'],
  });
  up.write(ollamaBody);
  up.end();
}

// ── Network Watcher ──────────────────────────────────────────────────
// On macOS (Darwin), monitors internet reachability via `scutil -r google.com`.
// When connectivity transitions from Not Reachable -> Reachable, immediately
// clear all backend cooldowns.
let isOnlineLast = true;
function startNetworkWatcher() {
  if (process.platform !== 'darwin') return;

  const interval = 5000;
  setInterval(() => {
    require('child_process').exec('scutil -r google.com', (err, stdout) => {
      const isOnline = !err && stdout.includes('Reachable') && !stdout.includes('Not Reachable');
      if (isOnline && !isOnlineLast) {
        proxyLog('network.restored', { message: 'Internet reachability restored; clearing all backend cooldowns' });
        failedBackendUntil.clear();
      }
      isOnlineLast = isOnline;
    });
  }, interval);
  proxyLog('network.watcher_init', { platform: process.platform, interval_ms: interval });
}

// ── Config loading & reload ────────────────────────────────────────────
// Substitute ${VAR} in endpoint URLs at config-load time only (not per-request).
// Scope: endpoints.*.url. Unset vars become empty strings + a stderr warning.
// Mutates config in place; returns same reference.
function interpolateEndpointUrls(config) {
  const eps = (config && (config.endpoints || config.backends)) || {};
  for (const [id, entry] of Object.entries(eps)) {
    if (!entry || typeof entry.url !== 'string') continue;
    const original = entry.url;
    if (!original.includes('${')) continue;
    const seenMissing = new Set();
    entry.url = original.replace(/\$\{([A-Z_][A-Z0-9_]*)\}/g, (_, name) => {
      const v = process.env[name];
      if (v == null || v === '') {
        if (!seenMissing.has(name)) {
          console.error(`c-thru: warning: endpoint '${id}'.url references unset env var \${${name}}`);
          seenMissing.add(name);
        }
        return '';
      }
      return v;
    });
  }
  return config;
}

function loadConfig() {
  const resolved = resolveConfigSelectionForReload();
  if (!resolved) { console.error('c-thru: no model-map.json found'); process.exit(1); }
  CONFIG_PATH = resolved.path;
  CONFIG_SOURCE = resolved.source;
  try {
    GLOBAL_CONFIG = interpolateEndpointUrls(JSON.parse(fs.readFileSync(CONFIG_PATH, 'utf8')));
    CONFIG_MTIME_MS = Math.floor(fs.statSync(CONFIG_PATH).mtimeMs);
  } catch (e) {
    console.error(`c-thru: failed to load ${CONFIG_PATH}: ${e.message}`);
    process.exit(1);
  }
}

// Walk up from dir looking for .claude/model-map.json.
// Used by SIGHUP reload to discover a newly-added project-local config
// without running the full sync (which would re-merge the layered profile).
function findProjectLocalConfig(startDir) {
  let dir = startDir;
  for (;;) {
    const candidate = path.join(dir, '.claude', 'model-map.json');
    try { fs.accessSync(candidate, fs.constants.R_OK); return candidate; } catch {}
    const parent = path.dirname(dir);
    if (parent === dir) return null;
    dir = parent;
  }
}

function resolveConfigSelectionForReload() {
  // Tier 1: explicit override path (same as resolveSelectedConfigPath).
  const override = process.env.CLAUDE_MODEL_MAP_PATH;
  if (override) {
    try { return { path: fs.realpathSync(override), source: 'override' }; } catch (e) { console.error(`c-thru: CLAUDE_MODEL_MAP_PATH '${override}' could not be resolved: ${e.message}`); }
  }

  // Tier 2: project-local .claude/model-map.json walked from cwd.
  // Bypasses the full profile-sync so SIGHUP is cheap; picks up configs
  // added after startup without needing to restart the proxy.
  const launchCwd = process.env.CLAUDE_MODEL_MAP_LAUNCH_CWD || process.cwd();
  const projectLocal = findProjectLocalConfig(launchCwd);
  if (projectLocal) return { path: projectLocal, source: 'project' };

  // Tier 3: profile graph (system + overrides, no project merge).
  return resolveSelectedConfigPath({ baseDir: __dirname, syncProfile: false });
}

// Check if model-map.json is older than either system.json or overrides.json.
// If so, re-run model-map-sync.js to regenerate the merged file. This handles
// the case where a user manually edits overrides without running model-map-edit
// (which normally re-merges atomically after every edit).
function maybeRegenerateMergedConfig() {
  const claudeDir = path.join(os.homedir(), '.claude');
  const systemPath = path.join(claudeDir, 'model-map.system.json');
  const overridesPath = path.join(claudeDir, 'model-map.overrides.json');
  const mergedPath = path.join(claudeDir, 'model-map.json');

  // Step 0: if the shipped repo config (config/model-map.json) is newer than
  // the installed system.json, refresh system.json from it. Otherwise edits
  // to the repo's shipped config never reach a running c-thru session until
  // ./install.sh is re-run — silent staleness, hard to debug.
  const shippedPath = path.join(__dirname, '..', 'config', 'model-map.json');
  try {
    const shippedMtime = fs.statSync(shippedPath).mtimeMs;
    let systemMtime = 0;
    try { systemMtime = fs.statSync(systemPath).mtimeMs; } catch {}
    if (shippedMtime > systemMtime) {
      // Validate before copying — never overwrite a working system.json with a
      // broken shipped config (would brick the proxy on next reload).
      try {
        JSON.parse(fs.readFileSync(shippedPath, 'utf8'));
        fs.copyFileSync(shippedPath, systemPath);
        console.error(`c-thru: refreshed system.json from shipped config (${shippedPath})`);
      } catch (e) {
        console.error(`c-thru: shipped config invalid (${e.message}) — keeping existing system.json`);
      }
    }
  } catch {}

  let mergedMtime = 0;
  try { mergedMtime = fs.statSync(mergedPath).mtimeMs; } catch {}

  let needSync = false;
  try {
    if (fs.statSync(systemPath).mtimeMs > mergedMtime) needSync = true;
    if (fs.statSync(overridesPath).mtimeMs > mergedMtime) needSync = true;
  } catch {}

  if (!needSync) return;

  // Run model-map-sync to regenerate.
  const syncTool = path.join(__dirname, 'model-map-sync.js');
  if (!fs.existsSync(syncTool)) return;
  try {
    const result = require('child_process').spawnSync(
      process.execPath,
      [syncTool, systemPath, overridesPath, '', mergedPath],
      { encoding: 'utf8', timeout: 5000 }
    );
    if (result.status === 0) {
      console.error(`c-thru: regenerated merged config from sources (system + overrides)`);
    }
  } catch {}
}

function reloadConfigFromDisk() {
  try {
    // Check if merged file is stale vs sources; re-merge if needed.
    maybeRegenerateMergedConfig();
    const resolved = resolveConfigSelectionForReload();
    if (!resolved) throw new Error('no model-map.json found');
    const nextConfig = interpolateEndpointUrls(JSON.parse(fs.readFileSync(resolved.path, 'utf8')));
    const nextMtime = Math.floor(fs.statSync(resolved.path).mtimeMs);
    GLOBAL_CONFIG = nextConfig;
    CONFIG_PATH = resolved.path;
    CONFIG_SOURCE = resolved.source;
    CONFIG_MTIME_MS = nextMtime;
    // Re-read benchmark.json so a SIGHUP from c-thru-benchmarks-update.sh
    // picks up fresh data without restarting the proxy.
    const nextBenchmark = loadBenchmark();
    if (nextBenchmark) BENCHMARK = nextBenchmark;
    const draining = activeRequests > 0 ? ` (draining ${activeRequests} in-flight requests)` : '';
    console.error(`c-thru: reloaded config from ${resolved.path}${draining}`);
    return true;
  } catch (e) {
    console.error(`c-thru: config reload failed: ${e.message}`);
    return false;
  }
}

function refreshConfigIfChanged() {
  try {
    const nextMtime = Math.floor(fs.statSync(CONFIG_PATH).mtimeMs);
    if (nextMtime !== CONFIG_MTIME_MS) reloadConfigFromDisk();
  } catch {}
}

// ── Config file watcher ───────────────────────────────────────────────
// Watch the resolved config path so any edit (including model-map-edit
// writing overrides + merged profile) triggers an automatic reload.
// Eliminates the need for manual /c-thru-config reload in most cases.
let configWatchHandle = null;
function armConfigWatcher(configPath) {
  if (configWatchHandle) fs.unwatchFile(configWatchHandle);
  if (!configPath) return;
  try {
    configWatchHandle = fs.watchFile(configPath, { interval: 1007 }, (curr, _prev) => {
      if (curr.mtimeMs !== CONFIG_MTIME_MS) {
        const drained = reloadConfigFromDisk();
        if (drained) {
          // If the reload resolved a different path, re-arm on the new path.
          if (CONFIG_PATH !== configPath) armConfigWatcher(CONFIG_PATH);
        } else {
          // If reload failed but the file changed, still update our mtime
          // so we don't keep retrying on unchanged files.
          try {
            CONFIG_MTIME_MS = Math.floor(fs.statSync(configPath).mtimeMs);
          } catch {}
        }
      }
    });
  } catch {}
}

// ── Main Server ──────────────────────────────────────────────────────
loadConfig();
armConfigWatcher(CONFIG_PATH);
startNetworkWatcher();
if (UNRECOGNIZED_CLI_FLAGS.length) {
  proxyLog('cli.unrecognized_flags', { flags: UNRECOGNIZED_CLI_FLAGS });
}

let activeRequests = 0;
const server = http.createServer((req, res) => {
  activeRequests++;
  const snapshot = GLOBAL_CONFIG;
  configStorage.run(snapshot, async () => {
    const ctx = newRequestContext();
    try {
      refreshConfigIfChanged();
      ctxLog(ctx, 'request', {
        method: req.method,
        url: req.url,
        bytes_in: Number(req.headers['content-length']) || 0,
        client: req.headers['user-agent'] || '',
      });
      traceLog(ctx, 'in.client', req.method, req.url, req.headers);

      const finalize = () => { activeRequests--; };
      res.on('finish', finalize);
      res.on('close', () => {
        if (!res.writableFinished) {
          ctxLog(ctx, 'client.disconnect', { received_ms: Date.now() - ctx.started });
          finalize();
        }
      });

      if (req.url === '/ping') return send(res, 200, {
        ok: true, pid: process.pid, config_path: CONFIG_PATH,
        active_tier: resolveActiveTier(CONFIG), active_mode: resolveLlmMode(CONFIG),
        bind_address: server.address().address,
        gemini_cache: { ...GEMINI_CACHE_STATS, entries: GEMINI_CACHE_MAP.size },
      });

      if (req.method === 'POST' && (req.url === '/c-thru/stats/clear' || req.url === '/c-thru/stats/clear/')) {
        const clearedAt = new Date().toISOString();
        persistentUsage = emptyUsage();
        flushPersistentUsageNowSync();
        proxyLog('stats.cleared', { cleared_at: clearedAt });
        return send(res, 200, { ok: true, cleared_at: clearedAt });
      }

      if (req.method === 'GET' && (req.url === '/c-thru/status' || req.url === '/c-thru/status/' || req.url.startsWith('/c-thru/status?'))) {
        const tier = resolveActiveTier(CONFIG);
        const mode = resolveLlmMode(CONFIG);
        // New schema: llm_profiles[capability] (capability-outer, not tier-outer)
        const allProfiles = CONFIG.llm_profiles || {};
        const active_capabilities = {};
        for (const [capabilityName, entry] of Object.entries(allProfiles)) {
          const m = resolveProfileModel(entry, tier, mode);
          if (m) active_capabilities[capabilityName] = m.replace(BACKEND_SIGIL_RE, '$1');
        }
        // agent_resolutions: overridden agents only by default; ?verbose=1 shows all.
        let verboseFlag = false;
        try { verboseFlag = new URL(req.url, 'http://x').searchParams.get('verbose') === '1'; } catch {}
        const overridesPath = process.env.CLAUDE_MODEL_MAP_OVERRIDES_PATH
          || path.join(os.homedir(), '.claude', 'model-map.overrides.json');
        let overriddenAgents = new Set();
        try {
          const ov = JSON.parse(fs.readFileSync(overridesPath, 'utf8'));
          overriddenAgents = new Set(Object.keys((ov && ov.agent_to_capability) || {}));
        } catch {}
        const allA2c = CONFIG.agent_to_capability || {};
        const agentKeys = verboseFlag
          ? Object.keys(allA2c)
          : [...overriddenAgents].filter(k => k in allA2c);
        const agent_resolutions = {};
        for (const agent of agentKeys) {
          const capVal = allA2c[agent];
          if (typeof capVal === 'string' && capVal.startsWith(MODEL_PIN_PREFIX)) {
            agent_resolutions[agent] = {
              capability: '[pinned]',
              model: capVal.slice(MODEL_PIN_PREFIX.length),
              pinned: true,
            };
          } else {
            const profEntry = allProfiles[capVal];
            let resolvedModel = profEntry ? resolveProfileModel(profEntry, tier, mode) : null;
            if (resolvedModel) resolvedModel = resolvedModel.replace(BACKEND_SIGIL_RE, '$1');
            agent_resolutions[agent] = {
              capability: capVal || null,
              model: resolvedModel || null,
              pinned: false,
            };
          }
        }
        return send(res, 200, {
          ok: true,
          mode,
          hardware_tier: tier,
          config_source: CONFIG_SOURCE,
          active_capabilities,
          agent_resolutions,
          usage: persistentUsage,
          // Cooldown state — backends the proxy is currently routing around.
          // Empty array when all configured backends are healthy.
          cooldown_backends: [...failedBackendUntil.entries()].map(([id, until]) => ({
            backend: id,
            expires_in_ms: Math.max(0, until - Date.now()),
          })),
          // Global default-route resolution — ultimate last-resort target.
          default_route: CONFIG.routes && CONFIG.routes.default ? CONFIG.routes.default : null,
        });
      }

      if (req.method === 'POST' && (req.url === '/c-thru/mode' || req.url === '/c-thru/mode/')) {
        const buf = await readBody(req);
        let payload; try { payload = JSON.parse(buf.toString()); } catch (e) { return sendAnthropicError(res, 400, `invalid JSON body: ${e.message}`); }
        const mode = payload?.mode;
        if (!mode || !LLM_MODE_ENUM.has(mode)) return sendAnthropicError(res, 400, 'invalid mode');
        process.env.CLAUDE_LLM_MODE = mode;
        proxyLog('mode-switch', { new_mode: mode, source: 'control-channel' });
        return send(res, 200, { ok: true, new_mode: mode, message: `Mode switched to ${mode}` });
      }

      if (req.method === 'POST' && (req.url === '/c-thru/reload' || req.url === '/c-thru/reload/')) {
        reloadConfigFromDisk();
        proxyLog('config-reload', { source: 'control-channel' });
        return send(res, 200, { ok: true, message: 'Reloaded' });
      }

      if (req.method === 'POST' && req.url === '/hooks/context') {
        const tier = resolveActiveTier(CONFIG);
        const mode = resolveLlmMode(CONFIG);
        proxyLog('hook_injection', { tier, mode });
        return send(res, 200, {
          hookSpecificOutput: {
            hookEventName: "SessionStart",
            additionalContext: `(c-thru) routing active. Profile: ${tier}, Mode: ${mode}.`
          }
        });
      }

      // /v1/files* — Gemini Files API proxy (upload, list, get, delete).
      // Anthropic file_<x> <-> Gemini files/<x> mapping is symmetrical.
      if (req.url === '/v1/files' || req.url === '/v1/files/' || req.url.startsWith('/v1/files?') || req.url.startsWith('/v1/files/')) {
        return handleFilesApi(req, res);
      }

      // /v1/models — Anthropic-shape model listing. Static enumeration over
      // CONFIG.model_routes (preferred over a Gemini API call: works offline,
      // surfaces routes the proxy *actually* serves rather than upstream catalog).
      if (req.method === 'GET' && (req.url === '/v1/models' || req.url === '/v1/models/' || req.url.startsWith('/v1/models?'))) {
        const routes = CONFIG.model_routes || {};
        const endpointsOrBackends = CONFIG.endpoints || CONFIG.backends || {};
        const data = [];
        const seen = new Set();
        // Resolve a route entry to its terminal endpoint id (best-effort, single hop).
        // Used to decide which non-claude- routes deserve a synthesized claude-via-*
        // alias for picker exposure (Claude Code's /model picker only displays
        // claude-* IDs from /v1/models).
        const routeEndpointId = (entry) => {
          if (typeof entry === 'string') return entry;
          if (entry && typeof entry === 'object') {
            if (typeof entry.endpoint === 'string') return entry.endpoint;
            // mode-keyed object → prefer 'connected', else first string value
            const cand = entry.connected || entry.default || Object.values(entry).find(v => typeof v === 'string');
            return typeof cand === 'string' ? cand : null;
          }
          return null;
        };
        // Endpoints whose routes get auto-synthesized claude-via-* aliases.
        // Default covers cloud-hosted non-Anthropic providers; users can override
        // via top-level `picker_alias_endpoints` in config. Anthropic-format
        // endpoints already surface their claude-* IDs natively, so excluded.
        const aliasEndpoints = new Set(
          Array.isArray(CONFIG.picker_alias_endpoints)
            ? CONFIG.picker_alias_endpoints
            : ['gemini_ai', 'gemini_vertex']
        );
        for (const key of Object.keys(routes)) {
          if (key.startsWith('re:')) continue; // regex routes have no canonical id
          if (seen.has(key)) continue;
          seen.add(key);
          data.push({
            type: 'model',
            id: key,
            display_name: key,
            created_at: '2024-01-01T00:00:00Z',
          });
        }
        // Synthesize claude-via-<key> aliases. Skip keys already starting with
        // claude- (the picker shows them directly), and skip if a claude-via-<key>
        // already exists in routes (user-defined wins).
        for (const key of Object.keys(routes)) {
          if (key.startsWith('re:')) continue;
          if (key.startsWith('claude-')) continue;
          const epId = routeEndpointId(routes[key]);
          if (!epId || !aliasEndpoints.has(epId)) continue;
          const aliasId = `claude-via-${key}`;
          if (seen.has(aliasId)) continue;
          seen.add(aliasId);
          data.push({
            type: 'model',
            id: aliasId,
            display_name: aliasId,
            created_at: '2024-01-01T00:00:00Z',
          });
        }
        return send(res, 200, { data, has_more: false, first_id: data[0]?.id || null, last_id: data[data.length - 1]?.id || null });
      }

      if (req.method === 'GET' && (req.url === '/v1/active-models' || req.url === '/v1/active-models/')) {
        const tier = resolveActiveTier(CONFIG);
        const mode = resolveLlmMode(CONFIG);
        // New schema: llm_profiles[capability] (capability-outer)
        const allProfiles2 = CONFIG.llm_profiles || {};
        const local_models = [];
        const capabilities = [];
        for (const [alias, entry] of Object.entries(allProfiles2)) {
          const m = resolveProfileModel(entry, tier, mode);
          if (!m) continue;
          const sigilMatch = m.match(BACKEND_SIGIL_RE);
          const base = sigilMatch ? sigilMatch[1] : m;
          // Determine locality: explicit @sigil -> check backend kind; bare model ->
          // check backends dict, then route target name (ollama* = local, else cloud).
          let isLocal = false;
          const epOrBk = CONFIG.endpoints || CONFIG.backends;
          if (sigilMatch) {
            const bk = epOrBk?.[sigilMatch[2]];
            isLocal = bk ? isLocalBackend(normalizeBackend(sigilMatch[2], bk)) : false;
          } else {
            const routeEntry = (CONFIG.model_routes || {})[base];
            const routeTarget = routeEntry && typeof routeEntry === 'object' && typeof routeEntry.endpoint === 'string'
              ? routeEntry.endpoint
              : routeEntry;
            if (routeTarget && typeof routeTarget === 'string') {
              const bk = epOrBk?.[routeTarget];
              if (bk) {
                isLocal = isLocalBackend(normalizeBackend(routeTarget, bk));
              } else {
                // Backend not in dict; infer from name convention: ollama* = local, cloud/anthropic/openai = not local
                const rt = routeTarget.toLowerCase();
                isLocal = rt.includes('ollama') && !rt.includes('cloud');
              }
            }
            // No route found: fall through to resolveBackend (handles sigil/capability aliases)
            if (!routeTarget) {
              const resolved = resolveBackend(m, CONFIG, tier, mode);
              isLocal = !resolved.error && isLocalBackend(resolved.backend) && !resolved.backend._ollamaFallback;
            }
          }
          capabilities.push({ capability: alias, model: base, local: isLocal });
          if (isLocal && !local_models.includes(base)) local_models.push(base);
        }
        return send(res, 200, { tier, mode, local_models, capabilities });
      }

      if (req.method === 'GET' && req.url.startsWith('/v1/probe-llm')) {
        return handleProbeLlm(req, res);
      }

      if (req.method === 'POST' && req.url.startsWith('/v1/messages')) {
        const buf = await readBody(req);
        let body;
        try {
          body = JSON.parse(buf.toString());
        } catch (e) {
          // Malformed request body. Real Anthropic returns 400 invalid_request_error
          // for this; previously we let it throw into the outer catch and returned 500
          // api_error which is misleading + masks client bugs (truncated bodies,
          // version mismatches, content-type errors).
          ctxLog(ctx, 'request.parse_error', { error: e.message, bytes_in: buf.length });
          return sendAnthropicError(res, 400, `invalid JSON in request body: ${e.message}`);
        }
        const hwTier = resolveActiveTier(CONFIG);
        const activeMode = resolveLlmMode(CONFIG);
        const requestStartedAt = Date.now();

        if (!body || typeof body.model !== 'string' || !body.model) {
          return sendAnthropicError(res, 400, 'model field is required');
        }

        // Apply model_overrides unconditionally before route/alias resolution.
        if (CONFIG.model_overrides && CONFIG.model_overrides[body.model]) {
          const overriddenFrom = body.model;
          body.model = CONFIG.model_overrides[body.model];
          ctxLog(ctx, 'model_override', { from: overriddenFrom, to: body.model });
        }

        let resolved = resolveBackend(body.model, CONFIG, hwTier, activeMode);
        if (resolved.error) {
          ctxLog(ctx, 'routing_error', { incoming_model: body.model, error: resolved.error });
          return sendAnthropicError(res, resolved.status || 400, resolved.error);
        }

        // ── Phase 3 ranking ──
        const RANK_MODES = {
          'fastest-possible': 'fastest',
          'smallest-possible': 'smallest',
          'best-opensource': 'best-opensource',
          'best-opensource-cloud': 'best-opensource-cloud',
          'best-opensource-local': 'best-opensource-local'
        };
        const criterion = RANK_MODES[activeMode];
        if (criterion && BENCHMARK) {
          const capKey = resolved.logicalRole || resolveCapabilityAlias(body.model, CONFIG, hwTier);
          const role = capKey ? BENCHMARK.capability_to_role?.[capKey] : null;
          if (role) {
            const candidates = Object.keys(CONFIG.model_routes || {}).filter(k => !k.startsWith('re:'));
            const best = pickBenchmarkBest(criterion, candidates, BENCHMARK, role, CONFIG.model_routes || {}, CONFIG.endpoints || CONFIG.backends || {});
            if (best && best !== resolved.effectiveModel) {
              const replaced = resolveBackend(best, CONFIG, hwTier, activeMode);
              if (!replaced.error) {
                ctxLog(ctx, 'ranking_promotion', { criterion, role, old_model: resolved.effectiveModel, new_model: replaced.effectiveModel });
                resolved = Object.assign({}, replaced, { logicalRole: resolved.logicalRole });
              }
            }
          }
        }

        let { backend, effectiveModel, logicalRole } = resolved;

        // ── Phase 2: mode filter + fallback_chains pre-dispatch selection ──
        // For filter modes (claude-only, opensource-only): scan fallback_chains for
        // the first candidate that satisfies the mode predicate. Returns the primary
        // unchanged for non-filter modes. Returns null when no compliant candidate exists.
        const capKey = logicalRole;
        const capChain = capKey && CONFIG.fallback_chains?.[hwTier]?.[capKey];
        // New schema: llm_profiles[capability] (capability-outer, not tier-outer)
        const profileEntry = capKey ? (CONFIG.llm_profiles || {})[capKey] : null;
        const onFailure = profileEntry?.on_failure || 'cascade';

        if (capChain) {
          const chainModels = capChain.map(c => (typeof c === 'string' ? c : c.model)).filter(Boolean);
          const filteredModel = applyModeFilter(
            activeMode, effectiveModel, chainModels,
            CONFIG.model_routes || {}, CONFIG.endpoints || CONFIG.backends || {}
          );
          if (filteredModel === null) {
            ctxLog(ctx, 'mode_filter.reject_all', { mode: activeMode, capability: capKey });
            return sendAnthropicError(res, 502,
              `No ${activeMode} model available for capability '${capKey}': all candidates rejected by mode filter`);
          }
          if (filteredModel !== effectiveModel) {
            const swapped = resolveBackend(filteredModel, CONFIG, hwTier, activeMode);
            if (!swapped.error) {
              ctxLog(ctx, 'mode_filter.swap', { from: effectiveModel, to: filteredModel, mode: activeMode });
              ({ backend: backend, effectiveModel: effectiveModel, logicalRole: logicalRole } =
                Object.assign(swapped, { logicalRole: capKey }));
            }
          }
        }

        const requestMeta = {
          capability: logicalRole,
          stream: !!body.stream,
          inBytes: buf.length,
          // Thread tier+mode through so forward functions can re-resolve via
          // resolveBackend if they need to fall back to a different upstream.
          hwTier,
          activeMode,
          startedAt: requestStartedAt,
          onFailure,
          originalModel: body.model,  // captured before body.model is rewritten to effectiveModel
          // Resolution-chain trace from resolveBackend (req:X -> route(...) -> ...).
          // Surfaced as x-c-thru-resolution-chain on the response. Updated by
          // fallback paths if a different model is ultimately dispatched.
          resolutionChain: resolved.chain || null,
        };

        ctxLog(ctx, 'dispatch', {
          incoming_model: body.model,
          resolved_model: effectiveModel,
          backend_id: backend.id,
          backend_format: backend.format || backend.kind,
          logical_role: logicalRole || 'none',
          tier: hwTier,
          mode: activeMode
        });

        body.model = effectiveModel;

        // ── Cooldown skip ──
        // If the primary resolved backend is in cooldown, jump directly to the
        // fallback logic instead of paying the TTFT cost of a known-bad backend.
        if (backend.fallback_to && isInCooldown(backend.id)) {
          ctxLog(ctx, 'dispatch.skip_cooldown', { backend: backend.id, fallback: backend.fallback_to });
          const handled = await tryFallbackOrFail(ctx, req, res, body, backend, requestMeta, {
            reason: 'backend is in cooldown from a previous failure',
            statusCode: 0
          });
          if (handled) return;
        }

        if (isOllamaLegacy(backend)) {
          return dispatchOllamaBackend(ctx, req, res, body, backend, effectiveModel, requestMeta);
        }
        if (backend.format === 'gemini') {
          return dispatchGeminiBackend(ctx, req, res, body, backend, effectiveModel, requestMeta);
        }
        if (backend.format === 'openai') {
          return sendAnthropicError(res, 501, 'format:"openai" not yet implemented — configure an OpenRouter endpoint with format:"anthropic" instead, or use a separate OpenAI-compat gateway');
        }
        return forwardAnthropic(ctx, req, res, body, backend, effectiveModel, requestMeta);
      }

      sendAnthropicError(res, 404, `not found: ${req.method} ${req.url}`);
    } catch (err) {
      proxyLog('fatal_error', { error: err.message, stack: err.stack });
      sendAnthropicError(res, 500, 'internal error');
    }
  });
});

server.listen(INITIAL_PORT, '127.0.0.1', () => {
  process.stdout.write(`READY ${server.address().port}\n`);
  console.error(`c-thru listening on :${server.address().port}`);
  try { fs.writeFileSync(PID_FILE, String(process.pid)); } catch {}
});

function cleanupPidFile() {
  try { if (fs.existsSync(PID_FILE)) fs.unlinkSync(PID_FILE); } catch {}
}

process.on('SIGHUP', () => reloadConfigFromDisk());
process.on('SIGTERM', () => { flushPersistentUsageNowSync(); cleanupPidFile(); process.exit(0); });
process.on('SIGINT', () => { flushPersistentUsageNowSync(); cleanupPidFile(); process.exit(0); });
// `beforeExit` fires on natural process termination (event loop emptied).
// `exit` is too late for async I/O. This catches "node ran out of work"
// shutdowns where SIGTERM/SIGINT didn't fire.
process.on('beforeExit', () => { flushPersistentUsageNowSync(); cleanupPidFile(); });
process.on('SIGPIPE', () => proxyLog('process.sigpipe', { message: 'ignored SIGPIPE' }));

process.on('uncaughtException', err => {
  if (err.code === 'EIO' || err.code === 'ECONNRESET' || err.code === 'EPIPE') {
    proxyLog('proxy.error.ignored', { code: err.code, message: err.message });
    return;
  }
  proxyLog('fatal_error_uncaught', { error: err.message, stack: err.stack });
  process.exit(1);
});

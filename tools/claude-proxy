function recordHealthEvent(backendId, state, reason) {
  healthMeta.eventSeq++;
  healthMeta.lastTransition = nowIso();
  const ev = { seq: healthMeta.eventSeq, ts: healthMeta.lastTransition, id: backendId, state, reason };
  healthMeta.recentEvents.push(ev);
  if (healthMeta.recentEvents.length > 100) healthMeta.recentEvents.shift();
  if (!stats.byBackendId[backendId]) stats.byBackendId[backendId] = { state: 'healthy', failure_count: 0 };
  stats.byBackendId[backendId].state = state;
  proxyLog('backend.health_change', ev);
}

// ── Model Resolution & Patterns ─────────────────────────────────────
const BACKEND_SIGIL_RE = /^(.*)@([a-zA-Z0-9_-]+)$/;

function profileAliasKey(alias) {
  return alias.toLowerCase().replace(/[^a-z0-9_-]/g, '_');
}

function resolveBackend(model, cfg, tier, mode) {
  const backends = cfg.backends || {};
  const modelRoutes = cfg.model_routes || {};
  
  // 1. Literal match in model_routes
  let id = modelRoutes[model];
  if (id && backends[id]) return { backend: { id, ...backends[id] }, effectiveModel: model, terminalLabel: model, routingKey: model };

  // 2. Pattern match in model_routes
  for (const [pattern, backendId] of Object.entries(modelRoutes)) {
    if (!pattern.startsWith('re:')) continue;
    try {
      const regex = new RegExp(pattern.slice(3));
      if (regex.test(model)) {
        id = backendId;
        if (backends[id]) return { backend: { id, ...backends[id] }, effectiveModel: model, terminalLabel: model, routingKey: pattern };
      }
    } catch {}
  }

  // 3. Sigil match (model@backend)
  const sigilMatch = model.match(BACKEND_SIGIL_RE);
  if (sigilMatch) {
    const [, baseModel, backendId] = sigilMatch;
    if (backends[backendId]) {
      return { backend: { id: backendId, ...backends[backendId] }, effectiveModel: baseModel, terminalLabel: baseModel, routingKey: backendId };
    }
  }

  // 4. Capability alias match
  const capAlias = resolveCapabilityAlias(model, cfg, tier);
  if (capAlias) {
    const profile = (cfg.llm_profiles || {})[tier];
    const entry = profile ? profile[capAlias] : null;
    if (entry) {
      const resolved = resolveProfileModel(entry, mode);
      if (resolved) {
        const nested = resolveBackend(resolved, cfg, tier, mode);
        if (!nested.error) {
          return { ...nested, logicalRole: capAlias, capability: capAlias };
        }
      }
    }
  }

  // 5. Hardcoded Anthropic patterns
  if (model.startsWith('claude-')) {
    const anthroEntry = Object.entries(backends).find(([, v]) => (v.kind || 'anthropic') === 'anthropic');
    if (anthroEntry) {
      const [id, backend] = anthroEntry;
      return { backend: { id, ...backend }, effectiveModel: model, terminalLabel: model, routingKey: 'claude-prefix' };
    }
  }

  // 6. Ollama fallback
  if (process.env.C_THRU_STRICT_MODELS === '1') {
    return { error: `'${model}' not in model_routes and C_THRU_STRICT_MODELS=1 is set`, status: 400 };
  }
  console.error(`c-thru: '${model}' not in model_routes — assuming local Ollama at ${DEFAULT_OLLAMA_URL}`);
  return {
    backend: { id: '__ollama_fallback__', kind: 'ollama', url: DEFAULT_OLLAMA_URL, _ollamaFallback: true },
    effectiveModel: model,
    terminalLabel: model,
    routingKey: 'ollama-fallback'
  };
}

function lookupPatternValue(section, model) {
  const obj = CONFIG[section] || {};
  for (const [k, v] of Object.entries(obj)) {
    if (!k.startsWith('re:')) continue;
    try {
      if (new RegExp(k.slice(3)).test(model)) return v;
    } catch {}
  }
  return null;
}


let persistentUsage = { total_input: 0, total_output: 0, by_model: {} };
function loadPersistentUsage() {
  try {
    if (fs.existsSync(USAGE_STATS_FILE)) {
      persistentUsage = JSON.parse(fs.readFileSync(USAGE_STATS_FILE, 'utf8'));
    }
  } catch {}
}
loadPersistentUsage();

function recordUsage(model, input, output) {
  persistentUsage.total_input += input;
  persistentUsage.total_output += output;
  if (!persistentUsage.by_model[model]) persistentUsage.by_model[model] = { input: 0, output: 0 };
  persistentUsage.by_model[model].input += input;
  persistentUsage.by_model[model].output += output;
  if (USAGE_LOG_FILE) {
    try {
      fs.appendFileSync(USAGE_LOG_FILE, JSON.stringify({ ts: nowIso(), model, input, output }) + '\n');
    } catch {}
  }
}

function flushPersistentUsageNowSync() {
  try {
    fs.mkdirSync(path.dirname(USAGE_STATS_FILE), { recursive: true });
    fs.writeFileSync(USAGE_STATS_FILE, JSON.stringify(persistentUsage, null, 2));
  } catch {}
}

function checkRotateProxyLog() {
  if (!PROXY_LOG_FILE) return;
  try {
    const stat = fs.statSync(PROXY_LOG_FILE);
    if (stat.size > PROXY_LOG_MAX_SIZE) {
      const old = PROXY_LOG_FILE + '.old';
      if (fs.existsSync(old)) fs.unlinkSync(old);
      fs.renameSync(PROXY_LOG_FILE, old);
    }
  } catch {}
}


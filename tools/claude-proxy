// ── Request handling ───────────────────────────────────────────────
function send(res, code, obj) {
  if (res.headersSent) return;
  const body = JSON.stringify(obj);
  res.writeHead(code, { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(body) });
  res.end(body);
}

function readBody(req) {
  return new Promise((resolve, reject) => {
    const chunks = [];
    req.on('data', c => chunks.push(c));
    req.on('error', reject);
    req.on('end', () => resolve(Buffer.concat(chunks)));
  });
}

async function httpProbe(urlStr, headers = {}, timeoutMs = 3000) {
  return new Promise(resolve => {
    try {
      const url = new URL(urlStr);
      const lib = url.protocol === 'https:' ? https : http;
      const req = lib.request(urlStr, { method: 'GET', timeout: timeoutMs, headers }, res => {
        resolve({ ok: res.statusCode >= 200 && res.statusCode < 300, statusCode: res.statusCode });
      });
      req.on('error', e => resolve({ ok: false, error: e.message }));
      req.on('timeout', () => { req.destroy(); resolve({ ok: false, error: 'timeout' }); });
      req.end();
    } catch (e) { resolve({ ok: false, error: e.message }); }
  });
}

async function ollamaPs(backendUrl) {
  return new Promise(resolve => {
    try {
      http.get(backendUrl.replace(/\/$/, '') + '/api/ps', res => {
        const chunks = [];
        res.on('data', c => chunks.push(c));
        res.on('end', () => {
          try { resolve(JSON.parse(Buffer.concat(chunks).toString()).models || []); } catch { resolve([]); }
        });
      }).on('error', () => resolve([]));
    } catch { resolve([]); }
  });
}

async function ollamaLoad(backendUrl, model, options = {}) {
  const url = backendUrl.replace(/\/$/, '') + '/api/generate';
  const body = JSON.stringify({ model, prompt: '', keep_alive: options.keepAlive || '60m', options: { num_ctx: options.numCtx || 65536 } });
  return new Promise((resolve, reject) => {
    const req = http.request(url, { method: 'POST', headers: { 'Content-Type': 'application/json' } }, res => {
      res.on('data', () => {}); // Drain
      res.on('end', () => resolve());
    });
    req.on('error', reject);
    req.write(body);
    req.end();
  });
}

async function ensureOllamaReadyOrSend(model, backendUrl, logicalRole, res) {
  debugLog('proxy.ollama.prepare.start', { model, backend_url: backendUrl, logical_role: logicalRole });
  const numCtx = (CONFIG.ollama_defaults && CONFIG.ollama_defaults.num_ctx) || 65536;
  
  try {
    await ollamaLoad(backendUrl, model, { numCtx });
    const maxWaitMs = 120000;
    const start = Date.now();
    while (Date.now() - start < maxWaitMs) {
      const active = await ollamaPs(backendUrl);
      if (active.some(m => m.name === model || m.name === model + ':latest')) {
        debugLog('proxy.ollama.prepare.ready', { model, backend_url: backendUrl });
        return true;
      }
      await new Promise(r => setTimeout(r, 1000));
    }
    throw new Error(`warming timeout for '${model}' after ${maxWaitMs}ms`);
  } catch (e) {
    proxyLog('ollama.warm.failure', { model, backend_url: backendUrl, error: e.message });
    send(res, 502, { error: `Ollama warming failed for '${model}': ${e.message}` });
    return false;
  }
}

async function forwardAnthropic(req, res, body, backend, effectiveModel, requestMeta) {
  const targetUrl = new URL(backend.url);
  const isHttps = targetUrl.protocol === 'https:';
  const lib = isHttps ? https : http;
  const authKey = backend.auth_env ? process.env[backend.auth_env] : '';
  
  const headers = { ...req.headers };
  delete headers.host;
  delete headers.connection;
  if (authKey) headers['x-api-key'] = authKey;
  
  const options = {
    hostname: targetUrl.hostname,
    port: targetUrl.port || (isHttps ? 443 : 80),
    path: targetUrl.pathname + targetUrl.search + (req.url.includes('?') ? '?' + req.url.split('?')[1] : ''),
    method: req.method,
    headers
  };

  const up = lib.request(options, upRes => {
    res.writeHead(upRes.statusCode, upRes.headers);
    upRes.pipe(res);
  });
  up.on('error', e => send(res, 502, { error: `backend anthropic at ${targetUrl.origin} error: ${e.message}` }));
  if (body) up.write(JSON.stringify(body));
  up.end();
}

function flattenMessagesForOllama(body) {
  const messages = Array.isArray(body.messages) ? [...body.messages] : [];
  
  // If Anthropic "system" field is present, prepend it as a system message for Ollama
  if (body.system) {
    let systemContent = '';
    if (typeof body.system === 'string') {
      systemContent = body.system;
    } else if (Array.isArray(body.system)) {
      systemContent = body.system
        .filter(c => c.type === 'text')
        .map(c => c.text)
        .join('\n');
    }
    if (systemContent) {
      messages.unshift({ role: 'system', content: systemContent });
    }
  }

  return messages.map(msg => {
    let content = '';
    if (typeof msg.content === 'string') {
      content = msg.content;
    } else if (Array.isArray(msg.content)) {
      content = msg.content
        .filter(c => c.type === 'text')
        .map(c => c.text)
        .join('\n');
    }
    return { role: msg.role, content };
  });
}

async function forwardOllama(req, res, body, backend, effectiveModel, requestMeta) {
  const url = backend.url.replace(/\/$/, '') + '/api/chat';
  const options = {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  };

  const up = http.request(url, options, upRes => {
    res.writeHead(upRes.statusCode, upRes.headers);
    upRes.pipe(res);
  });
  up.on('error', e => send(res, 502, { error: `backend ollama at ${backend.url} error: ${e.message}` }));
  up.write(JSON.stringify({
    model: effectiveModel,
    messages: flattenMessagesForOllama(body),
    stream: !!body.stream,
    options: { temperature: body.temperature || 0, num_ctx: body.num_ctx || 65536 }
  }));
  up.end();
}

function safeBuildForwardBody(req, res, body, resolved, errMsg) {

// ── Rolling log ───────────────────────────────────────────────────────
// Fixed path, 10 MB limit, 3 generations. Intercepts process.stderr so
// all console.error calls land here without touching existing call sites.

const PROXY_LOG_FILE = path.join(process.env.HOME || os.homedir(), '.claude', 'proxy.log');
const PROXY_LOG_MAX_BYTES = 10 * 1024 * 1024;
const PROXY_LOG_GENERATIONS = 3;
// Check rotation every N writes to amortise the statSync cost.
// At typical stderr line sizes (100-500 B) worst-case overshoot is ~100 KB.
const PROXY_LOG_ROTATION_CHECK_INTERVAL = 200;
let _proxyLogWrites = 0;

function rotateProxyLog() {
  // Drop oldest, shift remaining up, then move current → .1
  try { fs.unlinkSync(`${PROXY_LOG_FILE}.${PROXY_LOG_GENERATIONS}`); } catch {}
  for (let i = PROXY_LOG_GENERATIONS - 1; i >= 1; i--) {
    try { fs.renameSync(`${PROXY_LOG_FILE}.${i}`, `${PROXY_LOG_FILE}.${i + 1}`); } catch {}
  }
  try { fs.renameSync(PROXY_LOG_FILE, `${PROXY_LOG_FILE}.1`); } catch {}
}

function checkProxyLogRotation() {
  try {
    const stat = fs.statSync(PROXY_LOG_FILE, { throwIfNoEntry: false });
    if (stat && stat.size >= PROXY_LOG_MAX_BYTES) rotateProxyLog();
  } catch {}
}

(function installProxyLogInterceptor() {
  try { fs.mkdirSync(path.dirname(PROXY_LOG_FILE), { recursive: true }); } catch {}
  checkProxyLogRotation();
  const _orig = process.stderr.write.bind(process.stderr);
  process.stderr.write = function(chunk, encoding, callback) {
    try {
      const str = typeof chunk === 'string' ? chunk : chunk.toString('utf8');
      const ts = new Date().toISOString();
      const lines = str.split('\n');
      const trailingNewline = str.endsWith('\n');
      const body = (trailingNewline ? lines.slice(0, -1) : lines);
      const stamped = body.map(l => l ? `${ts} ${l}` : l).join('\n') + (trailingNewline ? '\n' : '');
      fs.appendFileSync(PROXY_LOG_FILE, stamped);
      if (++_proxyLogWrites % PROXY_LOG_ROTATION_CHECK_INTERVAL === 0) checkProxyLogRotation();
    } catch {}
    return _orig(chunk, encoding, callback);
  };
})();

// ── Config resolution ──────────────────────────────────────────────────

function canonicalizeDir(dir) {
  if (!dir || typeof dir !== 'string' || !dir.startsWith('/') || !fs.statSync(dir, { throwIfNoEntry: false })?.isDirectory()) return null;
  try { return fs.realpathSync(dir); } catch { return null; }
}

function canonicalizeFile(file) {
  if (!file || typeof file !== 'string' || !file.startsWith('/') || !fs.existsSync(file)) return null;
  const dir = canonicalizeDir(path.dirname(file));
  return dir ? path.join(dir, path.basename(file)) : null;
}

function findParentModelMap(dir) {
  const real = canonicalizeDir(dir);
  if (!real) return null;
  let cur = real;
  while (true) {
    const candidate = path.join(cur, '.claude', 'model-map.json');
    const realFile = canonicalizeFile(candidate);
    if (realFile) return realFile;
    if (cur === '/') break;
    cur = path.dirname(cur);
  }
  return null;
}

function repoDefaultsPath() {
  const candidate = canonicalizeFile(path.join(__dirname, '..', 'config', 'model-map.json'));
  return candidate || null;
}

function maybeSyncLayeredProfileModelMap() {
  const claudeDir = canonicalizeDir(process.env.CLAUDE_PROFILE_DIR || process.env.CLAUDE_DIR || process.env.CLAUDE_CONFIG_DIR || path.join(process.env.HOME || '', '.claude'));
  if (!claudeDir) return;
  // Prefer model-map.system.json (installed by install.sh) over the repo defaults so the
  // proxy works even when run from outside the repo. Fall back to the repo config/model-map.json.
  const systemPath = path.join(claudeDir, 'model-map.system.json');
  const defaultsPath = fs.existsSync(systemPath) ? systemPath : repoDefaultsPath();
  if (!defaultsPath) return;
  const overridesPath = path.join(claudeDir, 'model-map.overrides.json');
  if (!fs.existsSync(overridesPath)) return;
  const effectivePath = path.join(claudeDir, 'model-map.json');
  const syncTool = path.join(__dirname, 'model-map-sync.js');
  if (!fs.existsSync(syncTool)) return;
  try {
    const result = spawnSync(process.execPath, [syncTool, defaultsPath, overridesPath, effectivePath, effectivePath], { encoding: 'utf8', timeout: 5000 });
    if (result.status !== 0 && DEBUG) {
      console.error(`claude-proxy: layered model-map sync failed: ${result.stderr || result.stdout || 'unknown error'}`);
    }
  } catch {
    /* layered sync is best effort here */
  }
}

function resolveConfigPath() {
  maybeSyncLayeredProfileModelMap();
  const override = process.env.CLAUDE_MODEL_MAP_PATH;
  if (override) {
    const real = canonicalizeFile(override);
    if (real) return { path: real, source: 'override' };
  }

  const launchCwd = process.env.CLAUDE_MODEL_MAP_LAUNCH_CWD || process.cwd();

  // Check project dir env var
  const projectDir = process.env.CLAUDE_PROJECT_DIR;
  if (projectDir) {
    const real = canonicalizeFile(path.join(projectDir, '.claude', 'model-map.json'));
    if (real) return { path: real, source: 'project' };
  }

  // Walk upward from launch CWD
  const walked = findParentModelMap(launchCwd);
  if (walked) {
    // Skip if it's the same as the profile config
    const profileReal = canonicalizeFile(path.join(process.env.HOME || '', '.claude', 'model-map.json'));
    if (walked !== profileReal) return { path: walked, source: 'project' };
  }

  // Fallback to profile config
  const profileReal = canonicalizeFile(path.join(process.env.HOME || '', '.claude', 'model-map.json'));
  if (profileReal) return { path: profileReal, source: 'profile' };

  return null;
}


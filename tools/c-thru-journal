#!/bin/bash
# c-thru-journal v2: Code-Only Journaling
ACTION=$1
MESSAGE=$2

if [[ -z "$MESSAGE" ]]; then
    MESSAGE="Manual improvement"
fi

git add .
git reset supervisor_wiki.jsonl > /dev/null 2>&1
git reset supervisor_state.md > /dev/null 2>&1

case $ACTION in
    pass)
        git commit -m "eval-pass: $MESSAGE"
        ;;
    fail)
        git commit -m "eval-fail: $MESSAGE"
        ;;
    *)
        git commit -m "journal: $MESSAGE"
        ;;
esac

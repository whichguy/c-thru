#!/bin/bash
# c-thru — route Claude Code to any model provider
# Model lookup: 1) model-map.json model_routes+backends  2) local Ollama tag match  3) assume Ollama (passthrough)
# Supports: Ollama (local), OpenRouter, LiteLLM, Bedrock, Vertex, any custom endpoint.
#
# Installed as ~/.claude/bin/claude (first on PATH): locates the real claude binary
# later in PATH, applies routing env, and exec's it. Ollama backends use
# claude-proxy (Anthropic-compatible) + model-map remapping; Anthropic/OpenRouter
# backends talk to their URLs directly.
#
# Usage: c-thru                           — use routes.default when present, else transparent proxy fallback
#        c-thru --route background        — named route → --model (see model-map routes)
#        c-thru --model gemma4:26b        — Ollama (auto-detected)
#        c-thru --model bedrock-opus      — Bedrock (from model-map.json)
#        c-thru --model opus              — Ollama if not in model-map (name passed through)
#        c-thru --mode offline            — force LLM mode for this invocation (stripped before forwarding)
#        c-thru --profile 64gb           — force hardware tier (stripped before forwarding)
#        c-thru --list                    — show all available models
#        c-thru --help                    — show usage
#
# Escape hatch: CLAUDE_PROXY_BYPASS=1 — skip proxy URL (transparent path only).
# For Ollama-bound launches, match the direct Claude→Ollama client env as closely as possible:
#   ANTHROPIC_AUTH_TOKEN=ollama
#   ANTHROPIC_API_KEY=""
# Mixed-backend transparent configs still fall back to the legacy placeholder-key behavior.
# Debug: C_THRU_DEBUG=1 — print resolved env to stderr (transparent and routed).
#          C_THRU_DEBUG=2 — same plus proxy port, OLLAMA_*, placeholder flag, route keys sample.
#          CLAUDE_PROXY_DEBUG=1/2 — enable proxy-side debug logs (router forwards inherited env when spawning the proxy).
set -eo pipefail

# ── Color output — respects NO_COLOR and non-tty ────────────────────────────
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ] && [ "${TERM:-}" != "dumb" ]; then
  RED=$'\033[0;31m'
  GREEN=$'\033[0;32m'
  YELLOW=$'\033[1;33m'
  GRAY=$'\033[0;90m'
  BOLD=$'\033[1m'
  NC=$'\033[0m'
else
  RED='' GREEN='' YELLOW='' GRAY='' BOLD='' NC=''
fi

CONFIG=""
CONFIG_SOURCE="absent"
LAUNCH_CWD="$(pwd -P 2>/dev/null || pwd)"
LAUNCH_PROJECT_DIR=""
ORIGINAL_CLAUDE_PROFILE_DIR="${CLAUDE_DIR:-${CLAUDE_CONFIG_DIR:-$HOME/.claude}}"
CLAUDE_PROFILE_DIR="$ORIGINAL_CLAUDE_PROFILE_DIR"
OLLAMA_URL="${OLLAMA_BASE_URL:-http://localhost:11434}"
# CLAUDE_PROXY_PORT is intentionally NOT defaulted here.  When unset the proxy
# binds to port 0 (OS-assigned free port), enabling one independent proxy per
# shell.  Set CLAUDE_PROXY_PORT explicitly only when you need a fixed port
# (e.g. c-thru reload, c-thru restart, or direct ANTHROPIC_BASE_URL targeting).
export CLAUDE_PROXY_PORT
# Backward-compat aliases: CLAUDE_ROUTER_* → C_THRU_* (deprecated names still accepted)
[[ -n "${CLAUDE_ROUTER_DEBUG:-}"                ]] && C_THRU_DEBUG="${CLAUDE_ROUTER_DEBUG}"
[[ -n "${CLAUDE_ROUTER_NO_UPDATE:-}"            ]] && C_THRU_NO_UPDATE="${CLAUDE_ROUTER_NO_UPDATE}"
[[ -n "${CLAUDE_ROUTER_NO_COLOR:-}"             ]] && NO_COLOR="${CLAUDE_ROUTER_NO_COLOR}"
[[ -n "${CLAUDE_ROUTER_UPDATE_INTERVAL:-}"      ]] && C_THRU_UPDATE_INTERVAL="${CLAUDE_ROUTER_UPDATE_INTERVAL}"
[[ -n "${CLAUDE_ROUTER_OLLAMA_AUTOSTART:-}"     ]] && C_THRU_OLLAMA_AUTOSTART="${CLAUDE_ROUTER_OLLAMA_AUTOSTART}"
[[ -n "${CLAUDE_ROUTER_SKIP_PROXY_AUTOSTART:-}" ]] && C_THRU_SKIP_PROXY_AUTOSTART="${CLAUDE_ROUTER_SKIP_PROXY_AUTOSTART}"

PROXY_STARTED_PID=""
CLAUDE_CHILD_PID=""
PROXY_CLEANUP_ARMED=0
PROXY_PORT=""
ENSURED_PROXY_HTTP_BASE=""
PROXY_LOG_PATH=""
OLLAMA_PREP_SWEEP_STARTED=0
OLLAMA_PREP_STATE_FILE="${C_THRU_OLLAMA_PREP_STATE_FILE:-$CLAUDE_PROFILE_DIR/ollama-prep-state.json}"
OLLAMA_PREP_REFRESH_DAYS="${C_THRU_OLLAMA_REFRESH_DAYS:-7}"
OLLAMA_PREP_MIN_RETRY_SECONDS="${C_THRU_OLLAMA_PREP_MIN_RETRY_SECONDS:-86400}"
OLLAMA_INSTALL_MIN_RETRY_SECONDS="${C_THRU_OLLAMA_INSTALL_MIN_RETRY_SECONDS:-86400}"
OLLAMA_CLOUD_AUTH_TIMEOUT_SECONDS="${C_THRU_OLLAMA_AUTH_TIMEOUT_SECONDS:-10}"
OLLAMA_CLOUD_AUTH_VALIDATED=0
OLLAMA_CLOUD_SIGNIN_ATTEMPTED=0
LLM_PROFILE_CACHE_INITIALIZED=0
LLM_PROFILE_CACHE_NAME=""
LLM_PROFILE_CACHE_SOURCE=""
LLM_PROFILE_CACHE_MEMORY_GB=""
PROXY_PROFILE_SUMMARY_LOGGED=0
EPHEMERAL_SESSION_DIR=""
EPHEMERAL_SETTINGS_FILE=""
EPHEMERAL_AGENTS_JSON=""

# Canonical path of this script (for PATH walk — skip ourselves when installed as `claude`).
CTHRU_SELF_REAL="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
CTHRU_SELF_DIR="$(dirname "$CTHRU_SELF_REAL")"
CTHRU_REPO_ROOT="$(cd "$CTHRU_SELF_DIR/.." 2>/dev/null && pwd -P || true)"
MODEL_MAP_DEFAULTS_FILE="${CLAUDE_MODEL_MAP_DEFAULTS_PATH:-$CTHRU_REPO_ROOT/config/model-map.json}"
MODEL_MAP_OVERRIDES_FILE="${CLAUDE_MODEL_MAP_OVERRIDES_PATH:-$CLAUDE_PROFILE_DIR/model-map.overrides.json}"
MODEL_MAP_SYNC_STATE_FILE="${CLAUDE_MODEL_MAP_SYNC_STATE_FILE:-$CLAUDE_PROFILE_DIR/model-map-defaults-sync.json}"
MODEL_MAP_GIT_PULL_MIN_RETRY_SECONDS="${CLAUDE_MODEL_MAP_GIT_PULL_MIN_RETRY_SECONDS:-21600}"

canonicalize_dir() {
  local dir="$1"
  [[ -n "$dir" && "$dir" == /* && -d "$dir" ]] || return 1
  (cd "$dir" 2>/dev/null && pwd -P)
}

canonicalize_file() {
  local file="$1"
  [[ -n "$file" && "$file" == /* && -f "$file" ]] || return 1
  local real_dir
  real_dir="$(canonicalize_dir "$(dirname "$file")")" || return 1
  printf '%s/%s' "$real_dir" "$(basename "$file")"
}

layered_profile_model_map_enabled() {
  [[ -f "$MODEL_MAP_DEFAULTS_FILE" && -f "$MODEL_MAP_OVERRIDES_FILE" ]]
}

maybe_refresh_model_map_defaults_from_git() {
  # Superseded by c-thru-self-update.sh (has dirty-tree guard, debounce,
  # self_update override, and bounded logging). Kept as a no-op so any
  # external callers don't break on older installs that reference this name.
  true
}

sync_layered_profile_model_map() {
  local sync_tool="$CTHRU_SELF_DIR/model-map-sync.js"
  [[ -f "$sync_tool" ]] || return 0
  command -v node >/dev/null 2>&1 || return 0

  # 3-Tier Sync: Defaults -> Global Overrides -> Project Overrides (stored in _discovered_project_config)
  node "$sync_tool" "$MODEL_MAP_DEFAULTS_FILE" "$MODEL_MAP_OVERRIDES_FILE" "${_discovered_project_config:-}" "$CLAUDE_PROFILE_DIR/model-map.json" >/dev/null
  # Apply recommended-mappings.json as lowest-precedence tier (no-op if absent)
  local rec_tool="$CTHRU_SELF_DIR/model-map-apply-recommendations.js"
  if [[ -f "$rec_tool" && -n "$CTHRU_REPO_ROOT" ]]; then
    local _tmp="$CLAUDE_PROFILE_DIR/model-map.json.rec.$$"
    if node "$rec_tool" "$CTHRU_REPO_ROOT" "$CLAUDE_PROFILE_DIR/model-map.json" > "$_tmp" 2>/dev/null; then
      mv "$_tmp" "$CLAUDE_PROFILE_DIR/model-map.json"
    else
      rm -f "$_tmp"
    fi
  fi
}

find_parent_model_map() {
  local dir="$1"
  dir="$(canonicalize_dir "$dir")" || return 1
  while :; do
    local candidate="$dir/.claude/model-map.json"
    if [[ -f "$candidate" ]]; then
      canonicalize_file "$candidate"
      return 0
    fi
    [[ "$dir" == "/" ]] && break
    dir="$(dirname "$dir")"
  done
  return 1
}

# ARCH: resolve_model_map_config — 3-tier config selection: env override → project-local → profile.
#   Tier 1: CLAUDE_MODEL_MAP_PATH (explicit override) — must be an absolute readable file.
#   Tier 2: project-local (.claude/model-map.json at git root or walked up from CWD) — selected
#           by precedence only; NOT merged on top of the profile graph.
#   Tier 3: ~/.claude/model-map.json (profile graph, the only layered graph).
#   Sets CONFIG and CONFIG_SOURCE globals; returns 1 only if all tiers are absent.
resolve_model_map_config() {
  local override="${CLAUDE_MODEL_MAP_PATH:-}"
  local profile_real=""
  profile_real="$(canonicalize_file "$CLAUDE_PROFILE_DIR/model-map.json" 2>/dev/null || true)"
  if [[ -n "$override" ]]; then
    local override_real
    override_real="$(canonicalize_file "$override" 2>/dev/null || true)"
    if [[ -n "$override_real" ]]; then
      CONFIG="$override_real"
      CONFIG_SOURCE="override"
      return 0
    fi
    echo "c-thru: ignoring CLAUDE_MODEL_MAP_PATH because it is not an absolute readable file: $override" >&2
  fi

  local git_root=""
  git_root="$(git -C "$LAUNCH_CWD" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -n "$git_root" ]]; then
    local project_config="$git_root/.claude/model-map.json"
    local project_real
    project_real="$(canonicalize_file "$project_config" 2>/dev/null || true)"
    if [[ -n "$project_real" ]]; then
      CONFIG="$project_real"
      CONFIG_SOURCE="project"
      return 0
    fi
  fi

  local walked=""
  walked="$(find_parent_model_map "$LAUNCH_CWD" 2>/dev/null || true)"
  if [[ -n "$walked" && "$walked" != "$profile_real" ]]; then
    CONFIG="$walked"
    CONFIG_SOURCE="project"
    return 0
  fi

  if [[ -n "$profile_real" ]]; then
    CONFIG="$profile_real"
    CONFIG_SOURCE="profile"
    return 0
  fi

  # Repo root fallback (for running directly from source)
  local repo_config="$CTHRU_REPO_ROOT/config/model-map.json"
  local repo_real
  repo_real="$(canonicalize_file "$repo_config" 2>/dev/null || true)"
  if [[ -n "$repo_real" ]]; then
    CONFIG="$repo_real"
    CONFIG_SOURCE="repo"
    return 0
  fi

  CONFIG=""
  CONFIG_SOURCE="absent"
  return 1
}

# ARCH: setup_ephemeral_session — creates a per-session tmpdir that shadows ~/.claude so
#   the injected settings.json, agents, and skills don't pollute the user's permanent config.
#   settings.json is written LATER by write_ephemeral_settings() once the proxy port is known;
#   only the directory skeleton (symlinks + agent/skill dirs) is built here.
#   No-op when CLAUDE_PROXY_BYPASS=1 — the session is transparent so injection is unnecessary.
setup_ephemeral_session() {
  # Skip if bypass requested
  [[ "${CLAUDE_PROXY_BYPASS:-0}" == "1" ]] && return 0
  
  EPHEMERAL_SESSION_DIR=$(mktemp -d "${TMPDIR:-/tmp}/c-thru-session.XXXXXXXX")
  EPHEMERAL_SETTINGS_FILE="$EPHEMERAL_SESSION_DIR/settings.json"
  
  # 1. Shadow the entire .claude directory to make the session fully ephemeral
  # Link everything except what we override (settings, agents, skills) or what causes noise (backups)
  local item name
  # Use ls -A to catch hidden files
  while IFS= read -r name; do
    [[ -z "$name" ]] && continue
    item="$ORIGINAL_CLAUDE_PROFILE_DIR/$name"
    [[ "$name" == "settings.json" || "$name" == "agents" || "$name" == "skills" || "$name" == "backups" ]] && continue
    ln -s "$item" "$EPHEMERAL_SESSION_DIR/$name" 2>/dev/null || true
  done < <(ls -A "$ORIGINAL_CLAUDE_PROFILE_DIR" 2>/dev/null)

  # 2. Additive config: Copy the global .claude.json into the session dir
  # This avoids "config file not found" warnings when CLAUDE_CONFIG_DIR is redirected.
  if [[ -f "$HOME/.claude.json" ]]; then
    cp "$HOME/.claude.json" "$EPHEMERAL_SESSION_DIR/.claude.json" 2>/dev/null || true
  fi

  # 3. Additive Skills: merge user skills and c-thru skills
  mkdir -p "$EPHEMERAL_SESSION_DIR/skills"
  # Link user's existing skills first
  if [[ -d "$ORIGINAL_CLAUDE_PROFILE_DIR/skills" ]]; then
    while IFS= read -r name; do
      [[ -z "$name" ]] && continue
      ln -s "$ORIGINAL_CLAUDE_PROFILE_DIR/skills/$name" "$EPHEMERAL_SESSION_DIR/skills/$name" 2>/dev/null || true
    done < <(ls -A "$ORIGINAL_CLAUDE_PROFILE_DIR/skills" 2>/dev/null)
  fi
  # Link c-thru skills (additive, namespaced under c-thru)
  mkdir -p "$EPHEMERAL_SESSION_DIR/skills/c-thru"
  if [[ -d "$CTHRU_REPO_ROOT/skills" ]]; then
    for item in "$CTHRU_REPO_ROOT/skills"/*/; do
      [ -d "$item" ] || continue
      ln -s "${item%/}" "$EPHEMERAL_SESSION_DIR/skills/c-thru/$(basename "$item")" 2>/dev/null || true
    done
  fi

  # 3. Additive Agents: link c-thru agents (namespaced)
  # Linking is more reliable than --agents flag for preserving frontmatter (like "model:")
  # But we also populate --agents JSON for agents that Claude Code might not find via filesystem
  if [[ "${NO_AGENTS:-0}" != "1" ]]; then
    mkdir -p "$EPHEMERAL_SESSION_DIR/agents"
    # Link user's existing agents first
    if [[ -d "$ORIGINAL_CLAUDE_PROFILE_DIR/agents" ]]; then
      while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        ln -s "$ORIGINAL_CLAUDE_PROFILE_DIR/agents/$name" "$EPHEMERAL_SESSION_DIR/agents/$name" 2>/dev/null || true
      done < <(ls -A "$ORIGINAL_CLAUDE_PROFILE_DIR/agents" 2>/dev/null)
    fi
    # Link c-thru agents
    if [[ -d "$CTHRU_REPO_ROOT/agents" ]]; then
      for item in "$CTHRU_REPO_ROOT/agents"/*.md; do
        [ -f "$item" ] || continue
        ln -s "$item" "$EPHEMERAL_SESSION_DIR/agents/$(basename "$item")" 2>/dev/null || true
      done
    fi

    # Generate --agents JSON for robust discovery
    EPHEMERAL_AGENTS_JSON=$(node -e '
      const fs = require("fs");
      const path = require("path");
      const agentsDir = process.argv[1];
      const agents = {};
      if (fs.existsSync(agentsDir)) {
        fs.readdirSync(agentsDir).forEach(file => {
          if (!file.endsWith(".md")) return;
          const name = file.replace(".md", "");
          const content = fs.readFileSync(path.join(agentsDir, file), "utf8");
          const m = content.match(/^---\r?\n([\s\S]*?)\n---\r?\n/);
          let description = "";
          let prompt = content;
          let model = name;
          let tier_budget = 999999;
          
          if (m) {
            const frontmatter = m[1];
            const descMatch = frontmatter.match(/^description:\s*(.*)$/m);
            if (descMatch) description = descMatch[1].trim();
            
            const modelMatch = frontmatter.match(/^model:\s*(.*)$/m);
            if (modelMatch) model = modelMatch[1].trim();

            const budgetMatch = frontmatter.match(/^tier_budget:\s*(.*)$/m);
            if (budgetMatch) tier_budget = parseInt(budgetMatch[1].trim(), 10);

            prompt = content.slice(m[0].length).trim();
          }
          agents[name] = { 
            description, 
            prompt,
            model,
            tier_budget
          };
        });
      }
      console.log(JSON.stringify(agents));
    ' "$EPHEMERAL_SESSION_DIR/agents")
  fi

  # 4. Export the ephemeral config dir for the child process
  export CLAUDE_CONFIG_DIR="$EPHEMERAL_SESSION_DIR"
  export CLAUDE_PROFILE_DIR="$EPHEMERAL_SESSION_DIR"
  # settings.json is written later by write_ephemeral_settings() once the proxy
  # port is known (after the READY handshake).
}

cleanup_ephemeral_session() {
  if [[ -n "$EPHEMERAL_SESSION_DIR" && -d "$EPHEMERAL_SESSION_DIR" ]]; then
    rm -rf "$EPHEMERAL_SESSION_DIR"
  fi
}

# Write (or rewrite) the ephemeral settings.json from scratch using the now-known proxy port.
# Called after the proxy READY handshake so PROXY_PORT is set.
# No-op in bypass mode (EPHEMERAL_SETTINGS_FILE is empty).
# If PROXY_PORT is empty (non-Ollama cloud path), writes settings without the
# SessionStart HTTP hook — command hooks still fire, proxy context injection is skipped.
write_ephemeral_settings() {
  [[ -n "${EPHEMERAL_SETTINGS_FILE:-}" ]] || return 0
  local port="${PROXY_PORT:-}"
  local tools_dest="$CTHRU_SELF_DIR"

  # Resolve actual path for a tool (checks for .sh suffix too).
  find_tool_path() {
    local base="$1"
    if [[ -x "$tools_dest/$base" ]]; then echo "$tools_dest/$base";
    elif [[ -x "$tools_dest/$base.sh" ]]; then echo "$tools_dest/$base.sh";
    else echo "$tools_dest/$base"; fi
  }

  local session_cmd health_cmd classify_cmd map_changed_cmd postcompact_cmd planner_hint_cmd mcp_js
  session_cmd="$(find_tool_path c-thru-session-start)"
  health_cmd="$(find_tool_path c-thru-proxy-health)"
  classify_cmd="$(find_tool_path c-thru-classify)"
  map_changed_cmd="$(find_tool_path c-thru-map-changed)"
  postcompact_cmd="$(find_tool_path c-thru-postcompact-context)"
  planner_hint_cmd="$(find_tool_path c-thru-enter-plan-hook)"
  mcp_js="$(find_tool_path llm-capabilities-mcp.js)"

  # Hook inventory — every hook registered per session. To add a hook:
  #   1. Create tools/c-thru-<name>.sh with a # ARCH: <Event>/<matcher> header line.
  #   2. Add a find_tool_path variable above.
  #   3. Add one line to the appropriate event array below.
  # No persistent writes to ~/.claude/settings.json — all hooks are ephemeral.
  #
  # Event            Matcher         Script                    Purpose
  # SessionStart     (all)           hooks/context (HTTP)      classify_intent context injection (proxy only)
  # SessionStart     (all)           c-thru-session-start      proxy+Ollama health check
  # PostCompact      (all)           c-thru-postcompact-context re-inject context after compaction
  # UserPromptSubmit *               c-thru-proxy-health       asyncRewake if proxy down
  # UserPromptSubmit *               c-thru-classify           classify_intent tagging
  # PostToolUse      *               c-thru-map-changed        validate model-map.json on edit
  # PreToolUse       EnterPlanMode   c-thru-enter-plan-hook    advisory hint for /c-thru-plan

  if [[ -n "$port" ]]; then
    local hooks_url="http://127.0.0.1:${port}/hooks/context"
    cat > "$EPHEMERAL_SETTINGS_FILE" <<EOF
{
  "mcpServers": {
    "llm-capabilities": {
      "type": "stdio",
      "command": "node",
      "args": ["$mcp_js"]
    }
  },
  "hooks": {
    "SessionStart": [{"hooks": [{"type": "http", "url": "$hooks_url", "timeout": 3}, {"type": "command", "command": "$session_cmd", "timeout": 5}]}],
    "PostCompact": [{"hooks": [{"type": "command", "command": "$postcompact_cmd", "timeout": 5}]}],
    "UserPromptSubmit": [
      {"matcher": "*", "hooks": [{"type": "command", "command": "$health_cmd", "timeout": 3, "async": true, "asyncRewake": true}]},
      {"matcher": "*", "hooks": [{"type": "command", "command": "$classify_cmd", "timeout": 5, "async": true}]}
    ],
    "PostToolUse": [{"matcher": "*", "hooks": [{"type": "command", "command": "$map_changed_cmd", "timeout": 5}]}],
    "PreToolUse": [{"matcher": "EnterPlanMode", "hooks": [{"type": "command", "command": "$planner_hint_cmd", "timeout": 3}]}]
  },
  "permissions": {
    "allow": ["mcp__llm-capabilities__*"]
  }
}
EOF
  else
    # No proxy port (non-Ollama cloud path) — omit the SessionStart HTTP hook
    cat > "$EPHEMERAL_SETTINGS_FILE" <<EOF
{
  "mcpServers": {
    "llm-capabilities": {
      "type": "stdio",
      "command": "node",
      "args": ["$mcp_js"]
    }
  },
  "hooks": {
    "SessionStart": [{"hooks": [{"type": "command", "command": "$session_cmd", "timeout": 5}]}],
    "PostCompact": [{"hooks": [{"type": "command", "command": "$postcompact_cmd", "timeout": 5}]}],
    "UserPromptSubmit": [
      {"matcher": "*", "hooks": [{"type": "command", "command": "$health_cmd", "timeout": 3, "async": true, "asyncRewake": true}]},
      {"matcher": "*", "hooks": [{"type": "command", "command": "$classify_cmd", "timeout": 5, "async": true}]}
    ],
    "PostToolUse": [{"matcher": "*", "hooks": [{"type": "command", "command": "$map_changed_cmd", "timeout": 5}]}],
    "PreToolUse": [{"matcher": "EnterPlanMode", "hooks": [{"type": "command", "command": "$planner_hint_cmd", "timeout": 3}]}]
  },
  "permissions": {
    "allow": ["mcp__llm-capabilities__*"]
  }
}
EOF
  fi
}

resolve_launch_project_dir() {
  local override="${CLAUDE_PROJECT_DIR:-}"
  if [[ -n "$override" ]]; then
    local override_real
    override_real="$(canonicalize_dir "$override" 2>/dev/null || true)"
    if [[ -n "$override_real" ]]; then
      LAUNCH_PROJECT_DIR="$override_real"
      return 0
    fi
  fi

  local git_root=""
  git_root="$(git -C "$LAUNCH_CWD" rev-parse --show-toplevel 2>/dev/null || true)"
  if [[ -n "$git_root" ]]; then
    local git_root_real
    git_root_real="$(canonicalize_dir "$git_root" 2>/dev/null || true)"
    if [[ -n "$git_root_real" ]]; then
      LAUNCH_PROJECT_DIR="$git_root_real"
      return 0
    fi
  fi

  LAUNCH_PROJECT_DIR=""
  return 1
}

# --- --help / -h subcommand ---
# Defined here — before the config-sync/startup block — so that
# 'c-thru --help' works even when model-map.json is absent or invalid.
cmd_help() {
  echo -e "${BOLD}c-thru${NC} — route Claude Code to alternative model providers"
  echo ""
  echo -e "${BOLD}Usage:${NC}"
  echo "  c-thru [--route <name>] [--model <name>] [--local-only] [--best-cloud] [claude args...]"
  echo "  c-thru <subcommand> [options]"
  echo ""
  echo -e "${BOLD}Subcommands${NC} ${GRAY}(operate on c-thru itself):${NC}"
  echo -e "  ${GRAY}Lifecycle:${NC}"
  echo "  reload                    send SIGHUP to running proxy; confirm via /ping"
  echo "  restart [--force]         stop and re-spawn proxy (--force escalates to SIGKILL)"
  echo -e "  ${GRAY}Audit:${NC}"
  echo "  check-deps [--fix]        audit system deps; --fix installs missing optional tools via brew"
  echo -e "  ${GRAY}Introspection:${NC}"
  echo "  list                      show active hw profile, routes, and local Ollama models"
  echo "  explain <args>            print resolution chain for a hypothetical request (--help for args)"
  echo "  help                      show this help (also: --help, -h)"
  echo ""
  echo -e "${BOLD}Flags${NC} ${GRAY}(stripped before forwarding to claude):${NC}"
  echo "  --route <name>            use a named route from model-map.json"
  echo "  --model <model>           override model for this invocation"
  echo "  --local-only              synonym for --mode local-only"
  echo "  --offline                 synonym for --mode offline"
  echo "  --best-cloud              synonym for --mode cloud-best-quality"
  echo "  --best-opensource-cloud   synonym for --mode best-opensource-cloud"
  echo "  --best-opensource-local   synonym for --mode best-opensource-local"
  echo "  --best-opensource         synonym for --mode best-opensource"

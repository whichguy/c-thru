# --- reload / restart management subcommands ---
# Placed before ORIG_ARGS parsing so they're accessible even if the main launch path
# would be blocked (e.g., stale config causing validate_model_map_config to error).

# ARCH: cmd_reload — sends SIGHUP to the running proxy and confirms it survived the reload.
#   Port is derived from lsof on the live PID (not from config), so it works even when the
#   proxy was started on a dynamic OS-assigned port rather than CLAUDE_PROXY_PORT.
#   Falls back to CLAUDE_PROXY_PORT when lsof is unavailable; fails if neither is known.
#   Polls /ping for up to 2 s (20 × 100 ms) after SIGHUP to catch immediate crashes
#   (e.g., invalid model-map.json committed while the proxy is live).
cmd_reload() {
  local pid_file="$CLAUDE_PROFILE_DIR/proxy.pid"

  if [[ ! -f "$pid_file" ]]; then
    echo "c-thru reload: no proxy PID file at $pid_file — proxy may not be running" >&2
    echo "  the next 'c-thru' invocation will auto-spawn a fresh proxy" >&2
    return 1
  fi

  local proxy_pid
  proxy_pid="$(cat "$pid_file" 2>/dev/null)"
  if [[ -z "$proxy_pid" ]]; then
    echo "c-thru reload: PID file is empty — proxy may not be running" >&2
    return 1
  fi

  if ! kill -0 "$proxy_pid" 2>/dev/null; then
    echo "c-thru reload: pid $proxy_pid is not running (stale PID file at $pid_file)" >&2
    return 1
  fi

  if ! kill -HUP "$proxy_pid" 2>/dev/null; then
    echo "c-thru reload: failed to send SIGHUP to pid $proxy_pid" >&2
    return 1
  fi

  # Derive the actual listening port from lsof (proxy port is dynamic when CLAUDE_PROXY_PORT
  # is unset — the router learns it from the READY <port> handshake, not a fixed default).
  # Fall back to CLAUDE_PROXY_PORT when lsof is unavailable; fail if neither is known.
  local proxy_port=""
  if command -v lsof >/dev/null 2>&1; then
    proxy_port="$(lsof -iTCP -sTCP:LISTEN -n -P -p "$proxy_pid" 2>/dev/null | awk 'NR>1{print $9}' | grep -oE '[0-9]+$' | head -1 || true)"
  fi
  [[ -z "$proxy_port" ]] && proxy_port="${CLAUDE_PROXY_PORT:-}"
  if [[ -z "$proxy_port" ]]; then
    echo "c-thru: reload: cannot determine proxy port (lsof unavailable and CLAUDE_PROXY_PORT not set)" >&2
    return 1
  fi

  # Poll /ping for up to 2s to confirm proxy is still alive after config reload.
  local i
  local ping_json=""
  for ((i = 0; i < 20; i++)); do
    if ping_json="$(proxy_ping_json "$proxy_port")"; then
      break
    fi
    sleep 0.1
  done

  if [[ -z "$ping_json" ]]; then
    echo "c-thru reload: SIGHUP sent but proxy not responding on :$proxy_port — may have crashed" >&2
    return 1
  fi

  local new_tier=""
  if command -v jq >/dev/null 2>&1; then
    new_tier="$(jq -r '.active_tier // empty' 2>/dev/null <<< "$ping_json" || true)"
  fi
  echo "c-thru reload: proxy reloaded (pid $proxy_pid, port $proxy_port${new_tier:+, tier: $new_tier})"
  return 0
}

# ARCH: cmd_restart — SIGTERM + wait-for-listener-gone, then re-spawns a fresh proxy process.
#   Does NOT inherit the old port by default; the new proxy picks an OS-assigned port unless
#   CLAUDE_PROXY_PORT is set. This means the next c-thru session will negotiate a new port
#   via the READY <port> FIFO handshake in ensure_proxy_running.
#   --force escalates to SIGKILL when SIGTERM is ignored (e.g., busy GC, hung syscall).
#   Port is derived from lsof on the live PID before signaling — same rationale as cmd_reload.
cmd_restart() {
  local force=0
  [[ "${2:-}" == "--force" ]] && force=1

  local pid_file="$CLAUDE_PROFILE_DIR/proxy.pid"
  local proxy_pid=""
  local old_port=""

  if [[ -f "$pid_file" ]]; then
    proxy_pid="$(cat "$pid_file" 2>/dev/null)"
  fi

  # Derive the actual listening port from lsof before signaling; the proxy port is
  # dynamic when CLAUDE_PROXY_PORT is unset — guessing 9997 is unsafe.
  if [[ -n "$proxy_pid" ]] && kill -0 "$proxy_pid" 2>/dev/null && command -v lsof >/dev/null 2>&1; then
    old_port="$(lsof -iTCP -sTCP:LISTEN -n -P -p "$proxy_pid" 2>/dev/null | awk 'NR>1{print $9}' | grep -oE '[0-9]+$' | head -1 || true)"
  fi
  [[ -z "$old_port" ]] && old_port="${CLAUDE_PROXY_PORT:-}"
  if [[ -z "$old_port" ]]; then
    echo "c-thru: restart: cannot determine proxy port (lsof unavailable and CLAUDE_PROXY_PORT not set)" >&2
    return 1
  fi

  # If PID file didn't resolve a running process, fall back to lsof on the guessed port.
  if [[ -z "$proxy_pid" ]] || ! kill -0 "$proxy_pid" 2>/dev/null; then
    proxy_pid="$(proxy_listener_pid "$old_port" || true)"
  fi

  if [[ -n "$proxy_pid" ]] && kill -0 "$proxy_pid" 2>/dev/null; then
    echo "c-thru restart: stopping proxy (pid $proxy_pid, port $old_port)..." >&2
    kill -TERM "$proxy_pid" 2>/dev/null || true
    if ! wait_proxy_listener_gone "$old_port" 50; then
      if [[ "$force" -eq 1 ]]; then
        echo "c-thru restart: proxy did not stop after SIGTERM — sending SIGKILL" >&2
        kill -KILL "$proxy_pid" 2>/dev/null || true
        wait_proxy_listener_gone "$old_port" 30 || true
      else
        echo "c-thru restart: proxy did not stop within 5s — use 'c-thru restart --force'" >&2
        return 1
      fi
    fi
  else
    echo "c-thru restart: no running proxy found — spawning fresh..." >&2
  fi

  local proxy_js="$CLAUDE_PROFILE_DIR/tools/claude-proxy"
  if [[ ! -f "$proxy_js" ]]; then
    echo "c-thru restart: claude-proxy not found at $proxy_js — run install.sh" >&2
    return 1
  fi

  local startup_tag temp_log ready_pipe ready_line
  startup_tag="${$}.$RANDOM"
  temp_log="$(mktemp "${TMPDIR:-/tmp}/claude-proxy-restart-${startup_tag}.log" 2>/dev/null || true)"
  [[ -n "$temp_log" ]] || temp_log="/dev/null"
  ready_pipe="$CLAUDE_PROFILE_DIR/proxy.restart.${startup_tag}.pipe"
  rm -f "$ready_pipe"

  if [[ -n "${CLAUDE_PROXY_PORT:-}" ]]; then
    # Explicit port: proxy writes no READY line; poll directly.
    "$proxy_js" >/dev/null 2>"$temp_log" &
    local new_pid="$!"
    disown "$new_pid" 2>/dev/null || true
    local new_port="$CLAUDE_PROXY_PORT"
    if wait_proxy_ping_ready "$new_port" 50; then
      local ping_json new_tier=""
      ping_json="$(proxy_ping_json "$new_port")"
      if command -v jq >/dev/null 2>&1; then
        new_tier="$(jq -r '.active_tier // empty' 2>/dev/null <<< "$ping_json" || true)"
      fi
      echo "c-thru restart: proxy started (pid $new_pid, port $new_port${new_tier:+, tier: $new_tier})"
      return 0
    fi
  else
    # Dynamic port: capture READY <port> line from stdout via a fifo.
    if ! mkfifo "$ready_pipe" 2>/dev/null; then
      # fifo unavailable — spawn without readiness detection (best-effort fallback)
      "$proxy_js" >/dev/null 2>"$temp_log" &
      disown $! 2>/dev/null || true
      echo "c-thru restart: spawned proxy (readiness unknown — mkfifo unavailable)" >&2
      return 0
    fi
    "$proxy_js" >"$ready_pipe" 2>"$temp_log" &
    local new_pid="$!"
    disown "$new_pid" 2>/dev/null || true
    local ready_timeout="${CLAUDE_PROXY_READY_TIMEOUT_SECONDS:-45}"
    if IFS= read -r -t "$ready_timeout" ready_line <"$ready_pipe" && [[ "$ready_line" =~ ^READY\ ([0-9]+)$ ]]; then
      rm -f "$ready_pipe"
      local new_port="${BASH_REMATCH[1]}"
      local ping_json new_tier=""
      ping_json="$(proxy_ping_json "$new_port" || true)"
      if command -v jq >/dev/null 2>&1 && [[ -n "$ping_json" ]]; then
        new_tier="$(jq -r '.active_tier // empty' 2>/dev/null <<< "$ping_json" || true)"
      fi
      echo "c-thru restart: proxy started (pid $new_pid, port $new_port${new_tier:+, tier: $new_tier})"
      return 0
    fi
    rm -f "$ready_pipe"
  fi

  echo "c-thru restart: proxy did not become ready within 5s" >&2
  if [[ -s "$temp_log" ]]; then
    tail -5 "$temp_log" | sed 's/^/  /' >&2
  fi
  return 1
}

if [[ "${1:-}" == "reload" ]]; then
  cmd_reload; exit $?
fi

if [[ "${1:-}" == "restart" ]]; then
  cmd_restart "$@"; exit $?
fi

# ── Phase 1: Argument Pre-Parsing ──────────────────────────────────────────
# Parse c-thru flags early so they are active during ephemeral setup and warming.
# These flags are stripped later before forwarding to the real claude binary.
ORIG_ARGS=("$@")
explicit_model=""
route_name=""
i=0
n=${#ORIG_ARGS[@]}
while [[ $i -lt $n ]]; do
  a="${ORIG_ARGS[i]}"
  case "$a" in
    --route=*)          route_name="${a#--route=}"; i=$((i + 1)) ;;
    --route)            if [[ $((i+1)) -lt $n ]]; then route_name="${ORIG_ARGS[i+1]}"; i=$((i + 2)); else i=$((i + 1)); fi ;;
    --model=*)          explicit_model="${a#--model=}"; i=$((i + 1)) ;;
    --model)            if [[ $((i+1)) -lt $n ]]; then explicit_model="${ORIG_ARGS[i+1]}"; i=$((i + 2)); else i=$((i + 1)); fi ;;
    --mode=*)           export CLAUDE_LLM_MODE="${a#--mode=}"; i=$((i + 1)) ;;
    --mode)             if [[ $((i+1)) -lt $n ]]; then export CLAUDE_LLM_MODE="${ORIG_ARGS[i+1]}"; i=$((i + 2)); else echo "c-thru: --mode requires a value" >&2; exit 1; fi ;;
    --profile=*)        export CLAUDE_LLM_PROFILE="${a#--profile=}"; i=$((i + 1)) ;;
    --profile)          if [[ $((i+1)) -lt $n ]]; then export CLAUDE_LLM_PROFILE="${ORIG_ARGS[i+1]}"; i=$((i + 2)); else echo "c-thru: --profile requires a tier name" >&2; exit 1; fi ;;
    --local-only)              export CLAUDE_LLM_MODE="local-only"; i=$((i + 1)) ;;
    --best-cloud)              export CLAUDE_LLM_MODE="cloud-best-quality"; i=$((i + 1)) ;;
    --best-opensource-cloud)   export CLAUDE_LLM_MODE="best-opensource-cloud"; i=$((i + 1)) ;;
    --best-opensource-local)   export CLAUDE_LLM_MODE="best-opensource-local"; i=$((i + 1)) ;;
    --best-opensource)         export CLAUDE_LLM_MODE="best-opensource"; i=$((i + 1)) ;;
    --fastest)                 export CLAUDE_LLM_MODE="fastest-possible"; i=$((i + 1)) ;;
    --smallest)                export CLAUDE_LLM_MODE="smallest-possible"; i=$((i + 1)) ;;
    --offline)                 export CLAUDE_LLM_MODE="offline"; i=$((i + 1)) ;;
    --bypass-proxy)     export CLAUDE_PROXY_BYPASS=1; i=$((i + 1)) ;;
    --journal)          export CLAUDE_PROXY_JOURNAL=1; i=$((i + 1)) ;;
    --no-update)        export C_THRU_NO_UPDATE=1; i=$((i + 1)) ;;
    --no-agents)        export NO_AGENTS=1; i=$((i + 1)) ;;
    --debug)            export C_THRU_DEBUG=1; export CLAUDE_PROXY_DEBUG=1; i=$((i + 1)) ;;
    --proxy-debug=*)    export CLAUDE_PROXY_DEBUG="${a#--proxy-debug=}"; i=$((i + 1)) ;;
    --proxy-debug)
      if [[ $((i + 1)) -lt $n && "${ORIG_ARGS[i+1]}" =~ ^[12]$ ]]; then
        export CLAUDE_PROXY_DEBUG="${ORIG_ARGS[i+1]}"; i=$((i + 2))
      else
        export CLAUDE_PROXY_DEBUG=1; i=$((i + 1))
      fi
      ;;
    --router-debug=*)   export C_THRU_DEBUG="${a#--router-debug=}"; i=$((i + 1)) ;;
    --router-debug)
      if [[ $((i + 1)) -lt $n && "${ORIG_ARGS[i+1]}" =~ ^[12]$ ]]; then
        export C_THRU_DEBUG="${ORIG_ARGS[i+1]}"; i=$((i + 2))
      else
        export C_THRU_DEBUG=1; i=$((i + 1))
      fi
      ;;
    --memory-gb=*)
      _mgb="${a#--memory-gb=}"
      if ! [[ "$_mgb" =~ ^[0-9]+$ ]] || (( _mgb <= 0 )); then
        echo "c-thru: --memory-gb requires a positive integer (got '${_mgb}')" >&2; exit 1
      fi
      export CLAUDE_LLM_MEMORY_GB="$_mgb"; i=$((i + 1)) ;;
    --memory-gb)
      if [[ $((i+1)) -lt $n ]]; then
        _mgb="${ORIG_ARGS[i+1]}"
        if ! [[ "$_mgb" =~ ^[0-9]+$ ]] || (( _mgb <= 0 )); then
          echo "c-thru: --memory-gb requires a positive integer (got '${_mgb}')" >&2; exit 1
        fi
        export CLAUDE_LLM_MEMORY_GB="$_mgb"; i=$((i + 2))
      else i=$((i + 1)); fi ;;
    *) i=$((i + 1)) ;;
  esac
done

# ── Per-Process Ephemeral Session Control ──────────────────────────────────
# This ensures that hooks and agents only apply when c-thru is in place,
# and avoids modifying ~/.claude folders permanently.
setup_ephemeral_session
trap cleanup_ephemeral_session EXIT

# Check Ollama requirements for the active tier's agent tags before pre-pulling
ensure_active_tier_ollama_requirements

# Pre-pull active-tier Ollama models in background (stamp-guarded, once per config version).
ensure_active_tier_prepulled

MODEL=""
if [[ -z "$explicit_model" && -z "$route_name" && -f "$CONFIG" ]] && \
   jq -e '(.routes // {}) | has("default")' "$CONFIG" >/dev/null 2>&1; then
  route_name="default"
fi

if [[ -n "$explicit_model" ]]; then
  MODEL="$explicit_model"
elif [[ -n "$route_name" ]]; then
  if [[ ! -f "$CONFIG" ]]; then
    echo "c-thru: $CONFIG not found (required for --route)" >&2
    exit 1
  fi
  if ! jq -e '.routes | type == "object"' "$CONFIG" >/dev/null 2>&1; then
    echo "c-thru: model-map.json requires a 'routes' block for --route" >&2
    exit 1
  fi
  if ! jq -e --arg k "$route_name" '.routes | has($k)' "$CONFIG" >/dev/null 2>&1; then
    echo "c-thru: route '$route_name' not found or invalid in $CONFIG" >&2
    echo "c-thru: available routes: $(jq -r '.routes // {} | keys[]' "$CONFIG" 2>/dev/null | tr '\n' ' ')" >&2
    exit 1
  fi
  _resolved="$(resolve_routes_graph "$route_name")" || exit 1
  MODEL="$_resolved"
fi

# No explicit/default model: transparent proxy fallback (legacy behavior) + real claude binary.
if [[ -z "$MODEL" ]]; then
  REAL_CLAUDE="${CLAUDE_BIN:-$(find_real_claude)}"
  if [[ "${CLAUDE_PROXY_BYPASS:-}" == "1" ]]; then
    claude_router_debug_dump transparent
    apply_background_model_overrides "${MODEL:-}"
    run_real_claude "$REAL_CLAUDE" "${ORIG_ARGS[@]}"
    exit $?
  fi
  ensure_proxy_http_base || exit 1
  write_ephemeral_settings
  export ANTHROPIC_BASE_URL="$ENSURED_PROXY_HTTP_BASE"
  if transparent_proxy_can_match_ollama_env; then
    # In this query, we are supposed to have the env variables for ollama as specifically "ollama" for the pwd
    export ANTHROPIC_AUTH_TOKEN="ollama"
  else
    ensure_proxy_client_api_key
  fi
  claude_router_debug_dump transparent
  apply_background_model_overrides "${MODEL:-}"
  run_real_claude "$REAL_CLAUDE" "${ORIG_ARGS[@]}"
  exit $?
fi

REQUESTED_MODEL="${explicit_model:-${route_name:-$MODEL}}"

# Resolve chained route aliases on model id (graph walk, same semantics as claude-proxy)
EFFECTIVE_MODEL="$MODEL"
if [[ -f "$CONFIG" ]]; then
  EFFECTIVE_MODEL="$(resolve_routes_graph "$MODEL")" || exit 1
fi
EFFECTIVE_MODEL="$(resolve_profile_alias_model "$EFFECTIVE_MODEL")" || exit 1
log_llm_profile_selection "$EFFECTIVE_MODEL"
validate_ollama_cloud_auth_for_launch "$EFFECTIVE_MODEL" || exit 1

REAL_CLAUDE="${CLAUDE_BIN:-$(find_real_claude)}"

# ARCH: apply_provider_block — injects backend env vars (ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN,
#   ANTHROPIC_API_KEY, CLAUDE_CONFIG_DIR, plus arbitrary keys from the backend's `env` JSON)
#   into the current shell environment for the resolved provider.
#   Must be called after route resolution and before exec/claude — env vars set here are
#   inherited by the real claude binary (or the proxy) via the exec boundary.
#   Expands $OLLAMA_URL/$OLLAMA_BASE_URL placeholders in base_url at call time so the map
#   can be written with a symbolic reference and remain portable across host changes.
apply_provider_block() {
  local base_url="$1" auth_token="$2" api_key="$3" config_dir="$4" env_json="$5"
  # Expand placeholders
  base_url="${base_url/\$OLLAMA_URL/$OLLAMA_URL}"
  base_url="${base_url/\$OLLAMA_BASE_URL/$OLLAMA_URL}"
  [[ -n "$base_url"   ]] && export ANTHROPIC_BASE_URL="$base_url"
  
  if [[ -n "$auth_token" ]]; then
    export ANTHROPIC_AUTH_TOKEN="$auth_token"
  else
    unset ANTHROPIC_AUTH_TOKEN
  fi

  if [[ -n "$api_key" ]]; then
    export ANTHROPIC_API_KEY="$api_key"
  fi

  [[ -n "$config_dir" ]] && export CLAUDE_CONFIG_DIR="${config_dir//\$HOME/$HOME}"
  if [[ -n "$env_json" && "$env_json" != "{}" && "$env_json" != "null" ]]; then
    while IFS= read -r key; do
      val=$(printf '%s' "$env_json" | jq -r --arg k "$key" '.[$k]' 2>/dev/null)
      export -- "$key=$val"
    done < <(printf '%s' "$env_json" | jq -r 'keys[]' 2>/dev/null)
  fi
}

apply_ollama_client_block() {
  local client_base_url="$1" config_dir="$2" env_json="$3"
  # Use "ollama" auth token for the proxy.
  apply_provider_block "$client_base_url" "ollama" "" "$config_dir" "$env_json"
}

apply_proxy_fallback_client_block() {
  local config_dir="$1" env_json="$2"
  ensure_proxy_http_base || exit 1
  # In this query, we are supposed to have the env variables for ollama as specifically "ollama" for the pwd
  apply_provider_block "$ENSURED_PROXY_HTTP_BASE" "ollama" "" "$config_dir" "$env_json"
}

# Dispatch a resolved backend JSON blob to the appropriate client block.
# Usage: apply_resolved_backend <backend-json> <effective-model> <backend-id>
apply_resolved_backend() {
  local backend_json="$1" effective_model="$2" backend_id="$3"
  local KIND BASE_URL AUTH_ENV API_KEY
  KIND=$(jq -r '.kind // "anthropic"' <<< "$backend_json")
  BASE_URL=$(jq -r '.url // empty' <<< "$backend_json")
  AUTH_ENV=$(jq -r '.auth_env // empty' <<< "$backend_json")
  if [[ "$KIND" == "ollama" ]]; then
    OLLAMA_BACKEND_URL="$BASE_URL"
    ensure_proxy_http_base || exit 1
    apply_ollama_client_block "$ENSURED_PROXY_HTTP_BASE" "" "{}"
    OLLAMA_CLI_KEY="$(ollama_secret_from_backend_json "$backend_json")"
    ensure_ollama_running "$effective_model" "$OLLAMA_BACKEND_URL" "$OLLAMA_CLI_KEY" "active" "$backend_id"
    [[ "$OLLAMA_PREP_SWEEP_STARTED" != "1" ]] && run_background_ollama_prep_sweep "$effective_model" "$(ollama_cli_host "$OLLAMA_BACKEND_URL")" "$OLLAMA_CLI_KEY" "$backend_id"
  else
    API_KEY="${AUTH_ENV:+${!AUTH_ENV}}"
    if final_model_has_fallback_strategy "$effective_model"; then
      apply_proxy_fallback_client_block "" "{}"
    else
      apply_provider_block "$BASE_URL" "" "$API_KEY" "" "{}"
    fi
  fi
}

# --- Backend lookup chain ---
# Priority: 1) .model_routes+.backends (exact) → 2) .model_routes+.backends (pattern)
#           → 3) claude-* auto-anthropic → 4) Ollama tag auto-detect → 5) assume Ollama
OLLAMA_HTTP_BASE="${OLLAMA_URL%/api}"
TARGET_BACKEND_DATA=""
TARGET_BACKEND_ID=""
TARGET_PROVIDER_MODEL=""
TARGET_FORCE_PROXY=0

if [[ -n "$MODEL" && -f "$CONFIG" ]]; then
  TARGET_BACKEND_DATA="$(resolve_target_backend_for_model "$EFFECTIVE_MODEL" || true)"
  if [[ -n "$TARGET_BACKEND_DATA" ]]; then
    TARGET_BACKEND_ID="${TARGET_BACKEND_DATA%%$'\t'*}"
    TARGET_PROVIDER_MODEL="${TARGET_BACKEND_DATA#*$'\t'}"
    TARGET_PROVIDER_MODEL="${TARGET_PROVIDER_MODEL%%$'\t'*}"
    TARGET_FORCE_PROXY=1
  fi
fi

if [[ -n "$TARGET_BACKEND_ID" ]]; then
  BACKEND_ID="$TARGET_BACKEND_ID"
  BACKEND=$(jq -c --arg id "$BACKEND_ID" '.backends[$id] // empty' "$CONFIG" 2>/dev/null)
  if [[ -z "$BACKEND" || "$BACKEND" == "null" ]]; then
    echo "c-thru: backend '$BACKEND_ID' not defined for target '$EFFECTIVE_MODEL' in $CONFIG" >&2
    exit 1
  fi
  if [[ "$TARGET_FORCE_PROXY" == "1" ]]; then
    if jq -e --arg id "$BACKEND_ID" '.backends[$id].kind // "anthropic" | . == "ollama"' "$CONFIG" >/dev/null 2>&1; then
      apply_resolved_backend "$BACKEND" "$TARGET_PROVIDER_MODEL" "$BACKEND_ID"
    else
      apply_proxy_fallback_client_block "" "{}"
    fi
  else
    apply_resolved_backend "$BACKEND" "$TARGET_PROVIDER_MODEL" "$BACKEND_ID"
  fi

elif [[ -n "$MODEL" && -f "$CONFIG" ]] && BACKEND_ID=$(jq -r --arg m "$EFFECTIVE_MODEL" '.model_routes[$m] // empty' "$CONFIG" 2>/dev/null) && [[ -n "$BACKEND_ID" ]]; then
  # 1b) New schema: .model_routes[$EFFECTIVE_MODEL] → .backends[$id]
  BACKEND=$(jq -c --arg id "$BACKEND_ID" '.backends[$id] // empty' "$CONFIG" 2>/dev/null)
  if [[ -z "$BACKEND" || "$BACKEND" == "null" ]]; then
    echo "c-thru: backend '$BACKEND_ID' not defined for model '$EFFECTIVE_MODEL' in $CONFIG" >&2
    exit 1
  fi
  apply_resolved_backend "$BACKEND" "$EFFECTIVE_MODEL" "$BACKEND_ID"

elif [[ -n "$MODEL" && -f "$CONFIG" ]] && BACKEND_ID="$(lookup_model_pattern_value "model_routes" "$EFFECTIVE_MODEL")" && [[ -n "$BACKEND_ID" ]]; then
  BACKEND=$(jq -c --arg id "$BACKEND_ID" '.backends[$id] // empty' "$CONFIG" 2>/dev/null)
  if [[ -z "$BACKEND" || "$BACKEND" == "null" ]]; then
    echo "c-thru: backend '$BACKEND_ID' not defined for model '$EFFECTIVE_MODEL' in $CONFIG" >&2
    exit 1
  fi
  apply_resolved_backend "$BACKEND" "$EFFECTIVE_MODEL" "$BACKEND_ID"

elif [[ "$EFFECTIVE_MODEL" == claude-* ]] && [[ -f "$CONFIG" ]] && BACKEND_ID="$(pick_anthropic_backend_id)" && [[ -n "$BACKEND_ID" ]]; then
  BACKEND=$(jq -c --arg id "$BACKEND_ID" '.backends[$id] // empty' "$CONFIG" 2>/dev/null)
  if [[ -z "$BACKEND" || "$BACKEND" == "null" ]]; then
    echo "c-thru: backend '$BACKEND_ID' not defined for model '$EFFECTIVE_MODEL' in $CONFIG" >&2
    exit 1
  fi
  apply_resolved_backend "$BACKEND" "$EFFECTIVE_MODEL" "$BACKEND_ID"

elif curl -sf --max-time 3 "$OLLAMA_HTTP_BASE/api/tags" 2>/dev/null | jq -e --arg m "$EFFECTIVE_MODEL" '.models[] | select(.name == $m)' >/dev/null 2>&1; then
  # 2) Listed in local Ollama /api/tags — client speaks to claude-proxy; proxy forwards to Ollama
  ensure_proxy_http_base || exit 1
  apply_ollama_client_block "$ENSURED_PROXY_HTTP_BASE" "" "{}"
  ensure_ollama_running "$EFFECTIVE_MODEL" "$OLLAMA_HTTP_BASE" "${OLLAMA_API_KEY:-}"
  [[ "$OLLAMA_PREP_SWEEP_STARTED" != "1" ]] && run_background_ollama_prep_sweep "$EFFECTIVE_MODEL" "$(ollama_cli_host "$OLLAMA_HTTP_BASE")" "${OLLAMA_API_KEY:-}"
else
  # 3) Unknown to model-map and not in tag list
  if [[ "${C_THRU_STRICT_MODELS:-}" == "1" ]]; then
    echo "c-thru: error: '$EFFECTIVE_MODEL' is unknown and C_THRU_STRICT_MODELS=1 is set." >&2
    exit 1
  fi
  # Fallback: still assume Ollama; pass model name through
  echo "c-thru: '$EFFECTIVE_MODEL' not in model-map or local Ollama tags — assuming Ollama at $OLLAMA_HTTP_BASE" >&2
  ensure_proxy_http_base || exit 1
  apply_ollama_client_block "$ENSURED_PROXY_HTTP_BASE" "" "{}"
  ensure_ollama_running "$EFFECTIVE_MODEL" "$OLLAMA_HTTP_BASE" "${OLLAMA_API_KEY:-}"
  [[ "$OLLAMA_PREP_SWEEP_STARTED" != "1" ]] && run_background_ollama_prep_sweep "$EFFECTIVE_MODEL" "$(ollama_cli_host "$OLLAMA_HTTP_BASE")" "${OLLAMA_API_KEY:-}"
fi

claude_router_debug_dump routed

write_ephemeral_settings

# Router has already set ANTHROPIC_BASE_URL via apply_provider_block().
FINAL_MODEL_ARG="$EFFECTIVE_MODEL"
if [[ -z "$FINAL_MODEL_ARG" ]]; then
  FINAL_MODEL_ARG="$MODEL"
fi
FINAL_ARGS=()
while IFS= read -r -d '' arg; do
  FINAL_ARGS+=("$arg")
done < <(build_forwarded_args "$FINAL_MODEL_ARG")
debug_print_final_claude_command "$REAL_CLAUDE" "${FINAL_ARGS[@]}"
preflight_model_readiness "${PROXY_PORT:-}"
apply_background_model_overrides "${FINAL_MODEL_ARG:-}"
printf "  ${GRAY}•${NC} ${BOLD}%-10s${NC} launching session...\n" "status" >&2
run_real_claude "$REAL_CLAUDE" "${FINAL_ARGS[@]}"
exit $?

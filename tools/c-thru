    *) printf '%s' "$1" ;;
  esac
}

tab_field_encode() {
  local value="${1-}"
  if [[ -z "$value" ]]; then
    printf '%s' "__EMPTY__"
  else
    printf '%s' "$value"
  fi
}

tab_field_decode() {
  local value="${1-}"
  if [[ "$value" == "__EMPTY__" ]]; then
    printf '%s' ""
  else

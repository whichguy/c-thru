  fi
}

# ARCH: detect_total_memory_gb — RAM detection for hw-tier selection.
#   Override: CLAUDE_LLM_MEMORY_GB (must be a positive integer, else error).
#   Auto: sysctl hw.memsize (macOS) → /proc/meminfo (Linux) → returns 1 on failure.
#   Tier thresholds: <24→16gb, <40→32gb, <56→48gb, <96→64gb, ≥96→128gb.
detect_total_memory_gb() {
  if [[ -n "${CLAUDE_LLM_MEMORY_GB:-}" ]]; then
    if [[ "${CLAUDE_LLM_MEMORY_GB}" =~ ^[0-9]+$ ]] && (( CLAUDE_LLM_MEMORY_GB > 0 )); then
      printf '%s' "$CLAUDE_LLM_MEMORY_GB"
      return 0
    fi
    echo "c-thru: CLAUDE_LLM_MEMORY_GB must be a positive integer when set" >&2
    return 1
  fi

  local bytes=""
  if command -v sysctl >/dev/null 2>&1; then
    bytes="$(sysctl -n hw.memsize 2>/dev/null || true)"
  fi
  if [[ -z "$bytes" && -r /proc/meminfo ]]; then
    bytes="$(( $(awk '/MemTotal:/ {print $2; exit}' /proc/meminfo 2>/dev/null || echo 0) * 1024 ))"
  fi
  if [[ -z "$bytes" || ! "$bytes" =~ ^[0-9]+$ || "$bytes" -le 0 ]]; then
    return 1
  fi
  printf '%s' "$(( (bytes + 1073741823) / 1073741824 ))"
}

memory_gb_to_profile() {
  local memory_gb="$1"
  [[ "$memory_gb" =~ ^[0-9]+$ ]] || return 1
  if (( memory_gb < 24 )); then
    printf '%s' "16gb"
  elif (( memory_gb < 40 )); then
    printf '%s' "32gb"
  elif (( memory_gb < 56 )); then
    printf '%s' "48gb"
  elif (( memory_gb < 96 )); then
    printf '%s' "64gb"
  else
    printf '%s' "128gb"
  fi
}

llm_profile_exists() {
  local profile="$1"
  [[ -f "$CONFIG" && -n "$profile" ]] || return 1
  jq -e --arg p "$profile" '((.llm_profiles // {})[$p] | type) == "object"' "$CONFIG" >/dev/null 2>&1
}

llm_profiles_defined() {
  [[ -f "$CONFIG" ]] || return 1
  jq -e '((.llm_profiles // {}) | type) == "object" and ((.llm_profiles // {}) | length > 0)' "$CONFIG" >/dev/null 2>&1
}

ensure_llm_profile_context() {
  if [[ "$LLM_PROFILE_CACHE_INITIALIZED" == "1" ]]; then
    return 0
  fi

  local selected=""
  local source=""
  local memory_gb=""
  if [[ -n "${CLAUDE_LLM_PROFILE:-}" ]]; then
    selected="$CLAUDE_LLM_PROFILE"
    source="env"
  elif [[ -f "$CONFIG" ]]; then
    local configured
    configured="$(jq -r '.llm_active_profile // "auto"' "$CONFIG" 2>/dev/null)"
    if [[ -z "$configured" || "$configured" == "null" || "$configured" == "auto" ]]; then
      memory_gb="$(detect_total_memory_gb)" || {
        echo "c-thru: unable to determine machine memory for llm_active_profile=auto" >&2
        echo "c-thru: install required system tools or set CLAUDE_LLM_PROFILE explicitly" >&2
        return 1
      }
      selected="$(memory_gb_to_profile "$memory_gb")" || {
        echo "c-thru: unable to map detected machine memory to an llm profile" >&2
        return 1
      }
      source="auto"
    else
      selected="$configured"
      source="config"
    fi
  else
    return 1
  fi

  [[ -n "$selected" ]] || {
    echo "c-thru: unable to resolve llm profile name" >&2
    return 1
  }

  if [[ -f "$CONFIG" ]] && ! llm_profile_exists "$selected"; then
    echo "c-thru: resolved llm profile '$selected' is not defined in $CONFIG" >&2
    return 1
  fi

  LLM_PROFILE_CACHE_INITIALIZED=1
  LLM_PROFILE_CACHE_NAME="$selected"
  LLM_PROFILE_CACHE_SOURCE="$source"
  LLM_PROFILE_CACHE_MEMORY_GB="$memory_gb"
  return 0
}

resolve_llm_profile_name() {
  ensure_llm_profile_context || {
    echo "c-thru: unable to resolve llm profile name" >&2
    return 1
  }
  [[ -n "$LLM_PROFILE_CACHE_NAME" ]] || {
    echo "c-thru: unable to resolve llm profile name" >&2
    return 1
  }
  printf '%s' "$LLM_PROFILE_CACHE_NAME"
}

profile_capability_slots() {
  printf '%s\n' default classifier explorer reviewer workhorse coder judge orchestrator reasoner fast-scout agentic-coder
}

collect_active_profile_capability_assignments() {
  local default_override="$1"
  [[ -f "$CONFIG" ]] || return 0
  llm_profiles_defined || return 0

  local profile llm_mode slot requested resolved rec_suffix rec_model
  ensure_llm_profile_context || return 0
  profile="$LLM_PROFILE_CACHE_NAME"
  [[ -n "$profile" ]] || return 0
  llm_mode="$(resolve_llm_mode)"

  # rec_file path for (rec) suffix detection (bash 3.2-safe: no associative arrays)
  local rec_file="$CTHRU_REPO_ROOT/config/recommended-mappings.json"

  while IFS= read -r slot; do
    [[ -n "$slot" ]] || continue
    
    if [[ "$slot" == "default" && -n "$default_override" ]]; then
      requested="$default_override"
    else
      # llm_mode-aware resolution: mirrors resolveProfileModel() in model-map-resolve.js
      requested="$(jq -r --arg p "$profile" --arg key "$slot" --arg mode "$llm_mode" '
        (.llm_profiles // {})[$p][$key] as $e |
        if $e == null then empty
        elif ($e.modes // {}) | has($mode) then $e.modes[$mode]
        elif $mode == "offline" or $mode == "local-only" then $e.disconnect_model
        elif $mode == "connected" then $e.connected_model
        elif $mode == "semi-offload" or $mode == "cloud-judge-only" then $e.disconnect_model
        elif $mode == "cloud-best-quality" then ($e.cloud_best_model // $e.connected_model)
        elif $mode == "local-best-quality" then ($e.local_best_model // $e.disconnect_model)
        elif $mode == "cloud-only" then ($e.cloud_best_model // $e.connected_model)
        elif $mode == "cloud-thinking" then ($e.modes["cloud-thinking"] // $e.disconnect_model)
        elif $mode == "local-review" then ($e.modes["local-review"] // $e.connected_model)
        elif $mode == "claude-only" then ($e.modes["claude-only"] // $e.connected_model)
        elif $mode == "opensource-only" then ($e.modes["opensource-only"] // $e.disconnect_model)
        elif $mode == "fastest-possible" then ($e.modes["fastest-possible"] // $e.connected_model)
        elif $mode == "smallest-possible" then ($e.modes["smallest-possible"] // $e.disconnect_model)
        elif $mode == "best-opensource" then ($e.modes["best-opensource"] // $e.disconnect_model)
        elif $mode == "best-opensource-cloud" then ($e.modes["best-opensource-cloud"] // $e.cloud_best_model // $e.connected_model)
        elif $mode == "best-opensource-local" then ($e.modes["best-opensource-local"] // $e.local_best_model // $e.disconnect_model)
        else $e.connected_model
        end // empty
      ' "$CONFIG" 2>/dev/null)"
    fi
    [[ -n "$requested" && "$requested" != "null" ]] || continue
    looks_like_model_pattern_key "$requested" && continue
    resolved="$(resolve_routes_graph "$requested" 2>/dev/null || printf '%s' "$requested")"
    if is_llm_profile_alias "$resolved"; then
      resolved="$(resolve_profile_alias_model "$resolved")"
    fi
    [[ -n "$resolved" ]] || continue
    # (rec) suffix: check if slot's recommended model for this tier matches the requested model
    rec_suffix=""
    if [[ -f "$rec_file" ]]; then
      rec_model="$(jq -r --arg cap "$slot" --arg tier "$profile" \
        '(.recommendations // {})[$cap][$tier] // empty' "$rec_file" 2>/dev/null)"
      [[ -n "$rec_model" && "$rec_model" == "$requested" ]] && rec_suffix="(rec)"
    fi
    printf '%s\t%s\t%s\n' "$slot" "$resolved" "$rec_suffix"
  done < <(profile_capability_slots)
}

profile_has_capability_assignments() {
  local default_override="$1"
  local slot model _rec
  while IFS=$'\t' read -r slot model _rec; do
    [[ -n "$slot" && -n "$model" ]] && return 0
  done < <(collect_active_profile_capability_assignments "$default_override")
  return 1
}

log_llm_profile_selection() {
  [[ "$PROXY_PROFILE_SUMMARY_LOGGED" == "1" ]] && return 0
  [[ -f "$CONFIG" ]] || return 0
  llm_profiles_defined || return 0

  local profile llm_mode source summary_context launch_model="$1"
  ensure_llm_profile_context || return 0
  profile="$LLM_PROFILE_CACHE_NAME"
  [[ -n "$profile" ]] || return 0
  llm_mode="$(resolve_llm_mode)"
  source="${LLM_PROFILE_CACHE_SOURCE:-config}"

  case "$source" in
    auto)
      summary_context="auto-detected: ${LLM_PROFILE_CACHE_MEMORY_GB:-unknown} GB RAM"
      ;;
    env)
      summary_context="forced via env"
      ;;
    config)
      summary_context="config override"
      ;;
    *)
      summary_context="$source"
      ;;
  esac

  echo -e "  ${BOLD}${GRAY}⚡ c-thru routing${NC}" >&2
  printf "  ${GRAY}•${NC} ${BOLD}%-10s${NC} %-12s ${GRAY}(%s)${NC}\n" "profile" "$profile" "$summary_context" >&2
  printf "  ${GRAY}•${NC} ${BOLD}%-10s${NC} %-12s\n" "mode" "$llm_mode" >&2

  if [[ -n "$launch_model" ]]; then
    printf "  ${GRAY}•${NC} ${BOLD}%-10s${NC} ${GREEN}%s${NC}\n" "model" "$launch_model" >&2
  fi

  if profile_has_capability_assignments "$launch_model"; then
    local first=1
    local slot model _rec
    while IFS=$'\t' read -r slot model _rec; do
      [[ -n "$slot" && -n "$model" ]] || continue
      if (( first )); then
        printf "  ${GRAY}•${NC} ${BOLD}%-10s${NC} %-12s ${GRAY}→${NC} %s\n" "plan" "$slot" "$model" >&2
        first=0
      else
        printf "               ${BOLD}%-12s${NC} ${GRAY}→${NC} %s\n" "$slot" "$model" >&2
      fi
    done < <(collect_active_profile_capability_assignments "$launch_model")
  fi

  PROXY_PROFILE_SUMMARY_LOGGED=1
}

detect_connectivity() {
  # Fast check for internet connectivity.
  # Use a small timeout to avoid hanging the router.
  if command -v curl >/dev/null 2>&1; then
    if curl -Is --connect-timeout 2 http://www.google.com >/dev/null 2>&1; then
      return 0
    fi
  elif command -v ping >/dev/null 2>&1; then
    if ping -c 1 -W 2 8.8.8.8 >/dev/null 2>&1; then
      return 0
    fi
  fi
  return 1
}

resolve_llm_mode() {
  # Precedence: CLAUDE_LLM_MODE → CLAUDE_CONNECTIVITY_MODE (legacy) → CONFIG.llm_mode → CONFIG.llm_connectivity_mode (legacy) → (auto detection) → 'connected'
  if [[ -n "${CLAUDE_LLM_MODE:-}" ]]; then
    printf '%s' "$CLAUDE_LLM_MODE"
    return 0
  fi
  local legacy_env="${CLAUDE_CONNECTIVITY_MODE:-${CLAUDE_LLM_CONNECTIVITY_MODE:-}}"
  if [[ -n "$legacy_env" ]]; then
    [[ "$legacy_env" == "disconnect" ]] && printf 'offline' || printf 'connected'
    return 0
  fi

  local config_mode="connected"
  if [[ -f "$CONFIG" ]]; then
    config_mode="$(jq -r '.llm_mode // .llm_connectivity_mode // "connected"' "$CONFIG" 2>/dev/null)"
    [[ -z "$config_mode" || "$config_mode" == "null" ]] && config_mode="connected"
    [[ "$config_mode" == "disconnect" ]] && config_mode="offline"
  fi

  # If explicit 'offline' or other special mode is set in config, respect it.
  # If 'connected' or 'auto', perform live detection.
  if [[ "$config_mode" == "connected" || "$config_mode" == "auto" ]]; then
    if ! detect_connectivity; then
      printf 'offline'
      return 0
    fi
    printf 'connected'
    return 0
  fi

  printf '%s' "$config_mode"
}


resolve_profile_alias_model() {
  local requested="$1"
  is_llm_profile_alias "$requested" || {
    printf '%s' "$requested"
    return 0
  }

  [[ -f "$CONFIG" ]] || {
    printf '%s' "$requested"
    return 0
  }

  local profile llm_mode profile_key resolved
  profile="$(resolve_llm_profile_name)" || return 1
  llm_mode="$(resolve_llm_mode)"
  profile_key="$(profile_alias_key "$requested")"
  # llm_mode: mode-aware model selection — mirrors resolveProfileModel() in model-map-resolve.js
  resolved="$(jq -r --arg p "$profile" --arg key "$profile_key" --arg mode "$llm_mode" '
    (.llm_profiles // {})[$p][$key] as $e |
    if $e == null then empty
    elif ($e.modes // {}) | has($mode) then $e.modes[$mode]
    elif $mode == "offline" or $mode == "local-only" then $e.disconnect_model
    elif $mode == "connected" then $e.connected_model
    elif $mode == "semi-offload" or $mode == "cloud-judge-only" then $e.disconnect_model
    elif $mode == "cloud-best-quality" then ($e.cloud_best_model // $e.connected_model)
    elif $mode == "local-best-quality" then ($e.local_best_model // $e.disconnect_model)
    elif $mode == "cloud-only" then ($e.cloud_best_model // $e.connected_model)
    elif $mode == "cloud-thinking" then ($e.modes["cloud-thinking"] // $e.disconnect_model)
    elif $mode == "local-review" then ($e.modes["local-review"] // $e.connected_model)
    elif $mode == "claude-only" then ($e.modes["claude-only"] // $e.connected_model)
    elif $mode == "opensource-only" then ($e.modes["opensource-only"] // $e.disconnect_model)
    elif $mode == "fastest-possible" then ($e.modes["fastest-possible"] // $e.connected_model)
    elif $mode == "smallest-possible" then ($e.modes["smallest-possible"] // $e.disconnect_model)
    elif $mode == "best-opensource" then ($e.modes["best-opensource"] // $e.disconnect_model)
    elif $mode == "best-opensource-cloud" then ($e.modes["best-opensource-cloud"] // $e.cloud_best_model // $e.connected_model)
    elif $mode == "best-opensource-local" then ($e.modes["best-opensource-local"] // $e.local_best_model // $e.disconnect_model)
    else $e.connected_model
    end // empty
  ' "$CONFIG" 2>/dev/null)"
  if [[ -n "$resolved" && "$resolved" != "null" ]]; then
    printf '%s' "$resolved"
  else
    printf '%s' "$requested"
  fi
}

model_is_cloud_designated() {
  local model="$1"
  [[ -n "$model" ]] || return 1
  [[ "$model" == *":cloud" || "$model" == *"-cloud" ]]
}

# In local-enforcing modes, override the ANTHROPIC_DEFAULT_* / ANTHROPIC_SMALL_FAST_MODEL
# env vars so Claude Code's internal background requests (tool calls, summaries, etc.)
# route through the capability graph instead of leaking to Anthropic via model_routes.
# Only overrides slots that are unset or contain a cloud model name (claude-*).
apply_background_model_overrides() {
  local launch_model="${1:-}"
  # Always: suppress attribution header; subagent uses the same model as the main session
  # so agents spawned by Claude Code see the same backend without a second routing decision.
  [[ -z "${CLAUDE_CODE_ATTRIBUTION_HEADER:-}" ]] && export CLAUDE_CODE_ATTRIBUTION_HEADER=0
  if [[ -z "${CLAUDE_CODE_SUBAGENT_MODEL:-}" && -n "$launch_model" ]]; then
    export CLAUDE_CODE_SUBAGENT_MODEL="$launch_model"
  fi

  local llm_mode
  llm_mode="$(resolve_llm_mode)"
  case "$llm_mode" in
    offline|local-only|best-opensource-local|best-opensource|opensource-only|local-best-quality|semi-offload|cloud-judge-only)
      # Explicit empty API key: auth is via ANTHROPIC_AUTH_TOKEN=ollama; ensure no
      # accidentally-present Anthropic key leaks to the proxy or Claude CLI.
      [[ -z "${ANTHROPIC_API_KEY:-}" || "${ANTHROPIC_API_KEY:-}" == claude-* ]] && export ANTHROPIC_API_KEY=""
      # fast-generalist → gemma4:26b (local, 102 t/s) — appropriate for Haiku-tier background work
      if [[ -z "${ANTHROPIC_SMALL_FAST_MODEL:-}" || "${ANTHROPIC_SMALL_FAST_MODEL:-}" == claude-* ]]; then
        export ANTHROPIC_SMALL_FAST_MODEL="fast-generalist"
      fi
      if [[ -z "${ANTHROPIC_DEFAULT_HAIKU_MODEL:-}" || "${ANTHROPIC_DEFAULT_HAIKU_MODEL:-}" == claude-* ]]; then
        export ANTHROPIC_DEFAULT_HAIKU_MODEL="fast-generalist"
      fi
      # generalist → workhorse tier local model — appropriate for Sonnet-tier background work
      if [[ -z "${ANTHROPIC_DEFAULT_SONNET_MODEL:-}" || "${ANTHROPIC_DEFAULT_SONNET_MODEL:-}" == claude-* ]]; then
        export ANTHROPIC_DEFAULT_SONNET_MODEL="generalist"
      fi
      # large-general → judge tier local model — appropriate for Opus-tier background work
      if [[ -z "${ANTHROPIC_DEFAULT_OPUS_MODEL:-}" || "${ANTHROPIC_DEFAULT_OPUS_MODEL:-}" == claude-* ]]; then
        export ANTHROPIC_DEFAULT_OPUS_MODEL="large-general"
      fi
      ;;
  esac
}

backend_local_prep_skip_reason() {
  local backend_id="$1"
  [[ -f "$CONFIG" && -n "$backend_id" ]] || return 1

# Proxy port selection:
# - explicit CLAUDE_PROXY_PORT wins
# - CLAUDE_PROXY_USE_OLLAMA_PORT=1 forces 11434
# - otherwise router learns the port from the proxy-owned READY handshake
proxy_port_is_explicit() {
  [[ -n "${CLAUDE_PROXY_PORT:-}" || "${CLAUDE_PROXY_USE_OLLAMA_PORT:-0}" == "1" ]]
}

claude_proxy_listen_port() {
  if [[ -n "${CLAUDE_PROXY_PORT:-}" ]]; then
    printf '%s' "$CLAUDE_PROXY_PORT"
  elif [[ -n "$PROXY_PORT" ]]; then
    printf '%s' "$PROXY_PORT"
  elif [[ "${CLAUDE_PROXY_USE_OLLAMA_PORT:-0}" == "1" ]]; then
    printf '%s' "11434"
  fi
}

claude_proxy_http_base() {
  local port=""
  port="$(claude_proxy_listen_port)"
  [[ -n "$port" ]] || return 1
  printf '%s' "http://127.0.0.1:$port"
}

# True when model-map may send traffic to Anthropic-shaped APIs (kind omitted defaults to anthropic in proxy).
model_map_has_non_ollama_backend() {
  [[ -f "$CONFIG" ]] || return 1
  jq -e '
    (.backends // {}) as $b |
    ($b | length > 0) and
    ($b | to_entries | map(.value.kind // "anthropic") | any(. != "ollama"))
  ' "$CONFIG" >/dev/null 2>&1
}

proxy_placeholder_mode() {
  local raw="${C_THRU_PROXY_PLACEHOLDER_KEY:-}"
  if [[ -z "$raw" ]]; then
    printf '%s' "auto"
    return 0
  fi
  printf '%s' "$raw"
}

ensure_proxy_client_api_key() {
  [[ -n "${ANTHROPIC_API_KEY:-}" ]] && return 0

  case "$(proxy_placeholder_mode)" in
    0|false|FALSE|no|NO|off|OFF)
      return 0
      ;;
    *)
      export ANTHROPIC_API_KEY="proxied-placeholder"
      return 0
      ;;
  esac
}

transparent_proxy_can_match_ollama_env() {
  model_map_has_non_ollama_backend && return 1
  return 0
}

looks_like_model_pattern_key() {
  local key="$1"
  [[ "$key" == re:* ]] && return 0
  [[ "$key" == *"*"* || "$key" == *"?"* || "$key" == *"["* ]]
}

model_pattern_matches() {
  local key="$1" model="$2"
  if [[ "$key" == re:* ]]; then
    local regex="${key#re:}"
    [[ "$model" =~ $regex ]]
    return
  fi
  [[ "$model" == $key ]]
}

lookup_model_pattern_value() {
  local section="$1" model="$2"
  [[ ! -f "$CONFIG" ]] && return 0

  local key value
  while IFS=$'\t' read -r key value; do
    looks_like_model_pattern_key "$key" || continue
    if model_pattern_matches "$key" "$model"; then
      printf '%s' "$value"
      return 0
    fi
  done < <(
    jq -r --arg s "$section" '
      .[$s] // {} |
      to_entries[] |
      [.key, (.value | if type == "string" then . else @json end)] |
      @tsv
    ' "$CONFIG" 2>/dev/null
  )

  return 0
}

resolve_target_backend_for_model() {
  local model="$1"
  [[ -f "$CONFIG" ]] || return 1
  [[ -n "$model" ]] || return 1

  local resolved
  resolved="$(jq -r --arg m "$model" '
    (.targets // empty) as $targets |
    if ($targets | type) != "object" then
      empty
    elif ($targets[$m] // empty) != empty then
      [$targets[$m].backend // "", $targets[$m].model // ""] | @tsv
    else
      empty
    end
  ' "$CONFIG" 2>/dev/null || true)"
  [[ -n "$resolved" && "$resolved" != "null" ]] || return 1
  printf '%s\n' "$resolved"
}

pick_anthropic_backend_id() {
  [[ ! -f "$CONFIG" ]] && return 0
  jq -r '
    (.backends // {}) as $b |
    if ($b.anthropic.kind // "") == "anthropic" then
      "anthropic"
    else
      (
        $b | to_entries | map(select((.value.kind // "anthropic") == "anthropic")) | .[0].key // empty
      )
    end
  ' "$CONFIG" 2>/dev/null
}

final_model_has_fallback_strategy() {
  local model="$1"
  [[ -n "$model" && -f "$CONFIG" ]] || return 1
  jq -e --arg m "$model" '(.fallback_strategies // {}) | has($m)' "$CONFIG" >/dev/null 2>&1
}

# ARCH: resolve_routes_graph — traverses the model-map `routes` DAG until a leaf (non-route) node.
#   Resolution order: --route flag → routes.default → --model flag → Ollama passthrough.
#   Cycle detection: each visited node is stored; revisiting any node aborts with exit 1.
#   Max hops: ROUTES_MAX_DEPTH env → model-map routes_max_depth field → 32 (hard cap 256).
#   Prints the terminal model id on stdout; must be called before exec to avoid forwarding
#   a route alias name to the real claude binary as a model id.
resolve_routes_graph() {
  local start="$1"
  local max="${ROUTES_MAX_DEPTH:-}"
  if [[ -z "$max" && -f "$CONFIG" ]]; then
    max=$(jq -r '.routes_max_depth // empty | tostring' "$CONFIG" 2>/dev/null)
  fi
  [[ -z "$max" || "$max" == "null" ]] && max=32
  if ! [[ "$max" =~ ^[0-9]+$ ]] || (( max < 1 )); then
    max=32
  fi
  (( max > 256 )) && max=256
  local cur="$start"
  local -a path_entries=()
  local depth=0

  [[ ! -f "$CONFIG" ]] && { printf '%s' "$start"; return 0; }

  while jq -e --arg k "$cur" '(.routes // {}) | type == "object" and has($k)' "$CONFIG" >/dev/null 2>&1; do
    local p
    for p in "${path_entries[@]}"; do
      if [[ "$p" == "$cur" ]]; then
        echo "c-thru: route cycle involving '$cur' in $CONFIG" >&2
        return 1
      fi
    done
    path_entries+=("$cur")

    local nxt
    nxt=$(jq -r --arg k "$cur" '(.routes // {})[$k] // empty' "$CONFIG" 2>/dev/null)
    if [[ -z "$nxt" || "$nxt" == "null" ]]; then
      echo "c-thru: routes['$cur'] is empty or null in $CONFIG" >&2
      return 1
    fi

    cur="$nxt"
    depth=$((depth + 1))
    if (( depth > max )); then
      echo "c-thru: route chain exceeded ROUTES_MAX_DEPTH ($max) — check for cycles or raise ROUTES_MAX_DEPTH" >&2
      return 1
    fi
  done

  printf '%s' "$cur"
}

# Walk PATH for an executable `claude` that is not this script (real vendor binary).
find_real_claude() {
  local cand_real first_hit=""
  local -a P_ENTRIES
  IFS=':' read -ra P_ENTRIES <<< "${PATH:-}"
  for dir in "${P_ENTRIES[@]}"; do
    [[ -z "$dir" ]] && continue
    local cand="$dir/claude"
    if [[ -x "$cand" ]]; then
      cand_real="$(readlink -f "$cand" 2>/dev/null || echo "$cand")"
      [[ "$cand_real" == "$CTHRU_SELF_REAL" ]] && continue
      first_hit="$cand"
      break
    fi
  done
  if [[ -z "$first_hit" ]]; then
    echo "c-thru: real claude binary not found in PATH (after $CTHRU_SELF_REAL)" >&2
    exit 127
  fi
  printf '%s' "$first_hit"
}

# Block until claude-proxy answers /ping on port (reuse or cold-start from another process).
wait_proxy_ping_ready() {
  local port="$1"
  local max="${2:-50}"
  local i
  for ((i = 0; i < max; i++)); do
    curl -sf --max-time 2.0 "http://127.0.0.1:$port/ping" >/dev/null 2>&1 && return 0
    sleep 0.1
  done
  return 1
}

proxy_ping_json() {
  local port="$1"
  curl -sf --max-time 2.0 "http://127.0.0.1:$port/ping" 2>/dev/null
}

# Verify the listener on $port is genuinely our proxy and not some unrelated
# service (port collision). Returns 0 only if /ping returns valid JSON
# containing "ok":true. Stdout is suppressed unless DEBUG so the caller
# can use this in conditions without contaminating output.
verify_proxy_health() {
  local port="$1"
  local body
  body="$(proxy_ping_json "$port")" || return 1
  [[ -n "$body" ]] || return 1
  # Cheap shape check — "ok":true is the proxy's contract on /ping.
  case "$body" in
    *'"ok":true'*) return 0 ;;
    *) return 1 ;;
  esac
}

# Print everything that's known about a proxy startup failure: process
# state, port state, last log lines, config path. Caller passes the pid
# (might be empty if never spawned), the port (might be empty), the log
# path (might be empty), and a one-line headline.
diagnose_proxy_startup_failure() {
  local pid="$1"
  local port="$2"
  local log_path="$3"
  local headline="$4"
  echo "c-thru: $headline" >&2
  if [[ -n "$pid" ]]; then
    if kill -0 "$pid" 2>/dev/null; then
      echo "  process: pid=$pid is alive but unresponsive" >&2
    else
      echo "  process: pid=$pid is NOT alive (proxy exited during startup)" >&2
    fi
  fi
  if [[ -n "$port" ]]; then
    local listener
    listener="$(proxy_listener_pid "$port" 2>/dev/null || true)"
    if [[ -n "$listener" ]]; then
      echo "  port :$port: bound by pid=$listener" >&2
    else
      echo "  port :$port: nothing listening" >&2
    fi
    # Last-resort curl with verbose status line so we surface ECONNREFUSED vs HTTP 5xx vs empty body
    local probe
    probe="$(curl -sS --max-time 1.5 -o /dev/null -w 'http_code=%{http_code} errno=%{errormsg}' "http://127.0.0.1:$port/ping" 2>&1 || true)"
    [[ -n "$probe" ]] && echo "  /ping: $probe" >&2
  fi
  if [[ -n "$log_path" && -s "$log_path" ]]; then
    echo "  proxy log (last 20 lines, $log_path):" >&2
    tail -n 20 "$log_path" | sed 's/^/    /' >&2
  fi
  echo "  model-map config: ${CONFIG:-<unset>}" >&2
}

wait_proxy_listener_gone() {
  local port="$1"
  local max="${2:-50}"
  local i
  for ((i = 0; i < max; i++)); do
    local listener_pid=""
    listener_pid="$(proxy_listener_pid "$port" || true)"
    if [[ -z "$listener_pid" ]] && ! proxy_ping_json "$port" >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

proxy_listener_pid() {
  local port="$1"
  command -v lsof >/dev/null 2>&1 || return 1
  lsof -nP -iTCP:"$port" -sTCP:LISTEN -t 2>/dev/null | head -n1
}

# A7: probe a stored PID before signaling. Between when we captured $! and
# now, the process may have exited and its PID been recycled by something
# unrelated (shells, another `node`, the user's editor). `kill -0` checks
# that the process still exists and is still ours to signal, and the
# `ps comm=` check verifies it's still node/claude-proxy (not a PID-
# reuse impostor). Best-effort: failures fall through to the original
# kill-and-ignore-errors behavior.
pid_looks_like_proxy() {
  local pid="$1"
  [[ -z "$pid" ]] && return 1
  kill -0 "$pid" 2>/dev/null || return 1
  local comm
  comm="$(ps -p "$pid" -o comm= 2>/dev/null | awk '{print $1}')"
  case "$(basename "$comm" 2>/dev/null)" in
    node|claude-proxy|node*) return 0 ;;
    # Empty comm: kill -0 already confirmed the PID exists, so the process
    # is real — we just couldn't read its name (ps missing, kernel thread,
    # transient exec state). Allow the signal rather than leaking a zombie.
    "") return 0 ;;
    *) return 1 ;;
  esac
}

cleanup_proxy_children() {
  local ec="${1:-$?}"
  if [[ -n "${CLAUDE_CHILD_PID:-}" ]]; then
    if kill -0 "$CLAUDE_CHILD_PID" 2>/dev/null; then
      kill "$CLAUDE_CHILD_PID" >/dev/null 2>&1 || true
      wait "$CLAUDE_CHILD_PID" >/dev/null 2>&1 || true
    fi
    CLAUDE_CHILD_PID=""
  fi
  if [[ -n "${PROXY_STARTED_PID:-}" ]]; then
    if [[ "${C_THRU_KEEP_PROXY:-0}" == "1" ]]; then
      if [[ -n "${C_THRU_DEBUG:-}" && "$C_THRU_DEBUG" != "0" ]]; then
        echo "c-thru: leaving claude-proxy (pid $PROXY_STARTED_PID) running due to C_THRU_KEEP_PROXY=1" >&2
      fi
    elif pid_looks_like_proxy "$PROXY_STARTED_PID"; then
      kill "$PROXY_STARTED_PID" >/dev/null 2>&1 || true
      wait "$PROXY_STARTED_PID" >/dev/null 2>&1 || true
    fi
    PROXY_STARTED_PID=""
  fi
  # NOTE: do not return "$ec" here.  When this function is called from the
  # EXIT trap ("trap 'cleanup_proxy_children $?' EXIT"), the process exit code
  # is already determined by the shell before the trap fires; a return value
  # from a trap-invoked function is silently ignored and cannot change it.
  # Signal-handler paths (proxy_signal_handler) work correctly because they
  # call `exit` directly with the intended code rather than relying on return.
}

proxy_signal_handler() {
  local sig="$1"
  trap - EXIT INT TERM HUP
  cleanup_proxy_children 0
  case "$sig" in
    INT)  exit 130 ;;
    TERM) exit 143 ;;
    HUP)  exit 129 ;;
    *)    exit 1 ;;
  esac
}

# ARCH: arm_proxy_cleanup — arms EXIT/signal traps exactly once after the proxy is spawned.
#   Idempotent because ensure_proxy_running can be called from both the routing path and the
#   transparent path within the same session; double-arming would overwrite a live trap.
arm_proxy_cleanup() {
  [[ "$PROXY_CLEANUP_ARMED" == "1" ]] && return 0
  PROXY_CLEANUP_ARMED=1
  trap 'cleanup_proxy_children $?' EXIT
  trap 'proxy_signal_handler INT' INT
  trap 'proxy_signal_handler TERM' TERM
  trap 'proxy_signal_handler HUP' HUP
}

# Start claude-proxy when ANTHROPIC_BASE_URL targets it and /ping fails.
proxy_port_from_base_url() {
  local url="$1"
  # Extract explicit port if present, else empty.
  # A11: grep -oE is portable to BusyBox/Alpine; `sed -nE` isn't.
  echo "$url" | grep -oE '^https?://[^/:]+:[0-9]+' | grep -oE '[0-9]+$'
}

is_local_http_base_url() {
  local url="$1"
  case "$url" in
    http://127.0.0.1:*|http://localhost:*|http://0.0.0.0:*|http://[::1]:*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

proxy_logging_enabled() {
  [[ -n "${CLAUDE_PROXY_LOG_FILE:-}" || -n "${CLAUDE_PROXY_LOG_DIR:-}" ]]
}

ensure_proxy_log_parent_dir() {
  local target="$1"
  [[ -n "$target" ]] || return 1
  mkdir -p "$(dirname "$target")"
}

proxy_log_startup_path() {
  local startup_tag="$1"
  if [[ -n "${CLAUDE_PROXY_LOG_FILE:-}" ]]; then
    printf '%s' "$CLAUDE_PROXY_LOG_FILE"
  elif [[ -n "${CLAUDE_PROXY_LOG_DIR:-}" ]]; then
    printf '%s/proxy.startup.%s.log' "${CLAUDE_PROXY_LOG_DIR%/}" "$startup_tag"
  fi
}

proxy_log_final_path() {
  local port="$1"
  if [[ -n "${CLAUDE_PROXY_LOG_FILE:-}" ]]; then
    printf '%s' "$CLAUDE_PROXY_LOG_FILE"
  elif [[ -n "${CLAUDE_PROXY_LOG_DIR:-}" ]]; then
    printf '%s/proxy.%s.log' "${CLAUDE_PROXY_LOG_DIR%/}" "$port"
  fi
}

proxy_ephemeral_stderr_path() {
  local startup_tag="$1"
  printf '%s/.claude/proxy.stderr.%s.tmp' "$HOME" "$startup_tag"
}

describe_proxy_log_target() {
  local path="$1"
  [[ -n "$path" ]] || return 0
  printf ' — see %s' "$path"
}

# ARCH: ensure_proxy_running — per-shell proxy spawner (one proxy per c-thru invocation).
#   1. If CLAUDE_PROXY_PORT is set (explicit path), connect to that port — no spawn.
#   2. Otherwise, spawn claude-proxy as a foreground child (NOT disowned) so it dies
#      when this shell exits. The proxy binds on port 0 (OS-assigned).
#   3. Proxy writes "READY <port>" to a named FIFO (stdout); router blocks reading it
#      (timeout=45s) and records the port in PROXY_PORT.
#   4. Verifies /ping after READY — catches the race where the proxy crashes between
#      printing READY and actually answering HTTP (e.g. config syntax error).
ensure_proxy_running() {
  [[ "${C_THRU_SKIP_PROXY_AUTOSTART:-0}" == "1" ]] && return 0

  local base_url="$1"
  local port
  port="$(proxy_port_from_base_url "$base_url")"
  if ! proxy_port_is_explicit; then
    local proxy_js="$CLAUDE_PROFILE_DIR/tools/claude-proxy"
    if [[ ! -f "$proxy_js" ]]; then
      proxy_js="$CTHRU_REPO_ROOT/tools/claude-proxy"
    fi
    if [[ ! -f "$proxy_js" ]]; then
      echo "c-thru: claude-proxy missing at both $CLAUDE_PROFILE_DIR/tools/claude-proxy and $CTHRU_REPO_ROOT/tools/claude-proxy — run install.sh or start the proxy" >&2
      return 1
    fi

    if [[ -n "${PROXY_STARTED_PID:-}" ]]; then
      [[ -n "${PROXY_PORT:-}" ]] && wait_proxy_ping_ready "$PROXY_PORT" 20 && return 0
      kill "$PROXY_STARTED_PID" >/dev/null 2>&1 || true
      wait "$PROXY_STARTED_PID" >/dev/null 2>&1 || true
      PROXY_STARTED_PID=""
      PROXY_PORT=""
    fi

    local startup_tag temp_log ready_pipe ready_line ready_timeout
    startup_tag="${$}.$RANDOM"
    temp_log="$(proxy_log_startup_path "$startup_tag")"
    if [[ -z "$temp_log" ]]; then
      temp_log="$(proxy_ephemeral_stderr_path "$startup_tag")"
    fi
    ensure_proxy_log_parent_dir "$temp_log"
    ready_pipe="$CLAUDE_PROFILE_DIR/proxy.ready.$startup_tag.pipe"
    ready_timeout="${CLAUDE_PROXY_READY_TIMEOUT_SECONDS:-45}"
    rm -f "$ready_pipe"
    mkfifo "$ready_pipe"
    printf "  ${GRAY}•${NC} ${BOLD}%-10s${NC} starting...\r" "proxy" >&2
    C_THRU_DEBUG="${C_THRU_DEBUG:-}" \
    CLAUDE_MODEL_MAP_PATH="$CONFIG" \
      "$proxy_js" >"$ready_pipe" 2>"$temp_log" &
    PROXY_STARTED_PID="$!"
    arm_proxy_cleanup
    local start_ec=0
    if ! IFS= read -r -t "$ready_timeout" ready_line <"$ready_pipe"; then
      start_ec=1
      diagnose_proxy_startup_failure "$PROXY_STARTED_PID" "" "$temp_log" \
        "timed out waiting for claude-proxy readiness line (after ${ready_timeout}s)"
    elif [[ ! "$ready_line" =~ ^READY\ ([0-9]+)$ ]]; then
      start_ec=1
      diagnose_proxy_startup_failure "$PROXY_STARTED_PID" "" "$temp_log" \
        "malformed claude-proxy readiness line '$ready_line'"
    else
      PROXY_PORT="${BASH_REMATCH[1]}"
      local final_log=""
      final_log="$(proxy_log_final_path "$PROXY_PORT")"
      if [[ -n "$temp_log" ]]; then
        ensure_proxy_log_parent_dir "${final_log:-$temp_log}"
        if [[ -n "$final_log" && "$final_log" != "$temp_log" ]]; then
          mv -f "$temp_log" "$final_log"
        elif ! proxy_logging_enabled; then
          rm -f "$temp_log"
          final_log=""
        else
          final_log="$temp_log"
        fi
      fi
      PROXY_LOG_PATH="$final_log"
      # Defense-in-depth: between the proxy printing "READY <port>" and
      # actually answering /ping, it's running listen-loop init. If the
      # node process crashes here (config syntax error, missing module,
      # etc.) the port appears bound briefly then disappears. Catch that.
      if ! kill -0 "$PROXY_STARTED_PID" 2>/dev/null; then
        start_ec=1
        diagnose_proxy_startup_failure "$PROXY_STARTED_PID" "$PROXY_PORT" "$final_log" \
          "claude-proxy exited immediately after announcing READY (likely a config or runtime error)"
      elif ! wait_proxy_ping_ready "$PROXY_PORT" 20; then
        start_ec=1
        diagnose_proxy_startup_failure "$PROXY_STARTED_PID" "$PROXY_PORT" "$final_log" \
          "claude-proxy did not answer /ping on :$PROXY_PORT within 2s"
      elif ! verify_proxy_health "$PROXY_PORT"; then
        # /ping returned something but it wasn't the expected {"ok":true,...}
        # shape — port was likely already bound by an unrelated process when
        # we tried to spawn (collision), or the proxy half-initialized.
        start_ec=1
        diagnose_proxy_startup_failure "$PROXY_STARTED_PID" "$PROXY_PORT" "$final_log" \
          "claude-proxy /ping responded but body is not the expected shape (port collision or half-init?)"
      else
        printf "  ${GRAY}✓${NC} ${BOLD}%-10s${NC} ${GRAY}http://127.0.0.1:%s${NC}\n" "proxy" "$PROXY_PORT" >&2
      fi
    fi
    rm -f "$ready_pipe"
    if [[ "$start_ec" -eq 1 ]]; then
      kill "$PROXY_STARTED_PID" >/dev/null 2>&1 || true
      wait "$PROXY_STARTED_PID" >/dev/null 2>&1 || true
      PROXY_STARTED_PID=""
      PROXY_PORT=""
      PROXY_LOG_PATH=""
      if [[ -n "$temp_log" ]] && ! proxy_logging_enabled; then
        rm -f "$temp_log"
      fi
      rm -f "$ready_pipe"
      return 1
    fi
    return 0
  fi

  [[ -z "$port" ]] && return 0
  is_local_http_base_url "$base_url" || return 0

  # Reuse proxy already listening on this port (any start method).
  local ping_json=""
  ping_json="$(proxy_ping_json "$port" || true)"
  if [[ -n "$ping_json" ]]; then
    local ping_ok existing_config existing_pid kill_pid
    ping_ok="$(printf '%s' "$ping_json" | jq -r '.ok // false' 2>/dev/null || echo false)"
    existing_config="$(printf '%s' "$ping_json" | jq -r '.config_path // empty' 2>/dev/null || true)"
    existing_pid="$(printf '%s' "$ping_json" | jq -r '.pid // empty' 2>/dev/null || true)"
    if [[ "$ping_ok" == "true" && "$existing_config" == "${CONFIG:-}" ]]; then
      printf "  ${GRAY}✓${NC} ${BOLD}%-10s${NC} ${GRAY}http://127.0.0.1:%s${NC} ${GRAY}(reusing)${NC}\n" "proxy" "$port" >&2
      return 0
    fi

    kill_pid="$existing_pid"
    if [[ -z "$kill_pid" ]]; then
      kill_pid="$(proxy_listener_pid "$port" || true)"
    fi
    if [[ -n "$kill_pid" ]]; then
      echo "c-thru: restarting claude-proxy on :$port due to config mismatch (${existing_config:-<unknown>} != ${CONFIG:-<unset>})" >&2
      kill "$kill_pid" >/dev/null 2>&1 || true
      wait_proxy_listener_gone "$port" 30 || true
      ping_json=""
    else
      echo "c-thru: existing claude-proxy on :$port did not report a matching config path and could not be restarted safely" >&2
      return 0
    fi
  fi

  local existing_listener_pid=""
  existing_listener_pid="$(proxy_listener_pid "$port")" || true
  if [[ -n "$existing_listener_pid" ]]; then
    if wait_proxy_ping_ready "$port" 20; then
      return 0
    fi
    echo "c-thru: port :$port already has a listener (pid=$existing_listener_pid) but claude-proxy /ping did not answer — not launching another proxy" >&2
    return 0
  fi

  local proxy_js="$CLAUDE_PROFILE_DIR/tools/claude-proxy"
  if [[ ! -f "$proxy_js" ]]; then
    proxy_js="$CTHRU_REPO_ROOT/tools/claude-proxy"
  fi
  if [[ ! -f "$proxy_js" ]]; then
    # No local script — maybe you started claude-proxy manually from elsewhere.
    if wait_proxy_ping_ready "$port" 50; then
      return 0
    fi
    echo "c-thru: claude-proxy not reachable on :$port and missing at both $CLAUDE_PROFILE_DIR/tools/claude-proxy and $CTHRU_REPO_ROOT/tools/claude-proxy — run install.sh or start the proxy" >&2
    return 0
  fi

  local start_ec=0
  local lock_fd=""
  local lock_dir=""
  # A1: when a concurrent router already holds the lock, wait for its proxy
  # to come up via /ping. If that wait times out the holder probably died
  # without bringing up a proxy — block on the lock so we can take over
  # and spawn one ourselves, rather than returning "success" with nothing
  # listening.
  if command -v flock >/dev/null 2>&1; then
    exec {lock_fd}>"$CLAUDE_PROFILE_DIR/proxy.$port.lock"
    if ! flock -n "$lock_fd"; then
      if wait_proxy_ping_ready "$port" 50; then
        eval "exec ${lock_fd}>&-"
        return 0
      fi
      echo "c-thru: prior claude-proxy launch on :$port appears to have failed — retrying under blocking lock" >&2
      flock "$lock_fd"
      # Double-check: the previous holder may have finally succeeded while
      # we were blocked. If /ping answers now, we're done.
      if curl -sf --max-time 2.0 "http://127.0.0.1:$port/ping" >/dev/null 2>&1; then
        eval "exec ${lock_fd}>&-"
        return 0
      fi
    fi
  else
    lock_dir="$CLAUDE_PROFILE_DIR/proxy.$port.lock.d"
    # Clean up obviously stale lockdirs (older than 30s).
    if [[ -d "$lock_dir" ]]; then
      local lock_age
      lock_age=$(( $(date +%s) - $(stat -f %m "$lock_dir" 2>/dev/null || stat -c %Y "$lock_dir" 2>/dev/null || echo 0) ))
      [[ "$lock_age" -gt 30 ]] && rmdir "$lock_dir" 2>/dev/null || true
    fi
    # Distinguish EEXIST (lock held) from other mkdir failures (EROFS/EACCES
    # etc.), where we'd otherwise silently run with no lock at all.
    local mkdir_err_file="${TMPDIR:-/tmp}/c-thru-mkdir-err.$$.$RANDOM"
    if ! mkdir "$lock_dir" 2>"$mkdir_err_file"; then
      local mkdir_err
      mkdir_err="$(cat "$mkdir_err_file" 2>/dev/null || true)"
      rm -f "$mkdir_err_file" 2>/dev/null || true
      if [[ -d "$lock_dir" ]]; then
        if wait_proxy_ping_ready "$port" 50; then
          return 0
        fi
        echo "c-thru: prior claude-proxy launch on :$port appears to have failed — retrying" >&2
        # Take over the stale lockdir and fall through.
        rmdir "$lock_dir" 2>/dev/null || true
        if ! mkdir "$lock_dir" 2>/dev/null; then
          echo "c-thru: unable to acquire proxy lockdir on :$port after takeover attempt" >&2
          return 1
        fi
      else
        echo "c-thru: cannot create proxy lockdir ($lock_dir): ${mkdir_err:-unknown error}" >&2
        return 1
      fi
    else
      # mkdir succeeded; the 2>"$mkdir_err_file" redirection still created
      # an empty file, so clean it up.
      rm -f "$mkdir_err_file" 2>/dev/null || true
    fi
  fi

  if curl -sf --max-time 2.0 "http://127.0.0.1:$port/ping" >/dev/null 2>&1; then
    start_ec=0
  else
    local explicit_log=""
    explicit_log="$(proxy_log_final_path "$port")"
    local temp_log=""
    if [[ -n "$explicit_log" ]]; then
      ensure_proxy_log_parent_dir "$explicit_log"
      CLAUDE_PROXY_PORT="$port" C_THRU_DEBUG="${C_THRU_DEBUG:-}" \
      CLAUDE_MODEL_MAP_PATH="$CONFIG" \
        node "$proxy_js" >>"$explicit_log" 2>&1 &
      PROXY_LOG_PATH="$explicit_log"
    else
      temp_log="$(proxy_ephemeral_stderr_path "${$}.$port.$RANDOM")"
      ensure_proxy_log_parent_dir "$temp_log"
      CLAUDE_PROXY_PORT="$port" C_THRU_DEBUG="${C_THRU_DEBUG:-}" \
      CLAUDE_MODEL_MAP_PATH="$CONFIG" \
        node "$proxy_js" >/dev/null 2>"$temp_log" &
      PROXY_LOG_PATH=""
    fi
    PROXY_STARTED_PID="$!"
    arm_proxy_cleanup
    if ! wait_proxy_ping_ready "$port" 50; then
      start_ec=1
      echo "c-thru: timed out waiting for claude-proxy to answer /ping on :$port" >&2
      if [[ -n "$explicit_log" && -s "$explicit_log" ]]; then
        echo "c-thru: last proxy log lines from $explicit_log:" >&2
        tail -n 10 "$explicit_log" | sed 's/^/  /' >&2
      elif [[ -n "$temp_log" && -s "$temp_log" ]]; then
        echo "c-thru: last proxy log lines from $temp_log:" >&2
        tail -n 10 "$temp_log" | sed 's/^/  /' >&2
      fi
      # A7: only signal if the PID still belongs to our spawned node proxy.
      if pid_looks_like_proxy "$PROXY_STARTED_PID"; then
        kill "$PROXY_STARTED_PID" >/dev/null 2>&1 || true
        wait "$PROXY_STARTED_PID" >/dev/null 2>&1 || true
      fi
      PROXY_STARTED_PID=""
      PROXY_LOG_PATH=""
      # Do not remove temp_log on failure to aid troubleshooting
    elif [[ -n "$temp_log" ]]; then
      rm -f "$temp_log"
    fi
  fi

  if [[ -n "$lock_dir" ]]; then
    rmdir "$lock_dir" 2>/dev/null || true
  elif [[ -n "$lock_fd" ]]; then
    eval "exec ${lock_fd}>&-"
  fi

  if [[ "$start_ec" -eq 1 ]]; then
    echo "c-thru: claude-proxy did not become ready on :$port$(describe_proxy_log_target "$PROXY_LOG_PATH")" >&2
    echo "c-thru: check for port conflicts or invalid model-map config in $CONFIG" >&2
    return 1
  fi
  return 0
}

# ARCH: ensure_proxy_http_base — decides between explicit-port (CLAUDE_PROXY_PORT set) and
#   dynamic-spawn paths; both call ensure_proxy_running and populate ENSURED_PROXY_HTTP_BASE.
#   PROXY_PORT is normalized in both branches so write_ephemeral_settings and
#   system-prompt injection always see the real port regardless of how the proxy was started.
ensure_proxy_http_base() {
  if proxy_port_is_explicit; then
    local explicit_base=""
    explicit_base="$(claude_proxy_http_base)" || {
      echo "c-thru: failed to resolve explicit claude-proxy base URL" >&2
      return 1
    }
    ensure_proxy_running "$explicit_base" || return 1
    ENSURED_PROXY_HTTP_BASE="$explicit_base"
    # Normalize so both paths populate PROXY_PORT (used for system-prompt injection).
    PROXY_PORT="${PROXY_PORT:-$CLAUDE_PROXY_PORT}"
    return 0
  fi

  ensure_proxy_running "" || return 1
  ENSURED_PROXY_HTTP_BASE="$(claude_proxy_http_base)" || return 1
}

# Normalize an Ollama base URL to a CLI-safe host (scheme://host[:port], no path).
# Also tolerates users setting OLLAMA_BASE_URL to ".../api" by stripping that suffix.
ollama_cli_host() {
  local url="$1"
  # Strip trailing "/api" (common confusion: cloud docs sometimes show /api base)
  url="${url%/api}"
  # Strip any trailing slash
  url="${url%/}"
  # Keep only scheme://host[:port]
  # shellcheck disable=SC2001
  echo "$url" | sed -E 's#^(https?://[^/]+).*$#\1#'
}

# Only warm models for local Ollama to avoid launching Ollama UI/auth flows for cloud endpoints.
is_local_ollama_host() {
  local host="$1"
  case "$host" in
    http://localhost:*|http://127.0.0.1:*|http://0.0.0.0:*|http://[::1]:*|http://localhost|http://127.0.0.1|http://0.0.0.0)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

# HTTP-only liveness check for the Ollama REST server. No CLI dependency.
# Returns 0 if /api/version responds within 3s, 1 otherwise.
ollama_server_http_alive() {
  curl -sf --max-time 3 "${1}/api/version" -o /dev/null 2>/dev/null
}

# Braille spinner UX helpers — Gemma-CLI style persistent lines.
# Overwrite the current terminal line with an animated spinner frame.
_ollama_spin() {
  local sp="$1" label="$2" detail="$3" elapsed="$4"
  printf "\r  ${BOLD}%s${NC} %s  ${GRAY}%s${NC}  ${GRAY}(%s)${NC}          " \
    "$sp" "$label" "$detail" "$elapsed" >&2
}
# Print a persistent completion line (ends with \n — stays on screen).
_ollama_done() {
  local icon="$1" label="$2" detail="$3"
  printf "\r  ${BOLD}%s${NC} %s  ${GRAY}%s${NC}                              \n" \
    "$icon" "$label" "$detail" >&2
}

# Ollama API key for CLI: optional inline .api_key on backend JSON, else ${!.auth_env}.
ollama_secret_from_backend_json() {
  local json="$1"
  local inline envname
  inline=$(jq -r '.api_key // empty' <<< "$json")
  [[ -n "$inline" && "$inline" != "null" ]] && { printf '%s' "$inline"; return 0; }
  envname=$(jq -r '.auth_env // empty' <<< "$json")
  [[ -n "$envname" && "$envname" != "null" && -n "${!envname:-}" ]] && printf '%s' "${!envname}"
  return 0
}

cthru_debug_event() {
  local _dl="${C_THRU_DEBUG:-0}"
  [[ "$_dl" == "0" || "$_dl" == "false" ]] && return 0
  echo "c-thru debug: $*" >&2
}

ollama_prep_state_parent_dir() {
  mkdir -p "$(dirname "$OLLAMA_PREP_STATE_FILE")"
}

ollama_prep_state_get() {
  local section="$1"
  local key="$2"
  local field="$3"
  python3 - "$OLLAMA_PREP_STATE_FILE" "$section" "$key" "$field" <<'PY'
import json, os, sys
path, section, key, field = sys.argv[1:5]
if not os.path.exists(path):
    sys.exit(0)
try:
    with open(path, 'r', encoding='utf-8') as fh:
        data = json.load(fh)
except Exception:
    sys.exit(0)
value = ((data.get(section) or {}).get(key) or {}).get(field)
if value is None:
    sys.exit(0)
if isinstance(value, bool):
    sys.stdout.write("true" if value else "false")
else:
    sys.stdout.write(str(value))
PY
}

ollama_prep_state_update() {
  local section="$1"
  local key="$2"
  local event="$3"
  local status="$4"
  local age_text="${5:-}"
  local now=""
  now="$(date +%s)"
  ollama_prep_state_parent_dir
  python3 - "$OLLAMA_PREP_STATE_FILE" "$section" "$key" "$event" "$status" "$age_text" "$now" <<'PY'
import json, os, sys, tempfile
path, section, key, event, status, age_text, now = sys.argv[1:8]
try:
    with open(path, 'r', encoding='utf-8') as fh:
        data = json.load(fh)
except Exception:
    data = {}
bucket = data.setdefault(section, {})
entry = bucket.setdefault(key, {})
entry["last_status"] = status
if age_text:
    entry["last_age_text"] = age_text
if event == "cached":
    entry["last_seen_cached_at"] = now
elif event == "pull_attempt":
    entry["last_pull_attempt_at"] = now
elif event == "pull_success":
    entry["last_pull_success_at"] = now
elif event == "pull_failure":
    entry["last_pull_failure_at"] = now
elif event == "install_attempt":
    entry["last_install_attempt_at"] = now
elif event == "install_success":
    entry["last_install_success_at"] = now
elif event == "install_failure":
    entry["last_install_failure_at"] = now
parent = os.path.dirname(path)
if parent:
    os.makedirs(parent, exist_ok=True)
fd, tmp = tempfile.mkstemp(prefix=".ollama-prep-state.", dir=parent)
with os.fdopen(fd, 'w', encoding='utf-8') as fh:
    json.dump(data, fh, indent=2, sort_keys=True)
os.replace(tmp, path)
PY
}

ollama_prep_retry_allowed() {
  local section="$1"
  local key="$2"
  local field="$3"
  local min_seconds="$4"
  local last_attempt=""
  local now=""
  last_attempt="$(ollama_prep_state_get "$section" "$key" "$field" || true)"
  [[ "$min_seconds" =~ ^[0-9]+$ ]] || min_seconds=0
  [[ "$last_attempt" =~ ^[0-9]+$ ]] || return 0
  now="$(date +%s)"
  (( now - last_attempt >= min_seconds ))
}

ollama_model_state_key() {
  local model="$1"
  local cli_host="$2"
  printf '%s|%s' "$cli_host" "$model"
}

ollama_refresh_age_is_stale() {
  local age_text="$1"
  local threshold="${OLLAMA_PREP_REFRESH_DAYS:-7}"
  [[ -n "$age_text" ]] || return 1
  [[ "$threshold" =~ ^[0-9]+$ ]] || threshold=7
  case "$age_text" in
    *year*ago|*years*ago|*month*ago|*months*ago|*week*ago|*weeks*ago)
      return 0
      ;;
  esac
  if [[ "$age_text" =~ ([0-9]+)[[:space:]]+day ]]; then
    (( BASH_REMATCH[1] >= threshold ))
    return
  fi
  return 1
}

ollama_extract_age_text() {
  local model="$1"
  local list_output="$2"
  awk -v target="$model" '
    NR > 1 && $1 == target {
      if (NF >= 4) {
        out = $(NF-2) " " $(NF-1) " " $NF
        print out
      }
      exit
    }
  ' <<< "$list_output"
}

ensure_ollama_cli_available() {
  local mode="${1:-active}"
  if command -v ollama >/dev/null 2>&1; then
    cthru_debug_event "ollama requirements result mode=$mode cli=present"
    return 0
  fi

  cthru_debug_event "ollama requirements result mode=$mode cli=missing"
  if ! command -v brew >/dev/null 2>&1; then
    echo "c-thru: 'ollama' CLI not found — install Ollama or Homebrew to enable local model prep" >&2
    return 1
  fi

  if ! ollama_prep_retry_allowed "requirements" "ollama_cli" "last_install_attempt_at" "$OLLAMA_INSTALL_MIN_RETRY_SECONDS"; then
    echo "c-thru: 'ollama' CLI not found — skipping repeated Homebrew install attempt for now" >&2
    return 1
  fi

  ollama_prep_state_update "requirements" "ollama_cli" "install_attempt" "installing"
  echo "c-thru: 'ollama' CLI not found — attempting 'brew install ollama' in background..." >&2
  local install_log=""
  install_log="$(mktemp "${TMPDIR:-/tmp}/c-thru-ollama-install.XXXXXX.log" 2>/dev/null || true)"
  [[ -n "$install_log" ]] || install_log="/dev/null"
  (
    if brew install ollama >"$install_log" 2>&1; then
      ollama_prep_state_update "requirements" "ollama_cli" "install_success" "installed"
      cthru_debug_event "ollama requirements result mode=$mode install=success"
    else
      ollama_prep_state_update "requirements" "ollama_cli" "install_failure" "install_failed"
      cthru_debug_event "ollama requirements result mode=$mode install=failure"
      if [[ -s "$install_log" ]]; then
        echo "c-thru: failed to install 'ollama' via Homebrew — continuing without local model prep (see $install_log)" >&2
      else
        echo "c-thru: failed to install 'ollama' via Homebrew — continuing without local model prep" >&2
      fi
    fi
  ) &
  local install_pid="$!"
  local install_wait_steps="${C_THRU_OLLAMA_INSTALL_WAIT_STEPS:-10}"
  [[ "$install_wait_steps" =~ ^[0-9]+$ ]] || install_wait_steps=10
  local install_step=0
  while kill -0 "$install_pid" >/dev/null 2>&1 && (( install_step < install_wait_steps )); do
    sleep 0.1
    install_step=$((install_step + 1))
  done
  if kill -0 "$install_pid" >/dev/null 2>&1; then
    disown "$install_pid" 2>/dev/null || disown 2>/dev/null || true
  else
    wait "$install_pid" >/dev/null 2>&1 || true
    if command -v ollama >/dev/null 2>&1; then
      echo "c-thru: installed 'ollama' via Homebrew — continuing local model prep" >&2
      cthru_debug_event "ollama requirements result mode=$mode install=success continue=true"
      return 0
    fi
  fi
  return 1
}

resolve_ollama_backend_for_model() {
  local model="$1"
  [[ -f "$CONFIG" ]] || return 1
  [[ -n "$model" ]] || return 1

  local backend_id=""
  local target_data=""
  target_data="$(resolve_target_backend_for_model "$model" || true)"
  if [[ -n "$target_data" ]]; then
    backend_id="${target_data%%$'\t'*}"
  fi
  [[ -n "$backend_id" ]] || backend_id="$(jq -r --arg m "$model" '.model_routes[$m] // empty' "$CONFIG" 2>/dev/null || true)"
  [[ -n "$backend_id" ]] || backend_id="$(lookup_model_pattern_value "model_routes" "$model")"
  [[ -n "$backend_id" ]] || return 1

  local backend=""
  backend="$(jq -c --arg id "$backend_id" '.backends[$id] // empty' "$CONFIG" 2>/dev/null || true)"
  [[ -n "$backend" && "$backend" != "null" ]] || return 1

  local kind base_url cli_host api_key explicit_auth local_flag
  kind="$(jq -r '.kind // "anthropic"' <<< "$backend" 2>/dev/null)"
  [[ "$kind" == "ollama" ]] || return 1
  base_url="$(jq -r '.url // empty' <<< "$backend" 2>/dev/null)"
  cli_host="$(ollama_cli_host "$base_url")"
  api_key="$(ollama_secret_from_backend_json "$backend")"
  if [[ -z "$api_key" && -n "${OLLAMA_API_KEY:-}" ]]; then
    api_key="${OLLAMA_API_KEY}"
  fi
  explicit_auth=0
  [[ -n "$api_key" ]] && explicit_auth=1
  local_flag=0
  is_local_ollama_host "$cli_host" && local_flag=1
  printf '%s\t%s\t%s\t%s\t%s\n' "$cli_host" "$api_key" "$backend_id" "$explicit_auth" "$local_flag"
}

resolve_local_ollama_backend_for_model() {
  local model_or_backend="$1"
  local backend_data="$model_or_backend"
  if [[ "$backend_data" != *$'\t'* ]]; then
    backend_data="$(resolve_ollama_backend_for_model "$model_or_backend" || true)"
  fi
  [[ -n "$backend_data" ]] || return 1

  local cli_host rest backend_id explicit_auth local_flag cli_key
  cli_host="${backend_data%%$'\t'*}"
  rest="${backend_data#*$'\t'}"
  cli_key="${rest%%$'\t'*}"
  rest="${rest#*$'\t'}"
  backend_id="${rest%%$'\t'*}"
  rest="${rest#*$'\t'}"
  explicit_auth="${rest%%$'\t'*}"
  local_flag="${rest#*$'\t'}"
  [[ "$local_flag" == "1" ]] || return 1
  printf '%s\t%s\t%s\n' "$cli_host" "$cli_key" "$backend_id"
}

collect_active_profile_cloud_ollama_models() {
  [[ -f "$CONFIG" ]] || return 0
  llm_profiles_defined || return 0

  local capability resolved _rec backend_data cli_host cli_key backend_id explicit_auth local_flag rest
  while IFS=$'\t' read -r capability resolved _rec; do
    [[ -n "$resolved" ]] || continue
    model_is_cloud_designated "$resolved" || continue
    backend_data="$(resolve_ollama_backend_for_model "$resolved" || true)"
    [[ -n "$backend_data" ]] || continue
    cli_host="${backend_data%%$'\t'*}"
    rest="${backend_data#*$'\t'}"
    cli_key="${rest%%$'\t'*}"
    rest="${rest#*$'\t'}"
    backend_id="${rest%%$'\t'*}"
    rest="${rest#*$'\t'}"
    explicit_auth="${rest%%$'\t'*}"
    local_flag="${rest#*$'\t'}"
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$resolved" "$cli_host" "$(tab_field_encode "$cli_key")" "$backend_id" "$explicit_auth" "$local_flag" "$capability"
  done < <(collect_active_profile_capability_assignments) | sort -u
}

collect_active_profile_local_ollama_models() {
  [[ -f "$CONFIG" ]] || return 0
  llm_profiles_defined || return 0

  local profile
  ensure_llm_profile_context || return 0
  profile="$LLM_PROFILE_CACHE_NAME"
  [[ -n "$profile" ]] || return 0
  local llm_mode; llm_mode="$(resolve_llm_mode)"
  cthru_debug_event "ollama sweep profile profile=$profile mode=$llm_mode"

  local capability resolved _rec backend_data cli_host cli_key backend_id
  while IFS=$'\t' read -r capability resolved _rec; do
    [[ -n "$resolved" ]] || continue
    backend_data="$(resolve_local_ollama_backend_for_model "$resolved" || true)"
    [[ -n "$backend_data" ]] || continue
    cli_host="${backend_data%%$'\t'*}"
    cli_key="${backend_data#*$'\t'}"
    backend_id="${cli_key#*$'\t'}"
    cli_key="${cli_key%%$'\t'*}"
    printf '%s\t%s\t%s\t%s\t%s\n' "$resolved" "$cli_host" "$(tab_field_encode "$cli_key")" "$backend_id" "$capability"
  done < <(collect_active_profile_capability_assignments) | sort -u
}

run_background_ollama_prep_sweep() {
  local active_model="$1"
  local active_host="$2"
  local active_api_key="$3"
  local active_backend_id="${4:-}"
  local lines=""
  lines="$(collect_active_profile_local_ollama_models)"
  [[ -n "$lines" ]] || return 0

  local sweep_lines=""
  sweep_lines="$(awk -F '\t' -v model="$active_model" -v host="$active_host" -v backend="$active_backend_id" '
    !(model != "" && host != "" && $1 == model && $2 == host && (backend == "" || $4 == backend))
  ' <<< "$lines")"
  [[ -n "$sweep_lines" ]] || return 0

  local grouped_sweep=""
  grouped_sweep="$(awk -F '\t' '
    {
      key=$1 "\t" $2 "\t" $3 "\t" $4
      capability=$5
      if (!(key in seen)) {
        seen[key]=1
        order[++count]=key
        capabilities[key]=capability
      } else if (capability != "" && index("," capabilities[key] ",", "," capability ",") == 0) {
        capabilities[key]=capabilities[key] "," capability
      }
    }
    END {
      for (i = 1; i <= count; i++) {
        print order[i] "\t" capabilities[order[i]]
      }
    }
  ' <<< "$sweep_lines")"
  [[ -n "$grouped_sweep" ]] || return 0

  OLLAMA_PREP_SWEEP_STARTED=1
  local count
  count="$(printf '%s\n' "$grouped_sweep" | sed '/^$/d' | wc -l | tr -d ' ')"
  [[ "$count" =~ ^[0-9]+$ ]] || count=0
  (( count > 0 )) || return 0

  local sweep_descriptions=()
  local model cli_host cli_key backend_id capabilities
  while IFS=$'\t' read -r model cli_host cli_key backend_id capabilities; do
    [[ -n "$model" ]] || continue
    if [[ -n "$capabilities" ]]; then
      sweep_descriptions+=("$model [$capabilities]")
    else
      sweep_descriptions+=("$model")
    fi
  done <<< "$grouped_sweep"
  local joined_sweep=""
  printf -v joined_sweep '%s; ' "${sweep_descriptions[@]}"
  joined_sweep="${joined_sweep%; }"

  if [[ "${PROXY_ACTIVE_MODEL_WARMED:-0}" == "0" ]]; then
    printf "  ${GRAY}•${NC} ${BOLD}%-10s${NC} warming $count model(s) in background...\n" "fleet" >&2
  fi
  cthru_debug_event "ollama sweep start count=$count models=$(printf '%s' "$grouped_sweep" | cut -f1 | paste -sd ',' -)"
  (
    local entry model cli_host cli_key backend_id capabilities
    while IFS=$'\t' read -r model cli_host cli_key backend_id capabilities; do
      [[ -n "$model" && -n "$cli_host" ]] || continue
      cli_key="$(tab_field_decode "$cli_key")"
      ensure_ollama_running "$model" "$cli_host" "$cli_key" "sweep" "$backend_id" "$capabilities"
    done <<< "$grouped_sweep"
    cthru_debug_event "ollama sweep result count=$count"
  ) >/dev/null 2>&1 &
  disown 2>/dev/null || true
}

# ARCH: preflight_model_readiness — blocking pre-launch check that pulls and warms any Ollama
#   models the proxy reports as needed but not yet present locally.
#   Called in the main flow after the proxy is up, before exec'ing the real claude binary.
#   Bypassed on cloud-only configs (proxy /v1/active-models returns an empty local_models list).
#   Silent early-exits on: C_THRU_SKIP_PREFLIGHT=1, unknown proxy port, missing curl, or an
#   unreachable Ollama host — none of these are fatal to the session.
preflight_model_readiness() {
  local port="${1:-}"
  [[ "${C_THRU_SKIP_PREFLIGHT:-0}" == "1" ]] && return 0
  [[ -n "$port" ]] || return 0
  command -v curl >/dev/null 2>&1 || return 0

  local response
  response=$(curl -sf --max-time 3 "http://127.0.0.1:$port/v1/active-models" 2>/dev/null) || return 0
  [[ -n "$response" ]] || return 0

  local required_models
  if command -v jq >/dev/null 2>&1; then
    required_models=$(printf '%s' "$response" | jq -r '.local_models[]' 2>/dev/null) || return 0
  elif command -v node >/dev/null 2>&1; then
    required_models=$(node -e "
      try{const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
          d.local_models.forEach(m=>console.log(m));}catch{}" <<< "$response" 2>/dev/null) || return 0
  else
    return 0
  fi
  [[ -n "$required_models" ]] || return 0

  local ollama_base="${OLLAMA_URL:-http://localhost:11434}"
  local pulled_json pulled_models
  pulled_json=$(curl -sf --max-time 3 "${ollama_base%/}/api/tags" 2>/dev/null) || return 0
  if command -v jq >/dev/null 2>&1; then
    pulled_models=$(printf '%s' "$pulled_json" | jq -r '.models[].name' 2>/dev/null || true)
  else
    pulled_models=$(node -e "
      try{const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
          d.models.forEach(m=>console.log(m.name));}catch{}" <<< "$pulled_json" 2>/dev/null || true)
  fi

  local any_missing=0
  while IFS= read -r model; do
    [[ -n "$model" ]] || continue
    local bare_model="${model%%@*}"
    if ! printf '%s\n' "$pulled_models" | grep -qxF "$bare_model"; then
      any_missing=1
      printf "  ${GRAY}•${NC} ${BOLD}%-10s${NC} model '$bare_model' not found locally — pulling...\n" "fleet" >&2
      if command -v ollama >/dev/null 2>&1; then
        ollama pull "$bare_model" >&2
      else
        printf "  ${GRAY}!${NC} ${BOLD}%-10s${NC} 'ollama' CLI not on PATH — cannot pull '$bare_model'; session may fail\n" "fleet" >&2
      fi
      printf "  ${GRAY}•${NC} ${BOLD}%-10s${NC} warming $bare_model into VRAM...\n" "fleet" >&2
      curl -s "${ollama_base%/}/api/generate" \
        -d "{\"model\":\"${bare_model}\",\"prompt\":\"\",\"keep_alive\":\"5m\"}" \
        >/dev/null 2>&1 &
      disown $! 2>/dev/null || true
    fi
  done <<< "$required_models"
  [[ "$any_missing" -eq 0 ]] || printf '\n' >&2
}

ensure_active_tier_ollama_requirements() {
  [[ "${C_THRU_SKIP_PREPULL:-0}" == "1" ]] && return 0
  [[ -f "$CONFIG" ]] || return 0
  command -v ollama >/dev/null 2>&1 && return 0
  llm_profiles_defined || return 0

  local lines
  lines="$(collect_active_profile_local_ollama_models)"
  [[ -n "$lines" ]] || return 0

  # Local models are required but ollama is missing. Warn or install.
  ensure_ollama_cli_available "startup" || true
}

# ARCH: ensure_active_tier_prepulled — fires a disowned background subshell on every router
#   invocation to pull missing active-tier local Ollama models before they are first needed.
#   Debounced by .prepull-stamp-<tier> (mtime compared to model-map.json mtime); re-runs only
#   after a config change or fresh install. Stamp is touched BEFORE launching the background
#   job to prevent concurrent duplicate runs within the same second.
#   C_THRU_SKIP_PREPULL=1 disables entirely (CI/tests). All output is suppressed (>/dev/null).
ensure_active_tier_prepulled() {
  # Pre-pull all active-tier local Ollama models in the background so the first
  # request after a config change or fresh install does not block on a multi-GB pull.
  # Guarded by a stamp file (<profile-dir>/.prepull-stamp-<tier>) that is invalidated
  # whenever model-map.json is updated. Set C_THRU_SKIP_PREPULL=1 to disable (CI/tests).
  [[ "${C_THRU_SKIP_PREPULL:-0}" == "1" ]] && return 0
  [[ -f "$CONFIG" ]] || return 0
  command -v ollama >/dev/null 2>&1 || return 0
  llm_profiles_defined || return 0

  ensure_llm_profile_context || return 0
  local tier="$LLM_PROFILE_CACHE_NAME"
  [[ -n "$tier" ]] || return 0

  local stamp_file="$CLAUDE_PROFILE_DIR/.prepull-stamp-${tier}"
  if [[ -f "$stamp_file" && -f "$CONFIG" ]]; then
    local stamp_mtime config_mtime
    stamp_mtime="$(stat -f %m "$stamp_file" 2>/dev/null || stat -c %Y "$stamp_file" 2>/dev/null || echo 0)"
    config_mtime="$(stat -f %m "$CONFIG" 2>/dev/null || stat -c %Y "$CONFIG" 2>/dev/null || echo 0)"
    if (( stamp_mtime >= config_mtime )); then
      return 0
    fi
  fi

  local lines
  lines="$(collect_active_profile_local_ollama_models)"
  [[ -n "$lines" ]] || { touch "$stamp_file" 2>/dev/null || true; return 0; }

  # Touch stamp before launching background job to prevent concurrent runs.
  touch "$stamp_file" 2>/dev/null || true

  local count
  count="$(printf '%s\n' "$lines" | sed '/^$/d' | wc -l | tr -d ' ')"
  [[ "$count" =~ ^[0-9]+$ ]] && (( count > 0 )) || return 0

  cthru_debug_event "ollama prepull start tier=$tier count=$count"
  (
    local model cli_host cli_key backend_id
    while IFS=$'\t' read -r model cli_host cli_key backend_id _caps; do
      [[ -n "$model" && -n "$cli_host" ]] || continue
      cli_key="$(tab_field_decode "$cli_key")"
      ensure_ollama_running "$model" "$cli_host" "$cli_key" "prepull" "$backend_id"
    done <<< "$lines"
    cthru_debug_event "ollama prepull done tier=$tier count=$count"
  ) >/dev/null 2>&1 &
  disown 2>/dev/null || true
}

ollama_router_is_interactive() {
  [[ "${C_THRU_FORCE_INTERACTIVE:-0}" == "1" ]] && return 0
  [[ -t 0 && -t 1 ]]
}

ollama_router_prompt_yes_no() {
  local prompt="$1"
  local reply=""
  local normalized_reply=""
  if [[ "${C_THRU_AUTO_CONFIRM_OLLAMA_SIGNIN:-0}" == "1" ]]; then
    printf '%s' "$prompt" >&2
    return 0
  fi
  if [[ "${C_THRU_FORCE_INTERACTIVE:-0}" == "1" ]]; then
    printf '%s' "$prompt" >&2
    IFS= read -r reply || return 1
  elif [[ -r /dev/tty && -w /dev/tty ]]; then
    printf '%s' "$prompt" > /dev/tty
    IFS= read -r reply < /dev/tty || return 1
  else
    return 1
  fi

  normalized_reply="$(printf '%s' "$reply" | tr '[:upper:]' '[:lower:]')"
  case "$normalized_reply" in
    ""|y|yes)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

ollama_cloud_auth_probe() {
  local model="$1"
  local cli_host="$2"
  local ollama_api_key="${3:-}"
  local -a ollama_cli_env=(env OLLAMA_HOST="$cli_host")
  [[ -n "$ollama_api_key" ]] && ollama_cli_env+=(OLLAMA_API_KEY="$ollama_api_key")

  local -a timeout_cmd=()
  if command -v timeout >/dev/null 2>&1; then
    timeout_cmd=(timeout "$OLLAMA_CLOUD_AUTH_TIMEOUT_SECONDS")
  elif command -v gtimeout >/dev/null 2>&1; then
    timeout_cmd=(gtimeout "$OLLAMA_CLOUD_AUTH_TIMEOUT_SECONDS")
  fi

  # A9: capture stdout only; let stderr stream to the user's terminal so we
  # don't persist whatever Ollama happens to emit to stderr (which could
  # include its own API key on failure). We still need the text for
  # classification, so we also tee stderr into a private temp file that we
  # read back and delete immediately.
  local output=""
  local status=0
  local stderr_file=""
  stderr_file="$(mktemp -t c-thru-ollama-stderr.XXXXXX 2>/dev/null || echo "/tmp/c-thru-ollama-stderr.$$.$RANDOM")"
  : > "$stderr_file"
  chmod 0600 "$stderr_file" 2>/dev/null || true
  # Belt-and-braces: cleanup on any subshell exit (SIGKILL to parent still
  # leaks, but any normal ERR/EXIT path removes the temp).
  trap 'rm -f "$stderr_file" 2>/dev/null || true' RETURN
  if output="$("${ollama_cli_env[@]}" "${timeout_cmd[@]}" ollama pull "$model" 2>"$stderr_file")"; then
    cthru_debug_event "ollama cloud auth probe model=$model host=$cli_host status=ok"
    rm -f "$stderr_file"
    printf 'ok\t\n'
    return 0
  fi
  status=$?
  local stderr_text=""
  stderr_text="$(cat "$stderr_file" 2>/dev/null || true)"
  rm -f "$stderr_file"
  # Combine for classification only — not persisted anywhere.
  local combined="${output}"$'\n'"${stderr_text}"

  local summary=""
  summary="$(printf '%s\n' "$combined" | awk 'NF {sub(/^[[:space:]]+/, "", $0); print; exit}')"
  local lowered=""
  lowered="$(printf '%s' "$combined" | tr '[:upper:]' '[:lower:]')"

  if [[ "$lowered" == *"sign in"* || "$lowered" == *"signin"* || "$lowered" == *"unauthorized"* || "$lowered" == *"forbidden"* || "$lowered" == *"authentication"* || "$lowered" == *"not logged in"* ]]; then
    cthru_debug_event "ollama cloud auth probe model=$model host=$cli_host status=auth_required"
    printf 'auth_required\t%s\n' "$summary"
    return 0
  fi

  if [[ "$status" -eq 124 || "$status" -eq 143 || "$lowered" == *"cannot connect"* || "$lowered" == *"connection refused"* || "$lowered" == *"timed out"* || "$lowered" == *"timeout"* || "$lowered" == *"no such host"* || "$lowered" == *"failed to connect"* || "$lowered" == *"cannot reach"* ]]; then
    cthru_debug_event "ollama cloud auth probe model=$model host=$cli_host status=transport_error"
    printf 'transport_error\t%s\n' "$summary"
    return 0
  fi

  cthru_debug_event "ollama cloud auth probe model=$model host=$cli_host status=unknown_error"
  printf 'unknown_error\t%s\n' "$summary"
}

ensure_ollama_cloud_login() {
  local model="$1"
  local cli_host="$2"
  local ollama_api_key="${3:-}"
  local post_probe=""
  local post_status=""
  local post_message=""

  if [[ "$OLLAMA_CLOUD_AUTH_VALIDATED" == "1" ]]; then
    return 0
  fi

  if ! command -v ollama >/dev/null 2>&1; then
    echo "c-thru: Ollama cloud model '$model' requires authentication, but the 'ollama' CLI is not available." >&2
    return 1
  fi

  if ! ollama_router_is_interactive; then
    echo "c-thru: Ollama cloud models are configured but authentication is not validated." >&2
    echo "c-thru: Run 'ollama signin' and retry." >&2
    return 1
  fi

  if [[ "$OLLAMA_CLOUD_SIGNIN_ATTEMPTED" != "1" ]]; then
    echo "c-thru: Ollama cloud model access requires ollama.com sign-in." >&2
    if ! ollama_router_prompt_yes_no "Run 'ollama signin' now? [Y/n] "; then
      echo "c-thru: Ollama cloud authentication declined — aborting launch." >&2
      return 1
    fi

    OLLAMA_CLOUD_SIGNIN_ATTEMPTED=1
    if [[ "${C_THRU_FORCE_INTERACTIVE:-0}" == "1" ]]; then
      ollama signin || {
        echo "c-thru: 'ollama signin' failed — aborting launch." >&2
        return 1
      }
    else
      ollama signin </dev/tty >/dev/tty 2>&1 || {
        echo "c-thru: 'ollama signin' failed — aborting launch." >&2
        return 1
      }
    fi
  fi

  post_probe="$(ollama_cloud_auth_probe "$model" "$cli_host" "$ollama_api_key")"
  post_status="${post_probe%%$'\t'*}"
  post_message="${post_probe#*$'\t'}"
  if [[ "$post_status" == "ok" ]]; then
    OLLAMA_CLOUD_AUTH_VALIDATED=1
    return 0
  fi

  if [[ -n "$post_message" ]]; then
    echo "c-thru: Ollama cloud authentication is still not validated for '$model' (${post_message})." >&2
  else
    echo "c-thru: Ollama cloud authentication is still not validated for '$model'." >&2
  fi
  return 1
}

validate_ollama_cloud_auth_for_launch() {
  local active_model="$1"
  local candidate_lines=""
  local backend_data=""

  if model_is_cloud_designated "$active_model"; then
    backend_data="$(resolve_ollama_backend_for_model "$active_model" || true)"
    if [[ -n "$backend_data" ]]; then
      candidate_lines="$(printf '%s\t%s\n' "$active_model" "$backend_data")"
    fi
  fi

  local profile_lines=""
  profile_lines="$(collect_active_profile_cloud_ollama_models)"
  if [[ -n "$profile_lines" ]]; then
    if [[ -n "$candidate_lines" ]]; then
      candidate_lines+=$'\n'
    fi
    candidate_lines+="$profile_lines"
  fi

  [[ -n "$candidate_lines" ]] || return 0

  local deduped_lines=""
  deduped_lines="$(printf '%s\n' "$candidate_lines" | sed '/^$/d' | sort -u)"
  [[ -n "$deduped_lines" ]] || return 0

  local entry model cli_host cli_key backend_id explicit_auth local_flag probe probe_status probe_message rest capability
  while IFS= read -r entry; do
    [[ -n "$entry" ]] || continue
    model="${entry%%$'\t'*}"
    rest="${entry#*$'\t'}"
    cli_host="${rest%%$'\t'*}"
    rest="${rest#*$'\t'}"
    cli_key="${rest%%$'\t'*}"
    cli_key="$(tab_field_decode "$cli_key")"
    rest="${rest#*$'\t'}"
    backend_id="${rest%%$'\t'*}"
    rest="${rest#*$'\t'}"
    explicit_auth="${rest%%$'\t'*}"
    rest="${rest#*$'\t'}"
    local_flag="${rest%%$'\t'*}"
    capability="${rest#*$'\t'}"
    [[ -n "$model" && -n "$cli_host" ]] || continue
    if [[ "$OLLAMA_CLOUD_AUTH_VALIDATED" == "1" ]]; then
      continue
    fi
    if [[ "$explicit_auth" == "1" ]]; then
      cthru_debug_event "ollama cloud auth skip model=$model host=$cli_host reason=explicit_auth"
      continue
    fi

    probe="$(ollama_cloud_auth_probe "$model" "$cli_host" "$cli_key")"
    probe_status="${probe%%$'\t'*}"
    probe_message="${probe#*$'\t'}"
    case "$probe_status" in
      ok)
        OLLAMA_CLOUD_AUTH_VALIDATED=1
        ;;
      auth_required)
        ensure_ollama_cloud_login "$model" "$cli_host" "$cli_key" || return 1
        ;;
      transport_error)
        if [[ -n "$probe_message" ]]; then
          echo "c-thru: unable to validate Ollama cloud authentication for '$model' (${probe_message})." >&2
        else
          echo "c-thru: unable to validate Ollama cloud authentication for '$model' due to an Ollama transport error." >&2
        fi
        return 1
        ;;
      *)
        if [[ -n "$probe_message" ]]; then
          echo "c-thru: unable to validate Ollama cloud authentication for '$model' (${probe_message})." >&2
        else
          echo "c-thru: unable to validate Ollama cloud authentication for '$model'." >&2
        fi
        return 1
        ;;
    esac
  done <<< "$deduped_lines"
}

# Wait for a concurrent `ollama pull <model>` (from another c-thru session) to complete.
# Closes the dedup gap: rather than exiting early when another session is pulling, this
# blocks until that pull finishes (or times out), then verifies the model is cached.
# Sets global CONCURRENT_PULL_CACHED=1 if the model is now cached (caller can skip its
# own pull); =0 if still missing (caller should attempt its own pull) or on timeout.
# Always returns 0 (best-effort; never blocks routing). Uses `SECONDS` for elapsed time
# so no external command is needed.
# Args: $1 = model, $2 = cli_host (logging only), $3 = mode label (logging),
#       $4 = nameref to ollama_cli_env array, $5 = nameref to timeout_cmd array,
#       $6 = optional max_wait_seconds (default 600 = 10 min for large models)
wait_for_concurrent_pull() {
  local model="$1"
  local cli_host="$2"
  local mode="$3"
  local -n _wait_env_ref="$4"
  local -n _wait_to_ref="$5"
  local max_wait="${6:-600}"
  CONCURRENT_PULL_CACHED=0

  cthru_debug_event "ollama prep pull wait mode=$mode model=$model host=$cli_host reason=concurrent_pull"
  local wait_start=$SECONDS
  while pgrep -af 'ollama pull ' 2>/dev/null | awk '{$1=""; sub(/^ /,""); print}' | grep -Fxq "ollama pull $model"; do
    sleep 2
    if (( SECONDS - wait_start > max_wait )); then
      echo "c-thru: timed out waiting (${max_wait}s) for concurrent pull of '$model' — proceeding best-effort" >&2
      cthru_debug_event "ollama prep pull wait_timeout mode=$mode model=$model host=$cli_host elapsed=$((SECONDS - wait_start))"
      return 0
    fi
  done

  # Concurrent pull finished; verify the model is now cached. The other session may have
  # failed (network/disk), in which case we leave CONCURRENT_PULL_CACHED=0 and let the
  # caller retry with its own pull.
  local _post_list
  _post_list=$("${_wait_env_ref[@]}" "${_wait_to_ref[@]}" ollama list 2>/dev/null) || {
    cthru_debug_event "ollama prep pull wait_done mode=$mode model=$model host=$cli_host list_failed=true"
    return 0
  }
  if echo "$_post_list" | awk 'NR>1 {print $1}' | grep -Fxq "$model"; then
    CONCURRENT_PULL_CACHED=1
    cthru_debug_event "ollama prep pull wait_done mode=$mode model=$model host=$cli_host concurrent_pull_succeeded=true elapsed=$((SECONDS - wait_start))"
    return 0
  fi
  echo "c-thru: concurrent pull of '$model' did not result in cached model — retrying" >&2
  cthru_debug_event "ollama prep pull wait_done mode=$mode model=$model host=$cli_host concurrent_pull_succeeded=false elapsed=$((SECONDS - wait_start))"
  return 0
}

# ARCH: ensure_ollama_running — health-checks and, if needed, starts or repairs a local Ollama server,
#   then ensures the requested model is pulled and warm. Non-fatal: any failure returns 0 to
#   avoid blocking routing.
#   Server health: curl /api/version (not the CLI), so no ollama binary path is required.
#   Singleton guard: lsof on the port before spawning — guards against double-spawn; zombie
#   recovery retries HTTP 3×1s before kill+respawn.
#   Mode controls depth: "active" shows spinner + pulls synchronously; "prepull"/"sweep" run
#   in the background subshell callers already created.
#   Stale models (>7 days by mtime) are re-pulled unconditionally in all modes.
ensure_ollama_running() {
  local model="$1"
  local host="$2"
  local ollama_api_key="${3:-}"
  local mode="${4:-active}"
  local backend_id="${5:-}"
  local capabilities="${6:-}"
  local warm_skip_reason=""
  if model_is_cloud_designated "$model"; then
    warm_skip_reason="model_designated_cloud"
  fi
  if [[ -n "$backend_id" ]]; then
    local backend_skip_reason=""
    backend_skip_reason="$(backend_local_prep_skip_reason "$backend_id" || true)"
    if [[ -n "$backend_skip_reason" ]]; then
      warm_skip_reason="${warm_skip_reason:-$backend_skip_reason}"
    fi
  fi

  local cli_host
  cli_host="$(ollama_cli_host "$host")"
  is_local_ollama_host "$cli_host" || return 0

  cthru_debug_event "ollama prep start mode=$mode model=$model host=$cli_host"
  ensure_ollama_cli_available "$mode" || return 0

  local -a ollama_cli_env=(env OLLAMA_HOST="$cli_host")
  [[ -n "$ollama_api_key" ]] && ollama_cli_env+=(OLLAMA_API_KEY="$ollama_api_key")
  local state_key=""
  state_key="$(ollama_model_state_key "$model" "$cli_host")"

  local autostart="${C_THRU_OLLAMA_AUTOSTART:-1}"

  # 3s timeout for ollama CLI calls (list, pull). curl uses --max-time directly.
  local -a timeout_cmd=()
  if command -v timeout >/dev/null 2>&1; then
    timeout_cmd=(timeout 3)
  elif command -v gtimeout >/dev/null 2>&1; then
    timeout_cmd=(gtimeout 3)
  fi

  # Extract port from cli_host URL (e.g. http://localhost:11434 → 11434)
  local ollama_port
  ollama_port="${cli_host##*:}"
  ollama_port="${ollama_port%%/*}"

  # --- Probe 1: is the Ollama HTTP server reachable? ---
  # Use lsof for singleton guard and curl for HTTP health — no CLI dependency.
  local braille=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")

  if ! ollama_server_http_alive "$cli_host"; then
    [[ "$mode" == "active" ]] && _ollama_spin "${braille[0]}" "Ollama server" "$cli_host" "checking"

    if [[ "$autostart" != "1" ]]; then
      [[ "$mode" == "active" ]] && _ollama_done "${RED}✗${NC}" "Ollama server" "unreachable — skipping"
      echo "c-thru: cannot reach Ollama on $cli_host — is 'ollama serve' running? Skipping warm-up." >&2
      cthru_debug_event "ollama prep result mode=$mode model=$model host=$cli_host reachable=false"
      return 0
    fi

    # Check if port is already occupied (something is listening but HTTP failed).
    # Guard: only run lsof when port is a non-empty numeric string — bare URLs
    # like http://localhost (no port) would yield an empty ollama_port, causing
    # lsof -iTCP:"" to match all listeners and potentially kill an unrelated process.
    local port_pid=""
    if [[ -n "$ollama_port" && "$ollama_port" =~ ^[0-9]+$ ]] && command -v lsof >/dev/null 2>&1; then
      port_pid=$(lsof -nP -iTCP:"$ollama_port" -sTCP:LISTEN -t 2>/dev/null | head -n1 || true)
    fi

    local _alive=0
    if [[ -z "$port_pid" ]]; then
      # Nothing on the port — clean spawn
      [[ "$mode" == "active" ]] && _ollama_spin "${braille[1]}" "Ollama server" "$cli_host" "starting"
      nohup ollama serve </dev/null >/dev/null 2>&1 &
      disown 2>/dev/null || true
    else
      # Port occupied but HTTP dead — zombie or crashed server.
      # Retry HTTP 3 × 1s before giving up and killing it.
      local _zombie_alive=0
      for _i in 1 2 3; do
        sleep 1
        [[ "$mode" == "active" ]] && _ollama_spin "${braille[$(( _i % 10 ))]}" "Ollama server" "$cli_host" "retry ${_i}/3"
        if ollama_server_http_alive "$cli_host"; then _zombie_alive=1; break; fi
      done
      if (( _zombie_alive )); then
        # Server recovered on its own — skip spawn, mark alive
        _alive=1
      else
        # Kill zombie and respawn
        [[ "$mode" == "active" ]] && _ollama_spin "${braille[4]}" "Ollama server" "$cli_host" "killing zombie (pid $port_pid)"
        kill "$port_pid" 2>/dev/null || true
        sleep 0.5
        nohup ollama serve </dev/null >/dev/null 2>&1 &
        disown 2>/dev/null || true
        cthru_debug_event "ollama server zombie_kill pid=$port_pid port=$ollama_port host=$cli_host"
      fi
    fi

    # Wait up to 3s for HTTP to respond after spawn/respawn (skipped when _alive already set)
    if (( ! _alive )); then
      for _i in 1 2 3; do
        sleep 1
        [[ "$mode" == "active" ]] && _ollama_spin "${braille[$(( _i % 10 ))]}" "Ollama server" "$cli_host" "starting (${_i}s)"
        if ollama_server_http_alive "$cli_host"; then _alive=1; break; fi
      done
    fi
    if (( ! _alive )); then
      [[ "$mode" == "active" ]] && _ollama_done "${RED}✗${NC}" "Ollama server" "unreachable after spawn"
      echo "c-thru: cannot reach Ollama on $cli_host after spawn — skipping warm-up." >&2
      cthru_debug_event "ollama prep result mode=$mode model=$model host=$cli_host reachable=false"
      return 0
    fi
  fi

  [[ "$mode" == "active" ]] && _ollama_done "${GREEN}✓${NC}" "Ollama server" "$cli_host"
  cthru_debug_event "ollama prep server_alive mode=$mode host=$cli_host"

  # --- Probe 2: is the model already loaded in VRAM? ---
  # Use /api/ps REST endpoint — consistent with HTTP-only approach.
  local model_loaded=0
  local api_ps_json
  api_ps_json=$(curl -sf --max-time 3 "${cli_host}/api/ps" 2>/dev/null || true)
  if echo "$api_ps_json" | grep -qF "\"${model}\""; then
    model_loaded=1
    if [[ "$mode" != "sweep" ]]; then
      cthru_debug_event "ollama prep result mode=$mode model=$model host=$cli_host loaded=true"
      if [[ "$mode" == "active" ]]; then
        _ollama_done "${GREEN}✓${NC}" "$model" "already resident"
        PROXY_ACTIVE_MODEL_WARMED=1
      fi
      return 0
    fi
  fi

  # --- Probe 3: is the model cached on disk? ---
  local list_output
  list_output=$("${ollama_cli_env[@]}" "${timeout_cmd[@]}" ollama list 2>/dev/null) || {
    cthru_debug_event "ollama prep result mode=$mode model=$model host=$cli_host list_failed=true"
    return 0
  }
  local age_text=""
  age_text="$(ollama_extract_age_text "$model" "$list_output" || true)"

  if ! echo "$list_output" | awk 'NR>1 {print $1}' | grep -Fxq "$model"; then
    # Guard against concurrent pull of the same model (race from multiple prepull jobs).
    local _need_own_pull=1
    if pgrep -af 'ollama pull ' 2>/dev/null | awk '{$1=""; sub(/^ /,""); print}' | grep -Fxq "ollama pull $model"; then
      wait_for_concurrent_pull "$model" "$cli_host" "$mode" ollama_cli_env timeout_cmd 600
      if [[ "${CONCURRENT_PULL_CACHED:-0}" == "1" ]]; then
        ollama_prep_state_update "models" "$state_key" "pull_success" "cached"
        list_output=$("${ollama_cli_env[@]}" "${timeout_cmd[@]}" ollama list 2>/dev/null) || list_output=""
        age_text="$(ollama_extract_age_text "$model" "$list_output" || true)"
        _need_own_pull=0
      fi
    fi
    if (( _need_own_pull )); then
      if [[ "$mode" == "active" ]]; then
        _ollama_spin "${braille[0]}" "$model" "pulling" "0s"
      else
        echo "c-thru: '$model' not cached on $cli_host — pulling now..." >&2
      fi
      ollama_prep_state_update "models" "$state_key" "pull_attempt" "pulling"
      cthru_debug_event "ollama prep pull start mode=$mode model=$model host=$cli_host reason=missing"
      if ! "${ollama_cli_env[@]}" ollama pull "$model" >/dev/null 2>&1; then
        [[ "$mode" == "active" ]] && _ollama_done "${RED}✗${NC}" "$model" "pull failed (offline?)"
        echo "c-thru: failed to pull '$model' from $cli_host — try \`ollama pull $model\` manually (check network / disk space)" >&2
        ollama_prep_state_update "models" "$state_key" "pull_failure" "pull_failed"
        cthru_debug_event "ollama prep pull result mode=$mode model=$model host=$cli_host success=false"
        return 0
      fi
      list_output=$("${ollama_cli_env[@]}" "${timeout_cmd[@]}" ollama list 2>/dev/null) || {
        cthru_debug_event "ollama prep pull result mode=$mode model=$model host=$cli_host success=true list_after_failed=true"
        return 0
      }
      if ! echo "$list_output" | awk 'NR>1 {print $1}' | grep -Fxq "$model"; then
        [[ "$mode" == "active" ]] && _ollama_done "${RED}✗${NC}" "$model" "pull silent failure"
        echo "c-thru: '$model' still unavailable after pull — try \`ollama pull $model\` manually" >&2
        ollama_prep_state_update "models" "$state_key" "pull_failure" "pull_silent_failure"
        cthru_debug_event "ollama prep result mode=$mode model=$model host=$cli_host cached=false after_pull=true"
        return 0
      fi
      [[ "$mode" == "active" ]] && _ollama_done "${GREEN}✓${NC}" "$model" "pulled"
      ollama_prep_state_update "models" "$state_key" "pull_success" "cached"
      "$CTHRU_REPO_ROOT/tools/c-thru-ollama-gc.sh" record "$model" router "$cli_host" >/dev/null 2>&1 || true
      cthru_debug_event "ollama prep pull result mode=$mode model=$model host=$cli_host success=true verified=true"
      age_text="$(ollama_extract_age_text "$model" "$list_output" || true)"
    fi
  else
    ollama_prep_state_update "models" "$state_key" "cached" "cached" "$age_text"
  fi

  # --- Stale refresh: re-pull models older than OLLAMA_PREP_REFRESH_DAYS (all modes) ---
  # Active mode spawns the pull in background to avoid blocking the request.
  if ollama_refresh_age_is_stale "$age_text" && \
     ollama_prep_retry_allowed "models" "$state_key" "last_pull_attempt_at" "$OLLAMA_PREP_MIN_RETRY_SECONDS"; then
    local _refresh_skip=0
    if pgrep -af 'ollama pull ' 2>/dev/null | awk '{$1=""; sub(/^ /,""); print}' | grep -Fxq "ollama pull $model"; then
      wait_for_concurrent_pull "$model" "$cli_host" "$mode" ollama_cli_env timeout_cmd 600
      if [[ "${CONCURRENT_PULL_CACHED:-0}" == "1" ]]; then
        ollama_prep_state_update "models" "$state_key" "pull_success" "refreshed" "$age_text"
        list_output=$("${ollama_cli_env[@]}" "${timeout_cmd[@]}" ollama list 2>/dev/null || true)
        cthru_debug_event "ollama stale refresh result model=$model host=$cli_host success=true via=concurrent_wait"
      else
        cthru_debug_event "ollama stale refresh skip model=$model host=$cli_host reason=concurrent_pull_unverified"
      fi
      _refresh_skip=1
    fi
    if (( ! _refresh_skip )); then
      ollama_prep_state_update "models" "$state_key" "pull_attempt" "refreshing" "$age_text"
      cthru_debug_event "ollama stale refresh start model=$model host=$cli_host age=\"$age_text\""
      if [[ "$mode" == "active" ]]; then
        # Don't block the live request — refresh in background
        ( "${ollama_cli_env[@]}" ollama pull "$model" >/dev/null 2>&1 ) &
        disown $! 2>/dev/null || true
        cthru_debug_event "ollama stale refresh start mode=active model=$model host=$cli_host bg=true"
      else
        if "${ollama_cli_env[@]}" ollama pull "$model" >/dev/null 2>&1; then
          list_output=$("${ollama_cli_env[@]}" "${timeout_cmd[@]}" ollama list 2>/dev/null || true)
          if echo "$list_output" | awk 'NR>1 {print $1}' | grep -Fxq "$model"; then
            ollama_prep_state_update "models" "$state_key" "pull_success" "refreshed" "$age_text"
            "$CTHRU_REPO_ROOT/tools/c-thru-ollama-gc.sh" record "$model" router "$cli_host" >/dev/null 2>&1 || true
            cthru_debug_event "ollama stale refresh result model=$model host=$cli_host success=true verified=true"
          else
            ollama_prep_state_update "models" "$state_key" "pull_failure" "refresh_silent_failure" "$age_text"
            cthru_debug_event "ollama stale refresh result model=$model host=$cli_host success=false reason=not_in_list"
          fi
        else
          ollama_prep_state_update "models" "$state_key" "pull_failure" "refresh_failed" "$age_text"
          cthru_debug_event "ollama stale refresh result model=$model host=$cli_host success=false"
        fi
      fi
    fi
  fi

  if [[ -n "$warm_skip_reason" ]]; then
    cthru_debug_event "ollama prep result mode=$mode model=$model host=$cli_host warm_skipped=true reason=$warm_skip_reason"
    return 0
  fi

  # --- Cached + not resident → fire warm-up via /api/generate (keep-alive 60m) ---
  if [[ "$mode" == "sweep" && -n "$capabilities" ]]; then
    printf "  ${GRAY}•${NC} ${BOLD}%-18s${NC} warming %s (background)\n" "fleet" "$model" >&2
  elif [[ "$mode" != "active" ]]; then
    printf "  ${GRAY}•${NC} ${BOLD}%-18s${NC} warming %s (background)\n" "fleet" "$model" >&2
  fi
  cthru_debug_event "ollama prep warm start mode=$mode model=$model host=$cli_host"

  (
    curl -sf -X POST "$cli_host/api/generate" \
      -d "{\"model\":\"$model\",\"prompt\":\"\",\"keep_alive\":\"60m\",\"options\":{\"num_ctx\":65536}}" \
      >/dev/null 2>&1
  ) &
  disown $! 2>/dev/null || true
  cthru_debug_event "ollama prep result mode=$mode model=$model host=$cli_host warmed=true"

  # --- Active mode: braille spinner until model appears in /api/ps ---
  if [[ "$mode" == "active" && "$model_loaded" == "0" ]]; then
    local model_size_str=""
    local _list_for_size
    _list_for_size=$("${ollama_cli_env[@]}" "${timeout_cmd[@]}" ollama list 2>/dev/null || true)
    model_size_str=$(printf '%s' "$_list_for_size" | awk -v m="$model" 'NR>1 && $1==m {print $3" "$4; exit}' 2>/dev/null || true)

    local max_wait_iters=200  # 0.6s × 200 = 120s
    local i=0
    local start_loop_time=$SECONDS
    while (( i < max_wait_iters )); do
      local elapsed=$(( SECONDS - start_loop_time ))
      local time_str
      if (( elapsed >= 60 )); then
        time_str="$(( elapsed / 60 ))m $(( elapsed % 60 ))s"
      else
        time_str="${elapsed}s"
      fi
      local sp="${braille[$((i % 10))]}"
      _ollama_spin "$sp" "$model" "loading weights" "$time_str"
      sleep 0.6
      i=$(( i + 1 ))
      if (( i % 5 == 0 )); then
        api_ps_json=$(curl -sf --max-time 3 "${cli_host}/api/ps" 2>/dev/null || true)
        if echo "$api_ps_json" | grep -qF "\"${model}\""; then
          _ollama_done "${GREEN}✓${NC}" "$model" "ready  ${GRAY}${model_size_str:+($model_size_str, }${time_str}${model_size_str:+)}${NC}"
          PROXY_ACTIVE_MODEL_WARMED=1
          return 0
        fi
      fi
    done
    _ollama_done "${RED}✗${NC}" "$model" "load timeout"
    # exit (not return) — active mode is called directly in the router's main path,
    # so a load timeout is a hard stop for the session.
    exit 1
  fi
}

# Note: config file permissions should be set by installer, not runtime

get_system_info_summary() {
  local default_override="$1"
  local profile="" llm_mode=""
  profile="$(resolve_llm_profile_name 2>/dev/null || true)"
  llm_mode="$(resolve_llm_mode 2>/dev/null || true)"
  
  local plan_parts=()
  local slot model _rec
  while IFS=$'\t' read -r slot model _rec; do
    [[ -n "$slot" && -n "$model" ]] || continue
    plan_parts+=("$slot=$model")
  done < <(collect_active_profile_capability_assignments "$default_override" 2>/dev/null || true)

  local joined_plan=""
  if (( ${#plan_parts[@]} > 0 )); then
    printf -v joined_plan '%s, ' "${plan_parts[@]}"
    joined_plan="${joined_plan%, }"
  fi

  printf "c-thru routing active. Profile: %s, Mode: %s. Capabilities: %s." \
    "${profile:-unknown}" "${llm_mode:-unknown}" "${joined_plan:-none}"
}

# When C_THRU_DEBUG is 1 or 2, print routing env to stderr (secrets masked).
# $1: mode — transparent | routed
claude_router_debug_dump() {
  local _dl="${C_THRU_DEBUG:-0}"
  [[ "$_dl" == "0" || "$_dl" == "false" ]] && return 0
  local mode="$1"
  echo "c-thru debug ($mode, C_THRU_DEBUG=$_dl):" >&2
  if [[ "$mode" == "transparent" ]]; then
    echo "  MODEL=<unset; remapping is per-request in claude-proxy>" >&2
  else
    echo "  MODEL=$MODEL" >&2
    [[ -n "${EFFECTIVE_MODEL:-}" && "$EFFECTIVE_MODEL" != "$MODEL" ]] &&
      echo "  EFFECTIVE_MODEL=$EFFECTIVE_MODEL (routes graph)" >&2
  fi
  echo "  ANTHROPIC_BASE_URL=${ANTHROPIC_BASE_URL:-<unset>}" >&2
  if [[ -n "${ANTHROPIC_AUTH_TOKEN:-}" ]]; then
    echo "  ANTHROPIC_AUTH_TOKEN=<set:${#ANTHROPIC_AUTH_TOKEN} chars>" >&2
  else
    echo "  ANTHROPIC_AUTH_TOKEN=<unset>" >&2
  fi
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    echo "  ANTHROPIC_API_KEY=<set:${#ANTHROPIC_API_KEY} chars>" >&2
  fi
  echo "  CLAUDE_CONFIG_DIR=${CLAUDE_CONFIG_DIR:-<unset>}" >&2
  echo "  CONFIG=$CONFIG" >&2
  echo "  CONFIG_SOURCE=${CLAUDE_MODEL_MAP_SOURCE:-<unset>}" >&2
  echo "  CLAUDE_MODEL_MAP_LAUNCH_CWD=${CLAUDE_MODEL_MAP_LAUNCH_CWD:-<unset>}" >&2
  echo "  CLAUDE_PROJECT_DIR=${CLAUDE_PROJECT_DIR:-<unset>}" >&2
  [[ -n "${REAL_CLAUDE:-}" ]] && echo "  REAL_CLAUDE=$REAL_CLAUDE" >&2
  local _pport=""
  if [[ -n "${PROXY_PORT:-}" ]]; then
    _pport="$PROXY_PORT"
  elif [[ -n "${CLAUDE_PROXY_PORT:-}" ]]; then
    _pport="$CLAUDE_PROXY_PORT"
  elif [[ "${CLAUDE_PROXY_USE_OLLAMA_PORT:-0}" == "1" ]]; then
    _pport="11434"
  elif [[ -n "${ANTHROPIC_BASE_URL:-}" ]] && is_local_http_base_url "${ANTHROPIC_BASE_URL:-}"; then
    _pport="$(proxy_port_from_base_url "${ANTHROPIC_BASE_URL:-}")"
  fi
  [[ -n "$_pport" ]] && echo "  CLAUDE_PROXY_PORT=${_pport}" >&2
  [[ -n "${ANTHROPIC_BASE_URL:-}" ]] && echo "  claude-proxy base=${ANTHROPIC_BASE_URL}" >&2
  [[ -n "${PROXY_LOG_PATH:-}" ]] && echo "  claude-proxy log=${PROXY_LOG_PATH}" >&2
  if [[ "$_dl" == "2" ]]; then
    echo "  -- verbose --" >&2
    if [[ -n "$_pport" ]]; then
      echo "  proxy script: $CLAUDE_PROFILE_DIR/tools/claude-proxy" >&2
    fi
    echo "  OLLAMA_URL=$OLLAMA_URL" >&2
    echo "  OLLAMA_BASE_URL=${OLLAMA_BASE_URL:-<unset>}" >&2
    echo "  C_THRU_PROXY_PLACEHOLDER_KEY=${C_THRU_PROXY_PLACEHOLDER_KEY:-0}" >&2
    echo "  C_THRU_SKIP_PROXY_AUTOSTART=${C_THRU_SKIP_PROXY_AUTOSTART:-0}" >&2
    echo "  CLAUDE_PROXY_BYPASS=${CLAUDE_PROXY_BYPASS:-0}" >&2
    echo "  CLAUDE_PROXY_LOG_FILE=${CLAUDE_PROXY_LOG_FILE:-<unset>}" >&2
    echo "  CLAUDE_PROXY_LOG_DIR=${CLAUDE_PROXY_LOG_DIR:-<unset>}" >&2
    if [[ -f "$CONFIG" ]]; then
      echo "  model-map routes keys: $(jq -r '(.routes // {}) | keys | sort | join(", ")' "$CONFIG" 2>/dev/null || echo '<parse error>')" >&2
      echo "  model-map model_routes count: $(jq -r '(.model_routes // {}) | length' "$CONFIG" 2>/dev/null || echo '?')" >&2
    fi
  fi
  echo "" >&2
}

debug_print_final_claude_command() {
  local _dl="${C_THRU_DEBUG:-0}"
  [[ "$_dl" == "0" || "$_dl" == "false" ]] && return 0

  local url="${ANTHROPIC_BASE_URL:-}"
  local tok="${ANTHROPIC_AUTH_TOKEN:-}"
  local quiet_env="CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY=1 CLAUDE_CODE_COLOR=1"
  local prefix=""
  if [[ -n "$url" && -n "$tok" ]]; then
    prefix="ANTHROPIC_BASE_URL=$url ANTHROPIC_AUTH_TOKEN=$tok $quiet_env "
  else
    prefix="$quiet_env "
  fi

  local rendered=""
  local part quoted
  for part in "$@"; do
    if [[ "$part" =~ [[:space:]] || -z "$part" ]]; then
      quoted="\"$part\""
    else
      quoted="$part"
    fi
    if [[ -n "$rendered" ]]; then
      rendered+=" "
    fi
    rendered+="$quoted"
  done
  printf "  ${GRAY}•${NC} ${BOLD}%-10s${NC} %s%s\n" "launch" "$prefix" "$rendered" >&2
}

run_real_claude() {
  local -a cmd=("$@")
  local url="${ANTHROPIC_BASE_URL:-}"
  local tok="${ANTHROPIC_AUTH_TOKEN:-}"
  
  # Harassment prevention
  local quiet_env_survey="1"
  local quiet_env_color="1"

  # We use env to set variables safely without eval for the array
  if [[ -z "${PROXY_STARTED_PID:-}" ]]; then
    if [[ -n "$url" && -n "$tok" ]]; then
      exec env ANTHROPIC_BASE_URL="$url" \
               ANTHROPIC_AUTH_TOKEN="$tok" \
               CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY="$quiet_env_survey" \
               CLAUDE_CODE_COLOR="$quiet_env_color" \
               "${cmd[@]}"
    else
      exec env CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY="$quiet_env_survey" \
               CLAUDE_CODE_COLOR="$quiet_env_color" \
               "${cmd[@]}"
    fi
  fi

  arm_proxy_cleanup
  if [[ -n "$url" && -n "$tok" ]]; then
    env ANTHROPIC_BASE_URL="$url" \
        ANTHROPIC_AUTH_TOKEN="$tok" \
        CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY="$quiet_env_survey" \
        CLAUDE_CODE_COLOR="$quiet_env_color" \
        "${cmd[@]}" &
  else
    env CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY="$quiet_env_survey" \
        CLAUDE_CODE_COLOR="$quiet_env_color" \
        "${cmd[@]}" &
  fi
  CLAUDE_CHILD_PID="$!"
  wait "$CLAUDE_CHILD_PID"
  local ec="$?"
  CLAUDE_CHILD_PID=""
  return "$ec"
}

# ARCH: build_forwarded_args — strips c-thru-private flags (--route, --mode, --profile,
#   --memory-gb, --bypass-proxy, etc.) from ORIG_ARGS before passing to the real claude
#   binary; re-injects --model with the resolved concrete model name. This is the ONLY
#   place where the c-thru flag vocabulary is erased — do not strip flags elsewhere.
build_forwarded_args() {
  local desired_model="$1"
  local -a forwarded=()
  local i=0
  local saw_model=0
  local saw_skip_permissions=0

  while [[ $i -lt ${#ORIG_ARGS[@]} ]]; do
    local arg="${ORIG_ARGS[i]}"
    case "$arg" in
      --route)
        i=$((i + 2))
        continue
        ;;
      --route=*)
        i=$((i + 1))
        continue
        ;;
      --mode | --profile | --memory-gb)
        i=$((i + 2))
        continue
        ;;
      --mode=* | --profile=* | --memory-gb=* | --proxy-debug=* | --router-debug=*)
        i=$((i + 1))
        continue
        ;;
      --bypass-proxy | --journal | --no-update | --no-agents | --debug | \
      --local-only | --best-cloud | --best-opensource-cloud | --best-opensource-local | \
      --best-opensource | --fastest | --smallest | --offline)
        i=$((i + 1))
        continue
        ;;
      --proxy-debug | --router-debug)
        # Optional numeric arg — peek next; if 1|2, consume both, else just the flag
        if [[ $((i + 1)) -lt ${#ORIG_ARGS[@]} && "${ORIG_ARGS[i+1]}" =~ ^[12]$ ]]; then
          i=$((i + 2))
        else
          i=$((i + 1))
        fi
        continue
        ;;
      --model)
        if [[ "$saw_model" -eq 0 && -n "$desired_model" ]]; then
          forwarded+=("--model" "$desired_model")
          saw_model=1
        fi
        i=$((i + 2))
        continue
        ;;
      --model=*)
        if [[ "$saw_model" -eq 0 && -n "$desired_model" ]]; then
          forwarded+=("--model=$desired_model")
          saw_model=1
        fi
        i=$((i + 1))
        continue
        ;;
      --dangerously-skip-permissions)
        forwarded+=("$arg")
        saw_skip_permissions=1
        i=$((i + 1))
        continue
        ;;
      *)
        forwarded+=("$arg")
        i=$((i + 1))
        ;;
    esac
  done

  if [[ "$saw_skip_permissions" -eq 0 ]]; then
    forwarded=("--dangerously-skip-permissions" "${forwarded[@]}")
  fi
  if [[ -n "$desired_model" && "$saw_model" -eq 0 ]]; then
    forwarded=("--model=$desired_model" "${forwarded[@]}")
  fi

  # Inject system info summary if not bypassed
  if [[ "${CLAUDE_PROXY_BYPASS:-0}" != "1" && "${C_THRU_SKIP_INFO_INJECTION:-0}" != "1" ]]; then
    local info_summary
    info_summary="$(get_system_info_summary "$model")"
    # Append proxy URL so agents that call the proxy directly (e.g. context-injection
    # hooks) know where it is without hard-coding a port.
    [[ -n "${PROXY_PORT:-}" ]] && info_summary+=" Proxy: http://127.0.0.1:${PROXY_PORT}."
    forwarded+=("--append-system-prompt" "/no_thinking $info_summary")
  fi

  # ── Per-Process Ephemeral Injection ──────────────────────────────────────
  if [[ -n "$EPHEMERAL_SETTINGS_FILE" ]]; then
    forwarded+=("--settings" "$EPHEMERAL_SETTINGS_FILE")
  fi
  if [[ -n "$EPHEMERAL_AGENTS_JSON" && "$EPHEMERAL_AGENTS_JSON" != "{}" ]]; then
    forwarded+=("--agents" "$EPHEMERAL_AGENTS_JSON")
  fi

  printf '%s\0' "${forwarded[@]}"
}

# Helper: print a config section if it exists and has content
print_config_section() {
  local section="$1" label="$2"
  if [[ -f "$CONFIG" ]] && jq -e ".$section | length > 0" "$CONFIG" >/dev/null 2>&1; then
    echo "$label:"
    jq -r ".$section | to_entries[] | \"  \(.key)  →  \(.value)\"" "$CONFIG" 2>/dev/null
    echo ""
  fi
}

print_active_profile_table() {
  [[ -f "$CONFIG" ]] || return 0
  llm_profiles_defined || return 0

  local profile mode memory_gb source summary_context
  ensure_llm_profile_context || return 0
  profile="$LLM_PROFILE_CACHE_NAME"
  [[ -n "$profile" ]] || return 0
  local llm_mode; llm_mode="$(resolve_llm_mode)"
  memory_gb="${LLM_PROFILE_CACHE_MEMORY_GB:-}"
  source="${LLM_PROFILE_CACHE_SOURCE:-auto}"

  case "$source" in
    auto)   summary_context="auto-detected from ${memory_gb:-unknown} GB RAM" ;;
    env)    summary_context="forced by CLAUDE_LLM_PROFILE" ;;
    config) summary_context="configured in model-map" ;;
    *)      summary_context="$source" ;;
  esac

  echo "Active hardware profile: $profile ($summary_context, mode=$llm_mode)"
  echo ""

  local slot model rec_suffix
  while IFS=$'\t' read -r slot model rec_suffix; do
    [[ -n "$slot" && -n "$model" ]] || continue
    printf '  %-14s  %-40s%s\n' "$slot" "$model" "${rec_suffix:+  $rec_suffix}"
  done < <(collect_active_profile_capability_assignments)
  echo ""
}

# --- Show available models from all sources ---
show_models() {
  # Active hardware profile + capability assignments
  print_active_profile_table

  # Configured routes
  print_config_section "routes" "Configured routes (model-map.json)"

  # Local Ollama
  local ollama_http_base="${OLLAMA_URL%/api}"
  local ollama_models
  ollama_models=$(curl -sf --max-time 3 "$ollama_http_base/api/tags" 2>/dev/null | jq -r '.models[].name' 2>/dev/null) || true
  if [[ -n "$ollama_models" ]]; then
    echo "Local Ollama ($ollama_http_base):"
    while read -r m; do
      echo "  $m"
    done <<< "$ollama_models"
    echo ""
  fi

  echo "Any other model name is assumed to be available from local Ollama ($ollama_http_base)."

  # Update log footer
  local update_log="$CTHRU_REPO_ROOT/.c-thru-update.log"
  if [[ -f "$update_log" ]]; then
    local last_update
    last_update="$(tail -1 "$update_log" 2>/dev/null || true)"
    [[ -n "$last_update" ]] && echo "" && echo "Last self-update: $last_update"
  fi

  # Backend health — query running proxy if one is up (requires CLAUDE_PROXY_PORT or prior session start)
  local proxy_port=""
  proxy_port="$(claude_proxy_listen_port || true)"
  if [[ -n "$proxy_port" ]]; then
    local ping_json=""
    ping_json="$(proxy_ping_json "$proxy_port" || true)"
    if [[ -n "$ping_json" ]]; then
      local stats_json=""
      stats_json="$(curl -sf --max-time 2.0 "http://127.0.0.1:$proxy_port/debug/stats" 2>/dev/null || true)"
      if [[ -n "$stats_json" ]]; then
        local backend_ids
        backend_ids="$(printf '%s' "$stats_json" | jq -r '.byBackendId | keys[]' 2>/dev/null || true)"
        if [[ -n "$backend_ids" ]]; then
          echo ""
          echo "Backend health (proxy port $proxy_port):"
          while IFS= read -r bid; do
            local state last_fail latency
            state="$(printf '%s' "$stats_json" | jq -r --arg id "$bid" '.byBackendId[$id].state // "unknown"' 2>/dev/null)"
            last_fail="$(printf '%s' "$stats_json" | jq -r --arg id "$bid" '.byBackendId[$id].last_failure_class // "-"' 2>/dev/null)"
            latency="$(printf '%s' "$stats_json" | jq -r --arg id "$bid" '.byBackendId[$id].ewma_latency_ms // "-"' 2>/dev/null)"
            printf '  %-30s  state=%-12s  last_failure=%-12s  ewma_ms=%s\n' "$bid" "$state" "$last_fail" "$latency"
          done <<< "$backend_ids"
        fi
      fi
    fi
  fi
}


# --- brew_install_sync ---
# Synchronous, deduplicated `brew install <pkg>` for the check-deps --fix path.
# - Detects an in-flight `brew install <pkg>` from another c-thru session via
#   pgrep and waits (capped at 600s) for it to finish instead of racing.
# - Always runs in the foreground (no `&` / `nohup`) so the caller blocks
#   through post-install scripts and `brew link`.
# - Refreshes the bash hash table (`hash -r`) so `command -v <tool>` in the
#   same shell sees the freshly-installed binary.
# - Re-verifies via `command -v <verify_cmd>` (defaults to <pkg>) and returns
#   non-zero with a clear message if anything failed. Soft-fail only — never
#   trips `set -e` cascades in the caller.
#
# Usage: brew_install_sync <pkg> [verify_cmd]
brew_install_sync() {
  local pkg="${1:-}"
  local verify_cmd="${2:-$pkg}"

  if [[ -z "$pkg" ]]; then
    echo -e "  ${RED}   ❌ brew_install_sync: missing package name${NC}" >&2
    return 2
  fi

  if ! command -v brew >/dev/null 2>&1; then
    echo -e "  ${RED}   ❌ brew not found — cannot install '$pkg'${NC}" >&2
    return 2
  fi

  # Concurrent-pull dedup: if another c-thru session already has a
  # `brew install <pkg>` in flight (cmdline ends with " brew install <pkg>"),
  # wait for it instead of starting a duplicate. Cap the wait at 600s so a
  # genuinely stuck brew can't pin us forever.
  local waited=0
  local cap=600
  while pgrep -af "brew install " 2>/dev/null \
        | awk '{$1=""; sub(/^ /,""); print}' \
        | grep -Fxq "brew install $pkg"; do
    if (( waited == 0 )); then
      echo -e "  ${YELLOW}   Detected in-flight 'brew install $pkg' from another session — waiting...${NC}"
    fi
    sleep 1
    waited=$((waited + 1))
    if (( waited >= cap )); then
      echo -e "  ${RED}   ❌ Timed out after ${cap}s waiting for concurrent 'brew install $pkg'${NC}" >&2
      return 1
    fi
  done

  # If the concurrent install just finished and the binary is now present,
  # short-circuit — no need to re-install.
  hash -r 2>/dev/null || true
  if command -v "$verify_cmd" >/dev/null 2>&1; then
    if (( waited > 0 )); then
      echo -e "  ${GREEN}   ✅ '$pkg' became available after concurrent install (${waited}s)${NC}"
    fi
    return 0
  fi

  # Foreground, single-package install. No `&`, no `nohup` — caller blocks
  # through post-install scripts and any `brew link` step.
  if brew install "$pkg" >/dev/null 2>&1; then
    # Refresh the shell's PATH cache so command -v sees the new binary in
    # the same process. `hash -r` failures are non-fatal — fall through to
    # the verify step which is what actually gates success.
    hash -r 2>/dev/null || true
    if command -v "$verify_cmd" >/dev/null 2>&1; then
      echo -e "  ${GREEN}   ✅ $pkg installed${NC}"
      return 0
    fi
    echo -e "  ${RED}   ❌ brew install $pkg reported success but '$verify_cmd' is still not on PATH${NC}" >&2
    echo -e "  ${YELLOW}      Try opening a new shell, or run: hash -r; command -v $verify_cmd${NC}" >&2
    return 1
  fi

  echo -e "  ${RED}   ❌ brew install $pkg failed${NC}" >&2
  echo -e "  ${YELLOW}      Suggestion: check 'brew doctor', verify network/permissions, then retry manually:${NC}" >&2
  echo -e "  ${YELLOW}      brew install $pkg${NC}" >&2
  return 1
}

# --- check-deps subcommand ---
# Defined here — before the config-sync/startup block — so that
# 'c-thru check-deps' works in broken environments where config validation fails.
cmd_check_deps() {
  local fix=0
  for arg in "$@"; do
    [[ "$arg" == "--fix" ]] && fix=1
  done

  local any_required_missing=0

  echo "Dependencies:"

  # node (required, ≥15)
  if command -v node >/dev/null 2>&1; then
    local node_ver
    node_ver="$(node -e "process.stdout.write(process.version)" 2>/dev/null || true)"
    local node_major="${node_ver#v}"; node_major="${node_major%%.*}"
    if [[ -n "$node_major" && "$node_major" =~ ^[0-9]+$ && "$node_major" -ge 15 ]]; then
      echo -e "  ${GREEN}✓  node ${node_ver} (≥15 required)${NC}"
    else
      echo -e "  ${YELLOW}⚠️  node ${node_ver:-unknown} — claude-proxy requires ≥ 15 (AbortController)${NC}"
      echo -e "  ${YELLOW}   Fix: brew install node  (macOS)  |  https://nodejs.org  |  nvm install --lts${NC}"
      any_required_missing=1
    fi
  else
    echo -e "  ${RED}❌ node — required (claude-proxy will not start)${NC}"
    if command -v brew >/dev/null 2>&1; then
      echo -e "  ${RED}   Fix: brew install node${NC}"
    else
      echo -e "  ${RED}   Fix: https://nodejs.org  (or: nvm install --lts)${NC}"
    fi
    any_required_missing=1
  fi

  # jq (optional — features degrade but fallback to node works)
  if command -v jq >/dev/null 2>&1; then
    local jq_ver
    jq_ver="$(jq --version 2>/dev/null || true)"
    echo -e "  ${GREEN}✓  ${jq_ver:-jq}${NC}"
  else
    echo -e "  ${YELLOW}⚠️  jq — not found (some install/hook steps fall back to node)${NC}"
    if [[ "$fix" -eq 1 ]] && command -v brew >/dev/null 2>&1; then
      echo -e "  ${YELLOW}   Running: brew install jq${NC}"
      brew_install_sync "jq" "jq" || true
    elif command -v brew >/dev/null 2>&1; then
      echo -e "  ${YELLOW}   Fix: brew install jq  (or: apt install jq)  [or rerun with --fix]${NC}"
    else
      echo -e "  ${YELLOW}   Fix: apt install jq  (or https://stedolan.github.io/jq/)${NC}"
    fi
  fi

  # curl (low — fallback to ping; almost always present)
  if command -v curl >/dev/null 2>&1; then
    local curl_ver
    curl_ver="$(curl --version 2>/dev/null | head -1 | awk '{print $2}' || true)"
    echo -e "  ${GREEN}✓  curl ${curl_ver} (connectivity checks)${NC}"
  else
    echo -e "  ${YELLOW}⚠️  curl — not found (connectivity detection falls back to ping)${NC}"
  fi

  # lsof (low — port discovery for reload/restart)
  if command -v lsof >/dev/null 2>&1; then
    echo -e "  ${GRAY}✓  lsof (port discovery)${NC}"
  else
    echo -e "  ${YELLOW}⚠️  lsof — not found (c-thru reload port discovery will use env fallback)${NC}"
  fi

  # git (low — self-update only)
  if command -v git >/dev/null 2>&1; then
    echo -e "  ${GRAY}✓  git (self-update)${NC}"
  else
    echo -e "  ${YELLOW}⚠️  git — not found (self-update disabled; all other features work)${NC}"
  fi

  # ollama (optional — local models)
  if command -v ollama >/dev/null 2>&1; then
    local model_count
    model_count="$(ollama list 2>/dev/null | tail -n +2 | wc -l | tr -d ' ' || true)"
    echo -e "  ${GREEN}✓  ollama — ${model_count:-?} model(s) available${NC}"
    # Verify REST API connectivity
    if curl -sf --max-time 2 "${OLLAMA_URL}/api/tags" >/dev/null 2>&1; then
      echo -e "  ${GREEN}✓  ollama REST API — reachable at ${OLLAMA_URL}${NC}"
    else
      echo -e "  ${YELLOW}⚠️  ollama REST API — unreachable at ${OLLAMA_URL} (daemon down?)${NC}"
    fi
  else
    echo -e "  ${YELLOW}⚠️  ollama — not found (optional: enables local models)${NC}"
    if [[ "$fix" -eq 1 ]] && command -v brew >/dev/null 2>&1; then
      echo -e "  ${YELLOW}   Running: brew install ollama${NC}"
      brew_install_sync "ollama" "ollama" || true
    elif command -v brew >/dev/null 2>&1; then
      echo -e "  ${YELLOW}   Fix: brew install ollama  (or https://ollama.com)  [or rerun with --fix]${NC}"
    else
      echo -e "  ${YELLOW}   Fix: https://ollama.com${NC}"
    fi
  fi

  return "$any_required_missing"
}

# Early dispatch: handle --help and check-deps before config-sync / validation
# so they work even when model-map.json is absent, corrupt, or fails validation.
if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
  cmd_help; exit 0
fi
if [[ "${1:-}" == "check-deps" ]]; then
  cmd_check_deps "$@"; exit $?
fi
if [[ "${1:-}" == "/c-thru-control" ]]; then
  shift
  # We need the config resolved to start the proxy
  eval "$(CLAUDE_MODEL_MAP_LAUNCH_CWD="$LAUNCH_CWD" node "$CTHRU_SELF_DIR/model-map-config.js" --shell-env 2>/dev/null || true)"
  sync_layered_profile_model_map >/dev/null 2>&1 || true
  CONFIG="$CLAUDE_MODEL_MAP_PATH"
  # Try to ensure proxy is running before control
  ensure_proxy_running >/dev/null 2>&1 || true
  # Propagate the OS-assigned port so c-thru-control can reach the proxy.
  # ensure_proxy_running sets PROXY_PORT but not ANTHROPIC_BASE_URL.
  [[ -z "${ANTHROPIC_BASE_URL:-}" && -n "${PROXY_PORT:-}" ]] && \
    export ANTHROPIC_BASE_URL="http://127.0.0.1:$PROXY_PORT"
  # Do NOT use `exec` here — bash skips EXIT traps on exec, so the proxy would
  # survive after c-thru-control exits.  Run as a foreground child so that when
  # c-thru exits normally (exit $?), the EXIT trap fires cleanup_proxy_children
  # which kills the proxy.
  "$CTHRU_SELF_DIR/c-thru-control" "$@"
  exit $?
fi


#!/usr/bin/env node
'use strict';
// CLI wrapper: resolve a capability alias to a concrete model under the active selected config.
// Usage: CLAUDE_LLM_MODE=<mode> CLAUDE_MODEL_MAP_PATH=<path> node tools/c-thru-resolve <capability>
// Exit 0: resolved model on stdout. Exit 2: unknown capability. Exit 1: config/profile error.

const { loadSelectedConfig } = require('./model-map-config.js');
const {
  resolveProfileModel,
  resolveLlmMode,
  resolveActiveTier,
  resolveCapabilityAlias,
  resolveTerminalTarget,
} = require('./model-map-resolve.js');

let config;
let selected;
try {
  selected = loadSelectedConfig({ baseDir: __dirname });
  config = selected.config;
}
catch (e) {
  process.stderr.write('c-thru-resolve: cannot load active model-map: ' + e.message + '\n');
  process.exit(1);
}

const cap = process.argv[2];
if (!cap) {
  process.stderr.write('usage: c-thru-resolve <capability>\n');
  process.exit(1);
}

const tier     = resolveActiveTier(config);
const mode     = resolveLlmMode(config);
const capAlias = resolveCapabilityAlias(cap, config, tier);

if (!capAlias) {
  process.stderr.write('c-thru-resolve: unknown capability or agent: ' + JSON.stringify(cap) + '\n');
  process.exit(2);
}

const aliasKey = capAlias === 'general-default' ? 'default' : capAlias;
const entry = (config.llm_profiles || {})[aliasKey];
if (!entry || typeof entry !== 'object') {
  process.stderr.write('c-thru-resolve: no profile entry for ' + JSON.stringify(capAlias) + '\n');
  process.exit(2);
}

const resolved = resolveProfileModel(entry, tier, mode);
if (typeof resolved !== 'string' || !resolved) {
  process.stderr.write('c-thru-resolve: resolveProfileModel returned empty for ' + JSON.stringify(capAlias) + '\n');
  process.exit(1);
}
const target = resolveTerminalTarget(config, resolved);
process.stdout.write((target ? target.providerModel : resolved) + '\n');
